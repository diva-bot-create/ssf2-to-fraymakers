{
  "_comment": "Universal SSF2->Fraymakers animation split rules, derived from scanning all 7 characters. Each rule has a pattern (anim_name + ssf2 label sequence) and a resulting action. The converter uses these to decide how to emit animations. Actions: 'split' = emit multiple FM animations; 'loop_tail' = keep single animation, set endType=LOOP at loop_frame in AnimationStats; 'ignore_tail' = trailing labels are control-flow or sprite-sharing artifacts, truncate at first meaningful boundary; 'keep' = no change.",
  "patterns": {
    "aerials_continue": {
      "_applies_to": [
        "aerial_neutral",
        "aerial_forward",
        "aerial_back",
        "aerial_up",
        "aerial_down"
      ],
      "_trigger": "last label is 'continue'",
      "action": "split",
      "splits": [
        {
          "fm_name": "{anim}",
          "ssf2_labels": [
            "$first"
          ],
          "notes": "active aerial frames"
        },
        {
          "fm_name": "{anim}_land",
          "ssf2_labels": [
            "continue"
          ],
          "notes": "landing lag, maps to FM landAnimation"
        }
      ],
      "animation_stats": "{anim}: { landAnimation: \"{anim}_land\" }",
      "chars": [
        "mario",
        "captainfalcon",
        "fox",
        "jigglypuff",
        "link",
        "naruto",
        "samus"
      ]
    },
    "aerial_down_repeat": {
      "_applies_to": [
        "aerial_down"
      ],
      "_trigger": "labels contain 'repeat' before 'continue' (link)",
      "action": "split",
      "splits": [
        {
          "fm_name": "aerial_down",
          "ssf2_labels": [
            "aerial_down",
            "repeat"
          ],
          "notes": "spike + bounce frames"
        },
        {
          "fm_name": "aerial_down_land",
          "ssf2_labels": [
            "continue"
          ],
          "notes": "landing lag"
        }
      ],
      "chars": [
        "link"
      ]
    },
    "strong_all": {
      "_applies_to": [
        "strong_forward",
        "strong_up",
        "strong_down"
      ],
      "_trigger": "labels are [anim_name, 'charging', 'attack'] or [anim_name, 'charging', 'attack', ...]",
      "action": "split",
      "splits": [
        {
          "fm_name": "{anim}_in",
          "ssf2_labels": [
            "$first"
          ],
          "notes": "windup before charge loop"
        },
        {
          "fm_name": "{anim}_charge",
          "ssf2_labels": [
            "charging"
          ],
          "notes": "hold loop \u2014 AnimationStats endType=LOOP"
        },
        {
          "fm_name": "{anim}_attack",
          "ssf2_labels": [
            "attack"
          ],
          "notes": "release frames (combo2/remove treated as endlag, included here)"
        }
      ],
      "chars": [
        "mario",
        "captainfalcon",
        "fox",
        "jigglypuff",
        "link",
        "naruto",
        "samus"
      ]
    },
    "grab_and_carry": {
      "_applies_to": [
        "grab",
        "carry"
      ],
      "_trigger": "labels contain 'dashgrab' and 'grabbed' and 'attack'",
      "action": "split",
      "splits": [
        {
          "fm_name": "grab",
          "ssf2_labels": [
            "grab|carry"
          ],
          "notes": "standing grab attempt"
        },
        {
          "fm_name": "dash_grab",
          "ssf2_labels": [
            "dashgrab"
          ],
          "notes": "running grab attempt"
        },
        {
          "fm_name": "grab_hold",
          "ssf2_labels": [
            "grabbed|grabbed2|loop"
          ],
          "notes": "holding opponent (loop if present)"
        },
        {
          "fm_name": "grab_pummel",
          "ssf2_labels": [
            "attack"
          ],
          "notes": "pummel hit"
        }
      ],
      "_note": "samus/link also have 'tether' label \u2014 treat as part of grab_hold or separate ledge tether depending on char",
      "chars": [
        "mario",
        "captainfalcon",
        "jigglypuff",
        "link",
        "naruto",
        "samus"
      ]
    },
    "run_dash_turn": {
      "_applies_to": [
        "run"
      ],
      "_trigger": "labels are ['run','dash','turn'] or ['run','run','turn']",
      "action": "split",
      "splits": [
        {
          "fm_name": "dash",
          "ssf2_labels": [
            "dash|$second_run"
          ],
          "notes": "initial dash (before full run speed)"
        },
        {
          "fm_name": "run",
          "ssf2_labels": [
            "run|$first_run"
          ],
          "notes": "full run loop \u2014 AnimationStats endType=LOOP"
        },
        {
          "fm_name": "run_turn",
          "ssf2_labels": [
            "turn"
          ],
          "notes": "run turnaround"
        }
      ],
      "_note": "some chars use 'run,run,turn' where first run=loop, second is irrelevant; others use 'run,dash,turn'",
      "chars": [
        "mario",
        "captainfalcon",
        "fox",
        "jigglypuff",
        "link",
        "naruto",
        "samus"
      ]
    },
    "jump_backflip": {
      "_applies_to": [
        "jump"
      ],
      "_trigger": "labels contain 'backflip'",
      "action": "split",
      "splits": [
        {
          "fm_name": "jump",
          "ssf2_labels": [
            "jump"
          ],
          "notes": "forward/neutral jump squat+rise"
        },
        {
          "fm_name": "jump_back",
          "ssf2_labels": [
            "backflip"
          ],
          "notes": "backward jump (running away)"
        }
      ],
      "chars": [
        "mario",
        "captainfalcon",
        "fox",
        "jigglypuff",
        "link",
        "naruto",
        "samus"
      ]
    },
    "jump_aerial_backflip": {
      "_applies_to": [
        "jump_aerial"
      ],
      "_trigger": "labels contain 'backflip'",
      "action": "split",
      "splits": [
        {
          "fm_name": "jump_aerial",
          "ssf2_labels": [
            "jump_aerial"
          ],
          "notes": "forward/neutral double jump"
        },
        {
          "fm_name": "jump_aerial_back",
          "ssf2_labels": [
            "backflip"
          ],
          "notes": "backward double jump"
        }
      ],
      "chars": [
        "mario",
        "captainfalcon",
        "samus"
      ]
    },
    "idle_bored": {
      "_applies_to": [
        "idle"
      ],
      "_trigger": "labels contain 'bored' or 'blink'",
      "action": "split",
      "splits": [
        {
          "fm_name": "idle",
          "ssf2_labels": [
            "idle"
          ],
          "notes": "standard idle loop \u2014 AnimationStats endType=LOOP"
        },
        {
          "fm_name": "idle_bored",
          "ssf2_labels": [
            "bored|blink|wait"
          ],
          "notes": "idle fidget/taunt \u2014 plays when idle too long"
        }
      ],
      "_note": "'uncrouch' label in idle is crouch_out \u2014 NOT extracted from idle sprite; crouch_out should come from crouch animation's 'uncrouch' label instead",
      "chars": [
        "mario",
        "captainfalcon",
        "fox",
        "jigglypuff",
        "link",
        "naruto",
        "samus"
      ]
    },
    "crouch_loop": {
      "_applies_to": [
        "crouch"
      ],
      "_trigger": "labels are ['crouch','loop'] or ['crouch','redo',...]",
      "action": "split",
      "splits": [
        {
          "fm_name": "crouch_in",
          "ssf2_labels": [
            "crouch"
          ],
          "notes": "crouch transition"
        },
        {
          "fm_name": "crouch_loop",
          "ssf2_labels": [
            "loop|redo"
          ],
          "notes": "held crouch \u2014 AnimationStats endType=LOOP"
        }
      ],
      "_note": "naruto also has crawlforward/crawlback in crouch \u2014 those are unique to naruto, handle separately",
      "chars": [
        "mario",
        "captainfalcon",
        "fox",
        "jigglypuff",
        "link",
        "naruto",
        "samus"
      ]
    },
    "special_up_fall": {
      "_applies_to": [
        "special_up",
        "special_up_air"
      ],
      "_trigger": "last label is 'fallLoop' or 'grabbed'",
      "action": "split",
      "splits": [
        {
          "fm_name": "{anim}",
          "ssf2_labels": [
            "$first"
          ],
          "notes": "up special active frames"
        },
        {
          "fm_name": "helpless",
          "ssf2_labels": [
            "fallLoop"
          ],
          "notes": "helpless fall after up special \u2014 shared FM animation"
        }
      ],
      "_note": "'grabbed' variant (captainfalcon) means the up special ends in a grab state, not helpless \u2014 keep as single animation",
      "chars": [
        "mario",
        "fox",
        "link",
        "naruto"
      ]
    },
    "item_smash_charge": {
      "_applies_to": [
        "item_smash"
      ],
      "_trigger": "labels are ['item_smash','charging','attack'] \u2014 universal",
      "action": "split",
      "splits": [
        {
          "fm_name": "item_smash_in",
          "ssf2_labels": [
            "item_smash"
          ],
          "notes": "windup before charge"
        },
        {
          "fm_name": "item_smash_charge",
          "ssf2_labels": [
            "charging"
          ],
          "notes": "held charge loop \u2014 AnimationStats endType=LOOP"
        },
        {
          "fm_name": "item_smash",
          "ssf2_labels": [
            "attack"
          ],
          "notes": "release/active frames"
        }
      ],
      "chars": [
        "mario",
        "captainfalcon",
        "fox",
        "jigglypuff",
        "link",
        "naruto",
        "samus"
      ]
    },
    "item_throw_directions": {
      "_applies_to": [
        "item_throw",
        "item_throw_air"
      ],
      "_trigger": "labels contain 'toss_down','toss_up','toss_forward' \u2014 missing 'toss_back' means first label IS back",
      "action": "split",
      "splits": [
        {
          "fm_name": "{anim}_back",
          "ssf2_labels": [
            "$first"
          ],
          "notes": "backward throw (first segment = back in SSF2)"
        },
        {
          "fm_name": "{anim}_down",
          "ssf2_labels": [
            "toss_down"
          ],
          "notes": "downward throw"
        },
        {
          "fm_name": "{anim}_up",
          "ssf2_labels": [
            "toss_up"
          ],
          "notes": "upward throw"
        },
        {
          "fm_name": "{anim}_forward",
          "ssf2_labels": [
            "toss_forward"
          ],
          "notes": "forward throw"
        }
      ],
      "chars": [
        "mario",
        "captainfalcon",
        "link",
        "naruto",
        "samus"
      ]
    },
    "item_screw_fall": {
      "_applies_to": [
        "item_screw"
      ],
      "_trigger": "last label is 'fallLoop'",
      "action": "split",
      "splits": [
        {
          "fm_name": "item_screw",
          "ssf2_labels": [
            "item_screw"
          ],
          "notes": "screw attack active frames"
        },
        {
          "fm_name": "helpless",
          "ssf2_labels": [
            "fallLoop"
          ],
          "notes": "helpless fall \u2014 shared FM animation"
        }
      ],
      "_note": "captainfalcon's item_screw ends in 'grabbed' not 'fallLoop' \u2014 keep as single animation",
      "chars": [
        "fox",
        "link",
        "mario",
        "naruto"
      ]
    },
    "helpless_variants": {
      "_applies_to": [
        "helpless",
        "fly"
      ],
      "_trigger": "labels contain 'reg','spec' (helpless) or 'backflip' (fly/tumble)",
      "action": "split",
      "splits_helpless": [
        {
          "fm_name": "helpless",
          "ssf2_labels": [
            "helpless|reg"
          ],
          "notes": "standard helpless fall"
        },
        {
          "fm_name": "helpless_special",
          "ssf2_labels": [
            "spec"
          ],
          "notes": "post-special helpless (different animation)"
        }
      ],
      "splits_fly": [
        {
          "fm_name": "tumble",
          "ssf2_labels": [
            "fly"
          ],
          "notes": "standard tumble knockback"
        },
        {
          "fm_name": "tumble_back",
          "ssf2_labels": [
            "backflip"
          ],
          "notes": "reverse tumble (hit from behind)"
        }
      ],
      "chars_helpless": [
        "captainfalcon"
      ],
      "chars_fly": [
        "mario",
        "captainfalcon",
        "samus"
      ]
    },
    "ledge_loop": {
      "_applies_to": [
        "ledge_hang",
        "ledge_lean"
      ],
      "_trigger": "labels are ['ledge_hang|ledge_lean','loop'] or ['...','loop','tetherGrab']",
      "action": "split",
      "splits": [
        {
          "fm_name": "ledge_in",
          "ssf2_labels": [
            "$first"
          ],
          "notes": "snap-to-ledge transition"
        },
        {
          "fm_name": "ledge_loop",
          "ssf2_labels": [
            "loop"
          ],
          "notes": "held ledge \u2014 AnimationStats endType=LOOP"
        }
      ],
      "_note": "'tetherGrab' label (link/samus) is tether-grab ledge snap \u2014 keep as part of ledge_in or handle as ledge_tether separately",
      "chars": [
        "mario",
        "captainfalcon",
        "fox",
        "jigglypuff",
        "link",
        "naruto",
        "samus"
      ]
    },
    "shield_loop": {
      "_applies_to": [
        "shield"
      ],
      "_trigger": "labels are ['shield','loop|pause','shielddrop']",
      "action": "split",
      "splits": [
        {
          "fm_name": "shield_in",
          "ssf2_labels": [
            "shield"
          ],
          "notes": "shield raise"
        },
        {
          "fm_name": "shield_loop",
          "ssf2_labels": [
            "loop|pause"
          ],
          "notes": "held shield \u2014 AnimationStats endType=LOOP"
        },
        {
          "fm_name": "shield_out",
          "ssf2_labels": [
            "shielddrop"
          ],
          "notes": "shield drop (if present, else engine handles it)"
        }
      ],
      "chars": [
        "captainfalcon",
        "mario"
      ]
    },
    "taunt_shared_sprite": {
      "_applies_to": [
        "taunt_up",
        "taunt_down"
      ],
      "_trigger": "labels contain 'taunt_side' (taunts share a sprite)",
      "action": "ignore_tail",
      "reason": "SSF2 packs all 3 taunts in one sprite; each outer label (taunt_up/taunt_down/taunt_side) already gives us the right frame range. The 'taunt_side' label appearing in taunt_up/taunt_down is a sprite artifact \u2014 it just marks where the other taunt starts. Ignore it.",
      "chars": [
        "captainfalcon",
        "jigglypuff",
        "link",
        "naruto",
        "samus"
      ]
    },
    "idle_sprite_bleedthrough": {
      "_applies_to": [
        "item_float",
        "ladder",
        "respawn",
        "special",
        "special_down",
        "carry_items"
      ],
      "_trigger": "labels contain 'bored','blink','uncrouch','wait' \u2014 these animations share the idle inner sprite",
      "action": "ignore_tail",
      "reason": "These animations use the idle inner sprite and the full label list bleeds through. Truncate at first label boundary \u2014 only the first segment matters.",
      "chars": [
        "mario",
        "captainfalcon",
        "fox",
        "jigglypuff",
        "link",
        "naruto",
        "samus"
      ]
    },
    "hurt_substates": {
      "_applies_to": [
        "hurt",
        "defeat",
        "stunned",
        "screenko",
        "starko",
        "star_ko"
      ],
      "_trigger": "labels contain 'done1','hurt2','downed','shock','ball','faint','spin'",
      "action": "ignore_tail",
      "reason": "SSF2 packs all hurt variants (light/medium/heavy/downed/shock/ball) into one sprite with frame labels. Fraymakers has separate animations for each (hurt_light_low, hurt_medium, hurt_heavy, tumble, etc.) driven by the game engine, not frame labels. Ignore the tail \u2014 keep only the first segment and let Fraymakers route to the right hurt animation via engine.",
      "_note": "The individual hurt variants (hurt_light_low, hurt_medium, etc.) need to be hand-extracted or kept as the full hurt animation in the interim.",
      "chars": [
        "mario",
        "captainfalcon",
        "jigglypuff",
        "link",
        "naruto",
        "samus"
      ]
    },
    "naruto_crawl": {
      "_applies_to": [
        "crouch"
      ],
      "_trigger": "labels contain 'crawlforward','crawlback' (naruto-specific)",
      "action": "split",
      "splits": [
        {
          "fm_name": "crouch_in",
          "ssf2_labels": [
            "crouch",
            "redo"
          ],
          "notes": "crouch transition"
        },
        {
          "fm_name": "crouch_loop",
          "ssf2_labels": [
            "walking"
          ],
          "notes": "naruto crawl walk loop \u2014 AnimationStats endType=LOOP"
        },
        {
          "fm_name": "crouch_forward",
          "ssf2_labels": [
            "crawlforward"
          ],
          "notes": "crawl forward (naruto-unique)"
        },
        {
          "fm_name": "crouch_back",
          "ssf2_labels": [
            "crawlback"
          ],
          "notes": "crawl backward (naruto-unique)"
        }
      ],
      "chars": [
        "naruto"
      ]
    },
    "samus_fall_uspec": {
      "_applies_to": [
        "fall",
        "swim"
      ],
      "_trigger": "labels contain 'uspecFall' (samus-specific)",
      "action": "split",
      "splits": [
        {
          "fm_name": "{anim}",
          "ssf2_labels": [
            "$first",
            "redo"
          ],
          "notes": "standard fall"
        },
        {
          "fm_name": "fall_special",
          "ssf2_labels": [
            "uspecFall"
          ],
          "notes": "post-up-special fall (samus screw attack fall)"
        }
      ],
      "chars": [
        "samus"
      ]
    },
    "land_dodgeland": {
      "_applies_to": [
        "land"
      ],
      "_trigger": "labels contain 'dodgeland' (captainfalcon)",
      "action": "split",
      "splits": [
        {
          "fm_name": "land_light",
          "ssf2_labels": [
            "land"
          ],
          "notes": "standard landing"
        },
        {
          "fm_name": "land_heavy",
          "ssf2_labels": [
            "dodgeland"
          ],
          "notes": "landing after airdodge or hard landing"
        }
      ],
      "chars": [
        "captainfalcon"
      ]
    },
    "loop_tail_variants": {
      "_comment": "Animations where a trailing 'loop','redo','again' is just the loop point of the same animation \u2014 no split, set endType=LOOP in AnimationStats at the loop frame.",
      "action": "loop_tail",
      "cases": [
        {
          "anim": "fall",
          "tail": [
            "loop"
          ],
          "chars": [
            "captainfalcon"
          ],
          "loop_at": "frame 1"
        },
        {
          "anim": "fall",
          "tail": [
            "redo"
          ],
          "chars": [
            "jigglypuff",
            "naruto"
          ],
          "loop_at": "frame 1"
        },
        {
          "anim": "swim",
          "tail": [
            "loop"
          ],
          "chars": [
            "captainfalcon"
          ],
          "loop_at": "frame 1"
        },
        {
          "anim": "swim",
          "tail": [
            "redo"
          ],
          "chars": [
            "jigglypuff",
            "naruto"
          ],
          "loop_at": "frame 1"
        },
        {
          "anim": "wall_stick",
          "tail": [
            "loop"
          ],
          "chars": [
            "captainfalcon"
          ],
          "loop_at": "frame 1"
        },
        {
          "anim": "wall_stick",
          "tail": [
            "redo"
          ],
          "chars": [
            "jigglypuff",
            "naruto"
          ],
          "loop_at": "frame 1"
        },
        {
          "anim": "dizzy",
          "tail": [
            "again"
          ],
          "chars": [
            "link"
          ],
          "loop_at": "frame 2"
        },
        {
          "anim": "shield",
          "tail": [
            "again"
          ],
          "chars": [
            "jigglypuff"
          ],
          "loop_at": "frame 2",
          "fm_split": "shield_in -> shield_loop"
        },
        {
          "anim": "shield",
          "tail": [
            "loop"
          ],
          "chars": [
            "samus"
          ],
          "loop_at": "frame 2",
          "fm_split": "shield_in -> shield_loop"
        },
        {
          "anim": "shield",
          "tail": [
            "stopped"
          ],
          "chars": [
            "link",
            "naruto"
          ],
          "loop_at": "frame 2",
          "fm_split": "shield_in -> shield_loop"
        },
        {
          "anim": "buried",
          "tail": [
            "done1"
          ],
          "chars": [
            "jigglypuff"
          ],
          "loop_at": "frame 4",
          "_note": "'done1' is an exit label when buried ends, not a hurt sub-state here \u2014 treat as tail of buried loop"
        },
        {
          "anim": "mario.special_up_air",
          "tail": [
            "loop"
          ],
          "chars": [
            "mario"
          ],
          "loop_at": "frame 21",
          "_note": "tiny 3-frame loop at end of super jump air \u2014 AnimationStats endType=LOOP"
        }
      ]
    },
    "ignore_tail_control_flow": {
      "_comment": "Animations where the tail is a pure control-flow artifact (goback, done, remove, etc.) with no visual content difference \u2014 just truncate at the end of the active frames.",
      "action": "ignore_tail",
      "cases": [
        {
          "anim": "jab1",
          "tail": [
            "continue"
          ],
          "chars": [
            "jigglypuff"
          ],
          "_note": "jab endlag, 2f \u2014 ignore"
        },
        {
          "anim": "jab1",
          "tail": [
            "goback"
          ],
          "chars": [
            "captainfalcon"
          ],
          "_note": "goback = loop-back to jab-repeat entry \u2014 ignore, jab chain handled by AnimationStats/Script"
        },
        {
          "anim": "jab4",
          "tail": [
            "again",
            "finish"
          ],
          "chars": [
            "captainfalcon"
          ],
          "_note": "rapid jab loop + exit \u2014 jab4 is the rapid-fire jab; 'again' loops, 'finish' exits. Keep as single animation with AnimationStats endType=LOOP"
        },
        {
          "anim": "fly",
          "tail": [
            "done"
          ],
          "chars": [
            "link"
          ],
          "_note": "fly is only 18f, 'done' is 2f exit tail \u2014 ignore, same as mario's fly but without backflip"
