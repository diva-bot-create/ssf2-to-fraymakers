    },
    {
      "$id": "6e07767c-37c8-549d-8b93-ed6e7ed57ba7",
      "code": "if (SSF2API.isReady()) {\n\tself.self = /* ? */;\n\tself.self.setGlobalVariable(\"jab\", false);\n\tself.self.setGlobalVariable(\"jab2\", false);\n}\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "70bc5887-c4b9-56f4-87d8-950cc98e993c",
      "code": "",
      "length": 5,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "3e3f09be-c11d-577d-b5d5-1cdbd1a08579",
      "code": "if (self.self.getMetalStatus()) {\n\tself.self.playSound(\"metal_step_m1\");\n\treturn;\n}\nself.self.playSound(\"falcon_footstep\");",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "7ec28e46-3793-5df4-96aa-f98feb46d5dd",
      "code": "",
      "length": 8,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
