    {
      "$id": "5b856b68-1b80-58b8-85ed-9ecb186abb62",
      "length": 20,
      "name": "dash_attack",
      "pluginMetadata": {},
      "type": "LABEL"
    },
    {
      "$id": "80c65ecc-ea7f-5121-91d8-57a57ee3fa83",
      "code": "if (SSF2API.isReady()) {\n\tself.self = /* ? */;\n}\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "3a4ef6e3-b63f-593b-8e2e-5d3238029b42",
      "code": "self.playsound = SSF2API.random();\nself.audio = self.self.getGlobalVariable(\"audio\");\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "5aa5d084-0421-5890-9364-7213bca889e0",
      "code": "self.self.attachEffect(\"global_dust_heavy\");\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "90554e70-c2b0-5519-87a1-9a6bb0182489",
      "code": "if (root != null && parent != null) {\n}\nif (/* ? */) {\n\tself.self.setXSpeed(17, false);\n}\nself.self.attachEffect(\"wind_wave\", { x: self.self.flipX(35), y: -35, scaleX: 0.8, scaleY: 0.8, parentLock: true });\nif ((self.playsound > 0.2 && self.playsound <= 0.4) || self.audio != 1) {\n\tif (root != null && parent != null) {\n\t}\n\tif (/* ? */) {\n\t\tself.self.setGlobalVariable(\"audio\", 1);\n\t}\n}\nif ((self.playsound > 0.4 && self.playsound <= 0.6) || self.audio != 2) {\n\tif (root != null && parent != null) {\n\t}\n\tif (/* ? */) {\n\t\tself.self.setGlobalVariable(\"audio\", 2);\n\t}\n}\nif ((self.playsound > 0.6 && self.playsound <= 0.8) || self.audio != 3) {\n\tif (root != null && parent != null) {\n\t}\n\tif (/* ? */) {\n\t\tself.self.setGlobalVariable(\"audio\", 3);\n\t}\n}\nif ((self.playsound > 0.8 && self.playsound <= 1) || self.audio != 4) {\n\tif (root != null && parent != null) {\n\t}\n\tif (/* ? */) {\n\t\tself.self.setGlobalVariable(\"audio\", 4);\n\t}\n}\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "a6c46908-0905-56ac-b0e2-9feea9a37637",
      "code": "self.self.updateAttackBoxStats(1, { damage: 8 });\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "049dee87-e151-50f5-aefa-fdb4e7e11d96",
      "code": "",
      "length": 10,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "ebbf56c2-4e67-5c79-9811-5f643a2c09a7",
