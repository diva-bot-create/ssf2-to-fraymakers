      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "c28c8fc3-ab60-597f-9f53-70e6ce386a2d",
      "code": "self.self.getItem().activateItem();\nself.self.playAttackSound(1);\nself.self.attachEffect(\"global_dust_heavy\", { x: self.self.flipX(5), y: 3, scaleX: -0.5, scaleY: -0.5 });\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "5dc884a4-7234-5b7f-8791-8dd70df675c2",
      "code": "",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "22f47f04-c2a9-58fb-9d73-c88e13d42a87",
      "code": "self.self.getItem().deactivateItem();\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "9279c9e4-59c8-5137-bf1e-3426bc9a3996",
      "code": "",
      "length": 9,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
