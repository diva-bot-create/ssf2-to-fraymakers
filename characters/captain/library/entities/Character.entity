    {
      "$id": "450ff0a4-a71d-5e99-a2ab-507bc2dbf930",
      "length": 35,
      "name": "special_side_air",
      "pluginMetadata": {},
      "type": "LABEL"
    },
    {
      "$id": "da976ab7-dba4-5b04-8e0f-e1d38199a181",
      "length": 15,
      "name": "afterHit",
      "pluginMetadata": {},
      "type": "LABEL"
    },
    {
      "$id": "8fbe7fb3-432f-5f01-a9ea-69c2bccaedb8",
      "code": "self.hasHit = false;\nself.effect1 = null;\nif (SSF2API.isReady()) {\n\tself.self = /* ? */;\n\tself.self.addEventListener(SSF2Event.ATTACK_CONNECT, self.toFrame);\n\tself.self.addEventListener(SSF2Event.ATTACK_CONNECT_SHIELD, self.toFrame);\n\tself.self.addEventListener(SSF2Event.CHAR_ATTACK_COMPLETE, self.self.toHelpless);\n\tself.self.attachEffect(\"raptorboost_effect\", { y: 5 });\n}\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "3e82167c-6d2f-58d8-b790-91416cbd0a0d",
      "code": "self.self.playSound(\"raptorBoost1\");\nself.self.clearEffectsOnStateChange();\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "5a14dbbf-1a5e-5bd5-9df9-758a49ccbab5",
      "code": "",
      "length": 5,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "7810858a-cc12-5157-8432-6b1bb067ec33",
      "code": "self.effect1 = self.self.attachEffect(\"raptorboost_effect_trail\", { y: 5, parentLock: true });\nself.self.createTimer(1, 0, self.followCF);\nself.self.addEffectToList(self.effect1);\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "cf87b92c-0507-5239-81bb-45e17ea165c5",
      "code": "self.self.setXSpeed(18, false);\nself.self.playAttackSound(2);\nself.self.addEventListener(SSF2Event.GROUND_TOUCH, self.self.toHeavyLand);\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "e2e2b252-839d-5097-a9e9-e5e043ae51e2",
      "code": "",
      "length": 11,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "a0563cd1-74c3-5130-8be7-27c7f1800f60",
      "code": "self.self.setXSpeed(4, false);\nself.self.updateAttackStats({ xSpeedDecayAir: -0.3 });\nself.effect1.gotoAndStop(\"end\");\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "e2554e36-871c-55e2-b023-226bfd2561d4",
      "code": "",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "391f9956-0266-52f7-b59b-4de68f9e0fc2",
      "code": "self.self.updateAttackStats({ air_ease: -1 });\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "66f26081-6dfa-5a23-b1f6-cec86a52fb62",
      "code": "",
      "length": 3,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "129a4790-6643-52ad-96a4-c11ddf2e8a37",
      "code": "self.self.updateAttackStats({ allowControl: true });\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "a3cd475e-8445-593e-8900-d24729c66ab8",
      "code": "",
      "length": 7,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "5fa1a320-44b9-5f74-a8e7-77b966a31db4",
      "code": "if (self.self.isOnGround()) {\n\tself.self.endAttack();\n\treturn;\n}\nself.self.setGlobalVariable(\"usedSpec\", true);\nself.self.toHelpless();",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "27098c19-959d-51ca-ad03-942aeabe9561",
      "code": "self.hasHit = true;\nself.self.updateAttackStats({ canFallOff: false });\nself.self.updateAttackBoxStats(1, { allowTurboInterrupt: true, damage: 7, direction: 270, power: 40, kbConstant: 50, hitStun: 4, selfHitStun: 4, hasEffect: true, effect_id: \"effect_firehit_light\", effectSound: \"brawl_punch_m\", bypassShield: false, priority: 4 });\nself.self.removeEventListener(SSF2Event.GROUND_TOUCH, self.self.toHeavyLand);\nself.effect1.gotoAndStop(\"end\");\nself.self.addEffectToList(self.self.attachEffect(\"raptorboost_aerial_hit\", { y: 5, parentLock: true, syncHitStun: true }));\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "e1e6f8ac-cc61-5a79-b432-2a91614354ec",
      "code": "",
      "length": 2,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "4c422c6c-951a-5dbd-8bde-f100d53d5b29",
      "code": "self.self.setYSpeed(-7);\nself.self.setXSpeed(8.6, false);\nself.self.updateAttackStats({ xSpeedDecayAir: -0.1, air_ease: -1 });\nself.self.removeEventListener(SSF2Event.CHAR_ATTACK_COMPLETE, self.self.toHelpless);\nself.self.addEventListener(SSF2Event.GROUND_TOUCH, self.self.toLand);\nself.self.playSound(\"cfalcon_swing_l\");\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "82b78f86-d1b6-5208-b1dd-23dcb85560ed",
      "code": "",
      "length": 10,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
