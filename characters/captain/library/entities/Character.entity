      "pluginMetadata": {},
      "type": "LABEL"
    },
    {
      "$id": "8525930e-0c5a-5bd6-b0b5-47a7fde0ddec",
      "code": "self.hasHit = false;\nif (SSF2API.isReady()) {\n\tself.self = /* ? */;\n\tself.self.addEventListener(SSF2Event.GROUND_TOUCH, self.toFrame);\n\tself.self.addEventListener(SSF2Event.GROUND_TOUCH, self.self.resetMovement);\n\tself.self.addEventListener(SSF2Event.HIT_WALL, self.crash);\n}\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "e86346ee-9617-53d7-a15d-8834f4c65701",
      "code": "self.self.playVoiceSound(1);\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "f95a9cb4-7309-55db-a551-8d7717c92a1e",
      "code": "self.self.setYSpeed(-8);\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "e803c7b3-b690-5070-b6b3-124e62719914",
      "code": "",
      "length": 5,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "276bed34-3c34-5b1c-9698-451cd1825140",
      "code": "self.self.updateAttackStats({ air_ease: -1 });\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "a5cd8f6a-ea52-5990-ba8b-44be0b2b8f90",
      "code": "self.self.createTimer(1, 7, self.physics);\nself.self.playAttackSound(1);\nself.self.fireProjectile(\"captainfalcon_dspecairProj\", 0, 5);\nself.projectile = self.self.getCurrentProjectile();\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "84539754-c549-5007-85a1-6a9472cc5c24",
      "code": "",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "b9f69d6e-503d-5627-ad17-812bc90f6369",
      "code": "self.self.updateAttackBoxStats(1, { damage: 13, kbConstant: 65 });\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "f6b3e1bd-09a9-5040-9966-2a992b06f10a",
      "code": "",
      "length": 1,
      "pluginMetadata": {},
