      "code": "self.self.updateAttackStats({ xSpeedDecay: 0.75, xSpeedDecayAir: 0.875 });\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "c08e45a4-b60d-5369-ae76-142c26cf4bdd",
      "code": "",
      "length": 1,
      "pluginMetadata": {},
