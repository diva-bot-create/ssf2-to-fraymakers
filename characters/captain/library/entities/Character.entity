      "type": "LABEL"
    },
    {
      "$id": "c3f7c42e-f4a5-5535-b9b5-e62873b7e098",
      "code": "self.xframe = \"attack\";\nself.self.destroyTimer(self.effects);\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "2fd55e30-27cd-5b47-8a1a-559db841d1f6",
      "code": "",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "b9570fff-ee45-5f47-991d-3dd2cbef4d95",
      "code": "self.self.getItem().activateItem();\nself.self.playAttackSound(1);\nself.self.playVoiceSound(1);\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "49b051b9-cc00-5c9b-97dd-05f0afa2c443",
      "code": "",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "ae8c1f86-e954-587a-96dc-d3dd5dc1ff7d",
      "code": "self.self.getItem().deactivateItem();\nself.self.updateAttackStats({ chargetime_max: 0 });\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "76b0b959-6173-5402-a488-eac207b49810",
      "code": "",
      "length": 15,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
