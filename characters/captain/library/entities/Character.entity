    {
      "$id": "c69f1b1b-e4e3-560f-b463-17334e52fa8e",
      "code": "if (SSF2API.isReady()) {\n\tself.self = /* ? */;\n}\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "ac0e1aa3-1f49-5e75-a1d7-60983f5861d3",
      "code": "self.effect = self.self.attachEffect(\"global_dust_heavy\", { scaleX: 0.8, scaleY: 0.8 });\nself.effect.scaleX = -self.effect.scaleX;\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "4ae6cd95-0dcb-54b6-8046-67d2dde55276",
      "code": "self.self.setIntangibility(true);\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "1067bdc0-b6c9-5802-8448-5eebaaaae12d",
      "code": "",
      "length": 6,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "a97682df-ef8c-5e67-9b2d-944372545bd4",
      "code": "self.self.setIntangibility(false);\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "07fdaf15-58ac-5265-abab-23bce44b71db",
      "code": "",
      "length": 5,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
