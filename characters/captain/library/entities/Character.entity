      "code": "self.self.endAttack();\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "88fd23b6-bcd2-50a7-b242-408d4b6925b0",
      "code": "self.hasHit = true;\nself.self.resetMovement();\nself.self.setXSpeed(-7, false);\nself.self.setYSpeed(-22);\nself.self.destroyTimer(self.physics);\nself.self.removeEventListener(SSF2Event.GROUND_TOUCH, self.toFrame);\nself.self.updateAttackStats({ air_ease: -1 });\nSSF2API.getCamera().shake(6);\nif (self.projectile != null && !self.projectile.isDisposed()) {\n}",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
