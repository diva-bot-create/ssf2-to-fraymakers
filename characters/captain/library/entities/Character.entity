    {
      "$id": "d063d85e-d7a9-5b10-aa06-f25a2aea6394",
      "code": "self.self = /* ? */;\nif (SSF2API.isReady() && self.self) {\n}\nif (/* ? */) {\n\tself.playsound = SSF2API.random();\n\tself.audio = self.self.getGlobalVariable(\"audio\");\n}\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "12870b0e-41fa-5c31-92e0-042974cf97f1",
      "code": "self.self.playAttackSound(1);\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "c23eedad-6c36-543a-a795-1d0c8f814b19",
      "code": "self.self.setLandingLag(true);\nself.self.addEffectToList(self.self.attachEffect(\"trail_cfalcon_nair\", { y: 10, scaleX: 1.15, scaleY: 1.15, parentLock: true, syncHitStun: true }));\nself.self.clearEffectsOnStateChange();\nif ((self.playsound > 0.2 && self.playsound <= 0.4) || self.audio != 1) {\n\tself.self.playVoiceSound(1);\n\tself.self.setGlobalVariable(\"audio\", 1);\n}\nif ((self.playsound > 0.4 && self.playsound <= 0.6) || self.audio != 2) {\n\tself.self.playVoiceSound(2);\n\tself.self.setGlobalVariable(\"audio\", 2);\n}\nif ((self.playsound > 0.6 && self.playsound <= 0.8) || self.audio != 3) {\n\tself.self.playVoiceSound(3);\n\tself.self.setGlobalVariable(\"audio\", 3);\n}\nif ((self.playsound > 0.8 && self.playsound <= 1) || self.audio != 4) {\n\tself.self.playVoiceSound(4);\n\tself.self.setGlobalVariable(\"audio\", 4);\n}\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "ddc086c1-59f3-53cb-afac-f7a601c0968f",
      "code": "",
      "length": 4,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "cdc32874-f71a-501d-b987-25176588824b",
      "code": "self.self.updateAttackBoxStats(1, { damage: 7, direction: 45, power: 40, kbConstant: 100, hitStun: 3, selfHitStun: 1, weightKB: 0, hitLag: -1.1 });\nself.self.updateAttackBoxStats(2, { damage: 7, direction: 45, power: 40, kbConstant: 100, hitStun: 3, selfHitStun: 1, weightKB: 0, hitLag: -1.1 });\nself.self.refreshAttackID();\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "c132bea2-3c49-5a7d-9ecf-f7f200bb0f5f",
      "code": "self.self.playAttackSound(1);\nself.self.attachEffect(\"global_dust_blast\", { x: self.self.flipX(43), y: -27, parentLock: true });\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "5ab9d502-8e70-52dd-bdbb-6d11f74d86e1",
