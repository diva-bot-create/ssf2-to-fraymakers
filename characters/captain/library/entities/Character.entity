    {
      "$id": "ac7808c0-d498-5da9-8528-e7cf944852ff",
      "length": 17,
      "name": "tilt_down",
      "pluginMetadata": {},
      "type": "LABEL"
    },
    {
      "$id": "f5fc3b62-2a43-5529-897c-5b33d0452900",
      "code": "self.self = /* ? */;\nself.xframe = null;\nreturn;\n}\n\n\nfunction a_down__frame0() {\nif (SSF2API.isReady()) {\n\tself.self = /* ? */;\n\tself.playsound = SSF2API.random();\n\tself.audio = self.self.getGlobalVariable(\"audio\");\n}\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "a407ee59-db80-56e2-93ee-b714ec8aaec3",
      "code": "",
      "length": 2,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "52c85f96-700c-522d-84ec-0101216c4c3c",
      "code": "self.self.attachEffect(\"global_dust_light\");\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "7658e33b-d17b-506c-9728-963e49b28592",
      "code": "if ((self.playsound > 0.2 && self.playsound <= 0.4) || self.audio != 1) {\n\tself.self.playVoiceSound(1);\n\tself.self.setGlobalVariable(\"audio\", 1);\n}\nif ((self.playsound > 0.4 && self.playsound <= 0.6) || self.audio != 2) {\n\tself.self.playVoiceSound(2);\n\tself.self.setGlobalVariable(\"audio\", 2);\n}\nif ((self.playsound > 0.6 && self.playsound <= 0.8) || self.audio != 3) {\n\tself.self.playVoiceSound(3);\n\tself.self.setGlobalVariable(\"audio\", 3);\n}\nif ((self.playsound > 0.8 && self.playsound <= 1) || self.audio != 4) {\n\tself.self.playVoiceSound(4);\n\tself.self.setGlobalVariable(\"audio\", 4);\n}\nself.self.playAttackSound(1);\nself.self.addEffectToList(self.self.attachEffect(\"trail_cfalcon_dtilt\", { scaleX: 1.15, scaleY: 1.15, parentLock: true, syncHitStun: true }));\nself.self.clearEffectsOnStateChange();\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "8bf1d94d-da8b-55cc-ae50-dacf7dbb55da",
      "code": "",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "1c35fbad-17d5-534f-9be3-baa8c42dcc00",
      "code": "self.xframe = \"charging\";\nself.self.createTimer(4, -1, self.effects);\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "f3ab913f-3a6e-5fbc-9a1e-5b43fc58917f",
      "code": "",
      "length": 9,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "64b57083-a7ba-5ec2-8a38-6cc313041470",
      "code": "self.self.endAttack();\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
