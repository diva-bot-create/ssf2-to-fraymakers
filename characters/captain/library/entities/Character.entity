    },
    {
      "$id": "d7acc08a-d0dd-5af1-aa61-ad73848896ad",
      "code": "",
      "length": 5,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "524ca853-2565-55ca-b273-b6bba910642e",
      "code": "return;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "adfcf6ad-94d5-546e-b980-ae30edce4749",
      "code": "",
      "length": 6,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "b1a0329f-70bf-5f5f-bd91-5c9943be52f9",
      "code": "if (self.self.isOnGround()) {\n\tself.self.toLand();\n\treturn;\n}\nself.self.setGlobalVariable(\"usedSpec\", true);\nself.self.toHelpless();",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "23b876b0-000c-5a8d-b3a1-6e4139017fa9",
      "code": "self.self.resetMovement();\nself.self.updateAttackStats({ allowControl: false, air_ease: 0 });\nself.self.unnattachFromGround();\nself.self.removeEventListener(SSF2Event.CHAR_ATTACK_COMPLETE, self.self.toHelpless);\nself.self.removeEventListener(SSF2Event.GROUND_TOUCH, self.self.toHeavyLand);\nself.self.destroyTimer(self.checkGrabbed);\nself.self.destroyTimer(self.afterImage);\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "26ea1d4c-b20c-5eb6-b61e-1a5074668936",
      "code": "",
      "length": 2,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "fc8605ed-2694-58e4-9d10-de9c11e53955",
      "code": "self.self.resetMovement();\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "9a5df692-d471-5d50-a2cc-82b8e293c5db",
      "code": "self.self.updateAttackBoxStats(1, { effect_id: \"effect_firehit_heavy\" });\nself.self.refreshAttackID();\nself.self.resetMovement();\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "9ac8e80e-59c7-5f91-85f5-626587aba79d",
      "code": "",
      "length": 3,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "7decfedf-f783-5537-8cca-6340edcff243",
      "code": "self.self.setXSpeed(-6, false);\nself.self.setYSpeed(-20);\nself.self.playAttackSound(2);\nself.foe = self.self.getGrabbedOpponent();\nself.self.releaseOpponent();\nif (self.foe) {\n\tself.foe.forceHitStun(1, 0);\n}\nself.self.attachEffect(\"effect_explosion\", { scaleX: 1.5, scaleY: 1.5, x: self.self.flipX(20), y: -30 });\nself.self.playVoiceSound(1);\nself.self.updateAttackStats({ air_ease: -1 });\nSSF2API.getCamera().shake(5);\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "0956511d-aab0-5ca6-bbab-2cfed1b45e4a",
      "code": "",
      "length": 10,
