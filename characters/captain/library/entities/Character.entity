    },
    {
      "$id": "77ef8762-e498-53a5-bf3d-fc494e875f6f",
      "code": "self.self = /* ? */;\nself.horiz = 7;\nif (SSF2API.isReady() && self.self) {\n}",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "ef7991b2-8e13-5a7e-a838-70f2535fcdbf",
      "code": "",
      "length": 3,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "46058d3c-5af4-52c5-9536-c383ca787405",
      "code": "self.self.createTimer(1, 0, self.alterHoriz);\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "0f5c9ffe-7ebe-5265-b160-25034cdb7890",
      "code": "self.self.attachEffect(\"global_sparkle\", { x: self.flipX(18), y: -5 });\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "1f04ab72-c0e2-5071-a7ad-52a259c23648",
      "code": "",
      "length": 2,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "a3dc2361-29e6-5543-a49e-beffd21c39b8",
      "code": "self.self.playAttackSound(3);\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "2fd2a69b-b334-5151-a0e2-78e35e5c8e64",
      "code": "self.self.setXSpeed(self.horiz, false);\nself.self.setYSpeed(-23);\nself.self.createTimer(1, 14, self.checkGrabbed);\nself.self.createTimer(1, 3, self.afterImage);\nself.self.destroyTimer(self.alterHoriz);\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "726764a7-dcad-51ca-87ef-9f220002b329",
      "code": "self.self.updateAttackStats({ allowControl: true, air_ease: 2 });\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "8afeca46-c8fb-5cc3-8d2a-5988fe75b0ca",
      "code": "self.self.createTimer(2, 3, self.afterImage);\nself.self.updateAttackStats({ xSpeedCap: 7 });\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "81b52ca9-c5dc-54b2-a4d4-73f1042ed53b",
      "code": "",
      "length": 4,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "3e982299-7ec3-5474-bc6b-1aef608c6f58",
      "code": "self.self.createTimer(3, 2, self.afterImage);\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "7db2e03e-0d58-5904-9fef-0afc521c614b",
      "code": "if (self.self.isOnGround()) {\n\tself.self.toHeavyLand();\n}\nself.self.addEventListener(SSF2Event.GROUND_TOUCH, self.self.toHeavyLand);\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "ceee5145-aec1-5d43-8cbc-6e634be95e24",
      "code": "",
      "length": 3,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "3945bca1-2cbf-5090-bd3d-933da01ef9b2",
      "code": "self.self.playSound(\"raptorBoost1\");\nself.self.updateAttackStats({ air_ease: -1 });\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "5f882ad0-b364-5c1e-921c-a109e56345f4",
      "code": "self.self.updateAttackStats({ xSpeedDecayAir: -1.65 });\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "49c91937-8510-52ff-9eed-35f55899b40c",
      "code": "",
      "length": 4,
