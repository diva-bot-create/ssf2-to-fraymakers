      "code": "self.self.removeEventListener(SSF2Event.GROUND_TOUCH, self.self.toLand);\nself.self.endAttack();\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
