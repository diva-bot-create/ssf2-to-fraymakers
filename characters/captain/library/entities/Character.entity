      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "3694c6ff-7e89-5b92-8c21-b4dc7f2ba86d",
      "code": "self.self.resetJumps();\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "b9084f5d-072f-5dc4-b20c-c76b9b122121",
      "code": "",
      "length": 11,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "3f730a31-e378-5465-b691-216b387e1188",
      "code": "self.self.endAttack();\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "cccfd3ae-3bfb-53c1-9689-d02cad071e0f",
      "code": "self.self.resetMovement();\nself.self.setXSpeed(0);\nself.self.setYSpeed(0);\nself.self.updateAttackStats({ canFallOff: false });\nif (self.projectile != null && !self.projectile.isDisposed()) {\n\tself.self.playSound(\"metal_land_l\");\n\treturn;\n}\nself.self.playAttackSound(2);",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "9a968ca1-e896-5fa8-b30e-229fcb99123e",
      "code": "",
      "length": 14,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "30cfb725-86fe-52a3-876d-d39048619d8e",
      "code": "self.self.endAttack();\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "e2113c88-7efd-53ed-ab68-022c55c0b100",
      "code": "self.hasHit = true;\nself.self.resetMovement();\nself.self.setXSpeed(-8, false);\nself.self.setYSpeed(-11);\nself.self.updateAttackStats({ allowControl: true });\nself.self.destroyTimer(self.physics);\nself.self.removeEventListener(SSF2Event.GROUND_TOUCH, self.toFrame);\nif (self.projectile != null && !self.projectile.isDisposed()) {\n}",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
