    {
      "$id": "7a485618-4bc2-5a56-8f20-594de6582405",
      "length": 33,
      "name": "special_side",
      "pluginMetadata": {},
      "type": "LABEL"
    },
    {
      "$id": "bb5e3124-b3d3-5ca5-bc20-0b93e8a3a3b7",
      "length": 15,
      "name": "afterHit",
      "pluginMetadata": {},
      "type": "LABEL"
    },
    {
      "$id": "b68d93d3-db99-569d-be60-a763a3568171",
      "length": 15,
      "name": "fall",
      "pluginMetadata": {},
      "type": "LABEL"
    },
    {
      "$id": "4ae1265e-7807-5356-b5be-c34b253de56e",
      "code": "self.self = /* ? */;\nself.hasHit = false;\nif (SSF2API.isReady()) {\n\tself.grounded = self.self.isOnGround();\n\tself.self.addEventListener(SSF2Event.ATTACK_CONNECT, self.toFrame);\n\tself.self.addEventListener(SSF2Event.ATTACK_CONNECT_SHIELD, self.toFrame);\n\tself.self.addEffectToList(self.self.attachEffect(\"raptorboost_effect\", { syncHitStun: true, parentLock: true }));\n}\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "de060a46-4c6b-5aa8-9be2-d21da562dc1f",
      "code": "self.self.playSound(\"raptorBoost1\");\nself.self.clearEffectsOnStateChange();\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "4674f57f-aa73-5944-8707-a753b23433f2",
      "code": "",
      "length": 4,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "0bee1122-2599-51b2-aa35-9c7b38129677",
      "code": "self.effect1 = self.self.attachEffect(\"raptorboost_effect_trail\", { parentLock: true });\nself.self.addEffectToList(self.effect1);\nself.self.createTimer(1, 0, self.followCF);\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "58edc195-ee2c-5609-9daf-e4014720c469",
      "code": "self.self.setXSpeed(21.6, false);\nself.self.createTimer(2, 7, self.checkGround);\nself.self.playAttackSound(2);\nself.self.attachEffect(\"global_dust_heavy\");\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "f5b66c09-98dd-5e41-81c8-a006024d9389",
      "code": "",
      "length": 9,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "41f7d7ad-9ee3-5f5e-9016-aa787182f7ca",
      "code": "self.self.resetMovement();\nself.self.setXSpeed(0);\nself.self.updateAttackStats({ canFallOff: false });\nself.self.attachEffect(\"global_dust_cloud\");\nself.effect1.gotoAndStop(\"end\");\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "9b0921ff-cbd7-50f8-8d17-4552dcd10b87",
      "code": "",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "58982e4b-8402-5fa5-8609-d4a301456f35",
      "code": "SSF2API.getCamera().shake(4);\nif (self.self.getMetalStatus()) {\n\tself.self.playSound(\"metal_land_m\");\n\treturn;\n}\nself.self.playSound(\"falcon_dspecLand\");",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "5833d862-54a1-5afe-89aa-65a9295d5a07",
      "code": "",
      "length": 10,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "8a330739-4856-56e9-8667-8e103dc4a20c",
      "code": "self.self.resetMovement();\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "1052758c-1ac6-564e-8868-331c866f8926",
      "code": "",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "83c9e6a3-be3b-5130-95df-757ec36ea468",
      "code": "self.self.endAttack();\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "83da06c8-6014-5c4d-9cb4-c22c918db453",
      "code": "self.hasHit = true;\nself.self.updateAttackBoxStats(1, { allowTurboInterrupt: true, damage: 7, direction: 90, power: 78, kbConstant: 65, hitStun: 1, hitLag: -1.1, selfHitStun: 0, hasEffect: true, effect_id: \"effect_firehit_light\", effectSound: \"brawl_punch_m\", bypassShield: false, priority: 4 });\nself.self.updateAttackStats({ canFallOff: false });\nself.effect1.gotoAndStop(\"end\");\nself.self.addEffectToList(self.self.attachEffect(\"raptorboost_ground_hit\", { syncHitStun: true, parentLock: true }));\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "c7517f0f-da24-50bd-b438-5ab4b224dd92",
      "code": "",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "82cb532f-0ff3-513b-b8d2-cbfa0727f8a9",
      "code": "self.self.resetMovement();\nself.self.setXSpeed(0);\nself.checkGround();\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "4f421fb3-22cc-5f91-baa3-01b19b307b52",
      "code": "",
      "length": 2,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "b9de338f-4990-52b3-8132-26faa1a4ba4d",
      "code": "self.self.playSound(\"cfalcon_swing_l\");\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "40389e52-6600-5e15-8661-bdfff6db758c",
      "code": "",
      "length": 8,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "e22e90c9-6a53-5ad6-b08d-1ba989d3e845",
      "code": "self.self.endAttack();\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "7eca60ed-aa8e-5143-bc30-b603e97845a1",
      "code": "self.self.destroyTimer(self.checkGround);\nself.effect1.gotoAndStop(\"end\");\nself.self.addEventListener(SSF2Event.GROUND_TOUCH, self.self.toHeavyLand);\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
