    },
    {
      "$id": "c3f4cb92-a1d8-58e7-bda4-f208f91cab8f",
      "length": 28,
      "name": "grabbed",
      "pluginMetadata": {},
      "type": "LABEL"
    },
    {
      "$id": "fef78742-ceb3-537c-8dfb-76f9c8f29c2d",
      "code": "self.self = /* ? */;\nself.horiz = 7;\nif (SSF2API.isReady() && self.self) {\n}",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "3f133e69-1531-51b8-a996-9fb13961bbc5",
      "code": "self.self.createTimer(1, 0, self.alterHoriz);\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "fde8f92e-d524-5ab4-9188-0bbd3c0f913a",
      "code": "self.self.attachEffect(\"global_sparkle\", { x: self.flipX(18), y: 5 });\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "824bfd1e-a1b3-5cf4-b3d5-c195ce34eeb8",
      "code": "",
      "length": 2,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "b96bb9c1-9c08-5ce0-933f-0cb05acf6829",
      "code": "self.self.playAttackSound(3);\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "6c26d6d3-7aff-5f23-a3d0-cfc8343a2ed4",
      "code": "self.self.setXSpeed(self.horiz, false);\nself.self.setYSpeed(-23);\nself.self.createTimer(1, 14, self.checkGrabbed);\nself.self.createTimer(1, 3, self.afterImage);\nself.self.destroyTimer(self.alterHoriz);\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "4e635b35-1855-57ef-8443-e3db3a4516d0",
      "code": "self.self.updateAttackStats({ allowControl: true, air_ease: 2 });\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "d5db619f-f05a-510a-a34e-ec1e5de7c690",
      "code": "self.self.createTimer(2, 3, self.afterImage);\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "6a9e5c28-79d2-51f3-8993-efa08b6ebc79",
      "code": "",
      "length": 5,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "e1e13fa8-dfe9-5ce1-bc80-1ab7757fc952",
      "code": "self.self.createTimer(3, 2, self.afterImage);\nself.self.updateAttackStats({ xSpeedCap: 7 });\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "bc0ef376-802f-5530-bcc6-17bdc27300b7",
      "code": "if (self.self.isOnGround()) {\n\tself.self.toHeavyLand();\n}\nself.self.addEventListener(SSF2Event.GROUND_TOUCH, self.self.toHeavyLand);\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "f1570ab4-bd61-5535-85ac-de888478f9da",
      "code": "",
      "length": 3,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "c9aa7e7c-9098-5afa-aadb-4bb896edf61f",
      "code": "self.self.playSound(\"raptorBoost1\");\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "d524cd92-06cf-5bca-8576-301a9cd0b7ae",
      "code": "",
      "length": 2,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "c051926a-8137-5f43-a629-cfd15c158ff6",
      "code": "self.self.updateAttackStats({ xSpeedDecayAir: -1.65, air_ease: -1 });\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "3cf89dce-56c0-59ce-96ed-0fedfec1bba5",
      "code": "",
      "length": 8,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "569b679c-7985-59e0-ae76-55e80340e7ae",
      "code": "return;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "89f38153-1d66-5a55-8714-b48d65f4d14b",
      "code": "",
      "length": 7,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "b65289d7-17d6-5e0e-a06b-ac6ca12dc07d",
      "code": "if (self.self.isOnGround()) {\n\tself.self.toLand();\n\treturn;\n}\nself.self.setGlobalVariable(\"usedSpec\", true);\nself.self.toHelpless();",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "5f836213-4ff4-50b7-95f9-5b0022886dfd",
      "code": "self.self.resetMovement();\nself.self.updateAttackStats({ allowControl: false, air_ease: 0 });\nself.self.unnattachFromGround();\nself.self.removeEventListener(SSF2Event.CHAR_ATTACK_COMPLETE, self.self.toHelpless);\nself.self.removeEventListener(SSF2Event.GROUND_TOUCH, self.self.toHeavyLand);\nself.self.destroyTimer(self.checkGrabbed);\nself.self.destroyTimer(self.afterImage);\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "864bac62-dd17-50aa-a7f4-1dba32c72d8a",
      "code": "",
      "length": 2,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "ffb026be-244b-5078-a6da-2681a72a8cd7",
      "code": "self.self.resetMovement();\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "11068b77-6170-5b14-ae41-5c8eac9dd28e",
      "code": "self.self.updateAttackBoxStats(1, { effect_id: \"effect_firehit_heavy\" });\nself.self.refreshAttackID();\nself.self.resetMovement();\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "bc3e47eb-67d0-590b-ae53-161e9a3fbac4",
      "code": "",
      "length": 3,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "e305fb4d-f9f1-5a02-b518-3f49e752e46a",
      "code": "self.self.setXSpeed(-6, false);\nself.self.setYSpeed(-20);\nself.self.playAttackSound(2);\nself.foe = self.self.getGrabbedOpponent();\nself.self.releaseOpponent();\nif (self.foe) {\n\tself.foe.forceHitStun(1, 0);\n}\nself.self.attachEffect(\"effect_explosion\", { scaleX: 1.5, scaleY: 1.5, x: self.self.flipX(20), y: -25 });\nself.self.playVoiceSound(1);\nself.self.updateAttackStats({ air_ease: -1 });\nSSF2API.getCamera().shake(5);\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "099a04b5-7945-579d-ad7a-d177118da43a",
      "code": "",
