      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "8fba9081-6136-513a-ba2f-47b2c2eccbca",
      "code": "self.self.setIntangibility(false);\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "6a420a7d-1ede-5e2d-abed-e41e11cfd62b",
      "code": "if (self.self.getMetalStatus()) {\n\tSSF2API.playSound(\"metal_step_m1\");\n\treturn;\n}\nSSF2API.playSound(\"falcon_footstep\");",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
