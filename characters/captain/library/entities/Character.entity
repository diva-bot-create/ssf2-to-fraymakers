    {
      "$id": "2f85c64a-3c5a-5a58-b70e-61f4972e2345",
      "length": 23,
      "name": "throw_down",
      "pluginMetadata": {},
      "type": "LABEL"
    },
    {
      "$id": "3bd15286-f03c-50f6-9984-cdfcd31c35d3",
      "code": "if (SSF2API.isReady()) {\n\tself.self = /* ? */;\n\tself.playsound = SSF2API.random();\n\tself.audio = self.self.getGlobalVariable(\"audio\");\n\tself.self.swapDepthsWithGrabbedOpponent(false);\n}\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "cf434e42-45d3-5e2f-8eb6-13f517709c9d",
      "code": "self.self.playSound(\"cfalcon_kickwind\");\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "a573e0af-87ce-5d9a-a549-a57055ba9780",
      "code": "",
      "length": 6,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "03ed35fd-1c10-5c72-8be2-f78dd7564c97",
      "code": "self.self.setXSpeed(3, false);\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "e31844e6-7671-5fdc-83b1-146918862b42",
      "code": "SSF2API.getCamera().shake(9);\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "0b2056c5-36e0-5ce6-8a04-e55abbf94087",
      "code": "if ((self.playsound > 0.2 && self.playsound <= 0.4) || self.audio != 1) {\n\tself.self.playVoiceSound(1);\n\tself.self.setGlobalVariable(\"audio\", 1);\n}\nif ((self.playsound > 0.4 && self.playsound <= 0.6) || self.audio != 2) {\n\tself.self.playVoiceSound(2);\n\tself.self.setGlobalVariable(\"audio\", 2);\n}\nif ((self.playsound > 0.6 && self.playsound <= 0.8) || self.audio != 3) {\n\tself.self.playVoiceSound(3);\n\tself.self.setGlobalVariable(\"audio\", 3);\n}\nif ((self.playsound > 0.8 && self.playsound <= 1) || self.audio != 4) {\n\tself.self.playVoiceSound(4);\n\tself.self.setGlobalVariable(\"audio\", 4);\n}\nself.self.playSound(\"cfalcon_kickwind\");\nself.self.attachEffect(\"global_dust_cloud\");\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "7ebfddfa-377d-5530-8c66-4e0472821470",
      "code": "",
      "length": 11,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "243e014e-a658-5aaa-b3cc-0629faa91d91",
      "code": "self.self.endAttack();\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
