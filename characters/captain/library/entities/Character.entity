      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "307cfe6a-c174-5760-90d6-12e4ad8e71eb",
      "code": "self.self.getItem().deactivateItem();\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
