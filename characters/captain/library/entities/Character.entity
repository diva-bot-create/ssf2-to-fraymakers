    {
      "$id": "94021e6a-57e3-5970-b22d-d76f82b87be3",
      "code": "self.self.getItem().activateItem();\nself.self.playAttackSound(1);\nself.self.attachEffect(\"global_dust_light\", { x: self.self.flipX(-10) });\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "74e1ecbe-27bb-5ad1-92bc-dfdc43974464",
      "code": "self.self.getItem().deactivateItem();\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
