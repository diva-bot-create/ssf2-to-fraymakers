    },
    {
      "$id": "fdf909b2-d36f-5b40-9bdf-03808ffb6821",
      "code": "self.self.playSound(\"falcon_jumpS1\");\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "f029c9a2-0f6f-524a-912c-0efc9e1f071c",
      "code": "",
      "length": 3,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "ccff3a5b-36b6-5b8a-807f-2c274ede39b6",
      "code": "self.self.playSound(\"cfalcon_run_start\");\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "08c7227a-d9cf-51a3-9dfa-ecf8be513ba3",
      "code": "",
