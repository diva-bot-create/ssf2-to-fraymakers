    {
      "$id": "139f9a01-78f8-58ff-892b-b00b2246ec46",
      "code": "self.self.setIntangibility(true);\nself.self.addEventListener(SSF2Event.GROUND_TOUCH, self.dodgeLand);\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
