    },
    {
      "$id": "af9c014e-c0c0-55b4-9467-5047726be710",
      "code": "self.self = /* ? */;\nself.hasHit = false;\nif (SSF2API.isReady()) {\n\tself.self.playVoiceSound(1);\n}\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "637507ec-fc0c-52a9-bc8d-1a09182393dd",
      "code": "",
      "length": 3,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "bce72088-872e-5045-8f5b-579bd96ff76b",
      "code": "self.self.setXSpeed(-5, false);\nself.self.attachEffect(\"global_dust_heavy\");\nself.self.updateAttackStats({ air_ease: 0 });\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "b3a1460c-bee4-51f7-950c-d7fdd0e102ed",
      "code": "",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "bb062039-3bc6-5b40-a131-c0b38ba6af03",
      "code": "self.self.playAttackSound(1);\nself.self.createTimer(1, 13, self.physics);\nself.self.fireProjectile(\"captainfalcon_dspecProj\");\nself.projectile = self.self.getCurrentProjectile();\nself.self.addEventListener(SSF2Event.HIT_WALL, self.crash);\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "cf9afdf7-acff-5698-88d3-36b002dc30ef",
      "code": "",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "ffa06f8b-c30d-5c4b-83bd-0bcd25418900",
      "code": "self.self.updateAttackBoxStats(1, { damage: 12, kbConstant: 60 });\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
