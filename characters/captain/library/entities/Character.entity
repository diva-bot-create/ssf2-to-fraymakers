      "code": "self.self = /* ? */;\nif (self.self && SSF2API.isReady()) {\n}",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "1233c9f7-de9b-5560-b1f4-48a28f48b39a",
      "code": "",
      "length": 27,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "43268e99-598f-5687-85f9-ab6192ee79eb",
      "code": "self.self.destroyTimer(self.effects);\nself.self.updateAttackStats({ superArmor: true });\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "343662eb-5482-55d8-b8f4-f10a4c3819ad",
      "code": "",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "ebc1ba96-d951-569d-8ee9-3655cca9e8e0",
      "code": "self.self.getItem().activateItem();\nself.self.playAttackSound(1);\nself.self.playVoiceSound(1);\nSSF2API.getCamera().shake(6);\nself.self.attachEffect(\"global_dust_heavy\", { x: self.self.flipX(5), y: 3, scaleX: -0.75, scaleY: -0.75 });\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "c4d0452e-62dd-5c57-a9ed-361860166425",
      "code": "",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "3ed7575d-bef1-5f59-a284-3a117e27469d",
      "code": "self.self.getItem().deactivateItem();\nself.self.updateAttackStats({ superArmor: false });\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "391822a5-b48c-50ff-ac0a-a68f93144d59",
      "code": "",
