      "name": "strong_forward_attack",
      "pluginMetadata": {},
      "type": "LABEL"
    },
    {
      "$id": "4aed8358-7848-5a5d-9440-067468f6bc97",
      "code": "self.xframe = \"attack\";\nself.self.destroyTimer(self.effects);\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "a1c46d12-d2f2-58eb-b96b-82dd581cf2d6",
      "code": "",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "6f9081a6-2c73-5195-89a5-30dd98f87676",
      "code": "self.self.setXSpeed(10, false);\nself.self.playSound(\"cfalcon_smashstart\");\nself.self.attachEffect(\"global_dust_heavy\");\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "a05f9805-e220-5e8f-835b-ce9f6556ff24",
      "code": "self.self.attachEffect(\"wind_wave\", { x: self.self.flipX(55), y: -35, scaleX: 0.8, scaleY: 0.8 });\nself.self.attachEffect(\"global_dust_blast\", { x: self.self.flipX(60), y: -35, parentLock: true });\nself.self.playAttackSound(1);\nself.self.playVoiceSound(1);\nself.self.addEffectToList(self.self.attachEffect(\"trail_cfalcon_fsmash\", { scaleX: 1.15, scaleY: 1.15, parentLock: true, syncHitStun: true }));\nself.self.clearEffectsOnStateChange();\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "0963a0d9-2940-5d37-940f-0a999edffafd",
      "code": "",
      "length": 18,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
