    },
    {
      "$id": "7d68cb5d-7661-56b1-b396-1b011a4b3518",
      "code": "self.self.addEventListener(SSF2Event.GROUND_TOUCH, self.toFrame);\nself.self.addEventListener(SSF2Event.GROUND_TOUCH, self.self.resetMovement);\nself.self.removeEventListener(SSF2Event.HIT_WALL, self.crash);\nself.self.updateAttackStats({ canFallOff: false });\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "ba25cb78-2835-5119-b827-479591ce9102",
      "code": "",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "0864426f-7f8f-5a91-bc2f-a72d76388a4e",
      "code": "if (self.self.isOnGround()) {\n\tself.self.stancePlayFrame(\"continue\");\n}\nself.self.updateAttackStats({ air_ease: -1 });\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "9d08c3e2-d885-5300-9b2e-63f702d38f76",
      "code": "self.self.removeEventListener(SSF2Event.GROUND_TOUCH, self.toFrame);\nself.self.addEventListener(SSF2Event.GROUND_TOUCH, self.self.toLand);\nself.self.updateAttackStats({ air_ease: -1, allowControl: true });\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "5013aaa8-3162-58da-83b3-0c323fb7eb48",
