    {
      "$id": "2ce9c33d-c324-5764-a2c7-196a7a8f0dd1",
      "code": "if (SSF2API.isReady()) {\n\tself.self = /* ? */;\n\tself.self.setLandingLag(false);\n}\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "336a13c5-d768-5a32-b0c8-dfe062ec8ccb",
      "code": "self.self.setLandingLag(true);\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "e6e0280e-2891-56bf-a30b-f2756f13e759",
      "code": "",
      "length": 4,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "0f9f2166-581c-5dd4-96c5-c20ef0965285",
      "code": "self.self.playAttackSound(1);\nself.self.attachEffect(\"global_spark\", { x: self.self.flipX(-10), y: -30 });\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "d12f7e17-5784-513a-ab53-b5aa6a7d45c9",
      "code": "",
      "length": 14,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "e17ca684-3261-5c2d-ad35-a589c11f3bcf",
      "code": "self.self.setLandingLag(false);\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "877c1684-e3f3-5b6b-9991-7e26bca2fd2c",
      "code": "",
      "length": 6,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "7b958688-5a43-5bc9-b98e-fcbcfa9e7668",
      "code": "self.self.endAttack();\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "f50c11af-1b30-5fe0-9172-22009af1e914",
      "code": "",
      "length": 2,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "2a96e287-35ec-5f27-ab27-2644d0a1b95f",
      "code": "self.self.updateAttackStats({ allowControl: false });\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "bb499ad0-c616-5a0a-aa69-be3227103b8a",
      "code": "SSF2API.getCamera().shake(2);\nif (self.self.getMetalStatus()) {\n\tself.self.playSound(\"metal_land_m\");\n\treturn;\n}\nself.self.playSound(\"samus_landing_heavy\");",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
