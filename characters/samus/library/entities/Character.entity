    {
      "$id": "07d36198-69bc-5fa7-8489-3d1964e88f3a",
      "code": "if (SSF2API.isReady()) {\n\tself.self = /* ? */;\n\tself.isSuper = false;\n}\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "daeb754b-4a64-58a8-8557-cfec432b40f5",
      "code": "",
      "length": 9,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "0533c410-ca3d-59ec-bf05-f84bf947029a",
      "code": "self.self.attachEffect(\"effect_explosion\", { x: self.self.flipX(40), y: -30, scaleX: 0.5, scaleY: 0.5 });\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "66a4c4a3-c89f-560a-8755-962d0797c868",
      "code": "self.self.fireProjectile(\"homingmissile\", 0, 10);\nSSF2API.getCamera().shake(3);\nself.self.playAttackSound(1);\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "35ef46f9-4f69-5b4d-b67b-1eb41ad123f4",
      "code": "",
      "length": 17,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "c9b17f3a-218d-5cff-abe1-555dc89ab3f9",
      "code": "self.self.endAttack();\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
