    },
    {
      "$id": "e703c876-c6a8-5337-beb2-dd42aabe4342",
      "code": "self.self.setXSpeed(5, false);\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
