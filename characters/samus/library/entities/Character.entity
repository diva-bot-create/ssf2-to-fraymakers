    },
    {
      "$id": "ce6956eb-dd8d-5b67-8f11-ab56e32abded",
      "code": "if (SSF2API.isReady()) {\n\tself.self = /* ? */;\n}\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "48621edb-ad82-5767-9b42-e22c4d0359be",
      "code": "self.self.playSound(\"samus_kickwind\");\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "e49e8c59-302d-5c03-9eab-f6f4f14ea727",
      "code": "",
      "length": 5,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "28b8f65f-d273-5c1f-adbf-415418673b31",
      "code": "self.self.playAttackSound(1);\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "79eca15c-8f2c-5451-b1c3-282798993c9a",
