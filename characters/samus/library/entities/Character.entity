    {
      "$id": "bc645ef9-cae8-52c3-b684-7c69dd9bd8d3",
      "length": 1,
      "name": "strong_forward",
      "pluginMetadata": {},
      "type": "LABEL"
    },
    {
      "$id": "09b06cfd-3dea-5c18-b4ea-c95c9c56ad33",
      "code": "if (SSF2API.isReady()) {\n\tself.self = /* ? */;\n}\nself.xframe = null;\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "3bcd5d95-c61c-5ae2-9845-f8420ee495f6",
      "code": "self.xframe = \"charging\";\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "310dff33-1b9f-5e82-8a79-e8817dc8d023",
      "code": "",
      "length": 39,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "df69e63a-4ee5-54c8-af46-dd2fd3e60221",
      "code": "self.self.stancePlayFrame(\"charging\");\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "84db7976-d822-5726-b743-3b9f5f0103ad",
      "code": "self.xframe = \"attack\";\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "0bf79cc5-dff5-59ce-a649-1aa47868f916",
      "code": "self.self.attachEffect(\"global_dust_heavy\");\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "a35fb07e-e3d3-5c06-b7bc-97bfa48edff6",
      "code": "self.self.playSound(\"samus_swing_l\");\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "161a59e6-dd40-5d86-b9e0-8bafb914d3ac",
      "code": "",
      "length": 4,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "79080418-807c-5aab-982f-1e6da293f8f9",
      "code": "self.self.playSound(\"samus_tilt_down\");\nself.self.refreshAttackID();\nself.self.pushEffectBehind(self.self.attachEffect(\"samus_explosion\", { scaleX: 1.36, scaleY: 1.36, x: self.self.flipX(55), y: -27.5 }));\nself.self.attachEffect(\"samus_explosion2\", { scaleX: 1.36, scaleY: 1.36, x: self.self.flipX(55), y: -27.5 });\nself.self.attachEffect(\"effect_dust_light\");\nSSF2API.getCamera().shake(5);\nself.self.updateAttackBoxStats(1, { damage: 10, priority: 6, chargedPriority: 6, effect_id: \"effect_firehit\", direction: 50, weightKB: 0, power: 35, kbConstant: 120, effectSound: \"brawl_fire_l\", burn: true });\nself.self.updateAttackBoxStats(2, { damage: 11, priority: 6, chargedPriority: 6, effect_id: \"effect_firehit\", direction: 50, weightKB: 0, power: 35, kbConstant: 120, effectSound: \"brawl_fire_l\", burn: true });\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "dfe55158-7914-54c9-a287-8217f4810778",
      "code": "self.self.playSound(\"samus_kickwind\");\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "a6f7a21a-3094-5b13-a81c-dfd658b3761f",
      "code": "",
      "length": 12,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
