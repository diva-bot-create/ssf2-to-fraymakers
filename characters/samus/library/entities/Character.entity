      "pluginMetadata": {},
      "type": "LABEL"
    },
    {
      "$id": "c7957fd1-3a73-502a-a6f6-b172f959970d",
      "code": "if (SSF2API.isReady()) {\n\tself.self = /* ? */;\n\tself.isSuper = false;\n}\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "54e37bdc-b65e-5399-8d9e-91ac24f73a60",
      "code": "",
      "length": 8,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "82670309-9529-5785-963f-66c936385917",
      "code": "self.self.attachEffect(\"effect_explosion\", { x: self.self.flipX(40), y: -40, scaleX: 0.5, scaleY: 0.5 });\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "677a4266-a405-58e4-b5e2-20379859dbf7",
      "code": "self.self.fireProjectile(\"homingmissile\");\nSSF2API.getCamera().shake(3);\nself.self.playAttackSound(1);\nself.self.attachEffect(\"global_dust_light\");\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "4fcf2bca-2c47-5a0d-b68a-326bf2f2cd43",
      "code": "",
      "length": 18,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "de2a58c8-c5aa-577c-aa04-720efdcaedcc",
      "code": "self.self.endAttack();\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "00760bec-7dd6-5750-9494-d9c9f44e91c0",
      "code": "",
      "length": 9,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "ef9c3775-d20e-5111-a91d-4938f6d77225",
      "code": "self.self.attachEffect(\"effect_explosion\", { x: self.self.flipX(40), y: -40, scaleX: 0.5, scaleY: 0.5 });\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "d2c95c98-36d0-57fd-a023-db8f145e164d",
      "code": "self.self.fireProjectile(\"powermissile\");\nself.self.playAttackSound(2);\nself.self.attachEffect(\"global_dust_heavy\");\nSSF2API.getCamera().shake(6);\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
