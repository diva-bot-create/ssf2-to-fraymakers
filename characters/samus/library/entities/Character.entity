      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "97d105a9-a3d4-5e35-9d93-3b1e689c2421",
      "code": "self.self.playSound(\"samus_kickwind\");\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "d606b0f1-ee14-5e4c-8b0b-4cacb2278f21",
      "code": "",
      "length": 2,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "23d7ad99-1f8d-5583-89ff-3d211994c8ff",
      "code": "if (self.self.getMetalStatus()) {\n\tself.self.playSound(\"metal_land_m\");\n\treturn;\n}\nself.self.playSound(\"samus_landing_light\");",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
