    {
      "$id": "b3ccde54-7a34-552d-b3b4-e68e3573fd2c",
      "code": "self.self.playAttackSound(5);\nself.self.updateAttackBoxStats(1, { power: 80, kbConstant: 107 });\nself.self.updateAttackStats({ refreshRate: 99 });\nself.self.refreshAttackID();\nreturn;",
