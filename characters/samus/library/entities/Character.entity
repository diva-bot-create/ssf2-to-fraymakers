    },
    {
      "$id": "34efd11c-84f9-5f62-8bf3-e436399799a8",
      "code": "if (SSF2API.isReady()) {\n} else {\n\treturn;\n}\nself.self = /* ? */;\nif (self.self) {\n\tself.self.playSound(\"samus_dodge_run\");\n}",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "9f587f44-f90b-532e-9133-ecd1bb15cbac",
      "code": "",
      "length": 4,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "14d72702-aa55-5386-896e-77c70847a147",
      "code": "self.self.stancePlayFrame(\"run\");\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "aaab0120-643f-56bf-b70b-a598eb82bc60",
      "code": "if (self.self.getMetalStatus()) {\n\tself.self.playSound(\"metal_step_m1\");\n\treturn;\n}\nself.self.playSound(\"samus_step\");",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
