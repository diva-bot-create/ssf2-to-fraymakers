    },
    {
      "$id": "67b9dda6-0528-5133-bbee-6477fcd21d40",
      "code": "if (SSF2API.isReady()) {\n\tself.self = /* ? */;\n}\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "cc7192de-efe3-5705-9cf9-f168fd4d2321",
      "code": "self.self.attachEffect(\"global_dust_heavy\");\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "50874526-152a-5795-a94c-b6e2a9741a1b",
      "code": "",
      "length": 2,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "f5dd3127-73af-5236-9421-b65805e2e45d",
      "code": "self.self.attachEffect(\"global_spark\", { x: self.self.flipX(15), y: -80 });\nself.self.playAttackSound(1);\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "5445f7be-0cd8-5001-94b7-1eb149063f93",
      "code": "",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "46875574-906c-52b3-aed4-7b60347c2466",
      "code": "self.self.playAttackSound(2);\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "92fe8aa8-1cb7-505d-9269-ad3a9150e30c",
      "code": "",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "b5a5d9f2-55cf-5a1f-8448-e0cd5a972108",
      "code": "self.self.attachEffect(\"global_dust_cloud\", { x: self.self.flipX(15) });\nself.self.playAttackSound(3);\nif (self.self.getMetalStatus()) {\n\tself.self.playSound(\"metal_step_m1\");\n\tSSF2API.getCamera().shake(3);\n\treturn;\n}\nself.self.playSound(\"samus_step1\");",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "17df25a2-f0f1-5c8c-ba08-e708fe4c2e56",
      "code": "",
      "length": 10,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "2f2a7d20-769c-52a9-9e4e-e310fec27d0c",
      "code": "self.self.endAttack();\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
