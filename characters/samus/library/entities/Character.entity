      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "6c1987a1-4123-5daa-9223-4f108141c563",
      "code": "self.self.attachEffect(\"global_dust_cloud\", { x: self.self.flipX(35) });\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
