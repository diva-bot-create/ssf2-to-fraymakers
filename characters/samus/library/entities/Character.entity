    },
    {
      "$id": "fa255bf0-7e79-5e95-a745-0314ce33337e",
      "code": "if (self.self.isOnGround()) {\n\tself.self.toHeavyLand();\n\treturn;\n}\nself.self.setGlobalVariable(\"uspecfall\", true);\nself.self.endAttack();",
