    {
      "$id": "4ae9cae3-21fe-5fdc-9087-16d936bec0dd",
      "length": 1,
      "name": "special_neutral_air",
      "pluginMetadata": {},
      "type": "LABEL"
    },
    {
      "$id": "f005a5f4-d7ea-5ebe-915d-d88f1cf288f3",
      "code": "self.self = /* ? */;\nif ((self.self && SSF2API.isReady()) || false) {\n}\nif (self.fromGround) {\n} else {\n\tself.self.createTimer(1, -1, self.checkSpeckill, { persistent: true });\n}\nif (self.fullCharge) {\n\tself.curCharge = self.maxCharge - 1;\n\tself.fullCharge = false;\n}\nself.self.setGlobalVariable(\"SamusNSpecToAir\", false);\nself.self.stancePlayFrame(\"attack\");",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "a3d1b168-f528-54b7-8381-4120cc148318",
      "code": "",
      "length": 6,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "2d88cc6e-ef83-57a6-bdf9-15328208f3f7",
      "code": "self.self.destroyTimer(self.checkSpeckill);\nif (self.fullCharge) {\n\tself.self.stancePlayFrame(\"attack2\");\n\treturn;\n}\nself.self.fireProjectile(\"unchargedshot\");\nself.self.setXSpeed(self.speed, false);\nself.self.setYSpeed(-3);\nSSF2API.getCamera().shake(3);\nself.self.playAttackSound(2);",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "8b3d2f52-04bf-5fd4-b3f5-37ae57a4fc62",
      "code": "self.self.addEventListener(SSF2Event.GROUND_TOUCH, self.self.toHeavyLand);\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "201c9043-1c1a-5cc9-97d5-dbf552e739d7",
      "code": "",
      "length": 13,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "db42c92d-5186-5f98-9717-e20458aca465",
      "code": "self.self.endAttack();\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "9f0cbe27-e2a9-5f4c-a039-25e335e39397",
      "code": "self.self.fireProjectile(\"chargedshot\");\nself.self.setXSpeed(self.speed, false);\nself.self.setYSpeed(-5);\nSSF2API.getCamera().shake(8);\nself.self.playAttackSound(5);\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
