    {
      "$id": "6e3657b8-9814-59ae-bd83-743e45a139dd",
      "code": "self.self = /* ? */;\nif ((SSF2API.isReady() && self.self) || self.self.getGlobalVariable(\"screwAttackOn\")) {\n}",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "1c082556-6ed8-5dc2-9692-e44323e5743b",
      "code": "self.done = false;\nself.self.playSound(\"samus_jump1\");\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "e7b27cbb-888c-51ff-b3c2-5eb4fb1d83d7",
      "code": "self.done = false;\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "ba5aa93b-fe42-5d15-a49c-7aa0a04d0cb8",
      "code": "",
