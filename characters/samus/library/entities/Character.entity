    {
      "$id": "b4d6e440-bc13-5594-871b-0e9354bfeaa5",
      "length": 1,
      "name": "aerial_up",
      "pluginMetadata": {},
      "type": "LABEL"
    },
    {
      "$id": "10a158af-f41f-568b-b5c7-257f68b53fbb",
      "code": "if (SSF2API.isReady()) {\n\tself.self = /* ? */;\n\tself.self.setLandingLag(false);\n}\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "c8022eab-478c-5a79-afd7-27abc9b57337",
      "code": "",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "7794364b-431d-5f7f-8703-20b7794919fa",
      "code": "self.self.setLandingLag(true);\nself.self.playAttackSound(1);\nself.self.attachEffect(\"global_dust_spiral\", { x: self.self.flipX(5), y: -45, rotation: 185, scaleX: 1.3, scaleY: 1.8, parentLock: true });\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "66f8f69a-9d92-5abe-a3bc-41d4104001b8",
      "code": "self.self.updateAttackBoxStats(1, { direction: 80, damage: 1 });\nself.self.updateAttackBoxStats(2, { direction: 80, damage: 1 });\nself.self.refreshAttackID();\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "164237a2-2d07-50ee-a4cd-b8338f8659b7",
      "code": "self.self.refreshAttackID();\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "51ee89bd-b825-522c-bbcb-b97fa7d1b2b4",
      "code": "self.self.refreshAttackID();\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "a557cfbe-9412-5908-a2b2-7e3a77f758c6",
      "code": "self.self.refreshAttackID();\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "fa1e6524-1139-52c1-b750-b37392e627ee",
      "code": "self.self.refreshAttackID();\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "c17242ea-24e7-54bc-95ba-55a157ca0bd1",
      "code": "self.self.refreshAttackID();\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "b8059b8e-fb8e-57ee-a72c-ab226ffdd8f7",
      "code": "self.self.updateAttackBoxStats(1, { direction: 45, weightKB: 0, kbConstant: 120, power: 40, damage: 5 });\nself.self.updateAttackBoxStats(2, { direction: 45, weightKB: 0, kbConstant: 120, power: 40, damage: 5 });\nself.self.updateAttackBoxStats(3, { direction: 45, weightKB: 0, kbConstant: 120, power: 40, damage: 5 });\nself.self.updateAttackStats({ refreshRate: 999 });\nself.self.refreshAttackID();\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "a8fbfa44-fbc4-5348-804b-e577e731c59e",
      "code": "",
      "length": 7,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "6dda8601-2866-51e7-8c1f-e8f96f336a2e",
      "code": "self.self.setLandingLag(false);\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "8b801618-bf41-58f6-89f3-628cb23517d7",
      "code": "",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "466ec019-7c95-54a4-b6d6-b2c085bd677d",
      "code": "self.self.endAttack();\nreturn;",
