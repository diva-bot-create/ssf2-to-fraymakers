    {
      "$id": "88b293a3-67e3-50b9-8d4b-74f2c430eb9c",
      "code": "if (SSF2API.isReady()) {\n\tself.self = /* ? */;\n\tself.self.addEventListener(SSF2Event.CHAR_ATTACK_COMPLETE, self.self.toHelpless);\n\tself.self.playAttackSound(1);\n\tself.self.setYSpeed(-18.5);\n\tself.self.setIntangibility(true);\n}\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
