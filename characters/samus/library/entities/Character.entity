    },
    {
      "$id": "0c470927-d3fa-5596-b31a-1f3b218eaa70",
      "code": "if (self.self.getGlobalVariable(\"standtime\") == 0) {\n}\nif (/* ? */) {\n} else {\n\t/* ? */.gotoAndStop(/* ? */);\n\tself.self.createTimer(1, -1, self.standCountdown);\n\treturn;\n}",
      "length": 1,
