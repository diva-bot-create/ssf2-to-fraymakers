    {
      "$id": "0c4fe557-3131-50d2-8e04-39d1ddf839d5",
      "code": "self.self = /* ? */;\nself.effectCo = [0, 0];\nif (SSF2API.isReady()) {\n\tself.self.setLandingLag(false);\n}\nreturn;",
