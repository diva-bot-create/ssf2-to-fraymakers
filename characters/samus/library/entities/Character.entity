      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "8a8ac7d9-2fc9-503e-bdaf-fc362858c7a1",
      "code": "self.self.playAttackSound(3);\nreturn;",
      "length": 1,
      "pluginMetadata": {},
