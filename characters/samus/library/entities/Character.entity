    },
    {
      "$id": "318dde57-145c-5a16-bce9-6bb686b3c690",
      "code": "self.self.updateAttackBoxStats(1, { power: 80, kbConstant: 100, damage: 2, hitStun: 5, selfHitStun: 5 });\nself.self.updateAttackStats({ refreshRate: 90 });\nself.self.refreshAttackID();\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "b702a4eb-66ae-536b-a3e9-d2381923dbee",
      "code": "",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "821040eb-01c4-5598-ad54-3590b7c15d9d",
      "code": "self.self.updateAttackStats({ air_ease: 1 });\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "d9bdee5b-78e0-574c-a3fd-166bf5c72fb1",
      "code": "self.self.playAttackSound(5);\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "77e49214-344f-561c-b645-809a4ca721f8",
