    {
      "$id": "58650979-2c58-53bb-b5ce-68cb5bbf94e4",
      "length": 1,
      "name": "tilt_forward",
      "pluginMetadata": {},
      "type": "LABEL"
    },
    {
      "$id": "142e0e52-1f02-56a4-9707-8ed4608957dc",
      "code": "if (SSF2API.isReady()) {\n\tself.self = /* ? */;\n}\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "5de5a8d2-e73c-54f3-bb93-7a41478f0a46",
      "code": "self.self.attachEffect(\"global_dust_swirl_samus\");\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "b3e1df39-9342-519b-b987-f42eefe73c47",
      "code": "self.self.playAttackSound(1);\nself.self.attachEffect(\"global_dust_light\");\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "c68a7fa2-ea00-5663-bba5-fd1d029ebe46",
      "code": "self.self.attachEffect(\"global_spark\", { x: self.self.flipX(55), y: -55 });\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "7c7befb6-febd-578d-a650-0531a602ffcc",
      "code": "",
      "length": 4,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "36a798ef-93ab-5b22-bb19-d5e20a2ecb96",
      "code": "if (self.self.getMetalStatus()) {\n\tself.self.playSound(\"metal_step_s1\");\n\treturn;\n}\nself.self.playSound(\"samus_step1\");",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "cba49223-3f51-5b27-857b-fa4b8345727e",
      "code": "",
      "length": 8,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "78f9f2db-411e-5278-b84b-cd5c13825bf7",
      "code": "self.self.endAttack();\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
