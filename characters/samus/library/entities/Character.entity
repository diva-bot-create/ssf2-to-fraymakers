      "tweened": false,
      "type": "IMAGE"
    },
    {
      "$id": "64ff2fbf-cd71-5e24-ab88-111fa0379be1",
      "length": 1,
      "name": "grab",
      "pluginMetadata": {},
      "type": "LABEL"
    },
    {
      "$id": "271a4829-1a17-51e5-8680-4820accc5c5a",
      "code": "if (SSF2API.isReady()) {\n\tself.self = /* ? */;\n}\nself.xframe = \"grab\";\nself.grab = 2;\nself.pummeled = false;\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "43f5fbe5-e3fe-5652-a56b-1429095dc650",
      "code": "",
      "length": 6,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "5f921232-162d-5f55-a5f3-10155e7ca09d",
      "code": "self.self.playSound(\"samus_grab_beam\");\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "058b3d7f-8f81-5959-aa35-76c1a41ac2dc",
      "code": "self.self.attachEffect(\"global_dust_light\");\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "32c59787-9cf7-5983-a31b-c0fe8b81f42f",
      "code": "",
      "length": 37,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "ea199c2e-5c89-5d38-b715-91a6bcd545a4",
      "code": "self.self.endAttack();\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "576ef10a-8fd8-5451-9dbe-1071e5085340",
      "code": "self.xframe = \"grab\";\nif (self.pummeled) {\n\tself.self.stancePlayFrame(\"loop\");\n}\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "d7aa14a7-6157-563c-abd1-37902f486ff7",
      "code": "",
      "length": 7,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "c1717f19-6fbe-589b-80b9-0c35a5b34679",
      "code": "self.self.stancePlayFrame(\"loop\");\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "760a65c9-b3a2-5ca2-ab36-9b7718ed97d0",
      "code": "self.xframe = \"attack\";\nself.pummeled = true;\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "925d5102-cba2-5afe-b99e-816cab7b8c03",
      "code": "self.self.updateAttackBoxStats(1, { effect_id: \"effect_lightHit\" });\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "b9a52de0-6f3d-5318-b7e7-f8208db32f6e",
      "code": "self.self.playSound(\"brawl_punch_s\");\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "a4722b9c-9cf7-57d7-ad5f-2a0274c59885",
      "code": "",
      "length": 5,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "16530637-5451-5a12-b5e6-2dff4dd507d6",
      "code": "self.self.stancePlayFrame(\"grabbed\");\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "81c48b47-dfcb-59a8-9c0d-bf2d78d64568",
      "code": "self.self.forceAttack(\"tether\");\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "e74001cb-6c03-54c4-ad17-89b353987e68",
      "code": "self.xframe = \"grab\";\nself.self.setXSpeed(self.self.getXSpeed() * 1.7);\nif (self.pummeled) {\n\tself.self.stancePlayFrame(\"loop\");\n}\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "713024d1-c126-5413-81c3-fe1198391ef1",
      "code": "",
      "length": 7,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "cc67f8ba-f421-5177-a770-4d30d8c457c9",
      "code": "self.self.playSound(\"samus_grab_beam\");\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "86171d3b-3346-570a-99e8-7830aed370c9",
      "code": "self.self.setXSpeed(0);\nself.self.attachEffect(\"global_dust_light\");\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "6912cdea-d067-5677-8c72-21b62d7312e0",
      "code": "",
      "length": 8,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "724ec005-e904-5a7a-a503-10e52c919801",
      "code": "self.self.setXSpeed(-4.3, false);\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "e1cf8eb5-8804-5150-bf4c-99becab78932",
      "code": "",
      "length": 13,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "64ef4053-3b08-5e62-9e0e-4b30b9f7c8ad",
      "code": "self.self.endAttack();\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "5478f928-ebb3-59ce-90e4-2a14161d81e9",
