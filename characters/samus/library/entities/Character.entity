    },
    {
      "$id": "955725a0-889a-59c9-96f3-676d6f066edb",
      "code": "if (SSF2API.isReady()) {\n\tself.self = /* ? */;\n}\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "5f591073-2cf9-5350-9f7c-279f16155ddb",
      "code": "",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "2194c166-329c-57f3-827f-dc4d41caecaa",
      "code": "self.self.playAttackSound(1);\nself.self.setXSpeed(16, false);\nself.self.attachEffect(\"global_dust_heavy\");\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "a508e4aa-0e00-5e7b-bec3-53431c2973aa",
      "code": "",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "bf230aa9-6ceb-5285-a244-1ac7c9e03417",
      "code": "self.self.playSound(\"samus_swing_l\");\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "4644037a-5584-5c54-8a3f-fe02997137f3",
      "code": "self.self.updateAttackBoxStats(1, { damage: 9 });\nreturn;",
      "length": 1,
      "pluginMetadata": {},
