    {
      "$id": "85ef88c2-c723-55f6-ba64-c0ae86470007",
      "length": 1,
      "name": "tilt_down",
      "pluginMetadata": {},
      "type": "LABEL"
    },
    {
      "$id": "f07889ba-fda2-5b3e-a571-ba18fc70e0bf",
      "code": "if (SSF2API.isReady()) {\n\tself.self = /* ? */;\n}\nself.xframe = null;\nreturn;\n}\n\n\nfunction a_down__frame0() {\nif (SSF2API.isReady()) {\n\tself.self = /* ? */;\n}\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "294a6cf9-ffae-5eed-8124-d5c1f435c410",
      "code": "",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "b3e17836-a225-5e1e-9981-089542ffe526",
      "code": "self.xframe = \"charging\";\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "060f24c6-5431-5256-b836-c4131e0a7d33",
      "code": "self.attack = 0;\nself.wp = -1;\nself.self.playAttackSound(1);\nif (self.self.isCPU()) {\n} else {\n\tself.self.attachEffect(\"global_dust_light\");\n\tself.self.pushEffectBehind(self.self.attachEffect(\"samus_explosion\", { x: self.self.flipX(52), scaleX: 1.44, scaleY: 1.44 }));\n\tself.self.attachEffect(\"samus_explosion2\", { x: self.self.flipX(52), scaleX: 1.44, scaleY: 1.44 });\n\tSSF2API.getCamera().shake(5);\n\treturn;\n}\nself.attack = SSF2API.random();\nself.wp = self.self.getGlobalVariable(\"weapon\");\nif (0.2) {\n\tself.attack.self.importCPUControls([0, 9, 16, 1]);\n}",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "4d00cdd7-046d-5092-8ce1-af381dce97db",
      "code": "",
      "length": 18,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "c6fe89dc-b2ee-5c64-a8c1-d4837d486146",
      "code": "self.grab = 2;\nif (self.self.isCPU()) {\n} else {\n\tself.self.endAttack();\n\treturn;\n}\nself.grab = SSF2API.random();\nif (0.25) {\n\tself.grab.self.importCPUControls([0, 1, 16, 1]);\n}",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
