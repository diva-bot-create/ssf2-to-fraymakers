    },
    {
      "$id": "c8858c9d-49b9-5cc0-a967-4dd53dd53d86",
      "code": "if (SSF2API.isReady()) {\n\tself.self = /* ? */;\n}\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "5ad34b7a-c7da-5b14-91ca-9ac3a8d31de1",
      "code": "self.self.playSound(\"samus_kickwind\");\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "5d915308-6630-5d06-aa18-1c7e88809a96",
      "code": "",
      "length": 3,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "55941f0e-5d29-5c7d-9729-18f1ca4320bf",
      "code": "self.self.attachEffect(\"global_dust_heavy\", { flipOnX: true });\nself.self.playAttackSound(1);\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "79843fa0-9f2e-59de-9b7e-bebb70831b6d",
      "code": "",
