    {
      "$id": "90985ee6-d0d7-5a90-a3fd-4317d0ee5af6",
      "code": "if (SSF2API.isReady()) {\n\tself.self = /* ? */;\n}\nif (parent && SSF2API.isReady()) {\n}",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "9fbd0d9a-5603-5b56-9e1f-2e73f7d4eeb7",
      "code": "",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "d1a09272-46ca-52ac-99f7-e63fef1916be",
      "code": "self.self.playAttackSound(1);\nself.self.setLandingLag(true);\nself.self.attachEffect(\"global_dust_blast\", { x: self.self.flipX(40), y: -20, parentLock: true });\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "a9e4dfe5-037e-5d53-bc20-aaf6a4d5b6aa",
      "code": "",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "0a890566-71ef-5c64-b03d-88c3122d5861",
      "code": "self.self.updateAttackBoxStats(1, { damage: 10 });\nself.self.updateAttackBoxStats(2, { damage: 10 });\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "259b7094-9d0b-5100-80b7-8bcd7dc0cd1f",
      "code": "",
      "length": 12,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "9968c822-40d5-5e0e-bc04-2d71b9c8dcfa",
      "code": "self.self.setLandingLag(false);\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "96d2936a-ecf9-5e8b-a80b-8ad7f7f1d86b",
      "code": "",
      "length": 4,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "81194522-7373-5aa1-aa59-d0be37e7b88a",
      "code": "self.self.endAttack();\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "c52ff0be-249c-529d-bd32-a72159db715d",
      "code": "self.self.updateAttackStats({ allowControl: false });\nSSF2API.getCamera().shake(2);\nif (self.self.getMetalStatus()) {\n\tself.self.playSound(\"metal_land_m\");\n\treturn;\n}\nself.self.playSound(\"samus_landing_heavy\");",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "1ddb59ed-eb2b-5f69-ae4e-9d6553266490",
      "code": "",
      "length": 4,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "e1ed4cff-bf16-5bc7-b7f4-113b835128b5",
      "code": "self.self.endAttack();\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
