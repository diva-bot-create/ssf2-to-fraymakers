    },
    {
      "$id": "2f644353-8147-57d7-9fcd-74457f44bd01",
      "code": "if (SSF2API.isReady()) {\n\tself.self = /* ? */;\n}\nif (parent && SSF2API.isReady()) {\n}",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "24b5eae8-b584-5587-bcf3-d94ec4bba5a3",
      "code": "",
      "length": 3,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "ae301539-cb1b-53ed-8fee-21a75697dd11",
      "code": "self.self.playSound(\"samus_tilt_up2\");\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "e7fd0fb4-65c0-5442-9b67-0a975d9d7012",
      "code": "",
      "length": 2,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "bb80dec0-cf00-5a63-8602-83a9aca346e4",
      "code": "self.self.setXSpeed(6.5, false);\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "bacea540-20b8-5ce7-91e4-ed5fa1cab218",
      "code": "",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "c7018b7e-8bc1-5e37-a3e2-966f0af648e7",
      "code": "if (self.self.getMetalStatus()) {\n\tself.self.playSound(\"metal_land_m\");\n\treturn;\n}\nself.self.playSound(\"samus_landing_light\");",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "741618c5-a968-5a1d-bf5a-642217647e5e",
      "code": "",
      "length": 5,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "675f58c0-9699-5bcf-902d-191e4e9d3169",
      "code": "self.self.setIntangibility(false);\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "344af032-8508-5242-a99f-d02be9d667f2",
      "code": "self.self.endAttack();\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
