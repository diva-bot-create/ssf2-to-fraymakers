    },
    {
      "$id": "a48972d4-9f9a-5d6d-8a5c-600489b1682e",
      "code": "self.self = /* ? */;\nif (SSF2API.isReady() && self.self) {\n}",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "7b1b61bd-662d-5eab-96b8-b6f898fcbe3a",
      "code": "self.self.setYSpeed(-5);\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "143a642a-6f81-5045-807e-98585266a837",
      "code": "if (self.self.isOnGround()) {\n\tself.self.setXSpeed(0.5);\n}\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "6c61fa63-d315-5ce4-b339-ea33c0acab3a",
      "code": "",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "d4972944-8872-5cad-afc6-30754639a9e1",
      "code": "self.self.updateAttackStats({ allowControl: true });\nself.self.fireProjectile(\"bomb\");\nself.self.playAttackSound(1);\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "17e06f4a-1971-52f0-840c-0fdf1023e7da",
      "code": "",
      "length": 19,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "38c0a856-03ae-5a70-ab4c-66d3ad082b98",
      "code": "self.self.endAttack();\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "ec256c02-3892-5654-82e7-3a07c626c237",
      "code": "self.self.updateAttackStats({ allowFullInterrupt: true, allowControl: true, allowFastFall: false });\nself.self.setYSpeed(-2.1);\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
