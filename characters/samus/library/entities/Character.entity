    },
    {
      "$id": "3170ca12-8a04-5c50-b76e-361354d2010d",
      "code": "if (SSF2API.isReady()) {\n\tself.self = /* ? */;\n}\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "6635d637-cfa6-5c55-ace3-5f5617820fae",
      "code": "self.effect = self.self.attachEffect(\"global_dust_heavy\", { scaleX: 0.8, scaleY: 0.8 });\nself.effect.scaleX = -self.effect.scaleX;\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "8935a15a-426e-50f0-9ab3-92887243a973",
      "code": "if (parent && SSF2API.isReady()) {\n}",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "ae3ab864-8b82-5169-88a9-c0c161580c91",
      "code": "",
      "length": 11,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "f7286397-3bb1-57c1-a51d-179ed1bf8799",
      "code": "self.self.setIntangibility(false);\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "14a35003-2c9e-518b-a91a-0dfd97975dc4",
      "code": "",
