    {
      "$id": "43870dd9-5f84-5129-b3e4-9ef5e9087c20",
      "code": "if (SSF2API.isReady()) {\n\tself.self = /* ? */;\n\tself.self.addEventListener(SSF2Event.CHAR_ATTACK_COMPLETE, self.self.toHelpless);\n\tself.self.setIntangibility(true);\n}\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "70cb088a-6532-504e-86c8-5fd44d455868",
      "code": "",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "6966f827-8bb4-5dc5-8efb-88939965c6f1",
      "code": "self.self.setXSpeed(self.self.getXSpeed() / 2);\nself.self.playAttackSound(1);\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "876a40d9-bb46-579f-9339-5b16401deb9c",
      "code": "self.self.playAttackSound(2);\nself.self.setIntangibility(false);\nself.self.setYSpeed(-23);\nself.self.unnattachFromGround();\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "9ed0d154-1380-5070-b279-e65249c46bc9",
      "code": "",
