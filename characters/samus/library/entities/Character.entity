    },
    {
      "$id": "aa481fed-f7fb-55a0-9451-a74467ccbdd2",
      "code": "self.self = /* ? */;\nSSF2API.getCamera().shake(4);\nif ((parent && SSF2API.isReady()) || self.self) {\n\tself.ready = false;\n\tself.self.setGlobalVariable(\"canStartRise\", true);\n\tif (self.self.getMetalStatus()) {\n\t\tself.self.playSound(\"metal_land_l\");\n\t\treturn;\n\t}\n\tself.self.playSound(\"samus_landing_heavy\");\n}\n}\n\n\nfunction tech_ground__frame0() {\nself.self = /* ? */;\nif ((SSF2API.isReady() && self.self) || self.self.getMetalStatus()) {\n}",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "a295c475-48f0-5c81-ab23-98d3f7df51c6",
      "code": "",
      "length": 9,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "c5abfa4d-3a03-5f38-9307-9674cd50e04b",
      "code": "self.self.setIntangibility(false);\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "21b302dd-9c69-5a93-bede-b97be14d4b46",
      "code": "",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "14e5ace1-919d-589f-ab19-6c6b68ca8165",
      "code": "self.self.attachEffect(\"effect_land\");\nSSF2API.getCamera().shake(2);\nif ((parent && SSF2API.isReady()) || self.self) {\n\tif (self.self.getMetalStatus()) {\n\t\tself.self.playSound(\"metal_land_m\");\n\t\treturn;\n\t}\n\tself.self.playSound(\"samus_landing_light\");\n}",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "d59d27a7-7b89-5007-b7b4-61a730fdd69e",
      "code": "self.stop();\nself.ready = true;\nreturn;\n}\n\n\nfunction tech_ground__frame13() {\nself.self.endAttack();\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "72f60bd7-eea6-53ef-8acd-a7f1f09aab2e",
      "code": "self.self.stancePlayFrame(\"dead\");\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "dcfabb4e-2a29-59f3-b171-d8705e2434b6",
      "code": "if (self.self.isForcedCrash()) {\n} else {\n\tself.self.setIntangibility(true);\n}\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
