      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "95157fb7-676f-568e-a47f-9fcc46c30139",
      "code": "self.self.setIntangibility(false);\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
