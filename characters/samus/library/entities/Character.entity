      "length": 1,
      "name": "throw_up",
      "pluginMetadata": {},
      "type": "LABEL"
    },
    {
      "$id": "6ad8c7e2-ccec-555a-a71f-04f58af1ffbb",
      "code": "if (SSF2API.isReady()) {\n\tself.self = /* ? */;\n}\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "3f22ca02-e88a-5a06-b51d-8c4ce5f29d54",
      "code": "self.self.playSound(\"samus_kickwind\");\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "d5645bed-cf6c-5a7a-a54c-d4494aad05d8",
      "code": "",
      "length": 6,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "8bf2dedb-36cc-5586-a983-4f2eb9c4be6f",
      "code": "self.self.attachEffect(\"global_dust_cloud\");\nself.self.playSound(\"samus_grab_beam\");\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "8209cd35-a892-545e-8f5a-dc1ae4c671cb",
      "code": "self.self.refreshAttackID();\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "d95a3acd-aee0-51b8-82e9-75ecd867161c",
      "code": "",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
