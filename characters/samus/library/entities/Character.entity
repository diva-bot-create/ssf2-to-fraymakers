    {
      "$id": "bf6ba3aa-0bc5-5109-a520-ff69a53676f7",
      "length": 1,
      "name": "special_neutral",
      "pluginMetadata": {},
      "type": "LABEL"
    },
    {
      "$id": "a71560d1-3a74-5959-9c48-8272d179b737",
      "code": "self.self = /* ? */;\nif ((parent && SSF2API.isReady()) || self.self) {\n\tself.controls = self.self.getControls();\n\tself.maxCharge = self.self.getAttackStat(\"chargetime_max\");\n\tself.curCharge = self.self.getGlobalVariable(\"SamusNSpecCharge\");\n\tself.fullCharge = self.curCharge >= self.maxCharge;\n\tself.boost = self.self.getGlobalVariable(\"SamusNSpecBoost\");\n\tself.boostGuard = false;\n\tself.self.createTimer(1, -1, self.checkSpeckill, { persistent: true });\n\tif (self.fullCharge) {\n\t\tself.self.setGlobalVariable(\"SamusNSpecBoost\", self.maxCharge);\n\t\tself.boostGuard = true;\n\t\tself.press1B = false;\n\t\tself.press2B = false;\n\t\tself.press1S = false;\n\t\tself.press2S = false;\n\t\tself.press1L = false;\n\t\tself.press2L = false;\n\t\tself.press1R = false;\n\t\tself.press2R = false;\n\t\treturn;\n\t}\n\tself.self.setGlobalVariable(\"SamusNSpecBoost\", 0);\n\tself.self.createTimer(1, -1, self.checkPressed);\n\tself.self.addEventListener(SSF2Event.GROUND_LEAVE, self.fireAir);\n}",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "ba8de1d3-7174-5270-b0af-6f2e387c8520",
      "code": "",
      "length": 6,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "d6261f3e-4b19-5754-8bbd-77f19fe64eca",
      "code": "self.self.destroyTimer(self.checkPressed);\nSSF2API.print(\"chargeTime: \" + self.curCharge);\nif (self.fullCharge) {\n\tself.self.destroyTimer(self.checkSpeckill);\n\tself.self.stancePlayFrame(\"attack2\");\n\treturn;\n}\nif (self.press2B) {\n\tself.self.destroyTimer(self.checkSpeckill);\n\tself.self.setGlobalVariable(\"SamusNSpecCharge\", self.curCharge);\n\tself.self.stancePlayFrame(\"attack\");\n}\nself.self.setGlobalVariable(\"SamusNSpecSFX\", self.self.playAttackSound(1));\nself.self.createTimer(1, -1, self.checkControls);",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "2cb6f98b-78a9-5fbc-aa03-e81b28278ab3",
      "code": "",
      "length": 72,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "c867a6d6-f4c8-5aa4-a5f6-98be2252c963",
      "code": "self.self.stancePlayFrame(\"loop\");\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "186ff6fb-5483-57c3-a375-943ceb8dfd4a",
      "code": "self.self.removeEventListener(SSF2Event.GROUND_LEAVE, self.fireAir);\nself.self.fireProjectile(\"unchargedshot\");\nSSF2API.getCamera().shake(3);\nself.self.playAttackSound(2);\nself.self.setGlobalVariable(\"SamusNSpecBoost\", self.curCharge);\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "ab6de53d-2be8-556d-8baf-36a3af994c2f",
      "code": "self.self.attachEffect(\"global_dust_light\");\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "5f19c908-02ea-53b6-a562-3692ff3a067e",
      "code": "",
      "length": 13,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "be51bdbc-25ab-5776-89b0-62b12284a7a6",
      "code": "self.self.endAttack();\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "a6cbb382-d324-5aee-87d2-e88439fbc3da",
      "code": "self.self.fireProjectile(\"chargedshot\");\nself.self.attachEffect(\"global_dust_heavy\");\nSSF2API.getCamera().shake(8);\nself.self.playAttackSound(5);\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "d6c038fa-ec37-52c0-85f5-8fb30d74a176",
      "code": "",
