    {
      "$id": "72deba1d-58dd-570c-826d-63315068a401",
      "code": "self.self = /* ? */;\nif ((SSF2API.isReady() && self.self) || self.self.getGlobalVariable(\"screwAttackOn\")) {\n}",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "e3f19bea-b03f-5e0e-ba0a-2871a08044e0",
      "code": "self.self.playSound(\"samus_jump2_spin\");\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "d029bcaf-b528-5cc3-9a19-3d262b03fbfd",
      "code": "",
      "length": 2,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
