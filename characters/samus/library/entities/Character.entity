    {
      "$id": "bd1d3bf8-6a16-5bb1-a318-64db44b40537",
      "length": 1,
      "name": "strong_up",
      "pluginMetadata": {},
      "type": "LABEL"
    },
    {
      "$id": "5ecc0e89-1055-5971-aa5e-8ab4ee05efdb",
      "code": "if (SSF2API.isReady()) {\n\tself.self = /* ? */;\n}\nself.xframe = null;\nif (parent && SSF2API.isReady()) {\n}",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "d50ec945-ec6e-50ba-ae38-606a26ca5fa8",
      "code": "",
      "length": 2,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "b98df399-b110-5474-962c-b637fc584a19",
      "code": "self.xframe = \"charging\";\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "8f3bdeb1-d305-5bcf-ba8e-4b6a5e867830",
      "code": "",
      "length": 39,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "ff11807b-f62a-56ef-b539-457868cfbc1c",
      "code": "self.self.stancePlayFrame(\"charging\");\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "8b3cd801-10d7-5bb7-9ae3-ed404518f702",
      "code": "self.xframe = \"attack\";\nself.self.playAttackSound(1);\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "64508f85-c775-5ca0-bd7f-92415657dade",
      "code": "self.self.playAttackSound(1);\nself.self.pushEffectBehind(self.self.attachEffect(\"samus_explosion\", { x: self.self.flipX(37.7), y: -72, scaleX: 1.37, scaleY: 1.37 }));\nself.self.attachEffect(\"samus_explosion2\", { x: self.self.flipX(37.7), y: -72, scaleX: 1.37, scaleY: 1.37 });\nSSF2API.getCamera().shake(2);\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "f6126a91-e6f7-5539-8a78-ccd5ae5cd56a",
      "code": "self.self.attachEffect(\"global_dust_cloud\");\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "28a1b098-4cf5-5114-9054-38ba31093acf",
      "code": "self.self.playAttackSound(1);\nself.self.updateAttackBoxStats(1, { direction: 150, power: 35, kbConstant: 50 });\nself.self.refreshAttackID();\nself.self.pushEffectBehind(self.self.attachEffect(\"samus_explosion\", { x: self.self.flipX(13.2), y: -85.7, scaleX: 1.35, scaleY: 1.35 }));\nself.self.attachEffect(\"samus_explosion2\", { x: self.self.flipX(13.2), y: -85.7, scaleX: 1.35, scaleY: 1.35 });\nSSF2API.getCamera().shake(2);\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "e2b6c8e1-562c-5f81-9cb4-0cd44179710b",
      "code": "",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "0889e58a-aa46-5965-a70a-3d4283b2e7b4",
      "code": "self.self.playAttackSound(1);\nself.self.updateAttackBoxStats(1, { direction: 200, power: 25 });\nself.self.refreshAttackID();\nself.self.pushEffectBehind(self.self.attachEffect(\"samus_explosion\", { x: self.self.flipX(-9.3), y: -94.2, scaleX: 1.29, scaleY: 1.29 }));\nself.self.attachEffect(\"samus_explosion2\", { x: self.self.flipX(-9.3), y: -94.2, scaleX: 1.29, scaleY: 1.29 });\nSSF2API.getCamera().shake(2);\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "49a7e6e8-b588-50db-9f9f-07159d158d5f",
      "code": "",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "9ff9dfdd-aff9-5528-8928-5449fe75fd53",
      "code": "self.self.playAttackSound(1);\nself.self.updateAttackBoxStats(1, { direction: 250, damage: 2, power: 30 });\nself.self.refreshAttackID();\nself.self.pushEffectBehind(self.self.attachEffect(\"samus_explosion\", { x: self.self.flipX(-31), y: -89.2, scaleX: 1.28, scaleY: 1.28 }));\nself.self.attachEffect(\"samus_explosion2\", { x: self.self.flipX(-31), y: -89.2, scaleX: 1.28, scaleY: 1.28 });\nSSF2API.getCamera().shake(2);\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "e7aa9020-b590-559c-bac4-1d94e8353396",
      "code": "self.self.refreshAttackID();\nself.self.updateAttackBoxStats(1, { direction: 80, power: 50, kbConstant: 120 });\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "909ecd36-8861-5342-8543-6203b49cf9f7",
      "code": "self.self.playAttackSound(1);\nself.self.updateAttackBoxStats(1, { direction: 80, damage: 3, power: 50, kbConstant: 120 });\nself.self.refreshAttackID();\nself.self.pushEffectBehind(self.self.attachEffect(\"samus_explosion\", { x: self.self.flipX(-38), y: -68.5, scaleX: 1.25, scaleY: 1.25 }));\nself.self.attachEffect(\"samus_explosion2\", { x: self.self.flipX(-38), y: -68.5, scaleX: 1.25, scaleY: 1.25 });\nSSF2API.getCamera().shake(2);\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "1e36a848-0ba5-54f5-972e-b2469b336dd0",
      "code": "",
      "length": 10,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "7df77c7d-4af4-53e0-a8de-312c2d599d40",
      "code": "self.self.endAttack();\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
