    },
    {
      "$id": "8b1dff4d-ea6b-5c4d-875b-0589b26e55d7",
      "code": "self.self.setYSpeed(5);\nself.self.updateAttackBoxStats(1, { power: 30, kbConstant: 100, damage: 2, hitStun: 2, selfHitStun: 1 });\nself.self.updateAttackStats({ refreshRate: 1 });\nreturn;",
      "length": 1,
      "pluginMetadata": {},
