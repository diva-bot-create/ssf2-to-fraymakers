      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "ad0bd1b5-6295-5b71-8246-46de2d67342c",
      "code": "self.self.playAttackSound(4);\nreturn;",
      "length": 1,
      "pluginMetadata": {},
