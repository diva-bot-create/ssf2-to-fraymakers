    {
      "$id": "53d6d448-2cdf-5738-9c4b-fc5c3990d2d2",
      "code": "self.self.playAttackSound(6);\nif (self.self.isOnGround()) {\n\tself.self.toHeavyLand();\n}\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "dd3e6cba-794c-53e4-8f89-36dc7d7cc61d",
      "code": "if (self.self.isOnGround()) {\n\tself.self.toHeavyLand();\n\treturn;\n}\nself.self.setGlobalVariable(\"uspecfall\", true);\nself.self.endAttack();",
