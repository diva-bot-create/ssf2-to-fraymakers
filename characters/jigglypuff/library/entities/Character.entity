    {
      "$id": "cc808f2b-e840-55ea-a239-a5b372c92f34",
      "code": "self.xframeLink = \"start\";\nself.self = /* ? */;\nif ((parent && SSF2API.isReady()) || self.self) {\n\tself.self.addEventListener(SSF2Event.GROUND_TOUCH, self.slow);\n}\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "03758861-2e15-528e-b45c-d8aacf73cec4",
      "code": "",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "0c9fde37-e58c-508c-b036-9a11607827f2",
      "code": "self.xframeLink = \"windup\";\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "284334cc-45e4-592c-83e0-91f18aae5f83",
      "code": "",
      "length": 1,
