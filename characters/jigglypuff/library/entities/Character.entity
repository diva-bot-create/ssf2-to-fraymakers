      "name": "special_neutral_air",
      "pluginMetadata": {},
      "type": "LABEL"
    },
    {
      "$id": "88eeddea-441c-5130-ae54-68568ac883ab",
      "code": "self.controlCheckCount = 0;\nself.self = /* ? */;\nself.xframe = \"charging\";\nself.charge = \"slow\";\nself.controls = null;\nself.dir = null;\nself.ground = null;\nself.trail = false;\nself.xConstantTurn = 0;\nself.xconstant = 0;\nself.bounce = 5;\nself.frameCount = 45;\nself.frameInc = 24;\nself.turnDelay = 7;\nself.turnDelayCount = 0;\nif (SSF2API.isReady() && self.self) {\n}\nif (/* ? */) {\n\tself.self.createTimer(5, -1, self.playDust);\n}\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "27594944-fa51-5d17-811e-8bf9cad6266e",
      "code": "self.self.createTimer(1, -1, self.controlCheck);\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "32c35f63-f98b-5a81-93f5-86130a61021c",
      "code": "",
      "length": 7,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "54691872-05a8-54a4-9d71-8432c287f99c",
      "code": "self.self.playSound(\"jiggs_rollout2\");\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "bff9a33d-58d9-5712-946a-a85fb5cb67e7",
      "code": "",
      "length": 5,
      "pluginMetadata": {},
