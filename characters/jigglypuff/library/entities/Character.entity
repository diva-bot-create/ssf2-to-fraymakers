    {
      "$id": "adb32c37-340b-5580-8b9d-237e4f60deaf",
      "code": "self.xconstant = 20;\nself.bounce = 10;\nself.trail = true;\nself.self.updateAttackBoxStats(1, { damage: 13, power: 100, kbConstant: 80 });\nself.self.attachEffect(\"global_sparkle\", { x: self.flipX(-10), y: -15 });\nself.self.attachEffect(\"jigglypuff_nspec_wind\", { x: self.flipX(-10), y: -15 });\nself.self.attachEffect(\"global_dust_light\");\nself.self.playSound(\"jiggs_rollout1\");\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
