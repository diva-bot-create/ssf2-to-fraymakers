    {
      "$id": "ffa7b651-ac9b-56bc-a53e-805d4166fa10",
      "length": 1,
      "name": "throw_up",
      "pluginMetadata": {},
      "type": "LABEL"
    },
    {
      "$id": "c2c4a731-1823-512c-aee6-df02f3b97ac0",
      "code": "self.self = /* ? */;\nif (SSF2API.isReady() && self.self) {\n}\nif (/* ? */ && self.self) {\n}",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "91c7bc49-9075-568f-8ddb-9bbc0db5242d",
      "code": "self.self.attachEffect(\"global_sparkle\", { x: self.flipX(20), y: -10 });\nself.self.attachEffect(\"global_dust_swirl\");\nif ((self.playsound > 0.2 && self.playsound <= 0.4) || self.audio != 1) {\n\tself.self.playVoiceSound(1);\n\tself.self.setGlobalVariable(\"audio\", 1);\n}\nif ((self.playsound > 0.4 && self.playsound <= 0.6) || self.audio != 2) {\n\tself.self.playVoiceSound(2);\n\tself.self.setGlobalVariable(\"audio\", 2);\n}\nif ((self.playsound > 0.6 && self.playsound <= 0.8) || self.audio != 3) {\n\tself.self.playVoiceSound(3);\n\tself.self.setGlobalVariable(\"audio\", 3);\n}\nif ((self.playsound > 0.8 && self.playsound <= 1) || self.audio != 4) {\n\tself.self.playVoiceSound(4);\n\tself.self.setGlobalVariable(\"audio\", 4);\n}\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "71075328-9d50-5e04-b1a6-a33c8ed1f1cf",
      "code": "self.self.swapDepthsWithGrabbedOpponent(true);\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "fb63a026-d455-54c0-aac7-aa16c9678a25",
      "code": "self.self.attachEffect(\"global_sparkle\", { x: self.flipX(-10), y: -40 });\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "62ec8ff8-11b0-5f64-8c48-6e8c02fc4a6d",
      "code": "",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "29d507a9-a925-5aec-aabc-0ff0fe1e761e",
      "code": "SSF2API.getCamera().shake(10);\nself.self.attachEffect(\"global_sparkle\", { x: self.flipX(-5), y: -70 });\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "eb9011b4-1937-5021-bdea-7fd0f7e15691",
      "code": "",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "65cf79d9-3de7-524d-ba17-8022518864c6",
      "code": "SSF2API.getCamera().shake(10);\nself.self.attachEffect(\"global_sparkle\", { x: self.flipX(5), y: -90 });\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "e7926f3d-2559-5600-af08-7e5bad73d77d",
      "code": "",
      "length": 5,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "7f4b939c-487a-57b1-8bba-5c307cd3f7a0",
      "code": "if (self.self.getMetalStatus()) {\n\tself.self.playSound(\"metal_step_s1\");\n}\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "9174baa2-0c7b-5b5b-ac5d-c00291c23cca",
      "code": "",
      "length": 2,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "2dae9990-0ca7-5c6a-9da8-0d839130c825",
      "code": "self.getTarget = null;\nself.lvl = 0;\nif ((parent && SSF2API.isReady()) || self.self) {\n}\nif (/* ? */) {\n} else {\n\tself.self.endAttack();\n\treturn;\n}\nif ((self.self.getCPUForcedAction() == -1 ? self.self.getCPUForcedAction() == -1 : self.self.getCPUForcedAction() == 5)) {\n}\nself.getTarget = self.self.getCPUTarget();\nself.lvl = self.self.getCPULevel();\nif ((self.lvl == 9 && self.getTarget) || !self.getTarget.isDisposed()) {\n}\nif ((/* ? */ && self.getTarget.getX() > parent.x - 30) || self.getTarget.getY() < parent.y + 30) {\n}\nif (/* ? */) {\n\tself.self.importCPUControls([128, 4, 1088, 1]);\n}",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
