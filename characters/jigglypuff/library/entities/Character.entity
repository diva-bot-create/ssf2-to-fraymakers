      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "172e7714-c8e2-5f20-b179-fbfae361b3b8",
      "code": "self.self.destroyTimer(self.playDust);\nself.self.createTimer(3, -1, self.playDust);\nself.self.attachEffect(\"global_spark\", { x: self.flipX(20), y: -18 });\nself.frameCount = self.frameCount + self.frameInc * 1.5;\nself.self.playVoiceSound(1);\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "b4a64f4c-2f25-58b4-894f-f008e6d65e55",
      "code": "self.charge = \"full\";\nself.self.playAttackSound(3);\nself.self.attachEffect(\"global_spark\", { x: self.flipX(-20), y: -20 });\nself.self.attachEffect(\"global_sparkle\", { x: self.flipX(-10), y: -15 });\nself.self.attachEffect(\"global_dust_heavy\");\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "42e1aa8e-b43e-50ce-9ca1-9d3b43bd607e",
      "code": "",
      "length": 2,
      "pluginMetadata": {},
