    {
      "$id": "d7a4ad7b-f8ba-5569-afd0-52d5ca8cf89c",
      "length": 1,
      "name": "throw_back",
      "pluginMetadata": {},
      "type": "LABEL"
    },
    {
      "$id": "26912237-f41d-5fa6-90d7-2868ffdc6528",
      "code": "self.self = /* ? */;\nif ((parent && SSF2API.isReady()) || self.self) {\n\tself.xframe = null;\n\tself.prevYLoc = 0;\n\tself.countDown = 7;\n\tself.self.playSound(\"throw_woosh\");\n}\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "ed31d809-ce1b-5337-97c1-e3a7ec2fdef8",
      "code": "",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "b00af9c7-3421-5a2e-a70b-d5d4a4a7bb2c",
      "code": "self.prevYLoc = self.self.getY();\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "f5051982-a06e-5bb9-8627-8b1cd46644ea",
      "code": "if (SSF2API == null) {\n} else {\n\tself.self.setYSpeed(-10);\n\tself.prevYLoc = self.self.getY();\n}\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "48539829-4d4f-50ec-8758-477b89a683f9",
      "code": "if (SSF2API.isReady()) {\n\tself.self.setYSpeed(0);\n\tself.self.updateAttackStats({ air_ease: 0 });\n}\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "62c2dd1a-2161-5d58-bd72-8aee49e21174",
      "code": "if ((parent && SSF2API.isReady()) || self.self) {\n\tself.playsound = SSF2API.random();\n\tself.audio = self.self.getGlobalVariable(\"audio\");\n}\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "f80e3ddc-8bff-54c2-9556-5cf67319af28",
      "code": "self.self.playSound(\"throw_woosh\");\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "178f3d78-fba3-56c4-a266-d9089c2dc69b",
      "code": "if ((SSF2API.isReady() && self.self.getY() > SSF2API.getStage().getCameraBounds().y - 100) || self.countDown > 0) {\n\tself.self.setYSpeed(-25);\n\tif (20) {\n\t} else {\n\t\t_v1 = /* ? */;\n\t\t_v2 = /* ? */.countDown - 1;\n\t\t/* ? */.countDown = /* ? */.countDown - 1;\n\t\tself.prevYLoc = self.self.getY();\n\t\tself.self.stancePlayFrame(\"loop2\");\n\t}\n\tif ((self.playsound > 0.2 && self.playsound <= 0.4) || self.audio != 1) {\n\t\tself.self.playVoiceSound(1);\n\t\tself.self.setGlobalVariable(\"audio\", 1);\n\t}\n\tif ((self.playsound > 0.4 && self.playsound <= 0.6) || self.audio != 2) {\n\t\tself.self.playVoiceSound(2);\n\t\tself.self.setGlobalVariable(\"audio\", 2);\n\t}\n\tif ((self.playsound > 0.6 && self.playsound <= 0.8) || self.audio != 3) {\n\t\tself.self.playVoiceSound(3);\n\t\tself.self.setGlobalVariable(\"audio\", 3);\n\t}\n\tif ((self.playsound > 0.8 && self.playsound <= 1) || self.audio != 4) {\n\t\tself.self.playVoiceSound(4);\n\t\tself.self.setGlobalVariable(\"audio\", 4);\n\t}\n\treturn;\n}\nif (SSF2API == null) {\n} else {\n\tself.self.setYSpeed(0);\n}",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "a53f3a84-9240-5fb9-a5f7-eae82d7942f2",
      "code": "if (SSF2API.isReady()) {\n\tself.self.setYSpeed(20);\n\tself.self.setXSpeed(0, false);\n\tself.self.updateAttackStats({ air_ease: 30 });\n}\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "39159cee-d283-53d3-b1e1-736a85718262",
      "code": "if (SSF2API.isReady() && !self.self.isOnGround()) {\n\tself.self.setYSpeed(0);\n\tself.self.updateAttackStats({ allowControl: false, allowRun: false });\n\tSSF2API.getCamera().shake(10);\n}\nif (self.self.getMetalStatus()) {\n\tself.self.playSound(\"metal_land_s\");\n\treturn;\n}\nself.self.playSound(\"jiggs_landLight\");",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "4a3fb43a-95de-579a-b876-7500ea0a0524",
      "code": "",
      "length": 5,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "41d1bd4d-9106-5e40-8ec9-4a19689495e3",
      "code": "self.self.endAttack();\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
