    },
    {
      "$id": "cd3d4368-3746-54e8-ac51-4c4a02fb1d64",
      "length": 1,
      "name": "run",
      "pluginMetadata": {},
      "type": "LABEL"
    },
    {
      "$id": "3b46c36c-6792-5701-90bc-074e259dd7fd",
      "code": "self.self = /* ? */;\nif (SSF2API.isReady() && self.self) {\n}",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "2a376847-5944-5848-89e2-fa3c857fdcff",
      "code": "self.rand = 0;\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "5e9229fc-3bc2-530d-8fdb-3f5362d810fc",
      "code": "if (self.self.isCPU()) {\n\tself.rand = 10 * SSF2API.random();\n\tself.self.importCPUControls([128, 1]);\n}\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "9e3bcb69-fb5b-541d-9518-2b926c9bd676",
      "code": "",
      "length": 6,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "198e3174-a6e8-5917-8660-899a4f1d60dd",
      "code": "self.self.stancePlayFrame(\"run\");\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "e3b33b40-1a60-5171-a47b-4375892a9ae4",
      "code": "if (self.self.getMetalStatus()) {\n\tself.self.playSound(\"metal_step_s1\");\n\treturn;\n}\nself.self.playSound(\"jiggs_run1\");",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "e266c9a6-d4d3-52fa-be81-5d8714c4fd3c",
      "code": "",
      "length": 6,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "4c962171-b246-568a-9154-3ffa2d5a569f",
      "code": "if (self.self.getMetalStatus()) {\n\tself.self.playSound(\"metal_step_s2\");\n\treturn;\n}\nself.self.playSound(\"jiggs_run2\");",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "067277e6-ce51-5bed-9634-c1470ef1bbda",
      "code": "",
      "length": 5,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "6c65d9c4-7be2-5605-8404-1fb7ce2d2d9e",
      "code": "self.self.stancePlayFrame(\"run\");\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "9af4819d-ab40-55f4-aeb9-f8bead4350be",
      "code": "self.self.setGlobalVariable(\"canStartRise\", true);\nself.self.setGlobalVariable(\"jab\", false);\nself.self.setGlobalVariable(\"jab2\", false);\nSSF2API.playSound(\"jiggs_skid\");\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "0a9669e3-737c-5125-b463-59e60ef2de41",
      "code": "",
      "length": 5,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "d1580d22-8ce9-583d-9215-adb91bc43df2",
      "code": "self.gotoAndStop(\"run\");\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
