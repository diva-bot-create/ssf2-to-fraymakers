    {
      "$id": "da12c00f-3b3a-5d5c-9607-95f63dca97d4",
      "length": 1,
      "name": "dash_attack",
      "pluginMetadata": {},
      "type": "LABEL"
    },
    {
      "$id": "a4956f93-0986-5c77-9606-a473817343a7",
      "code": "self.self = /* ? */;\nif ((parent && SSF2API.isReady()) || self.self) {\n\tself.playsound = SSF2API.random();\n\tself.audio = self.self.getGlobalVariable(\"audio\");\n}\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "24943cf8-0bec-5d1d-a4dd-8af13daefec6",
      "code": "",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "90ca06dd-9a82-5ae5-8efe-b862426796a7",
      "code": "self.self.playAttackSound(1);\nif ((self.playsound > 0.2 && self.playsound <= 0.4) || self.audio != 1) {\n\tself.self.playVoiceSound(1);\n\tself.self.setGlobalVariable(\"audio\", 1);\n}\nif ((self.playsound > 0.4 && self.playsound <= 0.6) || self.audio != 2) {\n\tself.self.playVoiceSound(2);\n\tself.self.setGlobalVariable(\"audio\", 2);\n}\nif ((self.playsound > 0.6 && self.playsound <= 0.8) || self.audio != 3) {\n\tself.self.playVoiceSound(3);\n\tself.self.setGlobalVariable(\"audio\", 3);\n}\nif ((self.playsound > 0.8 && self.playsound <= 1) || self.audio != 4) {\n\tself.self.playVoiceSound(4);\n\tself.self.setGlobalVariable(\"audio\", 4);\n}\nself.self.setXSpeed(14, false);\nself.self.updateAttackStats({ xSpeedDecay: 0 });\nself.self.attachEffect(\"global_dust_heavy\");\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "869a3c07-151e-5cc2-b802-9ec7bd4ad570",
      "code": "",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "87c2763d-c86d-55ff-8f29-b32dadf63682",
      "code": "self.self.updateAttackBoxStats(1, { damage: 8 });\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "d01134c7-e336-52ad-b0a9-423946d1d9fd",
      "code": "",
      "length": 2,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "73b00d31-7d9a-5dac-9138-b8ec2199809a",
      "code": "self.self.attachEffect(\"global_dust_cloud\");\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "37a0425e-bd70-50ee-87ab-b96ddb6cb55c",
      "code": "self.self.updateAttackStats({ xSpeedDecay: -1 });\nif (self.self.getMetalStatus()) {\n\tself.self.playSound(\"metal_land_s\");\n}\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "3a274730-b5a9-5ed3-8e57-5039b5ea58a5",
      "code": "",
      "length": 8,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "a59641f5-102b-54b7-9337-b134672c9000",
      "code": "if (self.self.getMetalStatus()) {\n\tself.self.playSound(\"metal_step_s1\");\n}\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "8db697f0-f105-5c56-a1f5-9cef617eb53c",
      "code": "self.self.endAttack();\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
