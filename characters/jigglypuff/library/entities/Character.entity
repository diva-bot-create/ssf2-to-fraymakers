    {
      "$id": "3a8c0ddf-a0d1-5506-a0c4-7db31dc3c0df",
      "code": "self.self = /* ? */;\nif ((SSF2API.isReady() && self.self) || self.self.getGlobalVariable(\"screwAttackOn\")) {\n}",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "1230669c-2fda-5731-87f3-7f0e030e0196",
      "code": "if (self.self.getMidairJumpCount() != 1) {\n} else {\n\tself.self.playSound(\"jiggs_jump2\");\n\treturn;\n}\nif (self.self.getMidairJumpCount() != 2) {\n} else {\n\tself.self.playSound(\"jiggs_jump3\");\n}\nif (self.self.getMidairJumpCount() != 3) {\n} else {\n\tself.self.playSound(\"jiggs_jump4\");\n}\nif (self.self.getMidairJumpCount() != 4) {\n} else {\n\tself.self.playSound(\"jiggs_jump5\");\n}\nif (self.self.getMidairJumpCount() != 5) {\n} else {\n\tself.self.playSound(\"jiggs_jump6\");\n}",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
