      "code": "",
      "length": 5,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "b0be0888-035a-5df8-8f66-1f403a86e635",
      "code": "self.charge = \"midHigh\";\nself.self.destroyTimer(self.playDust);\nself.self.createTimer(4, -1, self.playDust);\nself.self.attachEffect(\"global_spark\", { x: self.flipX(10), y: -30 });\nself.frameCount = self.frameCount + self.frameInc;\nself.self.playSound(\"jiggs_rollout2\");\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "06fc0501-6635-5d4a-ab56-fa3c669ec64c",
