    {
      "$id": "9984e70a-17ff-580c-9b1e-5dd7c87d203f",
      "code": "self.self = /* ? */;\nif ((parent && SSF2API.isReady()) || self.self) {\n\tself.self.setIntangibility(true);\n}\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "c0c9a237-b055-55d9-b01c-bfeef0855555",
      "code": "",
      "length": 3,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "0fc389a5-dbc4-54cc-9171-5373c48485e7",
      "code": "self.self.playSound(\"jiggs_jump\");\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
