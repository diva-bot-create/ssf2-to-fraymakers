    {
      "$id": "aad7a130-50a7-578f-a7f1-ae9b934ad9fe",
      "length": 1,
      "name": "aerial_forward",
      "pluginMetadata": {},
      "type": "LABEL"
    },
    {
      "$id": "b5fd01b4-d32f-5425-9120-0f0be57e0b8b",
      "code": "self.self = /* ? */;\nif ((parent && SSF2API.isReady()) || self.self) {\n\tself.playsound = SSF2API.random();\n\tself.audio = self.self.getGlobalVariable(\"audio\");\n\tself.self.setLandingLag(false);\n}\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "25864fcd-d626-52bf-86ed-0b32461a4ff4",
      "code": "",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "4e40dfc7-f6aa-5a9d-9df6-9c9d38478f57",
      "code": "self.self.setLandingLag(true);\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "43d5951d-d3c9-540b-9d61-2556b3ba5261",
      "code": "self.self.playSound(\"jiggs_attack_l\");\nif ((self.playsound > 0.2 && self.playsound <= 0.4) || self.audio != 1) {\n\tself.self.playVoiceSound(1);\n\tself.self.setGlobalVariable(\"audio\", 1);\n}\nif ((self.playsound > 0.4 && self.playsound <= 0.6) || self.audio != 2) {\n\tself.self.playVoiceSound(2);\n\tself.self.setGlobalVariable(\"audio\", 2);\n}\nif ((self.playsound > 0.6 && self.playsound <= 0.8) || self.audio != 3) {\n\tself.self.playVoiceSound(3);\n\tself.self.setGlobalVariable(\"audio\", 3);\n}\nif ((self.playsound > 0.8 && self.playsound <= 1) || self.audio != 4) {\n\tself.self.playVoiceSound(4);\n\tself.self.setGlobalVariable(\"audio\", 4);\n}\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "b41332ff-8596-54f2-a59c-1ec3897ebeca",
      "code": "",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "2e4fc034-824d-5063-a769-5fb170d4b770",
      "code": "self.self.attachEffect(\"global_dust_blast\", { x: self.self.flipX(42), y: -10, parentLock: true });\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "1e2295c1-3819-59fc-807c-0921354c365b",
      "code": "self.self.updateAttackBoxStats(1, { damage: 7, kbConstant: 60, effectSound: \"brawl_kick_m\" });\nself.self.updateAttackBoxStats(2, { damage: 7, kbConstant: 40, effectSound: \"brawl_kick_m\" });\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "e47d6bb3-1108-5eb6-9b18-0b0c58491889",
      "code": "",
      "length": 5,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "e60864bc-ce34-5eb8-80aa-316bc4dbc3e5",
      "code": "self.self.setLandingLag(false);\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "9f1d227a-26fb-5507-adcd-92ffe1de9fa6",
      "code": "",
      "length": 2,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "21fa9e9b-68c8-5fb3-885b-5aab3c471f69",
      "code": "return;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "1af2c9c4-5c8d-5879-8f34-4666ca4c75a2",
      "code": "",
      "length": 2,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "1cf2dc58-2169-538f-9f31-e001eb8edff8",
      "code": "self.self.endAttack();\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "899d7385-6c8a-5425-ba20-3f2d1cf0535b",
      "code": "if (self.self.getMetalStatus()) {\n\tself.self.playSound(\"metal_land_s\");\n\treturn;\n}\nself.self.playSound(\"jiggs_landLight\");",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
