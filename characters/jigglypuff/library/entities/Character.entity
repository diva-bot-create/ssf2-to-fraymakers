    },
    {
      "$id": "fa1b3863-bae9-551b-bf30-02f733dd1c0f",
      "length": 1,
      "name": "strong_up",
      "pluginMetadata": {},
      "type": "LABEL"
    },
    {
      "$id": "d510fb67-74ed-537f-8354-0f3c55e5d4de",
      "code": "self.self = /* ? */;\nif ((parent && SSF2API.isReady()) || self.self) {\n\tself.playsound = SSF2API.random();\n\tself.audio = self.self.getGlobalVariable(\"audio\");\n\tself.xframe = null;\n}\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "7e9a0138-c385-5707-a833-97c43f924482",
      "code": "",
      "length": 2,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "b6026aa5-3b25-5568-95d1-ae4d45bd28bd",
      "code": "if (self.self.getCurrentKirbyPower() == null) {\n} else {\n\tself.self.stancePlayFrame(\"chargingpower\");\n}\nself.xframe = \"charging\";\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "817455f5-d2bf-5ed1-b918-3b8fc02d1db4",
      "code": "",
      "length": 39,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "7c13d2aa-478c-5274-832e-3f979c41cd8f",
      "code": "self.self.stancePlayFrame(\"charging\");\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "99960a6e-69b3-5cfa-a3ae-237703387697",
      "code": "self.xframe = \"attack\";\nself.self.attachEffect(\"global_dust_cloud\");\nif ((self.playsound > 0.2 && self.playsound <= 0.4) || self.audio != 1) {\n\tself.self.playVoiceSound(1);\n\tself.self.setGlobalVariable(\"audio\", 1);\n}\nif ((self.playsound > 0.4 && self.playsound <= 0.6) || self.audio != 2) {\n\tself.self.playVoiceSound(1);\n\tself.self.setGlobalVariable(\"audio\", 2);\n}\nif ((self.playsound > 0.6 && self.playsound <= 0.8) || self.audio != 3) {\n\tself.self.playVoiceSound(1);\n\tself.self.setGlobalVariable(\"audio\", 3);\n}\nif ((self.playsound > 0.5 && self.playsound <= 1) || self.audio != 4) {\n\tself.self.setGlobalVariable(\"audio\", 4);\n}\nself.self.playAttackSound(1);\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "bda8dcb4-ebd6-5f95-bfae-333451c67ccf",
      "code": "",
      "length": 3,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "5cdc6ad5-adcd-57cc-b5f1-27a57172d7f9",
      "code": "if (self.self.getMetalStatus()) {\n\tself.self.playSound(\"metal_step_m2\");\n\treturn;\n}\nself.self.playSound(\"jiggs_footstep2\");",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "efff3784-186f-5f30-a10e-450223e347fa",
      "code": "",
      "length": 2,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "1bdd5b48-cd29-5ae0-81fe-7f81ef6e2b8e",
      "code": "self.self.playSound(\"jiggs_footstep1\");\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "ce1f52ad-9c79-5e05-b06c-f86f7c5d39de",
      "code": "",
      "length": 11,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "c6f98932-706a-53f5-be53-3f87ae1e017a",
      "code": "self.self.endAttack();\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
