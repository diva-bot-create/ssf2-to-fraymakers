    {
      "$id": "471c2564-5706-5182-ad05-9350364730f7",
      "length": 10,
      "pluginMetadata": {},
      "symbol": "32ef86a4-7d64-5843-807b-4bd3e703e816",
      "tweenType": "LINEAR",
      "tweened": false,
      "type": "IMAGE"
    },
    {
      "$id": "bed901f6-4d04-5ee6-9d60-0b424ca6a10f",
      "length": 1,
      "name": "strong_forward",
      "pluginMetadata": {},
      "type": "LABEL"
    },
    {
      "$id": "9c590fbc-6727-5dea-81cb-649e19971225",
      "code": "self.self = /* ? */;\nif ((parent && SSF2API.isReady()) || self.self) {\n\tself.playsound = SSF2API.random();\n\tself.audio = self.self.getGlobalVariable(\"audio\");\n\tself.xframe = null;\n}\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "12f3bd4d-d633-528a-a7d1-000a2ca878b5",
      "code": "",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "c1b6ce99-0d84-5d94-bb3f-5dc62dac47a8",
      "code": "self.xframe = \"charging\";\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "5d586ec8-a67c-50b4-ae30-27b85c85d5a5",
      "code": "",
      "length": 39,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "52d274c6-5dd9-5f5f-8447-ff2e008c395f",
      "code": "self.self.stancePlayFrame(\"charging\");\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "56ab0d5a-ce10-5446-afdf-502a26d598c1",
      "code": "self.xframe = \"attack\";\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "927358cd-ef53-5a55-bac8-4a63c4528424",
      "code": "self.chargeTime = self.self.getExecTime() - 3;\nself.speedCharged = 5.75 * self.chargeTime / 40 + 12;\nself.self.setXSpeed(self.speedCharged, false);\nself.self.attachEffect(\"global_dust_heavy\");\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "3622bca0-e90d-5d86-bbb3-1c377c4dafa5",
      "code": "if ((self.playsound > 0.2 && self.playsound <= 0.4) || self.audio != 1) {\n\tself.self.playVoiceSound(1);\n\tself.self.setGlobalVariable(\"audio\", 1);\n}\nif ((self.playsound > 0.4 && self.playsound <= 0.6) || self.audio != 2) {\n\tself.self.playVoiceSound(1);\n\tself.self.setGlobalVariable(\"audio\", 2);\n}\nif ((self.playsound > 0.6 && self.playsound <= 0.8) || self.audio != 3) {\n\tself.self.playVoiceSound(1);\n\tself.self.setGlobalVariable(\"audio\", 3);\n}\nif ((self.playsound > 0.5 && self.playsound <= 1) || self.audio != 4) {\n\tself.self.setGlobalVariable(\"audio\", 4);\n}\nself.self.playAttackSound(1);\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "2f0b990a-c988-5e86-832f-34afc3b6b5fe",
      "code": "self.self.attachEffect(\"global_dust_blast\", { x: self.self.flipX(32), y: -15, parentLock: true });\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "d19ddbd3-0c66-56a9-82fa-66b2a4746d0f",
      "code": "",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "5f88d5f2-da1a-5606-b84c-e6659f25a40e",
      "code": "self.self.updateAttackBoxStats(1, { damage: 13, power: 6, kbConstant: 85 });\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "d7e4fd26-f616-5ca2-aa06-49957ce40ff3",
      "code": "",
      "length": 5,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "70b90b06-7730-5f24-97f5-122e94fcc0d6",
      "code": "if (self.self.getMetalStatus()) {\n\tself.self.playSound(\"metal_land_s\");\n\treturn;\n}\nself.self.playSound(\"jiggs_landLight\");",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "d158510b-2c83-550b-a72a-19830607a164",
      "code": "",
      "length": 5,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "4f4eba58-31ca-5889-bb48-43596b139fda",
      "code": "self.self.endAttack();\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
