    },
    {
      "$id": "16054d41-1916-5b71-89cb-92591b582461",
      "code": "self.self.playSound(\"jiggs_dsmash_spin\");\nself.self.playSound(\"jiggs_attack_m\");\nself.self.updateAttackBoxStats(1, { selfHitStun: 0, hitStun: 1 });\nself.self.refreshAttackID();\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "c270693f-5128-50ab-9238-b21212085b18",
      "code": "",
      "length": 2,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "df969e93-e058-552c-b0e8-d08de8b46653",
      "code": "self.self.playSound(\"jiggs_dsmash_spin\");\nself.self.playSound(\"jiggs_attack_m\");\nself.self.refreshAttackID();\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "6ff0a31d-8987-5b17-88a8-c244bd513e5a",
      "code": "",
      "length": 5,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "801d3af5-0951-5be2-a493-760997c6ab5e",
      "code": "self.self.setLandingLag(false);\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "9f4d465b-7916-54d7-9a88-3366dfaa7453",
      "code": "",
      "length": 4,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "d3341d81-ea74-578b-894b-b54a69c2d3c4",
      "code": "self.getTarget = null;\nself.lvl = 0;\nif ((parent && SSF2API.isReady()) || self.self) {\n}\nif (/* ? */) {\n} else {\n\tself.self.endAttack();\n\treturn;\n}\nif ((self.self.getCPUForcedAction() == -1 ? self.self.getCPUForcedAction() == -1 : self.self.getCPUForcedAction() == 5)) {\n}\nself.getTarget = self.self.getCPUTarget();\nself.lvl = self.self.getCPULevel();\nif ((self.lvl == 9 && SSF2API.random() < 0.1) || self.getTarget) {\n}\nif ((/* ? */ && self.getTarget.getX() < parent.x + 30) || self.getTarget.getX() > parent.x - 30) {\n}\nif (/* ? */ && self.getTarget.getY() + 30 > parent.y) {\n}",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "6a7e1665-910d-526c-b0c3-cfe253eae61a",
      "code": "self.self.removeAllEffects();\nif (self.self.getMetalStatus()) {\n\tself.self.playSound(\"metal_land_m\");\n\treturn;\n}\nself.self.playSound(\"jiggs_landHeavy\");",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "10618002-f650-5414-b4d6-8cc5019bbb6c",
      "code": "",
      "length": 7,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "31c63cec-1ce7-5928-95f9-5c25b0e2ef8c",
      "code": "if ((parent && SSF2API.isReady()) || self.self) {\n}\nif (/* ? */) {\n} else {\n\tself.self.endAttack();\n\treturn;\n}\nself.getTarget = self.self.getCPUTarget();\nself.lvl = self.self.getCPULevel();\nif ((self.lvl == 9 && self.getTarget) || !self.getTarget.isDisposed()) {\n\tif (self.getTarget.getCurrentAttackFrame() == \"hurt\") {\n\t\tself.getTarget.getCurrentAttackFrame() == \"hurt\";\n\t}\n}\nif ((/* ? */ && SSF2API.random() < 0.5) || self.getTarget.getX() < parent.x + 30) {\n}\nif ((/* ? */ && self.getTarget.getY() < parent.y + 30) || self.getTarget.getY() + 30 > parent.y) {\n\tself.self.importCPUControls([2048, 1, 0, 2, 1088, 1]);\n\tSSF2API.print(\"from dair land\");\n}",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
