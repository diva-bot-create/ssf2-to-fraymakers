    {
      "$id": "01f2a782-10b4-5487-8d8e-dde93dae4cf5",
      "length": 1,
      "name": "aerial_down",
      "pluginMetadata": {},
      "type": "LABEL"
    },
    {
      "$id": "aded97be-4aff-57b7-a015-089ee47288c8",
      "code": "self.self = /* ? */;\nif ((parent && SSF2API.isReady()) || self.self) {\n\tself.playsound = SSF2API.random();\n\tself.audio = self.self.getGlobalVariable(\"audio\");\n\tself.self.addEventListener(SSF2Event.GROUND_TOUCH, self.self.toLand);\n\tself.self.setLandingLag(false);\n}\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "136a166e-9805-566d-be56-b6187f41c490",
      "code": "if ((self.playsound > 0.2 && self.playsound <= 0.4) || self.audio != 1) {\n\tself.self.playVoiceSound(1);\n\tself.self.setGlobalVariable(\"audio\", 1);\n}\nif ((self.playsound > 0.4 && self.playsound <= 0.6) || self.audio != 2) {\n\tself.self.playVoiceSound(2);\n\tself.self.setGlobalVariable(\"audio\", 2);\n}\nif ((self.playsound > 0.6 && self.playsound <= 0.8) || self.audio != 3) {\n\tself.self.playVoiceSound(3);\n\tself.self.setGlobalVariable(\"audio\", 3);\n}\nif ((self.playsound > 0.8 && self.playsound <= 1) || self.audio != 4) {\n\tself.self.playVoiceSound(4);\n\tself.self.setGlobalVariable(\"audio\", 4);\n}\nself.self.setLandingLag(true);\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "d8127542-ba6b-5930-8347-cdfc043c0435",
      "code": "self.self.addEffectToList(self.self.attachEffect(\"global_dust_spiral\", { x: self.self.flipX(8), scaleX: 1.2, scaleY: 1.2, rotation: self.self.flipX(-30), loop: 2, parentLock: true }));\nself.self.clearEffectsOnStateChange();\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "167dd548-b3e5-502f-8e90-225d6751945b",
      "code": "self.self.playSound(\"jiggs_dsmash_spin\");\nself.self.playSound(\"jiggs_attack_m\");\nself.self.refreshAttackID();\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "3361bfe8-31ac-589f-8e4d-de30fdf44c35",
      "code": "",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "8b538c68-450a-5ec8-864a-1966db41dd3d",
      "code": "self.self.refreshAttackID();\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "2adb68c4-62e0-5704-bbfa-f90306e343d5",
      "code": "self.self.playSound(\"jiggs_dsmash_spin\");\nself.self.playSound(\"jiggs_attack_m\");\nself.self.refreshAttackID();\nreturn;",
