    {
      "$id": "2aaff9fa-d23c-5196-92d1-62052c2b6866",
      "length": 1,
      "name": "grab",
      "pluginMetadata": {},
      "type": "LABEL"
    },
    {
      "$id": "4e833083-1d0e-5ef0-84a0-1845ecdd39a3",
      "code": "self.self = /* ? */;\nif ((parent && SSF2API.isReady()) || self.self) {\n\tself.xframe = \"grab\";\n}\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "a41015dc-c53e-53b8-83bd-14828aac7b2c",
      "code": "",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "f46c2a7e-5b53-5dfe-a61f-a40632ea8687",
      "code": "SSF2API.playSound(\"grab_swing2\");\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "4bf33169-7267-5004-a637-b5069de06049",
      "code": "self.self.attachEffect(\"global_dust_light\");\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "28930728-0fdf-5d59-b69f-a6151a6678fb",
      "code": "",
      "length": 11,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "dc3e7520-4d47-5d25-956b-87964faedfc1",
      "code": "self.self.endAttack();\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "7552c7a1-7f1a-506c-9bcd-48a9004760fd",
      "code": "self.xframe = \"grab\";\nself.self.setXSpeed(self.self.getXSpeed() * 1.7);\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "675a9de5-f3ec-58b2-bb5a-25c8a336621e",
      "code": "",
      "length": 3,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "d8f4653b-6634-5b1f-a651-94e5117a13ae",
      "code": "SSF2API.playSound(\"grab_swing4\");\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "c7704ab3-b24f-5c7b-9c2b-783349cd9c77",
      "code": "self.self.setXSpeed(0);\nself.self.attachEffect(\"global_dust_light\");\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "1ced3e3c-34f9-5035-82e0-72078254e685",
      "code": "",
      "length": 14,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "eea29f26-a345-5844-9718-f5b96a1e28f6",
      "code": "self.self.endAttack();\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "8715507e-5e20-58bb-909a-8e5381f55491",
      "code": "self.xframe = \"grab\";\nself.stop();\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "0e4b52be-d217-58fd-888a-c2a647e3b59e",
      "code": "self.self.stancePlayFrame(\"grabbed\");\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "5010df4d-10d4-501e-92cd-074e10ad20c8",
      "code": "self.xframe = \"attack\";\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
