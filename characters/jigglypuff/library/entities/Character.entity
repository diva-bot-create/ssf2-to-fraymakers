    {
      "$id": "89876e3f-57a5-5539-99d7-91e294af48ac",
      "length": 1,
      "name": "ledge_attack",
      "pluginMetadata": {},
      "type": "LABEL"
    },
    {
      "$id": "1582bb13-b249-516f-adeb-b8e0f1c80ee6",
      "code": "self.self = /* ? */;\nif ((parent && SSF2API.isReady()) || self.self) {\n\tself.self.setIntangibility(true);\n\tself.playsound = SSF2API.random();\n\tself.audio = self.self.getGlobalVariable(\"audio\");\n}\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "47457e04-462a-570a-85c2-b7941b8e46fe",
      "code": "",
      "length": 3,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "f36dbd0a-c9d9-515d-9baa-a99fc2659fd5",
      "code": "self.self.playSound(\"jiggs_jump\");\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "9b0812d4-fb31-57b6-8670-410e9455d59f",
      "code": "",
      "length": 4,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "410d2050-dd52-565e-84b2-b8f78d3482a6",
      "code": "self.self.setXSpeed(10, false);\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "2141323d-3853-5eb1-8e12-2a433169f7a7",
      "code": "",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "ba8a205e-cbae-5e9c-b57e-e1dc84e8380b",
      "code": "self.self.attachEffect(\"global_dust_light\");\nself.self.playSound(\"jiggs_attack_l\");\nif ((self.playsound > 0.2 && self.playsound <= 0.4) || self.audio != 1) {\n\tself.self.playVoiceSound(1);\n\tself.self.setGlobalVariable(\"audio\", 1);\n}\nif ((self.playsound > 0.4 && self.playsound <= 0.6) || self.audio != 2) {\n\tself.self.playVoiceSound(2);\n\tself.self.setGlobalVariable(\"audio\", 2);\n}\nif ((self.playsound > 0.6 && self.playsound <= 0.8) || self.audio != 3) {\n\tself.self.playVoiceSound(3);\n\tself.self.setGlobalVariable(\"audio\", 3);\n}\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "08a6bdad-fd4c-5fcb-a9f4-ca970a9072c2",
      "code": "self.self.setIntangibility(false);\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "1ffd45fc-43dc-5dba-a7cb-13439101f7f7",
      "code": "",
      "length": 11,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "0fed9ece-7b41-584b-9db6-8e23109040bd",
      "code": "self.self.endAttack();\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
