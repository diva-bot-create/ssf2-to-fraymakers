    },
    {
      "$id": "81078ec0-79a9-5001-844a-6086a203e7ce",
      "code": "",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "9cea1cb4-05b4-5b34-8718-82fa76b90ebd",
      "code": "self.xframeLink = \"punch\";\nself.xSpeed = 0;\nself.ySpeed = 0;\nself.dir = \"forward\";\nself.self.playVoiceSound(1);\nself.self.playAttackSound(1);\nself.self.updateAttackStats({ air_ease: 0 });\nif (self.self.getControls().UP && !self.self.isOnGround()) {\n}\nif (/* ? */) {\n\tself.dir = \"down\";\n\tself.self.updateAttackStats({ air_ease: 3 });\n\tself.ySpeed = 3;\n\tself.xSpeed = 17;\n} else {\n\tself.dir = \"forward\";\n\tself.xSpeed = 20;\n\tself.ySpeed = 0;\n}\nself.self.setXSpeed(self.xSpeed, false);\nself.self.setYSpeed(self.ySpeed);\nself.self.setRotation(SSF2Utils.getAngleBetween(new Point(0, 0), new Point(self.xSpeed, self.self.flipX(-self.ySpeed))));\nself.self.attachEffect(\"global_spark\", { y: -10 });\nself.self.attachEffect(\"global_dust_light\");\nif (self.dir != \"up\") {\n\tif (self.dir != \"down\") {\n\t\tself.self.attachEffect(\"global_dust_blast\", { x: self.self.flipX(25), y: -10, parentLock: true });\n\t} else {\n\t\tself.self.attachEffect(\"global_dust_blast\", { x: self.self.flipX(27), y: -5, parentLock: true });\n\t}\n\tif ((parent && SSF2API.isReady()) || self.self) {\n\t\tself.self.addEventListener(SSF2Event.GROUND_TOUCH, self.boost);\n\t}\n\treturn;\n} else {\n\tself.self.attachEffect(\"global_dust_blast\", { x: self.self.flipX(19), y: -23, parentLock: true });\n}",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "98a6e2cc-c205-5b98-8263-1e5bebf17d6b",
      "code": "self.xframeLink = \"punch1\";\nself.self.updateAttackBoxStats(1, { direction: 125 });\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "212c2314-c391-5aec-91f1-86d9b0db3629",
      "code": "",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "9d01ce89-6425-52d1-942e-7d58775e3c93",
      "code": "self.xframeLink = \"punched\";\nself.self.removeEventListener(SSF2Event.GROUND_TOUCH, self.boost);\nreturn;",
