    {
      "$id": "bed851ed-1891-5d4d-9b7e-c739276c8b02",
      "length": 19,
      "name": "special_up",
      "pluginMetadata": {},
      "type": "LABEL"
    },
    {
      "$id": "bb89649a-8c83-5d66-984c-cefd20a28edb",
      "length": 32,
      "name": "fallLoop",
      "pluginMetadata": {},
      "type": "LABEL"
    },
    {
      "$id": "70163e5c-251b-58d4-8a3e-9aa13ce517f7",
      "code": "self.self = /* ? */;\nself.speed = -23;\nself.updateStats = true;\nif (SSF2API.isReady() && self.self) {\n}",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "5f47900b-2f65-50eb-847b-5cb0eafa1429",
      "code": "self.self.setXSpeed(self.self.getXSpeed() / 2);\nself.self.playSound(\"screw1\");\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "f20eb9f4-349e-5ab4-9aff-ececc27e187c",
      "code": "self.self.createTimer(1, 10, self.moveUp);\nself.self.setYSpeed(-23);\nself.self.playSound(\"screw2\");\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "bac578c3-5d74-540e-893c-8e65df9fd7cb",
      "code": "",
      "length": 3,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "f6ae9f9e-d0c8-589a-b340-abd51c55c3eb",
      "code": "self.self.playSound(\"screw3\");\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "acee4214-7832-58cc-a6a8-4ba6692ec320",
      "code": "",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "a5509e05-8a45-53aa-954b-87d1b98919c4",
      "code": "self.updateStats = false;\nself.self.updateAttackBoxStats(1, { power: 30, kbConstant: 100, damage: 2, hitStun: 2, selfHitStun: 1 });\nself.self.updateAttackBoxStats(2, { power: 0, kbConstant: 100, damage: 2, hitStun: 2, selfHitStun: 1 });\nself.self.updateAttackStats({ refreshRate: 1 });\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "056fc253-9ed8-5d33-ae04-501e6799a48e",
      "code": "",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "7bff207c-00be-5c10-a2fe-f5805c2da102",
      "code": "self.self.playSound(\"screw4\");\nself.self.setIASA(true);\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "52590be4-b0de-5a1f-b81a-cd41afca6c02",
      "code": "self.self.updateAttackBoxStats(1, { power: 80, kbConstant: 100, damage: 2, hitStun: 5, selfHitStun: 5 });\nself.self.updateAttackBoxStats(2, { power: 80, kbConstant: 100, damage: 2, hitStun: 5, selfHitStun: 5 });\nself.self.updateAttackStats({ refreshRate: 90 });\nself.self.refreshAttackID();\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "d5145730-a712-582f-a638-50b3a9ffd34f",
      "code": "",
      "length": 2,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "cebd738a-b150-5fee-8803-6789f5d40c77",
      "code": "self.self.playSound(\"screw5\");\nself.self.updateAttackStats({ air_ease: 4 + self.self.getCharacterStat(\"max_ySpeed\") * 0.4 });\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "4a8574c6-784c-5e65-b110-66e20ca588ee",
      "code": "",
      "length": 3,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "c57e7201-a430-5dee-b20a-30461eb7d379",
      "code": "self.self.playSound(\"screw6\");\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "7f4ffc14-5d23-594c-aeaa-5f22ac9584ac",
      "code": "",
      "length": 31,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "32ede529-8f88-5a91-983b-3d66a7820fb7",
      "code": "self.gotoAndStop(\"fallLoop\");\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
