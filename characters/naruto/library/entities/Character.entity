      "code": "self.self = /* ? */;\nif ((parent && SSF2API.isReady()) || self.self) {\n\tself.ready = false;\n\tSSF2API.getCamera().shake(3);\n\tif (self.self.getMetalStatus()) {\n\t\tself.self.playSound(\"metal_land_l\");\n\t\treturn;\n\t}\n\tself.self.playSound(\"naruto_landHeavy\");\n}\n}\n\n\nfunction tech_ground__frame0() {\nself.self = /* ? */;\nif ((parent && SSF2API.isReady()) || self.self) {\n\tself.self.setIntangibility(true);\n\tself.self.playSound(\"naruto_taunt\");\n}\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
