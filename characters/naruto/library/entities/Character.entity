    },
    {
      "$id": "ec86777e-a4bc-59e4-8b9d-c4e3f4a3700b",
      "length": 9,
      "name": "crawlforward",
      "pluginMetadata": {},
      "type": "LABEL"
    },
    {
      "$id": "8d1b7f1d-1805-5a41-939d-68b15b1486da",
      "length": 15,
      "name": "crawlback",
      "pluginMetadata": {},
      "type": "LABEL"
    },
    {
      "$id": "233f1891-55f0-59c0-a140-5f5038ae9893",
      "code": "self.self = /* ? */;\nself.moving = false;\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "c922adc5-c175-5da8-971f-ac81e08bc03e",
      "code": "",
      "length": 2,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "f2bf1208-a018-5ccf-983a-20425caaecec",
      "code": "self.self.setGlobalVariable(\"crouchdown\", true);\nself.moving = false;\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "8c02b166-307b-59f1-9ae0-696e31850d98",
      "code": "self.gotoAndStop(\"redo\");\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "5b1fd521-86f1-57da-ac3b-77b68758a681",
      "code": "self.moving = true;\nself.self.createTimer(1, -1, self.updateCrawl);\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "5f7d8c8a-24f5-5749-b235-1a736170ef0a",
      "code": "",
      "length": 5,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "be190cf3-0c95-50a0-91c0-61795066d678",
      "code": "if (self.self.getMetalStatus()) {\n\tself.self.playSound(\"metal_step_s2\");\n\treturn;\n}\nself.self.playSound(\"naruto_footstep\");",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "6d091ae8-101c-5a75-9bcd-f16449e96b56",
      "code": "",
      "length": 2,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "2680f78a-4275-5877-aac4-745e755e495e",
      "code": "self.gotoAndStop(\"crawlforward\");\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "cc9a6bdb-ec7b-501f-80be-a86f0d876bca",
      "code": "",
      "length": 9,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "bf86d629-2116-56f7-8aad-5901ca7e6b75",
      "code": "if (self.self.getMetalStatus()) {\n\tself.self.playSound(\"metal_step_s2\");\n\treturn;\n}\nself.self.playSound(\"naruto_footstep\");",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
