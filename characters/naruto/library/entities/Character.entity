    {
      "$id": "7f3bb9cb-ee6a-5566-b5eb-de21ead4a042",
      "length": 15,
      "name": "aerial_neutral",
      "pluginMetadata": {},
      "type": "LABEL"
    },
    {
      "$id": "e24f8e68-3620-5f66-b1f4-d626798dd772",
      "length": 4,
      "name": "continue",
      "pluginMetadata": {},
      "type": "LABEL"
    },
    {
      "$id": "8cd8e324-4fa3-5849-9a03-304a32cc0b33",
      "code": "self.self = /* ? */;\nif ((parent && SSF2API.isReady()) || self.self) {\n\tself.playsound = SSF2API.random();\n\tself.audio = self.self.getGlobalVariable(\"audio\");\n\tself.naruto_language = self.self.getGlobalVariable(\"language_Select\");\n\tself.self.setLandingLag(false);\n}\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "7c252088-4a9a-5e3d-bc26-0cca18efe6d2",
      "code": "if (self.naruto_language != \"ENG\") {\n\tif ((self.playsound > 0.2 && self.playsound <= 0.4) || self.audio != 1) {\n\t\tself.self.playVoiceSound(1);\n\t\tself.self.setGlobalVariable(\"audio\", 1);\n\t}\n\tif ((self.playsound > 0.4 && self.playsound <= 0.6) || self.audio != 2) {\n\t\tself.self.playVoiceSound(2);\n\t\tself.self.setGlobalVariable(\"audio\", 2);\n\t}\n\tif ((self.playsound > 0.6 && self.playsound <= 0.8) || self.audio != 3) {\n\t\tself.self.playVoiceSound(3);\n\t\tself.self.setGlobalVariable(\"audio\", 3);\n\t}\n\tif ((self.playsound > 0.8 && self.playsound <= 1) || self.audio != 4) {\n\t\tself.self.playVoiceSound(4);\n\t\tself.self.setGlobalVariable(\"audio\", 4);\n\t}\n\tself.self.playAttackSound(1);\n\tself.self.setLandingLag(true);\n\treturn;\n} else {\n\tif ((self.playsound > 0.2 && self.playsound <= 0.4) || self.audio != 1) {\n\t\tself.self.playSound(\"ENG_naruto_grunt1\", true);\n\t\tself.self.setGlobalVariable(\"audio\", 1);\n\t}\n\tif ((self.playsound > 0.4 && self.playsound <= 0.6) || self.audio != 2) {\n\t\tself.self.playSound(\"ENG_naruto_grunt2\", true);\n\t\tself.self.setGlobalVariable(\"audio\", 2);\n\t}\n\tif ((self.playsound > 0.6 && self.playsound <= 0.8) || self.audio != 3) {\n\t\tself.self.playSound(\"ENG_naruto_forgot1\", true);\n\t\tself.self.setGlobalVariable(\"audio\", 3);\n\t}\n\tif ((self.playsound > 0.8 && self.playsound <= 1) || self.audio != 4) {\n\t\tself.self.playSound(\"ENG_naruto_forgot2\", true);\n\t\tself.self.setGlobalVariable(\"audio\", 4);\n\t}\n}",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "8e7843c9-aa21-5686-8fce-b82bf2939b31",
      "code": "self.self.attachEffect(\"global_dust_blast\", { x: self.self.flipX(35), y: -10, parentLock: true });\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "712cc96e-ffec-511b-b65f-0ba03e2e058b",
      "code": "",
      "length": 2,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "99edb8f9-51d1-5105-b0a8-6eaf918ee62d",
      "code": "self.self.updateAttackBoxStats(1, { direction: 45, power: 31, damage: 4 });\nself.self.updateAttackBoxStats(2, { direction: 45, power: 31, damage: 4 });\nself.self.updateAttackBoxStats(3, { direction: 45, power: 31, damage: 4 });\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "23723e8b-5f98-5520-bd6c-08baca53a7aa",
      "code": "",
      "length": 2,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "433bb0c3-c356-5f6f-ab05-799328404b46",
      "code": "self.self.setLandingLag(false);\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "b4d6f800-d1a7-5c3f-b566-77b459de3bf4",
      "code": "",
      "length": 5,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "55b12965-2bd8-5f4b-bbfe-f3df8b1e7a44",
      "code": "self.self.endAttack();\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "fc61a9c8-c453-5677-9327-c26027d7bac0",
      "code": "SSF2API.getCamera().shake(2);\nif (self.self.getMetalStatus()) {\n\tself.self.playSound(\"metal_land_m\");\n\treturn;\n}\nself.self.playSound(\"naruto_landMedium\");",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "aa5a1305-9370-5f97-8950-39923c5b5be9",
      "code": "",
