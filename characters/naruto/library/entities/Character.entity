    },
    {
      "$id": "1b928c66-fbb4-5b13-bbec-3964b417c1d9",
      "length": 41,
      "name": "charging",
      "pluginMetadata": {},
      "type": "LABEL"
    },
    {
      "$id": "bbb319e8-5c87-5933-94c4-8b93a2653145",
      "length": 18,
      "name": "attack",
      "pluginMetadata": {},
      "type": "LABEL"
    },
    {
      "$id": "8c5d37a6-063f-5164-a5e3-4268a0995188",
      "code": "self.self = /* ? */;\nself.xframe = null;\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "47f19887-cae3-587b-a294-8ed3cbe08745",
      "code": "",
      "length": 2,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "73693e8e-fee8-54dc-8671-3f0c689ae035",
      "code": "self.xframe = \"charging\";\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "2bc9a7be-6bd0-5096-a006-afb57955c7a7",
      "code": "",
      "length": 39,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "d6b500dc-01bb-5b9d-aa82-6be950c2eced",
      "code": "self.self.stancePlayFrame(\"charging\");\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "de687581-89c7-58ee-b644-39bd4a987583",
      "code": "self.xframe = \"attack\";\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "57de1f72-de7d-52cc-b3d1-e0959d405193",
      "code": "self.self.attachEffect(\"global_dust_swirl\");\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "3c6b4727-8220-59b4-90e9-8f506fe05c30",
      "code": "",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "d48d694c-0c64-50df-b55d-c74ac04714d7",
      "code": "self.naruto_language = self.self.getGlobalVariable(\"language_Select\");\nif (self.naruto_language != \"ENG\") {\n\tself.self.playVoiceSound(1);\n\tself.self.playAttackSound(1);\n\tself.self.attachEffect(\"global_dust_light\");\n\treturn;\n} else {\n\tself.self.playVoiceSound(2);\n}",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "82aafd4b-c19f-54da-847e-72771bead226",
      "code": "",
      "length": 9,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "5b9e207a-fa34-5da1-82bd-b32c734c028a",
      "code": "if ((parent && SSF2API.isReady()) || self.self) {\n\tSSF2API.getCamera().shake(2);\n\tif (self.self.getMetalStatus()) {\n\t\tself.self.playSound(\"metal_step_m2\");\n\t\treturn;\n\t}\n\tself.self.playSound(\"naruto_footstep\");\n}",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "eeb708d7-73e2-5654-8659-83b4bdf5940d",
      "code": "",
      "length": 3,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "d5cdb5e1-2a17-5cf5-9c14-d3f3c78f8621",
      "code": "self.self.endAttack();\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
