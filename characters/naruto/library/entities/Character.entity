      "type": "LABEL"
    },
    {
      "$id": "8b6afa11-5a54-5097-b058-159fb4d736f8",
      "length": 41,
      "name": "charging",
      "pluginMetadata": {},
      "type": "LABEL"
    },
    {
      "$id": "a1b326f3-1b49-5d5c-a8af-dc9c2c00566c",
      "length": 16,
      "name": "attack",
      "pluginMetadata": {},
      "type": "LABEL"
    },
    {
      "$id": "0b6618c9-c20d-560e-9dbf-f55dc33c0fd2",
      "code": "self.self = /* ? */;\nif ((parent && SSF2API.isReady()) || self.self) {\n\tself.naruto_language = self.self.getGlobalVariable(\"language_Select\");\n}\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "fb8ddd42-9b88-5b59-83bc-1fd52b68d552",
      "code": "",
      "length": 5,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "18cd019d-ec47-56f9-9ff8-093319a68b9e",
      "code": "self.xframe = \"charging\";\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "bc197ebe-50df-51ed-a92c-4732878231af",
      "code": "",
      "length": 39,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "05fdc215-a227-5aeb-b828-b98d746c8726",
      "code": "self.self.stancePlayFrame(\"charging\");\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "a9e7c750-835f-519d-8d21-2f46f4ded5cd",
      "code": "self.xframe = \"attack\";\nif (self.naruto_language != \"ENG\") {\n\tself.self.playVoiceSound(1);\n\tself.self.playAttackSound(1);\n\tself.self.setXSpeed(26, false);\n\treturn;\n} else {\n\tself.self.playVoiceSound(2);\n}",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "65d25431-1cda-5d39-aca9-c472581eeda3",
      "code": "self.self.attachEffect(\"global_dust_heavy\");\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "80946217-208c-5355-b6dc-bd45883b7fbd",
      "code": "",
      "length": 8,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "82369faf-e85e-509a-8f5e-d39afae47862",
      "code": "self.self.setXSpeed(0, false);\nif ((parent && SSF2API.isReady()) || self.self) {\n\tSSF2API.getCamera().shake(2);\n\tif (self.self.getMetalStatus()) {\n\t\tself.self.playSound(\"metal_step_m1\");\n\t\treturn;\n\t}\n\tself.self.playSound(\"naruto_footstep\");\n}",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "2cb3db88-c5ce-5478-b694-08657a7cbd04",
      "code": "",
      "length": 4,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "9d160a84-86fc-5a02-bb6f-fb094e8cbfa2",
      "code": "self.self.endAttack();\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
