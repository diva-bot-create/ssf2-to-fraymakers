    },
    {
      "$id": "dad7efde-57ae-53d8-8941-ca9b2849c917",
      "code": "self.self.endAttack();\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "39b12717-d97a-5819-a49b-1ee30f81fd84",
      "code": "self.xframe = \"grab\";\nself.stop();\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "5fd55f95-157c-536c-87cd-1b1ea6083c2e",
      "code": "self.self.stancePlayFrame(\"grabbed\");\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "d1ac7ba1-3529-54ec-b5d2-69ce93559f42",
      "code": "self.xframe = \"attack\";\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
