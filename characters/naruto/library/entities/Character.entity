    {
      "$id": "83015814-80d9-5451-9c86-20bcc6e823b8",
      "code": "self.self = /* ? */;\nif ((parent && SSF2API.isReady()) || self.self) {\n\tself.self.playVoiceSound(1);\n\tself.self.playAttackSound(1);\n\tself.onGround = self.self.isOnGround();\n\tself.facing = self.self.isFacingRight();\n\tself.soundPlayed = false;\n\tself.reverse = false;\n\tself.opposite = 0;\n\tself.fired = false;\n\tself.self.setGlobalVariable(\"cloneStartedGround\", false);\n}\nself.xframe = \"start1\";\nif ((parent && SSF2API.isReady()) || self.self) {\n\tself.playsound = SSF2API.random();\n\tself.audio = self.self.getGlobalVariable(\"audio\");\n\tif (self.self.isOnGround()) {\n\t\tself.self.stancePlayFrame(\"start\");\n\t}\n}\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
