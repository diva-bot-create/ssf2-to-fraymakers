    },
    {
      "$id": "ba45c6bc-1b7d-5c97-8568-19b29d93b1e0",
      "code": "self.controls = self.self.getControls();\nif (self.controls.BUTTON1 != true) {\n} else {\n\tself.buttonCount = 1;\n}\nif ((self.controls.RIGHT == true && self.facing != true) || self.controls.LEFT == true) {\n\tself.opposite = self.opposite + 1;\n\tself.reverse = true;\n}\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "755c9e1d-8d6a-531d-9bbb-998e34b05b41",
      "code": "self.controls = self.self.getControls();\nif (self.controls.BUTTON1 != true) {\n} else {\n\tself.buttonCount = self.buttonCount + 1;\n}\nif ((self.controls.RIGHT == true && self.facing != true) || self.controls.LEFT == true) {\n\tself.opposite = self.opposite + 1;\n\tself.reverse = true;\n}\nreturn;",
      "length": 1,
