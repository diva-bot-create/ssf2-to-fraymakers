    },
    {
      "$id": "663578ad-791f-5e57-abb1-684357a48c8d",
      "code": "",
      "length": 6,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "9145b9b3-2556-536f-82b4-80b2ce48f4d9",
      "code": "self.self.stancePlayFrame(\"charging\");\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "204fb925-1590-58ca-9b2f-a3530e78644a",
      "code": "self.xframe = \"attack\";\nSSF2API.stopSound(self.sfxStop);\nSSF2API.stopSound(self.sfxStop2);\nself.self.updateAttackStats({ cancelSoundOnEnd: false, cancelVoiceOnEnd: false });\nif (self.naruto_language != \"ENG\") {\n\tself.self.playVoiceSound(2);\n\tself.self.attachEffect(\"naruto_rasenChargeParticle\");\n\treturn;\n} else {\n\tself.self.playVoiceSound(4);\n}",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "2745e6b0-f046-5448-9d58-244d248e643d",
      "code": "",
      "length": 2,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "f9604d57-b7cf-51c6-9f00-360ce7d5f740",
      "code": "self.self.playSound(\"rasengan_sfx1\");\nself.self.attachEffect(\"global_dust_heavy\");\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "5b71e9d6-7459-5ce5-a6c5-acb540f68e4f",
      "code": "",
