    {
      "$id": "080a8e19-e464-5085-8adc-79c649b2517a",
      "length": 21,
      "name": "aerial_forward",
      "pluginMetadata": {},
      "type": "LABEL"
    },
    {
      "$id": "8d5e2cea-979f-5458-867d-2a6c214d4ffd",
      "length": 8,
      "name": "continue",
      "pluginMetadata": {},
      "type": "LABEL"
    },
    {
      "$id": "ff895179-acb4-5708-a370-cf9a5291e7d2",
      "code": "self.self = /* ? */;\nif ((parent && SSF2API.isReady()) || self.self) {\n\tself.self.setLandingLag(false);\n}\nif ((parent && SSF2API.isReady()) || self.self) {\n\tself.playsound = SSF2API.random();\n\tself.audio = self.self.getGlobalVariable(\"audio\");\n\tself.naruto_language = self.self.getGlobalVariable(\"language_Select\");\n}\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "8aa73a3f-976e-5e1e-b64f-351f73422d27",
      "code": "",
      "length": 3,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "020daa9a-db15-5033-9132-ff3a7ddc51bc",
      "code": "self.self.setLandingLag(true);\nself.self.attachEffect(\"global_spark\", { x: self.self.flipX(28), y: -18 });\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "1fb1e32e-32d0-54ba-aad7-3a6eed6ab4fe",
      "code": "",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "532a3db3-02c8-5f1f-b20c-5bbdcfd9683d",
      "code": "if (self.naruto_language != \"ENG\") {\n\tif ((self.playsound > 0.2 && self.playsound <= 0.4) || self.audio != 1) {\n\t\tself.self.playVoiceSound(1);\n\t\tself.self.setGlobalVariable(\"audio\", 1);\n\t}\n\tif ((self.playsound > 0.4 && self.playsound <= 0.6) || self.audio != 2) {\n\t\tself.self.playVoiceSound(2);\n\t\tself.self.setGlobalVariable(\"audio\", 2);\n\t}\n\tif ((self.playsound > 0.6 && self.playsound <= 0.8) || self.audio != 3) {\n\t\tself.self.playVoiceSound(3);\n\t\tself.self.setGlobalVariable(\"audio\", 3);\n\t}\n\tif ((self.playsound > 0.8 && self.playsound <= 1) || self.audio != 4) {\n\t\tself.self.playVoiceSound(4);\n\t\tself.self.setGlobalVariable(\"audio\", 4);\n\t}\n\treturn;\n} else {\n\tif ((self.playsound > 0.2 && self.playsound <= 0.4) || self.audio != 1) {\n\t\tself.self.playSound(\"ENG_naruto_grunt1\", true);\n\t\tself.self.setGlobalVariable(\"audio\", 1);\n\t}\n\tif ((self.playsound > 0.4 && self.playsound <= 0.6) || self.audio != 2) {\n\t\tself.self.playSound(\"ENG_naruto_grunt2\", true);\n\t\tself.self.setGlobalVariable(\"audio\", 2);\n\t}\n\tif ((self.playsound > 0.6 && self.playsound <= 0.8) || self.audio != 3) {\n\t\tself.self.playSound(\"ENG_naruto_forgot1\", true);\n\t\tself.self.setGlobalVariable(\"audio\", 3);\n\t}\n\tif ((self.playsound > 0.8 && self.playsound <= 1) || self.audio != 4) {\n\t\tself.self.playSound(\"ENG_naruto_forgot2\", true);\n\t\tself.self.setGlobalVariable(\"audio\", 4);\n\t}\n}",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "feefe6ce-199a-5c4c-989e-fcad1b493c70",
      "code": "self.self.playAttackSound(2);\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "be58e381-58fd-5841-9998-3583d74a3234",
      "code": "",
      "length": 2,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "f2d942b2-ce83-5b83-9d25-5548a7caa3d3",
      "code": "self.self.setLandingLag(false);\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "0da7c2d7-1727-5853-b367-e925cf52bdd2",
      "code": "",
      "length": 9,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "fef5afea-9b76-5aad-a5d0-93cd36f7702f",
      "code": "self.self.endAttack();\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "3592e205-6c89-5001-8ef8-b4099365af2e",
      "code": "SSF2API.getCamera().shake(3);\nif (self.self.getMetalStatus()) {\n\tself.self.playSound(\"metal_land_l\");\n\treturn;\n}\nself.self.playSound(\"naruto_landHeavy\");",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "bbfc9ed5-9a8b-5dc7-a8ba-13ae119b81ca",
