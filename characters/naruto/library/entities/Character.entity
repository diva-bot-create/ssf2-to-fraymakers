    {
      "$id": "668a250d-1b79-575c-8267-c3fad395420e",
      "length": 2,
      "name": "grabbed",
      "pluginMetadata": {},
      "type": "LABEL"
    },
    {
      "$id": "a232dedf-b033-5f50-9475-9bb24b060715",
      "length": 9,
      "name": "attack",
      "pluginMetadata": {},
      "type": "LABEL"
    },
    {
      "$id": "3de3b62f-2322-5292-9e4e-d339d16bbaa1",
      "code": "self.self = /* ? */;\nself.xframe = \"grab\";\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "faec8295-47db-5668-bc6e-2abf8ed02b22",
      "code": "",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "12362423-dfac-54aa-af80-df9bc07adf03",
      "code": "SSF2API.playSound(\"grab_swing4\");\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "23e859f6-5940-546b-b477-d1596bcf36e7",
      "code": "self.self.attachEffect(\"global_dust_light\");\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "36d52ea0-3de8-5ece-be42-79f12d61eeb7",
      "code": "",
      "length": 11,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "a79b368e-7246-5e6d-a05b-846707e1307b",
      "code": "self.self.endAttack();\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "651ba3b7-518f-5e59-b244-72503f06d52b",
      "code": "self.xframe = \"grab\";\nself.self.setXSpeed(self.self.getXSpeed() * 1.2);\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "53b914c4-4dae-5359-9ea8-3dc843e17e4e",
      "code": "",
      "length": 3,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "47cdf0b8-e79e-54f8-87df-c6cf4167409a",
      "code": "SSF2API.playSound(\"grab_swing6\");\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "8d442113-25d7-582b-a0e7-f86b75f91407",
      "code": "self.self.setXSpeed(0);\nself.self.attachEffect(\"global_dust_light\");\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "4847070e-55f6-5385-b142-c1c6e75c0570",
      "code": "",
