    {
      "$id": "834e010b-f208-5a4e-b3b4-9865d8f82b2d",
      "length": 27,
      "name": "aerial_down",
      "pluginMetadata": {},
      "type": "LABEL"
    },
    {
      "$id": "eac7277d-3ee9-5cc5-bbbe-a26ba7a0ffcc",
      "length": 8,
      "name": "continue",
      "pluginMetadata": {},
      "type": "LABEL"
    },
    {
      "$id": "dae0362b-3bc1-55b4-9334-c32884ea8f75",
      "code": "self.self = /* ? */;\nif ((parent && SSF2API.isReady()) || self.self) {\n\tself.self.setLandingLag(false);\n}\nif ((parent && SSF2API.isReady()) || self.self) {\n\tself.playsound = SSF2API.random();\n\tself.audio = self.self.getGlobalVariable(\"audio\");\n\tself.naruto_language = self.self.getGlobalVariable(\"language_Select\");\n}\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "742c0741-91b8-5459-81d1-c103bab62806",
      "code": "self.self.setLandingLag(true);\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "c8c7ec76-0357-5cb1-ba71-49eb77f34c62",
      "code": "",
      "length": 2,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "e3a2a873-77b8-5a54-a8a0-c32a0375795a",
      "code": "self.self.updateAttackStats({ air_ease: -1 });\nself.self.playAttackSound(1);\nself.self.setXSpeed(9, false);\nself.self.setYSpeed(15);\nself.self.playAttackSound(2);\nself.self.updateAttackStats({ allowControl: false });\nif (self.naruto_language != \"ENG\") {\n\tif ((self.playsound > 0.2 && self.playsound <= 0.4) || self.audio != 1) {\n\t\tself.self.playVoiceSound(1);\n\t\tself.self.setGlobalVariable(\"audio\", 1);\n\t}\n\tif ((self.playsound > 0.4 && self.playsound <= 0.6) || self.audio != 2) {\n\t\tself.self.playVoiceSound(2);\n\t\tself.self.setGlobalVariable(\"audio\", 2);\n\t}\n\tif ((self.playsound > 0.6 && self.playsound <= 0.8) || self.audio != 3) {\n\t\tself.self.playVoiceSound(3);\n\t\tself.self.setGlobalVariable(\"audio\", 3);\n\t}\n\tif ((self.playsound > 0.8 && self.playsound <= 1) || self.audio != 4) {\n\t\tself.self.playVoiceSound(4);\n\t\tself.self.setGlobalVariable(\"audio\", 4);\n\t}\n\treturn;\n} else {\n\tif ((self.playsound > 0.2 && self.playsound <= 0.4) || self.audio != 1) {\n\t\tself.self.playSound(\"ENG_naruto_grunt1\", true);\n\t\tself.self.setGlobalVariable(\"audio\", 1);\n\t}\n\tif ((self.playsound > 0.4 && self.playsound <= 0.6) || self.audio != 2) {\n\t\tself.self.playSound(\"ENG_naruto_grunt2\", true);\n\t\tself.self.setGlobalVariable(\"audio\", 2);\n\t}\n\tif ((self.playsound > 0.6 && self.playsound <= 0.8) || self.audio != 3) {\n\t\tself.self.playSound(\"ENG_naruto_forgot1\", true);\n\t\tself.self.setGlobalVariable(\"audio\", 3);\n\t}\n\tif ((self.playsound > 0.8 && self.playsound <= 1) || self.audio != 4) {\n\t\tself.self.playSound(\"ENG_naruto_forgot2\", true);\n\t\tself.self.setGlobalVariable(\"audio\", 4);\n\t}\n}",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "fd74d733-58d3-5216-ab53-d2fb81355f67",
      "code": "",
      "length": 20,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "ebaf8c51-6acd-5625-af64-266f06dc15bd",
      "code": "self.self.setLandingLag(false);\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "956829bb-e280-515f-9a86-416177b4f6cc",
      "code": "self.self.endAttack();\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "54555054-afa5-511a-95b1-2b4bcb78b9fa",
      "code": "SSF2API.getCamera().shake(3);\nself.self.setXSpeed(9, false);\nSSF2API.getCamera().shake(3);\nif (self.self.getMetalStatus()) {\n\tself.self.playSound(\"metal_land_l\");\n\treturn;\n}\nself.self.playSound(\"naruto_landHeavy\");",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "6145a9f2-52d3-5dea-9179-d61177eb0bd6",
      "code": "",
      "length": 6,
