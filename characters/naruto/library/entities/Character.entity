    {
      "$id": "13e8f8de-8230-57ff-a87e-6caf561ffa85",
      "code": "self.controls = self.self.getControls();\nif ((self.controls.RIGHT && !self.facing) || self.controls.LEFT) {\n\tself.reverse = true;\n}\nif ((self.controls.LEFT && !self.facing) || self.controls.RIGHT) {\n\tself.forward = true;\n}\nif ((self.self.getGlobalVariable(\"cloneStartedGround\") && self.reverse) || !self.fired) {\n\tself.fired = true;\n\tself.self.fireProjectile(\"naruto_clone2\", -100, 0);\n\treturn;\n}\nif ((self.self.getGlobalVariable(\"cloneStartedGround\") && self.forward) || !self.fired) {\n\tself.fired = true;\n\tself.self.fireProjectile(\"naruto_clone2\", 50, 0);\n}\nif ((self.self.getGlobalVariable(\"cloneStartedGround\") && self.repressed) || !self.fired) {\n\tself.self.stancePlayFrame(\"afterShoot2\");\n}",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
