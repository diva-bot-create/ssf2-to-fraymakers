      "code": "self.self = /* ? */;\nif ((parent && SSF2API.isReady()) || self.self) {\n\tself.xframe = \"hurt1\";\n\tself.self.setGlobalVariable(\"jab\", false);\n\tself.self.setGlobalVariable(\"jab2\", false);\n}\nreturn;",
