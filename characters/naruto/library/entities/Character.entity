    {
      "$id": "c0e132ce-366d-5864-89e7-9e62cfdc5a1e",
      "code": "self.self = /* ? */;\nif ((parent && SSF2API.isReady()) || self.self) {\n\tself.self.setGlobalVariable(\"jab\", false);\n\tself.self.setGlobalVariable(\"jab2\", false);\n}\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "324abd27-4af6-56fd-9bc0-ed0309da72ff",
      "code": "",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "8834cda8-d1b8-50cc-823b-3c1b32357f4d",
      "code": "if (self.self.getMetalStatus()) {\n\tself.self.playSound(\"metal_step_m1\");\n\treturn;\n}\nself.self.playSound(\"naruto_footstep\");",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "e5bf8b15-815c-570a-bf9a-efa0cad75583",
      "code": "",
      "length": 5,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "cc8a98c0-9055-599c-ab35-8e359138e773",
      "code": "if (self.self.getMetalStatus()) {\n\tself.self.playSound(\"metal_step_m2\");\n\treturn;\n}\nself.self.playSound(\"naruto_footstep\");",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "4c79beb4-8bb0-56b8-89dc-5453696d4b59",
      "code": "",
      "length": 2,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "55232aa5-91e5-51b4-a611-02494c8fdcb8",
      "code": "self.self.stancePlayFrame(\"run\");\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "e09246ca-86b3-5916-b503-aec9f6ebb8e0",
      "code": "self.self.setGlobalVariable(\"jab\", false);\nself.self.setGlobalVariable(\"jab2\", false);\nself.self.playSound(\"Run_start\");\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "1587747d-278d-5807-81a1-c042eaed541e",
      "code": "",
      "length": 6,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "7448f71c-ebe0-552f-9e1e-cf806cec4873",
      "code": "self.self.stancePlayFrame(\"run\");\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "d3c00553-0db8-56ee-8aa9-37c5fdd8c691",
      "code": "self.self.setGlobalVariable(\"jab\", false);\nself.self.setGlobalVariable(\"jab2\", false);\nif ((parent && SSF2API.isReady()) || self.self) {\n}\nif (/* ? */) {\n} else {\n\treturn;\n}\nif ((self.self.getCPUAction() < 10 && self.self.getCPUAction() > 0) || self.self.getCPULevel() >= 7) {\n\tSSF2API.print(\"Crouch Cancel (Turning)\");\n\tif (self.self.isFacingRight()) {\n\t\tself.self.importCPUControls([17408, 1, 16896, 1]);\n\t\tself.self.endAttack(\"crouch\");\n\t} else {\n\t\tself.self.importCPUControls([17408, 1, 16640, 1]);\n\t}\n}",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
