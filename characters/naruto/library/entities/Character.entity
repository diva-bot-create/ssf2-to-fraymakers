    {
      "$id": "16139f43-1cc4-5936-bfff-32c3a9c03539",
      "code": "self.self = /* ? */;\nif ((parent && SSF2API.isReady()) || self.self) {\n\tself.self.setGlobalVariable(\"canStartRise\", true);\n\tif (self.self.getMetalStatus()) {\n\t} else {\n\t\tself.self.playSound(\"naruto_ledge_grab\", true);\n\t}\n}\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "f2e4f2d3-6e04-5bc9-b760-9127488d611e",
      "code": "",
      "length": 18,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "0385e947-8a4e-5065-bf11-22fc2c8382e1",
      "code": "self.self.stancePlayFrame(\"loop\");\nreturn;",
