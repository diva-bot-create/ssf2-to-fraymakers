    },
    {
      "$id": "2bc74555-ad63-5589-ac96-e731b317f42e",
      "code": "self.self.attachEffect(\"naruto_rasenUseParticle\");\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "fc750717-24c4-5a75-b55c-af1cc9d0cd90",
      "code": "",
      "length": 19,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "9a36ad16-ed8e-5a87-b795-dabbf5781a1b",
      "code": "self.self.endAttack();\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "dba7b457-2e09-57d9-83e2-519bb9c074c4",
      "code": "self.xframe = \"attack\";\nself.hasHit = true;\nif (self.oodama) {\n\tself.self.playSound(\"naruto_bunshin\");\n\tself.self.stancePlayFrame(\"rasenshuriken\");\n\tself.self.attachEffect(\"naruto_rasenUseParticle\");\n\tself.self.attachEffect(\"global_dust_heavy\");\n\treturn;\n}\nself.self.fireProjectile(\"naruto_rasengan\");",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "6a784f33-48c8-5666-a452-c119372f4d54",
      "code": "",
      "length": 7,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "41dfaca5-cf68-5819-9421-652f8cdb2937",
      "code": "self.self.attachEffect(\"naruto_rasenUseParticle\");\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "ce89be0d-f671-54d8-bc4c-3acef77ba18a",
      "code": "",
      "length": 14,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "b5adea60-eb25-5946-b373-581fcaa79790",
      "code": "self.self.endAttack();\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "3aa0e3ec-ad06-531a-b7d9-1683634231f6",
      "code": "self.xframe = \"attack2\";\nself.oodama = true;\nself.self.updateAttackBoxStats(1, { hitStun: 15, priority: -1 });\nself.self.updateAttackStats({ air_ease: 2, cancelSoundOnEnd: false, cancelVoiceOnEnd: false, allowControl: false });\nself.self.setXSpeed(self.self.getXSpeed() * 0.3);\nself.self.attachEffect(\"global_sparkle\", { x: self.flipX(35), y: -35 });\nif (self.hasHit) {\n\tself.self.playSound(\"rasengan_sfx1\");\n}\nSSF2API.stopSound(self.sfxStop);\nSSF2API.stopSound(self.sfxStop2);\nif (self.naruto_language != \"ENG\") {\n\tself.self.playVoiceSound(5);\n\treturn;\n} else {\n\tself.self.playVoiceSound(6);\n}",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "2be134f9-63da-537c-9c80-d6be8384e010",
      "code": "",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "1be66ddb-ec41-5966-a6c3-8148482eaee8",
      "code": "self.self.attachEffect(\"naruto_rasenEffect2\");\nself.self.attachEffect(\"global_dust_swirl\");\nself.self.attachEffect(\"global_dust_heavy\");\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "bc4d4107-28d0-5412-8dd7-4cb7b3f10a9f",
      "code": "",
      "length": 2,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "7995fb9e-dec8-51dc-a460-20d47361831f",
      "code": "self.self.attachEffect(\"naruto_rasenParticle\");\nself.self.attachEffect(\"global_dust_heavy\");\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "cc939bf2-a860-575d-aef4-53d63e15c5a8",
      "code": "",
      "length": 6,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "2ceb20d6-e0f9-5e9a-92ef-cbed8174d809",
      "code": "self.self.playSound(\"naruto_sfx_rasenshuriken\");\nself.self.fireProjectile(\"rasenshuriken\", 40, -30);\nself.self.attachEffect(\"global_dust_heavy\");\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "77aad053-e201-5814-bf42-903af72abed5",
      "code": "",
