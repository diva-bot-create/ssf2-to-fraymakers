    },
    {
      "$id": "17d7a922-40e8-54a3-9ac1-0f8b4323d48e",
      "code": "self.self.playAttackSound(1);\nself.self.setLandingLag(true);\nif (self.naruto_language != \"ENG\") {\n\tif ((self.playsound > 0.2 && self.playsound <= 0.4) || self.audio != 1) {\n\t\tself.self.playVoiceSound(1);\n\t\tself.self.setGlobalVariable(\"audio\", 1);\n\t}\n\tif ((self.playsound > 0.4 && self.playsound <= 0.6) || self.audio != 2) {\n\t\tself.self.playVoiceSound(2);\n\t\tself.self.setGlobalVariable(\"audio\", 2);\n\t}\n\tif ((self.playsound > 0.6 && self.playsound <= 0.8) || self.audio != 3) {\n\t\tself.self.playVoiceSound(3);\n\t\tself.self.setGlobalVariable(\"audio\", 3);\n\t}\n\tif ((self.playsound > 0.8 && self.playsound <= 1) || self.audio != 4) {\n\t\tself.self.playVoiceSound(4);\n\t\tself.self.setGlobalVariable(\"audio\", 4);\n\t}\n\treturn;\n} else {\n\tif ((self.playsound > 0.2 && self.playsound <= 0.4) || self.audio != 1) {\n\t\tself.self.playSound(\"ENG_naruto_grunt1\", true);\n\t\tself.self.setGlobalVariable(\"audio\", 1);\n\t}\n\tif ((self.playsound > 0.4 && self.playsound <= 0.6) || self.audio != 2) {\n\t\tself.self.playSound(\"ENG_naruto_grunt2\", true);\n\t\tself.self.setGlobalVariable(\"audio\", 2);\n\t}\n\tif ((self.playsound > 0.6 && self.playsound <= 0.8) || self.audio != 3) {\n\t\tself.self.playSound(\"ENG_naruto_forgot1\", true);\n\t\tself.self.setGlobalVariable(\"audio\", 3);\n\t}\n\tif ((self.playsound > 0.8 && self.playsound <= 1) || self.audio != 4) {\n\t\tself.self.playSound(\"ENG_naruto_forgot2\", true);\n\t\tself.self.setGlobalVariable(\"audio\", 4);\n\t}\n}",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "c4c54885-9e43-580c-bf25-8cccee866b67",
      "code": "self.self.attachEffect(\"global_dust_blast\", { x: self.self.flipX(-35), y: -22, parentLock: true });\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "bb8846f0-2b1b-54ae-a464-2d7c916c2bfc",
      "code": "self.self.updateAttackBoxStats(1, { direction: 40, power: 28, damage: 6 });\nself.self.updateAttackBoxStats(2, { direction: 40, power: 28, damage: 6 });\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "152525ad-8ce7-5588-b1fb-678eee18d69a",
      "code": "",
      "length": 5,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "94a642d5-7ba5-5567-8ef0-1da77ff5648c",
      "code": "self.self.setLandingLag(false);\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "89397a74-9fd6-512f-8161-0146bdde7d70",
      "code": "",
      "length": 4,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "cbfe0c41-efb6-5ca8-a797-53d9b19ecbfd",
      "code": "self.self.endAttack();\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "f8005a3a-d745-5856-a328-446f40c59bef",
      "code": "SSF2API.getCamera().shake(2);\nif (self.self.getMetalStatus()) {\n\tself.self.playSound(\"metal_land_m\");\n\treturn;\n}\nself.self.playSound(\"naruto_landMedium\");",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
