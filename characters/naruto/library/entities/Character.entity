    {
      "$id": "b056b6b0-bd8c-5f48-b3f9-521a6e82026d",
      "length": 28,
      "name": "throw_down",
      "pluginMetadata": {},
      "type": "LABEL"
    },
    {
      "$id": "34c2f9e0-3634-529f-9ec5-f92e8ec24b47",
      "code": "self.self = /* ? */;\nself.xframe = null;\nif ((parent && SSF2API.isReady()) || self.self) {\n\tself.playsound = SSF2API.random();\n\tself.audio = self.self.getGlobalVariable(\"audio\");\n\tself.naruto_language = self.self.getGlobalVariable(\"language_Select\");\n\tself.self.attachEffect(\"naruto_summonClone\");\n\tself.self.setRotation(0);\n}\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "5a4fb4e1-481f-5901-b027-2a368eefa249",
      "code": "self.self.playAttackSound(1);\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "b1b059fb-fc31-537f-8398-371997db84df",
      "code": "",
      "length": 2,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "0edf9504-bc06-5803-bca5-6ff94c53d71e",
      "code": "self.self.attachEffect(\"global_dust_heavy\", { x: self.self.flipX(-70) });\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "3b0d4cc2-2ea8-5172-bef7-c3c97db898c5",
      "code": "",
      "length": 2,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "fe143218-9fa2-51b9-9e5a-2b133aac5b75",
      "code": "SSF2API.getCamera().shake(9);\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "4dae59e3-b8e0-5035-a936-6d520f06cea5",
      "code": "",
      "length": 1,
      "pluginMetadata": {},
