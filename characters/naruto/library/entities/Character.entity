    {
      "$id": "d53aafdd-599a-55f1-be63-25de4989e743",
      "length": 25,
      "name": "getup_attack",
      "pluginMetadata": {},
      "type": "LABEL"
    },
    {
      "$id": "835eaea6-cc29-5b7c-8026-ae529e14ca7f",
      "code": "self.self = /* ? */;\nif ((parent && SSF2API.isReady()) || self.self) {\n\tself.self.setIntangibility(true);\n\tself.playsound = SSF2API.random();\n\tself.audio = self.self.getGlobalVariable(\"audio\");\n\tself.naruto_language = self.self.getGlobalVariable(\"language_Select\");\n}\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "9f13e8fe-f904-5d74-bc28-200ff4a21147",
      "code": "",
      "length": 6,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "4d7ec9d1-5609-5f6b-a6dd-a9e09d0dea58",
      "code": "self.self.setIntangibility(true);\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "1e189e84-cea3-5929-a0b5-e361f877eb2c",
      "code": "",
      "length": 2,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "b43686d1-71b8-5e93-b003-cb04c92390f7",
      "code": "if (self.naruto_language != \"ENG\") {\n\tif ((self.playsound > 0.2 && self.playsound <= 0.4) || self.audio != 1) {\n\t\tself.self.playVoiceSound(1);\n\t\tself.self.setGlobalVariable(\"audio\", 1);\n\t}\n\tif ((self.playsound > 0.4 && self.playsound <= 0.6) || self.audio != 2) {\n\t\tself.self.playVoiceSound(2);\n\t\tself.self.setGlobalVariable(\"audio\", 2);\n\t}\n\tif ((self.playsound > 0.6 && self.playsound <= 0.8) || self.audio != 3) {\n\t\tself.self.playVoiceSound(3);\n\t\tself.self.setGlobalVariable(\"audio\", 3);\n\t}\n\tif ((self.playsound > 0.8 && self.playsound <= 1) || self.audio != 4) {\n\t\tself.self.playVoiceSound(4);\n\t\tself.self.setGlobalVariable(\"audio\", 4);\n\t}\n\treturn;\n} else {\n\tif ((self.playsound > 0.2 && self.playsound <= 0.4) || self.audio != 1) {\n\t\tself.self.playSound(\"ENG_naruto_grunt1\", true);\n\t\tself.self.setGlobalVariable(\"audio\", 1);\n\t}\n\tif ((self.playsound > 0.4 && self.playsound <= 0.6) || self.audio != 2) {\n\t\tself.self.playSound(\"ENG_naruto_grunt2\", true);\n\t\tself.self.setGlobalVariable(\"audio\", 2);\n\t}\n\tif ((self.playsound > 0.6 && self.playsound <= 0.8) || self.audio != 3) {\n\t\tself.self.playSound(\"ENG_naruto_forgot1\", true);\n\t\tself.self.setGlobalVariable(\"audio\", 3);\n\t}\n\tif ((self.playsound > 0.8 && self.playsound <= 1) || self.audio != 4) {\n\t\tself.self.playSound(\"ENG_naruto_forgot2\", true);\n\t\tself.self.setGlobalVariable(\"audio\", 4);\n\t}\n}",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "da406149-fa27-5c9a-b302-495421335d8b",
      "code": "",
      "length": 3,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "c07332e6-cd87-55cc-ae71-4f9ed4429efc",
      "code": "if (self.naruto_language != \"ENG\") {\n\tif ((self.playsound > 0.2 && self.playsound <= 0.4) || self.audio != 1) {\n\t\tself.self.playVoiceSound(1);\n\t\tself.self.setGlobalVariable(\"audio\", 1);\n\t}\n\tif ((self.playsound > 0.4 && self.playsound <= 0.6) || self.audio != 2) {\n\t\tself.self.playVoiceSound(2);\n\t\tself.self.setGlobalVariable(\"audio\", 2);\n\t}\n\tif ((self.playsound > 0.6 && self.playsound <= 0.8) || self.audio != 3) {\n\t\tself.self.playVoiceSound(3);\n\t\tself.self.setGlobalVariable(\"audio\", 3);\n\t}\n\tif ((self.playsound > 0.8 && self.playsound <= 1) || self.audio != 4) {\n\t\tself.self.playVoiceSound(4);\n\t\tself.self.setGlobalVariable(\"audio\", 4);\n\t}\n\tself.self.playAttackSound(2);\n\tself.self.attachEffect(\"global_dust_light\", { flipOnX: true });\n\treturn;\n} else {\n\tif ((self.playsound > 0.2 && self.playsound <= 0.4) || self.audio != 1) {\n\t\tself.self.playSound(\"ENG_naruto_grunt1\", true);\n\t\tself.self.setGlobalVariable(\"audio\", 1);\n\t}\n\tif ((self.playsound > 0.4 && self.playsound <= 0.6) || self.audio != 2) {\n\t\tself.self.playSound(\"ENG_naruto_grunt2\", true);\n\t\tself.self.setGlobalVariable(\"audio\", 2);\n\t}\n\tif ((self.playsound > 0.6 && self.playsound <= 0.8) || self.audio != 3) {\n\t\tself.self.playSound(\"ENG_naruto_forgot1\", true);\n\t\tself.self.setGlobalVariable(\"audio\", 3);\n\t}\n\tif ((self.playsound > 0.8 && self.playsound <= 1) || self.audio != 4) {\n\t\tself.self.playSound(\"ENG_naruto_forgot2\", true);\n\t\tself.self.setGlobalVariable(\"audio\", 4);\n\t}\n}",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "b1ce15bd-6200-5b74-902b-9c4bf2cf671f",
