      "length": 21,
      "name": "attack",
      "pluginMetadata": {},
      "type": "LABEL"
    },
    {
      "$id": "64876516-adf6-5d21-a1a7-d81431df10b1",
      "code": "self.self = /* ? */;\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "2f3f6b14-2f54-5a14-8b0c-615a06f07502",
      "code": "",
      "length": 3,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "f31efcfc-ef04-5589-a073-7ab501b807f3",
      "code": "self.xframe = \"charging\";\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "5066e88a-57ea-5399-a6cf-9d0603dc8790",
      "code": "",
      "length": 39,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "bbaa9623-7ef7-505b-8e6c-c80977f64445",
      "code": "self.self.stancePlayFrame(\"charging\");\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "47078c0c-8016-51d3-8c55-29705133269b",
      "code": "self.xframe = \"attack\";\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "61c40ba3-b631-5ed8-a47d-a971beb6f7d6",
      "code": "",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "c8d05ca4-c108-53d4-8269-f4a97f9ef0b0",
      "code": "self.self.getItem().activateItem();\nself.self.playAttackSound(1);\nself.self.playVoiceSound(1);\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "79c0241e-75e5-58ea-af69-63e19a960d58",
      "code": "",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "a5a799a3-3389-59f6-886f-e0ff913ba927",
      "code": "self.self.getItem().deactivateItem();\nself.self.updateAttackStats({ chargetime_max: 0 });\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "51fcf830-131d-50d5-bd0d-8c46c1ab8ef0",
      "code": "",
      "length": 15,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
