      "code": "self.self.refreshAttackID();\nself.self.updateAttackBoxStats(1, { effectSound: \"brawl_kick_m\", effect_id: \"effect_hit2\", direction: 31, power: 30, kbConstant: 125, damage: 7, weightKB: 0 });\nself.self.updateAttackBoxStats(2, { effectSound: \"brawl_kick_m\", effect_id: \"effect_hit2\", direction: 31, power: 30, kbConstant: 125, damage: 7, weightKB: 0 });\nself.self.updateAttackStats({ air_ease: 0.57, allowControl: false, allowFastFall: true });\nself.self.setYSpeed(-6.8);\nself.self.setXSpeed(0);\nreturn;",
