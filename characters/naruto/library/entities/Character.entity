    {
      "$id": "b7c1199c-ee8a-5762-816c-b0e82a98e9a2",
      "code": "self.self = /* ? */;\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "3591a36c-699f-5029-be0c-fb9e4b95de88",
      "code": "self.self.fireProjectile(\"naruto_dodgelog\");\nself.self.attachEffect(\"naruto_bunshindissappear\");\nself.effect = self.self.attachEffect(\"global_dust_heavy\", { scaleX: 0.8, scaleY: 0.8 });\nself.effect.scaleX = -self.effect.scaleX;\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "b49e6990-239f-5296-b23e-21ebac0f22f9",
      "code": "self.self.setIntangibility(true);\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "543d2120-01d2-5c33-82a6-d1ef499f8b54",
      "code": "",
