{
  "_meta": {
    "description": "SSF2 animation/xframe name → Fraymakers CState + animation name mapping.",
    "sources": [
      "https://ajewelofrarity.github.io/FraymakersDocs/docs/classes/CState.html",
      "Extracted from mario.ssf xframe mappings (abc_parser.rs)"
    ],
    "notes": [
      "SSF2 uses xframe labels (e.g. 'a' = stand, 'b' = walk) set by self.xframe = '...'",
      "Fraymakers uses named animations that match CState names (lowercase_with_underscores)",
      "Some SSF2 animations have no FM equivalent and must be mapped to closest state"
    ]
  },

  "ground_movement": {
