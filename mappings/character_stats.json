{
  "_meta": {
    "description": "SSF2 getOwnStats() field → Fraymakers CharacterStats field mapping.",
    "sources": [
      "https://ssf2-modding.readthedocs.io/en/latest/reference/API.html#SSF2Character",
      "https://ajewelofrarity.github.io/FraymakersDocs/docs/classes/CharacterStats.html",
      "src/abc_parser.rs (stat extraction)"
    ],
    "scale_notes": "SSF2 uses pixels/frame at 60fps; FM uses its own unit scale. Movement speeds generally transfer directly. Jump speeds may need ×0.7–0.9 tuning."
  },

  "movement": {
    "walkSpeed":            { "fm": "walkSpeedCap",               "status": "mapped",   "scale": 1.0 },
    "walkAccel":            { "fm": "walkSpeedAcceleration",      "status": "mapped",   "scale": 1.0 },
    "walkInitialSpeed":     { "fm": "walkSpeedInitial",           "status": "mapped",   "scale": 1.0 },
    "runSpeed":             { "fm": "runSpeedCap",                "status": "mapped",   "scale": 1.0 },
    "runAccel":             { "fm": "runSpeedAcceleration",       "status": "mapped",   "scale": 1.0 },
    "runInitialSpeed":      { "fm": "runSpeedInitial",            "status": "mapped",   "scale": 1.0 },
    "dashSpeed":            { "fm": "dashSpeed",                  "status": "mapped",   "scale": 1.0 },
    "groundSpeedAccel":     { "fm": "groundSpeedAcceleration",   "status": "mapped",   "scale": 1.0 },
    "groundSpeedCap":       { "fm": "groundSpeedCap",            "status": "mapped",   "scale": 1.0 },
    "airSpeedAccel":        { "fm": "aerialSpeedAcceleration",   "status": "mapped",   "scale": 1.0 },
    "airSpeedCap":          { "fm": "aerialSpeedCap",            "status": "mapped",   "scale": 1.0 },
    "airFriction":          { "fm": "aerialFriction",            "status": "mapped",   "scale": 1.0 },
    "friction":             { "fm": "/* no direct field */",      "status": "todo",     "note": "SSF2 ground friction; FM uses groundSpeedAcceleration implicitly" },
    "crawlSpeed":           { "fm": "crawlSpeed",                "status": "mapped",   "scale": 1.0 }
  },

  "jumping": {
    "jumpSpeed":            { "fm": "jumpSpeed",                  "status": "mapped",   "scale": 1.0 },
    "doubleJumpSpeed":      { "fm": "doubleJumpSpeeds[0]",        "status": "mapped",   "scale": 1.0, "note": "SSF2 has single djump speed; FM is an array for multi-jump" },
    "shortHopSpeed":        { "fm": "shortHopSpeed",              "status": "mapped",   "scale": 1.0, "note": "SSF2 doesn't store shorthop directly; derive from jumpSpeed×0.55" },
    "doubleJumpCount":      { "fm": "doubleJumpSpeeds.length",    "status": "partial",  "note": "FM infers count from array length" },
    "jumpForwardSpeed":     { "fm": "jumpSpeedForwardInitialXSpeed", "status": "mapped", "scale": 1.0 },
    "jumpBackSpeed":        { "fm": "jumpSpeedBackwardInitialXSpeed", "status": "mapped", "scale": 1.0 }
  },

  "gravity_fall": {
    "gravity":              { "fm": "gravity",                    "status": "mapped",   "scale": 1.0 },
    "terminalVelocity":     { "fm": "terminalVelocity",           "status": "mapped",   "scale": 1.0 },
    "fastFallSpeed":        { "fm": "fastFallSpeed",              "status": "mapped",   "scale": 1.0 }
  },

  "weight": {
    "weight":               { "fm": "weight",                     "status": "mapped",   "scale": 1.0, "note": "SSF2 weight 100 = average; FM same convention" }
  },

  "airdash": {
    "airDashSpeed":         { "fm": "airdashInitialSpeed",        "status": "mapped",   "scale": 1.0 },
    "airDashSpeedCap":      { "fm": "airdashSpeedCap",            "status": "mapped",   "scale": 1.0 },
    "airDashAccel":         { "fm": "airdashAccelMultiplier",     "status": "mapped",   "scale": 1.0 },
    "airDashCancelConservation": { "fm": "airdashCancelSpeedConservation", "status": "mapped", "scale": 1.0 },
    "airDashLimit":         { "fm": "airdashLimit",               "status": "mapped",   "scale": 1.0 }
  },

  "rolls": {
    "techRollSpeed":        { "fm": "techRollSpeed",              "status": "mapped",   "scale": 1.0 },
    "techRollSpeedStart":   { "fm": "techRollSpeedStartFrame",    "status": "mapped",   "scale": 1.0 },
    "techRollSpeedLength":  { "fm": "techRollSpeedLength",        "status": "mapped",   "scale": 1.0 },
    "dodgeRollSpeed":       { "fm": "dodgeRollSpeed",             "status": "mapped",   "scale": 1.0 },
    "dodgeRollSpeedStart":  { "fm": "dodgeRollSpeedStartFrame",   "status": "mapped",   "scale": 1.0 },
    "dodgeRollSpeedLength": { "fm": "dodgeRollSpeedLength",       "status": "mapped",   "scale": 1.0 },
    "getupRollSpeed":       { "fm": "getupRollSpeed",             "status": "mapped",   "scale": 1.0 },
    "getupRollSpeedStart":  { "fm": "getupRollSpeedStartFrame",   "status": "mapped",   "scale": 1.0 },
    "getupRollSpeedLength": { "fm": "getupRollSpeedLength",       "status": "mapped",   "scale": 1.0 },
    "ledgeRollSpeed":       { "fm": "ledgeRollSpeed",             "status": "mapped",   "scale": 1.0 },
    "ledgeRollSpeedStart":  { "fm": "ledgeRollSpeedStartFrame",   "status": "mapped",   "scale": 1.0 },
    "ledgeRollSpeedLength": { "fm": "ledgeRollSpeedLength",       "status": "mapped",   "scale": 1.0 },
    "ledgeJumpX":           { "fm": "ledgeJumpXSpeed",            "status": "mapped",   "scale": 1.0 },
    "ledgeJumpY":           { "fm": "ledgeJumpYSpeed",            "status": "mapped",   "scale": 1.0 }
  },

  "ecb_collision_body": {
    "_note": "SSF2 ECB is defined per-frame in sprite data. Fraymakers uses explicit head/hip/foot positions for floor/aerial states.",
    "ecbTop":               { "fm": "floorHeadPosition",          "status": "todo",     "note": "Derive from sprite bounding box analysis (sprite_parser.rs)" },
    "ecbWidth":             { "fm": "floorHipWidth",              "status": "todo",     "note": "Derive from sprite bounding box" },
    "ecbBottom":            { "fm": "floorFootPosition",          "status": "todo",     "note": "Usually 0 (feet at origin)" },
    "ecbTopAerial":         { "fm": "aerialHeadPosition",         "status": "todo" },
    "ecbWidthAerial":       { "fm": "aerialHipWidth",             "status": "todo" },
    "ecbBottomAerial":      { "fm": "aerialFootPosition",         "status": "todo" },
    "ecbHipXOffset":        { "fm": "floorHipXOffset",            "status": "todo" },
    "ecbHipYOffset":        { "fm": "floorHipYOffset",            "status": "todo" }
  },

  "scale": {
    "baseScaleX":           { "fm": "baseScaleX",                 "status": "mapped",   "scale": 1.0 },
    "baseScaleY":           { "fm": "baseScaleY",                 "status": "mapped",   "scale": 1.0 }
  },

  "shield": {
    "shieldFrontWidth":     { "fm": "shieldFrontWidth",           "status": "mapped" },
    "shieldFrontHeight":    { "fm": "shieldFrontHeight",          "status": "mapped" },
    "shieldFrontXOffset":   { "fm": "shieldFrontXOffset",         "status": "mapped" },
    "shieldFrontYOffset":   { "fm": "shieldFrontYOffset",         "status": "mapped" },
    "shieldBackWidth":      { "fm": "shieldBackWidth",            "status": "mapped" },
    "shieldBackHeight":     { "fm": "shieldBackHeight",           "status": "mapped" },
    "shieldBackXOffset":    { "fm": "shieldBackXOffset",          "status": "mapped" },
    "shieldBackYOffset":    { "fm": "shieldBackYOffset",          "status": "mapped" },
    "shieldCrossupThreshold": { "fm": "shieldCrossupThreshold",   "status": "mapped" }
  },

  "camera": {
    "camBoxOffsetX":        { "fm": "cameraBoxOffsetX",           "status": "mapped" },
    "camBoxOffsetY":        { "fm": "cameraBoxOffsetY",           "status": "mapped" },
    "camBoxWidth":          { "fm": "cameraBoxWidth",             "status": "mapped" },
    "camBoxHeight":         { "fm": "cameraBoxHeight",            "status": "mapped" }
  },

  "voice": {
    "attackVoiceIds":       { "fm": "attackVoiceIds",             "status": "todo",     "note": "SSF2 uses SWF sound assets; FM uses content ids" },
    "hurtLightVoiceIds":    { "fm": "hurtLightVoiceIds",          "status": "todo" },
    "hurtMediumVoiceIds":   { "fm": "hurtMediumVoiceIds",         "status": "todo" },
    "hurtHeavyVoiceIds":    { "fm": "hurtHeavyVoiceIds",          "status": "todo" },
    "koVoiceIds":           { "fm": "koVoiceIds",                 "status": "todo" },
    "attackVoiceSilenceRate":  { "fm": "attackVoiceSilenceRate",  "status": "mapped" },
    "hurtLightSilenceRate":    { "fm": "hurtLightSilenceRate",    "status": "mapped" },
    "hurtMediumSilenceRate":   { "fm": "hurtMediumSilenceRate",   "status": "mapped" },
    "hurtHeavySilenceRate":    { "fm": "hurtHeavySilenceRate",    "status": "mapped" },
    "koVoiceSilenceRate":      { "fm": "koVoiceSilenceRate",      "status": "mapped" }
  },

  "no_equivalent_in_fm": {
    "finalSmash":           "SSF2 final smash mechanic; FM has no equivalent",
    "shieldData":           "SSF2 shield degradation is automatic; FM uses shieldFront/BackWidth",
    "smashBall":            "SSF2-specific item",
    "assistCrystal":        "Fraymakers has its own assist system",
    "pokemon":              "SSF2-specific"
  }
}
