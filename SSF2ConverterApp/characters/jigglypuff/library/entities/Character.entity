    {
      "$id": "e52e3e8f-f00b-5d1c-8b6c-ddf1524ee568",
      "code": "self.self.playSound(\"jiggs_dthrow\");\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "f5fd031b-b312-522b-bad3-a04f4e6d8b8d",
      "code": "",
      "length": 8,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "bb968a8b-6024-5791-bb1d-d707bb2533a3",
      "code": "if (self.self.getMetalStatus()) {\n\tself.self.playSound(\"metal_land_s\");\n\treturn;\n}\nself.self.playSound(\"jiggs_landLight\");",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "369bf758-da6d-562a-a446-110e5f10e05b",
