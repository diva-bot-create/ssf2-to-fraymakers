      "code": "self.charge = \"mid\";\nself.self.destroyTimer(self.playDust);\nself.self.createTimer(4, -1, self.playDust);\nself.self.attachEffect(\"global_spark\", { x: self.flipX(15), y: -20 });\nself.frameCount = self.frameCount + self.frameInc;\nreturn;",
