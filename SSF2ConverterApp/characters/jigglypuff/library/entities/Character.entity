    {
      "$id": "80a693d9-3f69-5c43-89c2-d12b45ce25b3",
      "code": "self.self.removeAllEffects();\nif (self.self.getMetalStatus()) {\n\tself.self.playSound(\"metal_land_m\");\n\treturn;\n}\nself.self.playSound(\"jiggs_landHeavy\");",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "34f38e49-424d-550c-a7e8-e8c130806016",
