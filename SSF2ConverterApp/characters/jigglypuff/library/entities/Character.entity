    },
    {
      "$id": "b81df329-8ca4-51b4-bc93-1297f07bf968",
      "code": "self.self.attachEffect(\"effect_land\");\nif ((parent && SSF2API.isReady()) || self.self) {\n\tif (self.self.getMetalStatus()) {\n\t\tself.self.playSound(\"metal_land_s\");\n\t\treturn;\n\t}\n\tself.self.playSound(\"jiggs_landLight\");\n}",
