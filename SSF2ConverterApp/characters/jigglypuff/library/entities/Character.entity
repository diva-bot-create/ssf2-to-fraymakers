    {
      "$id": "db87ebc2-3855-5481-9bd9-dfa273194ddc",
      "code": "self.self = /* ? */;\nif ((parent && SSF2API.isReady()) || self.self) {\n\tself.playsound = SSF2API.random();\n\tself.audio = self.self.getGlobalVariable(\"audio\");\n\tself.xframe = null;\n}\nreturn;\n}\n\n\nfunction a_down__frame0() {\nself.self = /* ? */;\nif ((parent && SSF2API.isReady()) || self.self) {\n\tself.playsound = SSF2API.random();\n\tself.audio = self.self.getGlobalVariable(\"audio\");\n}\nreturn;",
