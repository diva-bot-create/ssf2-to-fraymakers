    },
    {
      "$id": "b2b250d5-82b9-5ec2-95b8-479abf01f5fc",
      "code": "self.xframe = \"charging\";\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
