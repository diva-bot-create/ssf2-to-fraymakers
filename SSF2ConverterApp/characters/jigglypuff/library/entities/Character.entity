    {
      "$id": "1ebdf932-7e07-5abe-bf9c-6075177fd3c9",
      "length": 10,
      "name": "dash",
      "pluginMetadata": {},
      "type": "LABEL"
    },
    {
      "$id": "252511c6-5587-50ce-b45f-1ea44ac3bea9",
      "length": 14,
      "name": "run",
      "pluginMetadata": {},
      "type": "LABEL"
    },
    {
      "$id": "cc7f1f1d-9bce-5535-9e99-fdda690fbbe0",
      "code": "self.self = /* ? */;\nif (SSF2API.isReady() && self.self) {\n}",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "78440563-d13d-519c-88c5-a862bf155f15",
      "code": "self.rand = 0;\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "f344e48c-9926-58d5-9f0c-b73cfc845a7e",
      "code": "if (self.self.isCPU()) {\n\tself.rand = 10 * SSF2API.random();\n\tself.self.importCPUControls([128, 1]);\n}\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "8565a91f-d16c-550f-8f7d-9f7f04ca3de0",
      "code": "",
      "length": 6,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "e39fca31-5c1c-59c8-b1f7-eda5a8439ca2",
      "code": "self.self.stancePlayFrame(\"run\");\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "91371fd9-6165-5358-be14-6b1889aeb7fa",
      "code": "if (self.self.getMetalStatus()) {\n\tself.self.playSound(\"metal_step_s1\");\n\treturn;\n}\nself.self.playSound(\"jiggs_run1\");",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "c1041fc2-4a51-5285-85ce-d40fbf3916b2",
      "code": "",
      "length": 6,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "2b918857-d6bf-57c5-b119-0617f9b541d4",
      "code": "if (self.self.getMetalStatus()) {\n\tself.self.playSound(\"metal_step_s2\");\n\treturn;\n}\nself.self.playSound(\"jiggs_run2\");",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "1432db5a-6b1c-5fb0-8215-dba8314a5860",
      "code": "",
      "length": 5,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
