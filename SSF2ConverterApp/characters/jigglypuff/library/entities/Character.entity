      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "31608454-e5ad-5738-8d1b-66a849894edf",
      "code": "",
      "length": 3,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "33cc9cfa-9138-5e7b-8a00-5447e9ca773c",
      "code": "self.self.attachEffect(\"global_dust_light\");\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "e868d6c7-7728-5633-a7ab-af9583587eaa",
      "code": "",
      "length": 3,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "e38fec86-e7f1-5d30-bf55-04250a0a0041",
      "code": "self.self.stancePlayFrame(\"midHighGo\");\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "235e3141-4acb-50b0-b3d2-e88ff9b432d8",
      "code": "self.self.playSound(\"jiggs_rollout1\");\nself.xconstant = 20;\nself.bounce = 10;\nself.trail = true;\nself.self.updateAttackBoxStats(1, { damage: 13, power: 100, kbConstant: 80 });\nself.self.attachEffect(\"global_sparkle\", { x: self.flipX(-10), y: -15 });\nself.self.attachEffect(\"jigglypuff_nspec_wind\", { x: self.flipX(-10), y: -15 });\nself.self.attachEffect(\"global_dust_light\");\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "ab770a33-36ca-5545-b526-a85ba004e2f7",
      "code": "",
      "length": 3,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "23a1ff50-f8fe-5919-a458-08c48728a275",
      "code": "self.self.attachEffect(\"global_sparkle\", { x: self.flipX(-10), y: -15 });\nself.self.attachEffect(\"jigglypuff_nspec_wind\", { x: self.flipX(-10), y: -15 });\nself.self.attachEffect(\"global_dust_light\");\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "3c994730-2625-5199-9105-0808ac2d0af9",
      "code": "",
      "length": 3,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "8dc64ec3-78a2-5abd-b8f7-9b362425e462",
      "code": "self.self.stancePlayFrame(\"fullGo\");\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "daa88098-3fad-5165-b1a4-a172b4851d36",
      "code": "self.self.updateAttackStats({ xSpeedDecay: 0 });\nself.self.setXSpeed(0);\nself.self.unnattachFromGround();\nself.self.setXSpeed(-1, false);\nself.self.setYSpeed(-self.bounce);\nself.self.addEventListener(SSF2Event.GROUND_TOUCH, self.self.toIdle);\nself.tehLoopCount = 0;\nself.self.destroyTimer(self.roll);\nself.self.destroyTimer(self.turn);\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "3ba09095-b55f-58ae-bde1-e2775b22cc6b",
      "code": "_v1 = self;\n_v2 = self.tehLoopCount + 1;\nself.tehLoopCount = self.tehLoopCount + 1;\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "1b30044b-fe21-5f24-9c07-648ddaec2bab",
      "code": "",
      "length": 5,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "38238993-323b-5bcf-972a-eaa84b19e6b0",
      "code": "self.self.stancePlayFrame(\"loop\");\nif (self.tehLoopCount <= 3) {\n} else {\n\t/* ? */.self.updateAttackStats({ allowFullInterrupt: true, allowDoubleJump: true, doubleJumpCancelAttack: true });\n\treturn;\n}",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "5f4cb3cb-be2f-5475-b0a1-1baf7c108973",
      "code": "self.self.setXSpeed(3, false);\nself.self.updateAttackStats({ xSpeedDecay: -0.1 });\nself.self.destroyTimer(self.roll);\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "5fe0c777-ba6f-5699-8dc6-96172e5f6659",
      "code": "",
      "length": 18,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "f9457342-7ab3-5df0-a608-2cc6eb257f6b",
      "code": "self.self.endAttack(\"land\");\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "f985a688-add1-5e92-be87-d14f449c6273",
      "code": "self.self.updateAttackStats({ canFallOff: false });\nself.self.updateAttackBoxStats(1, { damage: 3 });\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "978b29dd-de12-5e76-9952-b588a1add513",
      "code": "",
      "length": 8,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "ce90d78e-9f4b-50ab-921a-0b8845d7349a",
      "code": "self.self.stancePlayFrame(\"turning\");\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
