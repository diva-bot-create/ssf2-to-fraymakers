    },
    {
      "$id": "44219b24-4151-5d8b-bc92-0f38bc92c4c4",
      "code": "self.xframeLink = \"punch\";\nself.self.playVoiceSound(1);\nself.self.playAttackSound(1);\nself.self.setXSpeed(20, false);\nself.self.updateAttackStats({ air_ease: 0, rotate: true });\nif (self.self.getControls().UP && !self.self.isOnGround()) {\n}\nif (/* ? */) {\n\tself.self.updateAttackStats({ air_ease: 3 });\n\tself.self.setYSpeed(3);\n\tself.self.setXSpeed(17, false);\n}\nself.self.attachEffect(\"global_spark\", { y: -10 });\nself.self.attachEffect(\"global_dust_light\");\nself.self.attachEffect(\"global_dust_blast\", { x: self.self.flipX(25), y: -10, parentLock: true });\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "63afc152-043e-51b1-a2e9-7d1897b43ce1",
      "code": "self.xframeLink = \"punch1\";\nself.self.updateAttackBoxStats(1, { direction: 125 });\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "1e0f5aa3-ae05-5954-b18c-e44c6ccd2b8e",
      "code": "self.self.updateAttackStats({ rotate: false });\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
