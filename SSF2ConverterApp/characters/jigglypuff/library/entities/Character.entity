    {
      "$id": "679caa6f-ae80-57ef-b955-93497b47b437",
      "code": "self.self = /* ? */;\nif ((parent && SSF2API.isReady()) || self.self) {\n\tself.ready = false;\n\tself.self.setGlobalVariable(\"canStartRise\", true);\n\tif (self.self.getMetalStatus()) {\n\t\tself.self.playSound(\"metal_land_m\");\n\t\treturn;\n\t}\n\tself.self.playSound(\"jiggs_landHeavy\");\n}\n}\n\n\nfunction tech_ground__frame0() {\nself.self = /* ? */;\nif ((SSF2API.isReady() && self.self) || self.self.getMetalStatus()) {\n}",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "233151ec-4e5a-5bb6-a971-ab897c4de033",
      "code": "",
