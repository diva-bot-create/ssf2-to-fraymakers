    },
    {
      "$id": "0dda8e13-f6e5-5f42-8ba7-9a9c479b3371",
      "code": "self.self.playSound(\"jiggs_dsmash_spin\");\nreturn;\n}\n\n\nfunction a_down__frame14() {\nself.self.updateAttackStats({ allowFullInterrupt: true });\nif (self.self.getMetalStatus()) {\n\tself.self.playSound(\"metal_step_s1\");\n}\nreturn;",
