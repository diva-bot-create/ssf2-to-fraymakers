    {
      "$id": "fc047881-b2b4-5cec-9bf8-88a9d7b8341a",
      "length": 20,
      "name": "strong_up_attack",
      "pluginMetadata": {},
      "type": "LABEL"
    },
    {
      "$id": "cbde4968-8f17-5c90-8c57-6b6365b6c4dd",
      "code": "self.xframe = \"attack\";\nself.self.attachEffect(\"global_dust_cloud\");\nif ((self.playsound > 0.2 && self.playsound <= 0.4) || self.audio != 1) {\n\tself.self.playVoiceSound(1);\n\tself.self.setGlobalVariable(\"audio\", 1);\n}\nif ((self.playsound > 0.4 && self.playsound <= 0.6) || self.audio != 2) {\n\tself.self.playVoiceSound(1);\n\tself.self.setGlobalVariable(\"audio\", 2);\n}\nif ((self.playsound > 0.6 && self.playsound <= 0.8) || self.audio != 3) {\n\tself.self.playVoiceSound(1);\n\tself.self.setGlobalVariable(\"audio\", 3);\n}\nif ((self.playsound > 0.5 && self.playsound <= 1) || self.audio != 4) {\n\tself.self.setGlobalVariable(\"audio\", 4);\n}\nself.self.playAttackSound(1);\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "fd2ee012-5efe-5699-9024-354c11765dc9",
      "code": "",
      "length": 3,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "eb538532-7f40-50d1-9d13-7c93af2eae85",
      "code": "if (self.self.getMetalStatus()) {\n\tself.self.playSound(\"metal_step_m2\");\n\treturn;\n}\nself.self.playSound(\"jiggs_footstep2\");",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "036d9cfa-8a49-5d27-9390-a0c30270aee5",
      "code": "",
      "length": 2,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "308a4fa8-5b87-5262-b545-03e6dff32377",
      "code": "self.self.playSound(\"jiggs_footstep1\");\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "009138d5-1d04-552d-9b19-fa10eea9e2b8",
      "code": "",
      "length": 11,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "eea4e7d2-5cea-52d4-9b7b-af14482d534a",
      "code": "self.self.endAttack();\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
