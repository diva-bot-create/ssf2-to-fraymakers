    },
    {
      "$id": "f3173c1e-11fc-5a2c-91c7-1acb58630a28",
      "code": "self.self = /* ? */;\nif ((parent && SSF2API.isReady()) || self.self) {\n\tself.playsound = SSF2API.random();\n\tself.audio = self.self.getGlobalVariable(\"audio\");\n\tself.self.setLandingLag(false);\n}\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "7428f4c2-74b8-5a67-a5fe-9ad1b878826e",
      "code": "",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "c42be101-f04d-57e0-b234-08baab82b9e4",
      "code": "self.self.setLandingLag(true);\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "6e007f5e-9e73-59b7-a7ba-f107ec99efac",
      "code": "self.self.attachEffect(\"global_dust_blast\", { x: self.self.flipX(33), y: -6, parentLock: true });\nself.self.playAttackSound(1);\nif ((self.playsound > 0.2 && self.playsound <= 0.4) || self.audio != 1) {\n\tself.self.playVoiceSound(1);\n\tself.self.setGlobalVariable(\"audio\", 1);\n}\nif ((self.playsound > 0.4 && self.playsound <= 0.6) || self.audio != 2) {\n\tself.self.playVoiceSound(2);\n\tself.self.setGlobalVariable(\"audio\", 2);\n}\nif ((self.playsound > 0.6 && self.playsound <= 0.8) || self.audio != 3) {\n\tself.self.playVoiceSound(3);\n\tself.self.setGlobalVariable(\"audio\", 3);\n}\nif ((self.playsound > 0.8 && self.playsound <= 1) || self.audio != 4) {\n\tself.self.playVoiceSound(4);\n\tself.self.setGlobalVariable(\"audio\", 4);\n}\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "a2fe3c47-32ab-51cf-a7bc-57fae3dced93",
      "code": "self.self.updateAttackBoxStats(1, { damage: 4, kbConstant: 80, effectSound: \"brawl_kick_s\" });\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "7c1589fc-88e0-5994-94b2-56c0a72e5254",
      "code": "",
      "length": 10,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "482335bf-b829-5fed-b3db-ecad0e1aa2fe",
      "code": "self.self.updateAttackBoxStats(1, { damage: 8 });\nself.self.updateAttackBoxStats(2, { damage: 7 });\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "b119bc78-088f-525b-a561-c99b006c5488",
      "code": "",
      "length": 3,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
