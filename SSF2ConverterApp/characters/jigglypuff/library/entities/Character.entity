      "code": "self.getTarget = null;\nself.lvl = 0;\nif ((parent && SSF2API.isReady()) || self.self) {\n}\nif (/* ? */) {\n} else {\n\tself.self.endAttack();\n\treturn;\n}\nif ((self.self.getCPUForcedAction() == -1 ? self.self.getCPUForcedAction() == -1 : self.self.getCPUForcedAction() == 5)) {\n}\nself.getTarget = self.self.getCPUTarget();\nself.lvl = self.self.getCPULevel();\nif ((self.lvl == 9 && SSF2API.random() < 0.1) || self.getTarget) {\n}\nif ((/* ? */ && self.getTarget.getX() < parent.x + 30) || self.getTarget.getX() > parent.x - 30) {\n}\nif (/* ? */ && self.getTarget.getY() + 30 > parent.y) {\n}",
