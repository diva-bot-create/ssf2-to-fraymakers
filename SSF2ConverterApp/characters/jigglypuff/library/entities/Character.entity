    {
      "$id": "23d49552-a3bb-5b2d-b8f2-9e2c1cbc9870",
      "code": "self.self = /* ? */;\nself.done = false;\nif ((SSF2API.isReady() && self.self) || self.self.getGlobalVariable(\"screwAttackOn\")) {\n}",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "4424ed88-17b4-54d9-b0e3-5845eec4e6cb",
      "code": "",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "cf5c543f-5446-5f38-a4bb-58816db6d726",
      "code": "self.self.playSound(\"jiggs_jump\");\nreturn;",
      "length": 1,
      "pluginMetadata": {},
