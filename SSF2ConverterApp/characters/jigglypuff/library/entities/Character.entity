    },
    {
      "$id": "410d2050-dd52-565e-84b2-b8f78d3482a6",
      "code": "self.self.setXSpeed(10, false);\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "2141323d-3853-5eb1-8e12-2a433169f7a7",
      "code": "",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "ba8a205e-cbae-5e9c-b57e-e1dc84e8380b",
      "code": "self.self.attachEffect(\"global_dust_light\");\nself.self.playSound(\"jiggs_attack_l\");\nif ((self.playsound > 0.2 && self.playsound <= 0.4) || self.audio != 1) {\n\tself.self.playVoiceSound(1);\n\tself.self.setGlobalVariable(\"audio\", 1);\n}\nif ((self.playsound > 0.4 && self.playsound <= 0.6) || self.audio != 2) {\n\tself.self.playVoiceSound(2);\n\tself.self.setGlobalVariable(\"audio\", 2);\n}\nif ((self.playsound > 0.6 && self.playsound <= 0.8) || self.audio != 3) {\n\tself.self.playVoiceSound(3);\n\tself.self.setGlobalVariable(\"audio\", 3);\n}\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "08a6bdad-fd4c-5fcb-a9f4-ca970a9072c2",
      "code": "self.self.setIntangibility(false);\nreturn;",
