    {
      "$id": "e60d0f22-2ae1-5001-897e-c8b7b37d8f8c",
      "length": 39,
      "name": "throw_down",
      "pluginMetadata": {},
      "type": "LABEL"
    },
    {
      "$id": "ee6b6cbd-3c1c-5a60-9112-0adc2a45a143",
      "code": "self.self = /* ? */;\nif (SSF2API.isReady() && self.self) {\n}",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "3459dd32-2100-51be-b607-2c7e6be0e485",
      "code": "",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "459e3094-08be-5f1f-820b-69b871bcc5a7",
      "code": "self.self.forceGrabbedHurtFrame(\"downed\");\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "f16e0a76-8eca-5ea4-8270-434e4c1f1df4",
      "code": "",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "e1b5c067-945e-573e-9421-379b988e6bfc",
      "code": "if ((parent && SSF2API.isReady()) || self.self) {\n\tself.playsound = SSF2API.random();\n\tself.audio = self.self.getGlobalVariable(\"audio\");\n}\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "3939dcae-8bb5-56e7-9a93-7562bcfb29c3",
      "code": "self.self.refreshAttackID();\nif ((self.playsound > 0.2 && self.playsound <= 0.4) || self.audio != 1) {\n\tself.self.playVoiceSound(1);\n\tself.self.setGlobalVariable(\"audio\", 1);\n}\nif ((self.playsound > 0.4 && self.playsound <= 0.6) || self.audio != 2) {\n\tself.self.playVoiceSound(2);\n\tself.self.setGlobalVariable(\"audio\", 2);\n}\nif ((self.playsound > 0.6 && self.playsound <= 0.8) || self.audio != 3) {\n\tself.self.playVoiceSound(3);\n\tself.self.setGlobalVariable(\"audio\", 3);\n}\nif ((self.playsound > 0.8 && self.playsound <= 1) || self.audio != 4) {\n\tself.self.playVoiceSound(4);\n\tself.self.setGlobalVariable(\"audio\", 4);\n}\nif (self.self.getMetalStatus()) {\n\tself.self.playSound(\"metal_land_m\");\n}\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "dea31248-23c5-5d1e-9f51-0cb4e081c76f",
      "code": "",
      "length": 2,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "69c79f0a-667d-58b4-93d7-9499e175bc84",
      "code": "self.self.playSound(\"jiggs_dthrow\");\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "a02596e5-9379-51de-93db-fe0943c70553",
      "code": "",
      "length": 2,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "e0ea7520-0f94-5012-a09b-88712fb3c551",
      "code": "self.self.refreshAttackID();\nself.self.updateAttackBoxStats(1, { damage: 3 });\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "dfc8c5dd-e046-5909-a630-cd0122ea9830",
      "code": "",
      "length": 2,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "ca75906f-8237-50bd-af7a-f0c35ad7520f",
      "code": "self.self.playSound(\"jiggs_dthrow\");\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "d9e79f71-ba9f-541a-9b58-c14c8ddd6b06",
      "code": "",
      "length": 5,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "d1dbba25-8511-5c95-922b-620e858d8ec8",
      "code": "self.self.playSound(\"jiggs_dthrow\");\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "1e69e619-3176-5db9-8cc0-e6c2900325e5",
      "code": "",
      "length": 2,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "fbb557bc-f470-5072-a741-1965c688591d",
      "code": "SSF2API.getCamera().shake(10);\nself.self.refreshAttackID();\nself.self.updateAttackBoxStats(1, { damage: 1, hasEffect: true });\nreturn;",
      "length": 1,
      "pluginMetadata": {},
