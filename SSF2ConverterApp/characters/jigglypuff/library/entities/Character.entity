    },
    {
      "$id": "e54b6ddc-6e37-5de8-ae33-e20a8e4bdefa",
      "code": "if ((parent && SSF2API.isReady()) || self.self) {\n}\nif (/* ? */) {\n} else {\n\tself.self.endAttack();\n\treturn;\n}\nself.getTarget = self.self.getCPUTarget();\nself.lvl = self.self.getCPULevel();\nif ((self.lvl == 9 && self.getTarget) || !self.getTarget.isDisposed()) {\n\tif (self.getTarget.getCurrentAttackFrame() == \"hurt\") {\n\t\tself.getTarget.getCurrentAttackFrame() == \"hurt\";\n\t}\n}\nif ((/* ? */ && SSF2API.random() < 0.5) || self.getTarget.getX() < parent.x + 30) {\n}\nif ((/* ? */ && self.getTarget.getY() < parent.y + 30) || self.getTarget.getY() + 30 > parent.y) {\n\tself.self.importCPUControls([2048, 1, 0, 2, 1088, 1]);\n\tSSF2API.print(\"from dair land\");\n}",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
