    {
      "$id": "e2213327-b995-5f85-b1bf-12226ad71dc7",
      "length": 17,
      "name": "aerial_up",
      "pluginMetadata": {},
      "type": "LABEL"
    },
    {
      "$id": "d72d76d8-d7e4-59f0-9de4-052c12fc8d7a",
      "code": "self.self = /* ? */;\nself.getTarget = null;\nself.lvl = 0;\nif ((parent && SSF2API.isReady()) || self.self) {\n\tself.playsound = SSF2API.random();\n\tself.audio = self.self.getGlobalVariable(\"audio\");\n\tself.self.setLandingLag(false);\n}\nif ((parent && SSF2API.isReady()) || self.self) {\n}\nif (/* ? */) {\n} else {\n\treturn;\n}\nif ((self.self.getCPUForcedAction() == -1 ? self.self.getCPUForcedAction() == -1 : self.self.getCPUForcedAction() == 5)) {\n}\nself.getTarget = self.self.getCPUTarget();\nself.lvl = self.self.getCPULevel();\nif ((self.lvl == 9 && SSF2API.random() < 0.4) || self.getTarget) {\n}\nif ((/* ? */ && self.getTarget.getMC().currentLabel != \"defend\") || self.getTarget.getMC().currentLabel != \"airdodge\") {\n}\nif ((/* ? */ && !self.self.inUpperRightWarningBounds()) || !self.self.inLowerRightWarningBounds()) {\n}\nif ((/* ? */ && !self.self.inLowerLeftWarningBounds()) || self.getTarget.getX() < parent.x + 15) {\n}\nif ((/* ? */ && self.getTarget.getY() < parent.y + 25) || self.getTarget.getY() + 15 > parent.y + 25) {\n\tself.self.importCPUControls([1088, 2]);\n\tSSF2API.print(\"from uair\");\n\tself.self.endAttack();\n}",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "ab4d882c-6843-5844-9cb1-3b04618f0114",
      "code": "",
      "length": 2,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "ab3c4674-150e-59bf-89e8-0603bd507bfa",
      "code": "self.self.setLandingLag(true);\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "b397b695-f86a-54b4-bd78-991d92d1d0ae",
      "code": "self.self.playAttackSound(1);\nif ((self.playsound > 0.2 && self.playsound <= 0.4) || self.audio != 1) {\n\tself.self.playVoiceSound(1);\n\tself.self.setGlobalVariable(\"audio\", 1);\n}\nif ((self.playsound > 0.4 && self.playsound <= 0.6) || self.audio != 2) {\n\tself.self.playVoiceSound(2);\n\tself.self.setGlobalVariable(\"audio\", 2);\n}\nif ((self.playsound > 0.6 && self.playsound <= 0.8) || self.audio != 3) {\n\tself.self.playVoiceSound(3);\n\tself.self.setGlobalVariable(\"audio\", 3);\n}\nif ((self.playsound > 0.8 && self.playsound <= 1) || self.audio != 4) {\n\tself.self.playVoiceSound(4);\n\tself.self.setGlobalVariable(\"audio\", 4);\n}\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "ac29b795-a97f-505e-b206-524d1e0c33d8",
      "code": "self.self.setLandingLag(false);\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
