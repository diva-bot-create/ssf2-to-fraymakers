      "code": "self.xframeLink = \"endlag\";\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "2857e737-6605-5770-82b6-2fa57cdba72b",
      "code": "self.self.setRotation(self.self.getRotation() / 2);\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
