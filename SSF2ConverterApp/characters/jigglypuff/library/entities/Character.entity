    },
    {
      "$id": "661c172d-1fe0-5897-9192-69da344c33b5",
      "code": "",
      "length": 7,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "4604001c-daae-5442-8b07-f06713866e76",
      "code": "self.self.setIntangibility(false);\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "4e9012e5-ea83-5347-9f82-2a459c4d3132",
      "code": "",
      "length": 3,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "3a2ec942-80f1-5192-8047-aae0c103eebe",
      "code": "if (self.self.getMetalStatus()) {\n\tself.self.playSound(\"metal_land_m\");\n\treturn;\n}\nself.self.playSound(\"jiggs_landLight\");",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
