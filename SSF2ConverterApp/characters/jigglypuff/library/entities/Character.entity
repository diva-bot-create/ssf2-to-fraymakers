      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "52356a37-a222-5a80-b3d3-6eb6d3cc626b",
      "code": "self.self.setLandingLag(false);\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
