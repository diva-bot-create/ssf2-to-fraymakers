    {
      "$id": "ce52dff7-11fc-52aa-a5d7-aa6e628110cd",
      "length": 16,
      "name": "tilt_down",
      "pluginMetadata": {},
      "type": "LABEL"
    },
    {
      "$id": "0a2ab853-3269-5fd9-a1a5-812a8a79e869",
      "code": "self.self = /* ? */;\nself.xframe = null;\nreturn;\n}\n\n\nfunction a_down__frame0() {\nself.self = /* ? */;\nif ((parent && SSF2API.isReady()) || self.self) {\n\tself.playsound = SSF2API.random();\n\tself.audio = self.self.getGlobalVariable(\"audio\");\n}\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "82cd3296-5e94-5460-825a-fc922dcadb1d",
      "code": "self.xframe = \"charging\";\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "a93653bc-c1a8-59ff-91fa-76b509262b6e",
      "code": "self.self.playSound(\"brawl_swing_m\");\nself.self.attachEffect(\"global_dust_light\");\nself.self.attachEffect(\"global_dust_swirl\");\nif ((self.playsound > 0.2 && self.playsound <= 0.4) || self.audio != 1) {\n\tself.self.playVoiceSound(1);\n\tself.self.setGlobalVariable(\"audio\", 1);\n}\nif ((self.playsound > 0.4 && self.playsound <= 0.6) || self.audio != 2) {\n\tself.self.playVoiceSound(2);\n\tself.self.setGlobalVariable(\"audio\", 2);\n}\nif ((self.playsound > 0.6 && self.playsound <= 0.8) || self.audio != 3) {\n\tself.self.playVoiceSound(3);\n\tself.self.setGlobalVariable(\"audio\", 3);\n}\nif ((self.playsound > 0.8 && self.playsound <= 1) || self.audio != 4) {\n\tself.self.playVoiceSound(4);\n\tself.self.setGlobalVariable(\"audio\", 4);\n}\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "bf64f3f9-c586-55fb-9a11-d4f04a18f435",
      "code": "",
      "length": 12,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
