    },
    {
      "$id": "71c408b3-a3cc-5506-b435-20eccd4a7dc0",
      "code": "self.self.playSound(\"mario_spin\");\nself.self.attachEffect(\"global_dust_spiral\", { x: self.self.flipX(6), y: -15, scaleX: 1.2, scaleY: 1.2, rotation: self.self.flipX(-30), parentLock: true });\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "7969aa88-2aed-5980-b21a-8a8ff75a3163",
      "code": "self.self.refreshAttackID();\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
