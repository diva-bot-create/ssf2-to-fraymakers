    {
      "$id": "e88f2b57-b3dc-54a3-9de7-d8cc9bbdd6e8",
      "code": "self.self.refreshAttackID();\nif (self.self.isOnGround()) {\n} else {\n\tself.self.setYSpeed(-4);\n}\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "a1f3f93a-6515-5f8e-bd17-fad2466bdbab",
      "code": "self.self.playVoiceSound(1);\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "a50cdc14-ace9-5d42-8ba6-38e5ca9c87fe",
      "code": "self.self.updateAttackBoxStats(1, { damage: 5, direction: 65, power: 75, kbConstant: 100, weightKB: 0 });\nself.self.refreshAttackID();\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
