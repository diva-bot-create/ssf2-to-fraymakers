    },
    {
      "$id": "f7c912b0-a7b9-5f4b-9582-690d8bdfadef",
      "code": "self.self.fireProjectile(\"mario_fireball\", 22, -20);\nself.self.attachEffect(\"nSpecWave\", { x: self.self.flipX(10), y: -25, rotation: self.self.flipX(20) });\nself.self.playSound(\"mario_fireballspawn\");\nself.self.playSound(\"mario_fireballsfx\");\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
