    {
      "$id": "1a9e3ea0-a716-511f-a05d-15c793ec15f1",
      "code": "self.self = /* ? */;\nif ((parent && SSF2API.isReady()) || self.self) {\n\tself.self.playSound(\"mario_lift\");\n}\nif ((parent && SSF2API.isReady()) || self.self) {\n\tself.self.setIntangibility(true);\n}\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "f9725d09-2b8d-554a-8231-b272e5c6ac35",
      "code": "",
      "length": 2,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "8c450cc7-289f-5fda-829d-75d926d17f88",
      "code": "self.self.playSound(\"mario_runstart\");\nreturn;",
