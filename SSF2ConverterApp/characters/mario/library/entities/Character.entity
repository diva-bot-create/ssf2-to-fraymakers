    },
    {
      "$id": "ffbd327c-c5e8-51f3-a049-1eb87a0b8265",
      "length": 3,
      "name": "loop",
      "pluginMetadata": {},
      "type": "LABEL"
    },
    {
      "$id": "deab06fe-3e81-56aa-acd0-acf02f6294bb",
      "code": "if ((parent && SSF2API.isReady()) || self.self) {\n\tself.self.attachEffectOverlay(\"upSpecSparkle\");\n}\nself.self = /* ? */;\nself.angle = Math.atan(26 / 18) * 180 / Math.PI;\nself.speed = 25;\nself.angleAlt = 5.5;\nif ((parent && SSF2API.isReady()) || self.self) {\n\tself.controls = self.self.getControls();\n\tself.facingRight = self.self.isFacingRight();\n\tself.controls = self.self.getControls();\n\tif ((self.facingRight && self.controls.LEFT) || !self.facingRight) {\n\t\tself.angle = self.angle + self.angleAlt;\n\t}\n\tif ((self.facingRight && self.controls.RIGHT) || !self.facingRight) {\n\t\tself.angle = self.angle - self.angleAlt;\n\t}\n}\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "32ba2095-9007-53b8-ae47-15822ffa6bb0",
      "code": "self.self.setIntangibility(true);\nself.controls = self.self.getControls();\nif ((self.facingRight && self.controls.LEFT) || !self.facingRight) {\n\tself.angle = self.angle + self.angleAlt;\n}\nif ((self.facingRight && self.controls.RIGHT) || !self.facingRight) {\n\tself.angle = self.angle - self.angleAlt;\n}\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "8e38acf8-ab0b-591e-989a-432923e65087",
      "code": "self.controls = self.self.getControls();\nif ((self.facingRight && self.controls.LEFT) || !self.facingRight) {\n\tself.angle = self.angle + self.angleAlt;\n}\nif ((self.facingRight && self.controls.RIGHT) || !self.facingRight) {\n\tself.angle = self.angle - self.angleAlt;\n}\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "0ab6dd72-531a-5707-a1fe-debdfe4d3a61",
      "code": "self.self.setIntangibility(false);\nself.self.updateAttackBoxStats(1, { damage: 1 });\nself.self.refreshAttackID();\nself.self.playSound(\"mario_uspec\");\nself.controls = self.self.getControls();\nif ((self.facingRight && self.controls.LEFT) || !self.facingRight) {\n\tself.angle = self.angle + self.angleAlt;\n}\nif ((self.facingRight && self.controls.RIGHT) || !self.facingRight) {\n\tself.angle = self.angle - self.angleAlt;\n}\nself.angle = 45;\nself.self.updateAttackBoxStats(1, { direction: self.angle });\nself.self.addEventListener(SSF2Event.GROUND_TOUCH, self.self.toHeavyLand);\nself.self.addEventListener(SSF2Event.CHAR_ATTACK_COMPLETE, self.self.toHelpless);\nself.self.createTimer(1, -1, self.moveIt);\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "1a2a4132-475f-5574-8334-13a1d054f59f",
      "code": "self.self.refreshAttackID();\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "0716beb6-9dae-5cd3-bec8-4e253f54674b",
