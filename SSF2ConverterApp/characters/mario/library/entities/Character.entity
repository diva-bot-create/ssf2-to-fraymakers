    },
    {
      "$id": "15836ce1-d0cf-5d0f-9780-4d6a8f27f8af",
      "code": "if (parent && SSF2API.isReady()) {\n}",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "c286324c-103d-5d30-8a4f-c5569e2cfa6c",
      "code": "",
      "length": 5,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "3467af27-6612-5647-814e-4e11cc9b58c9",
      "code": "self.self.fireProjectile(\"mario_fireball\", 22, -20);\nself.self.attachEffect(\"nSpecWave\", { x: self.self.flipX(25), y: -25 });\nself.self.attachEffect(\"global_dust_light\");\nself.self.playSound(\"mario_fireballspawn\");\nself.self.playSound(\"mario_fireballsfx\");\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "f903c5c8-2122-5924-87ea-709e9abeb37b",
      "code": "",
      "length": 15,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "488f8c8c-a52d-5582-9f3c-9b1f40c6506e",
      "code": "self.self.endAttack();\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "e2452654-e1af-5bf4-8d32-050272fc57fd",
      "length": 23,
