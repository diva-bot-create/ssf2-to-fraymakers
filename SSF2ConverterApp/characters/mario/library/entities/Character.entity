    {
      "$id": "f0adb13f-7a09-59c1-a9ef-2954b664b30d",
      "length": 25,
      "name": "ledge_attack",
      "pluginMetadata": {},
      "type": "LABEL"
    },
    {
      "$id": "bb4f4e0e-9943-5ba5-b085-9c6d7ed5acca",
      "code": "self.self = /* ? */;\nif ((parent && SSF2API.isReady()) || self.self) {\n\tself.playsound = SSF2API.random();\n\tself.audio = self.self.getGlobalVariable(\"audio\");\n\tself.self.setIntangibility(true);\n}\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "526797dd-6699-5b06-8682-5d5edbd513d8",
      "code": "",
      "length": 2,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "add174df-9eb7-5250-9808-62ad6feb2945",
      "code": "self.self.playSound(\"mario_runstart\");\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "330a77e0-67fd-5cc4-99a8-4b03e3bbdba0",
      "code": "",
      "length": 5,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "843291c5-c360-5f4e-9ebb-c52fcbdc1401",
      "code": "self.self.playSound(\"brawl_swing_l\");\nself.self.setXSpeed(8, false);\nself.self.setYSpeed(-4);\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "0d9bf1a3-8829-5a02-974d-2249aca69097",
      "code": "",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "09ffdd67-89f4-5e1a-8599-fe56848524ab",
      "code": "self.self.attachEffect(\"global_dust_light\");\nif ((self.playsound > 0.2 && self.playsound <= 0.4) || self.audio != 1) {\n\tself.self.playVoiceSound(1);\n\tself.self.setGlobalVariable(\"audio\", 1);\n}\nif ((self.playsound > 0.4 && self.playsound <= 0.6) || self.audio != 2) {\n\tself.self.playVoiceSound(2);\n\tself.self.setGlobalVariable(\"audio\", 2);\n}\nif ((self.playsound > 0.6 && self.playsound <= 0.8) || self.audio != 3) {\n\tself.self.playVoiceSound(3);\n\tself.self.setGlobalVariable(\"audio\", 3);\n}\nif ((self.playsound > 0.8 && self.playsound <= 1) || self.audio != 4) {\n\tself.self.playVoiceSound(4);\n\tself.self.setGlobalVariable(\"audio\", 4);\n}\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "90836f53-5127-59ca-a24d-a1cac95086b1",
      "code": "self.self.setIntangibility(false);\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "ce772f72-3930-5f65-8f6a-69091e30b376",
      "code": "",
      "length": 3,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "59fabc0f-7b9d-58d6-a296-e7625bd71341",
      "code": "if (self.self.getMetalStatus()) {\n\tself.self.playSound(\"metal_land_m\");\n\treturn;\n}\nself.self.playSound(\"mario_landLight\");",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "36d30b93-4933-5f2e-8225-a16b915d7f9d",
      "code": "",
      "length": 7,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "afcf0a70-813a-5083-ba5e-45d88ba8aac2",
      "code": "self.self.endAttack();\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
