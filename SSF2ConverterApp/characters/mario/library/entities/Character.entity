      "$id": "e1571910-ca56-527d-b7b8-bce86ecbe148",
      "code": "self.self.updateAttackBoxStats(1, { weightKB: 40, damage: 2 });\nself.self.updateAttackStats({ refreshRate: 50 });\nself.self.refreshAttackID();\nself.self.setGlobalVariable(\"canStartRise\", true);\nself.self.removeAllEffects();\nSSF2API.getCamera().shake(3);\nif (self.self.getMetalStatus()) {\n\tself.self.playSound(\"metal_land_s\");\n\treturn;\n}\nself.self.playSound(\"mario_landLight\");",
      "length": 1,
