    {
      "$id": "75e5302d-8e1b-5fa4-bc45-b8b44d0c4ca5",
      "code": "self.self.setGlobalVariable(\"canStartRise\", true);\nself.self.removeAllEffects();\nSSF2API.getCamera().shake(4);\nif (self.self.getMetalStatus()) {\n\tself.self.playSound(\"metal_land_m\");\n\treturn;\n}\nself.self.playSound(\"mario_landHeavy\");",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
