    },
    {
      "$id": "32cff709-6c88-53cc-a8ea-5c9e5a5d7e6d",
      "length": 15,
      "name": "throw_forward",
      "pluginMetadata": {},
      "type": "LABEL"
    },
    {
      "$id": "5a2388da-5d70-5291-80a3-88d6df1495df",
      "code": "self.self = /* ? */;\nif ((parent && SSF2API.isReady()) || self.self) {\n\tself.playsound = SSF2API.random();\n\tself.audio = self.self.getGlobalVariable(\"audio\");\n}\nself.enemy = null;\nif ((parent && SSF2API.isReady()) || self.self) {\n\tself.enemy = self.self.getGrabbedOpponents()[0];\n\tself.self.swapDepths(self.enemy);\n}\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "8dddb83f-f716-5bb3-b664-182d960682fa",
      "code": "self.self.playSound(\"throw_woosh\");\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "c9bad4bd-6f61-52e2-9387-bd5f698102f9",
      "code": "",
      "length": 2,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "f6e49066-0ecb-5f08-bb4e-0ccf282801ca",
      "code": "self.self.playSound(\"throw_woosh\");\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "903849ca-60b3-57f1-add0-f72e5dc510b1",
      "code": "",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "efe2f08e-e68c-5987-b77e-3a5136d8ba72",
      "code": "self.enemy.flip();\nself.self.attachEffect(\"global_dust_swirl\");\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "15d2e275-adff-5e39-89bf-17a2ab47e1c3",
      "code": "if ((self.playsound > 0.2 && self.playsound <= 0.4) || self.audio != 1) {\n\tself.self.playVoiceSound(1);\n\tself.self.setGlobalVariable(\"audio\", 1);\n}\nif ((self.playsound > 0.4 && self.playsound <= 0.6) || self.audio != 2) {\n\tself.self.playVoiceSound(2);\n\tself.self.setGlobalVariable(\"audio\", 2);\n}\nif ((self.playsound > 0.6 && self.playsound <= 0.8) || self.audio != 3) {\n\tself.self.playVoiceSound(3);\n\tself.self.setGlobalVariable(\"audio\", 3);\n}\nif ((self.playsound > 0.8 && self.playsound <= 1) || self.audio != 4) {\n\tself.self.playVoiceSound(4);\n\tself.self.setGlobalVariable(\"audio\", 4);\n}\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "cee403e2-91cf-55e8-8a72-b4de4c1dde09",
      "code": "",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "ba3f4329-3d93-58e5-a38d-613811dfce20",
      "code": "self.self.swapDepths(self.enemy);\nself.enemy.flip();\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "2e273eb3-1025-54ba-8eed-b4e654a23915",
      "code": "self.self.swapDepths(self.enemy);\nSSF2API.getCamera().shake(9);\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "57d2d41c-2190-59ba-a911-36152244f47a",
      "code": "",
      "length": 3,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "6f4ecf11-1ee4-5fdc-95a4-2e366f313352",
      "code": "self.self.endAttack();\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
