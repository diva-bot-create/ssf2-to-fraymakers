      "code": "self.self.updateAttackBoxStats(1, { power: 45, kbConstant: 90, direction: 60, damage: 3, weightKB: 0 });\nself.self.refreshAttackID();\nself.self.updateAttackStats({ air_ease: 0 });\nself.self.destroyTimer(self.moveIt);\nself.self.setYSpeed(0);\nself.self.setXSpeed(0);\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "22f1ca4d-2876-5dac-b4f3-3d827f943a7d",
