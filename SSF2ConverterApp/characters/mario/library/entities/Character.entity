    {
      "$id": "645a918a-b372-5223-b7c4-37e28aab7b25",
      "length": 33,
      "name": "throw_back",
      "pluginMetadata": {},
      "type": "LABEL"
    },
    {
      "$id": "3ab7aec4-62bc-5d29-bfae-5d255ef462db",
      "code": "self.self = /* ? */;\nif ((parent && self.self) || SSF2API.isReady()) {\n\tself.enemy = self.self.getGrabbedOpponents()[0];\n\tself.self.swapDepths(self.enemy);\n}\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "306619b6-ef7e-5333-a53e-1d5be9501c31",
      "code": "self.self.playSound(\"throw_woosh\");\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "5d969203-4b63-50ea-9281-5521bbe923e0",
      "code": "",
      "length": 4,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "ad23af77-4196-5a6d-9e83-b1896c42bdd7",
      "code": "self.self.playSound(\"throw_woosh\");\nself.enemy.flip();\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "787eca91-17f6-5aa5-8583-c5789321d200",
      "code": "",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "f57a8f63-d17f-5f06-a0fc-af263b643968",
