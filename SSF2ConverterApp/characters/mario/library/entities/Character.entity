      "code": "",
      "length": 6,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "89d21b9f-8a66-5f9d-a61c-c6dc7a0f4107",
      "code": "if (self.self.isCPU()) {\n\tif (self.self.getCPUAction() != 3) {\n\t} else {\n\t\tself.self.setAttackEnabled(false, \"b_down_air\");\n\t\tself.self.addEventListener(SSF2Event.GROUND_TOUCH, self.reenableForCPU, { persistent: true });\n\t}\n}\nif (self.self.isOnGround()) {\n\tself.self.setGlobalVariable(\"canStartRise\", true);\n}\nself.self.endAttack();\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
