    {
      "$id": "ece0ff5e-ca6e-5ea0-8523-1602ef43773f",
      "length": 22,
      "name": "throw_up",
      "pluginMetadata": {},
      "type": "LABEL"
    },
    {
      "$id": "b7f2539c-a820-5801-812a-d3f961e168ed",
      "code": "self.self = /* ? */;\nif ((parent && SSF2API.isReady()) || self.self) {\n\tself.playsound = SSF2API.random();\n\tself.audio = self.self.getGlobalVariable(\"audio\");\n\tself.enemy = self.self.getGrabbedOpponents()[0];\n\tself.self.swapDepths(self.enemy);\n}\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "aa748269-8148-5e5f-9d59-8d31b23668ff",
      "code": "self.self.playSound(\"throw_woosh\");\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "ccbb3a8d-63b7-5f0c-98b4-d474c794e5fa",
      "code": "",
      "length": 10,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "4e87325b-7c4d-5f04-921d-bc45e5c076b2",
      "code": "SSF2API.getCamera().shake(9);\nif ((self.playsound > 0.2 && self.playsound <= 0.4) || self.audio != 1) {\n\tself.self.playVoiceSound(1);\n\tself.self.setGlobalVariable(\"audio\", 1);\n}\nif ((self.playsound > 0.4 && self.playsound <= 0.6) || self.audio != 2) {\n\tself.self.playVoiceSound(2);\n\tself.self.setGlobalVariable(\"audio\", 2);\n}\nif ((self.playsound > 0.6 && self.playsound <= 0.8) || self.audio != 3) {\n\tself.self.playVoiceSound(3);\n\tself.self.setGlobalVariable(\"audio\", 3);\n}\nif ((self.playsound > 0.8 && self.playsound <= 1) || self.audio != 4) {\n\tself.self.playVoiceSound(4);\n\tself.self.setGlobalVariable(\"audio\", 4);\n}\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "5007ca1c-11f8-51c5-b938-a94639054a87",
      "code": "",
      "length": 8,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "b5dd2a93-5f7c-510b-859b-8ebc21130994",
      "code": "self.self.endAttack();\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
