    {
      "$id": "0051e6aa-8cf9-5aac-b611-6ff67ada1140",
      "length": 17,
      "name": "ledge_climb",
      "pluginMetadata": {},
      "type": "LABEL"
    },
    {
      "$id": "c68eab92-8419-59f9-8209-923f331d97b4",
      "code": "self.self = /* ? */;\nif ((parent && SSF2API.isReady()) || self.self) {\n\tself.self.setIntangibility(true);\n\tself.self.playSound(\"mario_lift\");\n}\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "7512ca3b-a19c-55b5-beb6-f0943a0f943e",
      "code": "",
      "length": 2,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "63615327-32c5-5776-ba2f-fa14e8b9b796",
      "code": "self.self.playSound(\"mario_runstart\");\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "b45cea1c-1264-590a-8917-a1c59d2c3129",
      "code": "",
      "length": 2,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "7a09f135-d367-50ce-9adb-e5acf9ce3710",
      "code": "self.self.setXSpeed(6, false);\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "e9753e0e-221b-5015-a817-f5c942cf641a",
      "code": "",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "c37bfe10-a9fe-590d-859a-e28e6c4bab2e",
      "code": "if (self.self.getMetalStatus()) {\n\tself.self.playSound(\"metal_land_m\");\n\treturn;\n}\nself.self.playSound(\"mario_landLight\");",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "6386213c-8575-546c-92da-ac4bc57e311c",
      "code": "",
      "length": 6,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "fbf4a04f-44c5-5ac8-b12b-efe7d3e148e8",
      "code": "self.self.setIntangibility(false);\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
