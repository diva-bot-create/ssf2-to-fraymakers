    {
      "$id": "68fdca8d-1a68-5ced-925c-b39d317520ff",
      "length": 21,
      "name": "strong_up_attack",
      "pluginMetadata": {},
      "type": "LABEL"
    },
    {
      "$id": "9baa71bc-ec1b-5936-9290-9251830d4c7b",
      "code": "self.xframe = \"attack\";\nself.self.attachEffect(\"global_dust_cloud\");\nself.self.clearEffectsOnStateChange();\nself.self.playVoiceSound(1);\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "d650ffc2-af3f-59a4-8688-50eabb373bb0",
      "code": "self.self.playSound(\"brawl_swing_l\");\nself.self.playSound(\"mario_kickswing\");\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "761e5543-743a-58cf-9fcd-78db4d56707b",
      "code": "",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "6f9b2d46-8ca5-513f-af37-16a506b72104",
      "code": "SSF2API.getCamera().shake(2);\nif (self.self.getMetalStatus()) {\n\tself.self.playSound(\"metal_land_s\");\n\treturn;\n}\nself.self.playSound(\"mario_lightLand\");",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "136f7d95-204e-5aae-b99c-f5fec7afd770",
      "code": "",
      "length": 16,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
