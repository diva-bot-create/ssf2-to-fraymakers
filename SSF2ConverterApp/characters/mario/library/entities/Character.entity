      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "b5d770f8-9df6-509a-a4ef-89a5f731dbfc",
      "code": "if (self.self.getMetalStatus()) {\n\tself.self.playSound(\"metal_step_m1\");\n\treturn;\n}\nself.self.playSound(\"mario_footstep\");",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "0f9fe180-f132-5624-bc92-1244254b6557",
      "code": "",
      "length": 3,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "50f49d77-96fd-5c23-9cf2-aac503a03c97",
      "code": "if (self.self.getMetalStatus()) {\n\tself.self.playSound(\"metal_step_m2\");\n\treturn;\n}\nself.self.playSound(\"mario_footstep2\");",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "8bcbc36f-1125-5420-aa22-f8676133401a",
      "code": "self.self.endAttack();\nreturn;",
