    },
    {
      "$id": "0fc98127-84f8-5678-bfa8-a93e310a0f4a",
      "code": "if (self.self.getMetalStatus()) {\n} else {\n\tself.self.playSound(\"letsago\", true);\n}\nself.self.playSound(\"mario_jumpsfx\");\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
