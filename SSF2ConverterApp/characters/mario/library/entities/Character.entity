    },
    {
      "$id": "3c8bea19-8926-5f1a-b711-21f91470c6b0",
      "code": "self.self.updateAttackBoxStats(1, { direction: 55, damage: 8, power: 13, effect_id: \"effect_hit2\", effectSound: \"brawl_kick_s\" });\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "f1523035-348a-51d9-b511-6634398103db",
      "code": "",
