      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "ea56cfef-d97d-55e2-92db-b4799683ea63",
      "code": "self.self.attachEffect(\"global_dust_heavy\");\nself.self.attachEffect(\"effect_explosion\", { x: self.self.flipX(48), y: -25 });\nSSF2API.getCamera().shake(6);\nself.self.playSound(\"mario_Fsmash_sfx\");\nself.self.playVoiceSound(1);\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "456aed36-8d38-5f5c-b470-5cc542c633ae",
      "code": "",
