      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "7b2adaf7-0b1b-558f-a334-0a22d0a7c5a5",
      "code": "self.self.refreshAttackID();\nself.self.destroyTimer(self.rise);\nif (self.self.isOnGround()) {\n} else {\n\tself.self.setGlobalVariable(\"canStartRise\", false);\n}\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "71c1c962-767b-573a-841f-2aef97f7e0ff",
