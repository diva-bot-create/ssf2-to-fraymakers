    {
      "$id": "b5909cf1-40f2-58f8-8466-b595a2c4e05d",
      "code": "self.self = /* ? */;\nif (self.self && SSF2API.isReady()) {\n}",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "05b4904d-646f-542b-9f89-a6a9816b0791",
      "code": "self.self.clearEffectsOnStateChange();\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "20918041-22b6-5d61-a85c-46669e630ec3",
      "code": "self.self.setLandingLag(true);\nself.self.playSound(\"brawl_swing_s\");\nself.self.attachEffect(\"global_dust_blast\", { x: self.self.flipX(25), y: -15, parentLock: true });\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "c4e61173-299f-5e7a-a33b-d5fcf3e2e3f9",
      "code": "",
