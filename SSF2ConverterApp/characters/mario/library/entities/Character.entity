    {
      "$id": "444a4473-32e5-5272-b174-7a0e6a9ff59a",
      "code": "self.self = /* ? */;\nif ((parent && SSF2API.isReady()) || self.self) {\n\tself.self.setXSpeed(14, false);\n}\nreturn;",
      "length": 1,
      "pluginMetadata": {},
