    },
    {
      "$id": "92f7be67-90b4-5860-a29e-cee0672aba16",
      "code": "if (self.self.getMetalStatus()) {\n\tself.self.playSound(\"metal_land_m\");\n\treturn;\n}\nself.self.playSound(\"mario_landHeavy\");",
