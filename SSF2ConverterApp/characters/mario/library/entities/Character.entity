    {
      "$id": "19a774e0-aae2-5e0a-8cd2-4e87828e45c4",
      "code": "self.self = /* ? */;\nif (SSF2API.isReady()) {\n\tself.self.setGlobalVariable(\"canStartRise\", true);\n\tself.self.setGlobalVariable(\"jab\", false);\n\tself.self.setGlobalVariable(\"jab2\", false);\n}\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "1d303fe2-1df6-5f0e-8d2a-6b4af5639e5d",
      "code": "",
      "length": 2,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "af496d49-3c79-5623-b263-accd1a1b93dd",
      "code": "if (self.self.getMetalStatus()) {\n\tself.self.playSound(\"metal_step_m1\");\n\treturn;\n}\nself.self.playSound(\"mario_footstep\");",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "63d1af3e-29af-5699-8be3-d2da5365e756",
      "code": "",
      "length": 6,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "fae29e7b-eb8a-5425-84f3-d8401d3772ea",
      "code": "if (self.self.getMetalStatus()) {\n\tself.self.playSound(\"metal_step_m2\");\n\treturn;\n}\nself.self.playSound(\"mario_footstep2\");",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "7ac31218-55d2-570e-861f-1b9e2813347d",
      "code": "",
