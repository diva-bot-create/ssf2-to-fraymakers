    {
      "$id": "229e069b-44cf-5cec-8696-5c0e232fc10a",
      "length": 33,
      "name": "special_down",
      "pluginMetadata": {},
      "type": "LABEL"
    },
    {
      "$id": "152f532e-2e7e-5de5-9f10-341a8c51edf2",
      "code": "self.self = /* ? */;\nself.riseAmt = -6;\nself.riseAmtMax = -12;\nself.riseAmtIncr = -2;\nself.pressed1 = false;\nself.pressed2 = false;\nif ((SSF2API.isReady() && self.self) || !self.self.isOnGround()) {\n}",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "09d655d8-efb7-5682-8b36-09a5e86a96de",
      "code": "",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "fa790a1d-c8c8-5eb9-8850-933cfc16a49c",
      "code": "self.self.playSound(\"mario_dspec\");\nself.self.refreshAttackID();\nself.self.updateAttackStats({ air_ease: -1 });\nself.self.attachEffect(\"global_dust_spin\", { y: -28, scaleX: 0.55, parentLock: true });\nself.self.createTimer(1, 0, self.rise);\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "030549d6-5c5c-5e45-83cb-22eb64c68930",
      "code": "",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
