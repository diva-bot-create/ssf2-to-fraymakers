    {
      "$id": "4da4b006-cb09-5e23-8c81-381fa29a7f1d",
      "length": 19,
      "name": "special_side",
      "pluginMetadata": {},
      "type": "LABEL"
    },
    {
      "$id": "79294d67-d60a-5ca2-b9d1-362b75efa70e",
      "code": "self.self = /* ? */;\nself.gliding = false;\nif (SSF2API.isReady()) {\n\tself.self.addEventListener(SSF2Event.GROUND_LEAVE, self.glideAway);\n}\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "3308ebe0-2e2f-5371-96a2-1f1ba2bcf4be",
      "code": "",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "f7e2b3f0-6510-5964-80ae-2fca96c4c080",
      "code": "self.self.removeEventListener(SSF2Event.GROUND_LEAVE, self.glideAway);\nself.self.playSound(\"mario_capespawn\");\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "9959b797-d907-541d-b568-8234477f5257",
      "code": "",
      "length": 2,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "b12cba07-13b9-5759-8053-b90b309230cd",
      "code": "self.self.playSound(\"mario_cape\");\nif (!self.gliding && !self.self.isOnGround()) {\n\tself.self.attachEffect(\"global_dust_heavy\");\n\tself.self.attachEffect(\"global_dust_swirl\");\n}\nself.self.refreshAttackID();\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "f58ec708-937a-5afd-9871-0c050f56f9f3",
      "code": "",
      "length": 12,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
