    {
      "$id": "da1c3837-3a8f-5746-9b28-8ad6c94cc06b",
      "code": "self.self = /* ? */;\nself.speed = -23;\nself.updateStats = true;\nif (SSF2API.isReady() && self.self) {\n}\n}\n\n\nfunction b_up__frame0() {\nif ((parent && SSF2API.isReady()) || self.self) {\n\tself.self.addEventListener(SSF2Event.CHAR_ATTACK_COMPLETE, self.self.toHelpless);\n}\nself.self = /* ? */;\nself.angle = Math.atan(26 / 18) * 180 / Math.PI;\nself.speed = 25;\nself.angleAlt = 5.5;\nif ((parent && SSF2API.isReady()) || self.self) {\n\tself.controls = self.self.getControls();\n\tself.facingRight = self.self.isFacingRight();\n\tself.controls = self.self.getControls();\n\tif ((self.facingRight && self.controls.LEFT) || !self.facingRight) {\n\t\tself.angle = self.angle + self.angleAlt;\n\t}\n\tif ((self.facingRight && self.controls.RIGHT) || !self.facingRight) {\n\t\tself.angle = self.angle - self.angleAlt;\n\t}\n}\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "363afdad-2960-5ec3-8ebf-a6079593d752",
      "code": "self.self.setXSpeed(self.self.getXSpeed() / 2);\nself.self.playSound(\"screw1\");\nreturn;\n}\n\n\nfunction b_up__frame1() {\nself.self.setIntangibility(true);\nself.controls = self.self.getControls();\nif ((self.facingRight && self.controls.LEFT) || !self.facingRight) {\n\tself.angle = self.angle + self.angleAlt;\n}\nif ((self.facingRight && self.controls.RIGHT) || !self.facingRight) {\n\tself.angle = self.angle - self.angleAlt;\n}\nreturn;",
      "length": 1,
