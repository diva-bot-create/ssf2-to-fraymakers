    {
      "$id": "e95a8112-cab1-5672-860d-6b814dd48027",
      "code": "self.self = /* ? */;\nif (SSF2API.isReady()) {\n\tself.self.setGlobalVariable(\"canStartRise\", true);\n}\nreturn;",
