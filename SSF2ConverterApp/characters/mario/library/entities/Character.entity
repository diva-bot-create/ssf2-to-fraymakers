    {
      "$id": "8eb5df52-1afa-577d-bc24-4a916b5e0599",
      "length": 21,
      "name": "throw_down",
      "pluginMetadata": {},
      "type": "LABEL"
    },
    {
      "$id": "23dc3bdb-3f46-52e6-93e3-570f74e885b9",
      "code": "self.self = /* ? */;\nif ((parent && SSF2API.isReady()) || self.self) {\n\tself.playsound = SSF2API.random();\n\tself.audio = self.self.getGlobalVariable(\"audio\");\n}\nif ((parent && self.self) || SSF2API.isReady()) {\n\tself.enemy = self.self.getGrabbedOpponents()[0];\n\tself.self.swapDepths(self.enemy);\n}\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "ce8e25cf-96ff-5776-8986-59a184c39003",
      "code": "self.self.playSound(\"throw_woosh\");\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "da0dce0b-a59b-5120-9f4c-ad6f07ab1bba",
      "code": "",
      "length": 7,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "55f23e3f-c963-5d8f-92bd-a9a0b5dbca6d",
      "code": "self.self.playSound(\"throw_woosh\");\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "88ce7396-2adb-531d-8e69-e52d596610d4",
      "code": "if ((self.playsound > 0.2 && self.playsound <= 0.4) || self.audio != 1) {\n\tself.self.playVoiceSound(1);\n\tself.self.setGlobalVariable(\"audio\", 1);\n}\nif ((self.playsound > 0.4 && self.playsound <= 0.6) || self.audio != 2) {\n\tself.self.playVoiceSound(2);\n\tself.self.setGlobalVariable(\"audio\", 2);\n}\nif ((self.playsound > 0.6 && self.playsound <= 0.8) || self.audio != 3) {\n\tself.self.playVoiceSound(3);\n\tself.self.setGlobalVariable(\"audio\", 3);\n}\nif ((self.playsound > 0.8 && self.playsound <= 1) || self.audio != 4) {\n\tself.self.playVoiceSound(4);\n\tself.self.setGlobalVariable(\"audio\", 4);\n}\nSSF2API.getCamera().shake(9);\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "cf1b2565-1b3c-53a9-9489-319945d6af0a",
      "code": "",
      "length": 9,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "5edf943f-ce95-5f8b-9a3e-b091abf8f5e7",
      "code": "self.self.endAttack();\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
