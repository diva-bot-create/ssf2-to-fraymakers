    },
    {
      "$id": "4f7dcbf5-8452-55f4-b745-148fe35acba3",
      "code": "self.self = /* ? */;\nif (SSF2API.isReady()) {\n\tself.self.setGlobalVariable(\"canStartRise\", true);\n\tself.self.setGlobalVariable(\"jab\", false);\n\tself.self.setGlobalVariable(\"jab2\", false);\n}\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "b8f73918-9741-581f-8dce-4dad5fd71a8d",
      "code": "",
      "length": 3,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "fcdb2184-4317-5d21-9b40-3b5a8e265b71",
      "code": "if (self.self.getMetalStatus()) {\n\tself.self.playSound(\"metal_step_m1\");\n\treturn;\n}\nself.self.playSound(\"mario_footstep\");",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
