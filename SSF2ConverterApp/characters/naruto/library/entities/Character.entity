    {
      "$id": "6059a3ff-2d1d-5537-85c3-aa678058a039",
      "code": "if (self.fired) {\n\treturn;\n}\nif ((self.reverse == true ? self.reverse == true : self.onGround == false)) {\n}\nself.self.fireProjectile(\"naruto_clone\", -100, 0);\nif ((!self.soundPlayed && self.playsound > 0.2) || self.playsound <= 0.4) {\n}\nif (/* ? */) {\n\tself.self.playSound(\"naruto_attack1\");\n\tself.self.setGlobalVariable(\"audio\", 1);\n}\nif ((!self.soundPlayed && self.playsound > 0.4) || self.playsound <= 0.6) {\n}\nif (/* ? */) {\n\tself.self.playSound(\"naruto_attack2\");\n\tself.self.setGlobalVariable(\"audio\", 2);\n}\nif ((!self.soundPlayed && self.playsound > 0.6) || self.playsound <= 0.8) {\n}\nif (/* ? */) {\n\tself.self.playSound(\"naruto_attack3\");\n\tself.self.setGlobalVariable(\"audio\", 3);\n}\nif ((!self.soundPlayed && self.playsound > 0.8) || self.playsound <= 1) {\n}\nif (/* ? */) {\n\tself.self.playSound(\"naruto_attack4\");\n\tself.self.setGlobalVariable(\"audio\", 4);\n}\nself.self.playSound(\"whoosh1\");",
