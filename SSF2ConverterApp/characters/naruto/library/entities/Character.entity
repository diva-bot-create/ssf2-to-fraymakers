    },
    {
      "$id": "64876516-adf6-5d21-a1a7-d81431df10b1",
      "code": "self.xframe = \"attack\";\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "2f3f6b14-2f54-5a14-8b0c-615a06f07502",
      "code": "",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "ed2f35d1-d6b0-5ea0-b20b-e3b61b03ab6f",
      "code": "self.self.getItem().activateItem();\nself.self.playAttackSound(1);\nself.self.playVoiceSound(1);\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "532a1848-9e4a-5754-96ac-1ffbf3322354",
      "code": "",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "f31efcfc-ef04-5589-a073-7ab501b807f3",
      "code": "self.self.getItem().deactivateItem();\nself.self.updateAttackStats({ chargetime_max: 0 });\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "5066e88a-57ea-5399-a6cf-9d0603dc8790",
      "code": "",
