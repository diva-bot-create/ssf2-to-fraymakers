    },
    {
      "$id": "68f764c4-bc92-542a-b0ed-c025ba612e28",
      "code": "self.self = /* ? */;\nif ((parent && SSF2API.isReady()) || self.self) {\n\tself.onGround = self.self.isOnGround();\n\tself.facing = self.self.isFacingRight();\n\tself.reverse = false;\n\tself.forward = false;\n\tself.fired = false;\n\tself.pressed = true;\n\tself.repressed = false;\n\tself.self.createTimer(1, -1, self.checkControls);\n}\nself.xframe = \"start\";\nself.soundPlayed = false;\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "e5b7c364-a9a6-59b1-9868-5d05ccec0691",
      "code": "self.controls = self.self.getControls();\nif ((self.controls.RIGHT && !self.facing) || self.controls.LEFT) {\n\tself.reverse = true;\n}\nif ((self.controls.LEFT && !self.facing) || self.controls.RIGHT) {\n\tself.forward = true;\n}\nself.self.setGlobalVariable(\"cloneStartedGround\", true);\nif (self.self.getGlobalVariable(\"cloneStartedGround\")) {\n\tself.self.playVoiceSound(1);\n}\nif (self.self.getGlobalVariable(\"cloneStartedGround\")) {\n\tself.self.playAttackSound(1);\n}\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "256d5778-e6a8-5682-974b-32b705985b5d",
      "code": "self.controls = self.self.getControls();\nif ((self.controls.RIGHT && !self.facing) || self.controls.LEFT) {\n\tself.reverse = true;\n}\nif ((self.controls.LEFT && !self.facing) || self.controls.RIGHT) {\n\tself.forward = true;\n}\nself.self.attachEffect(\"naruto_summonClone\");\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "a46f8723-f5a7-54c4-832c-eca7829cd245",
      "code": "self.controls = self.self.getControls();\nif ((self.controls.RIGHT && !self.facing) || self.controls.LEFT) {\n\tself.reverse = true;\n}\nif ((self.controls.LEFT && !self.facing) || self.controls.RIGHT) {\n\tself.forward = true;\n}\nself.xframe = \"handClasp\";\nself.self.attachEffect(\"global_sparkle\", { y: -30 });\nself.self.attachEffect(\"global_dust_swirl\");\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
