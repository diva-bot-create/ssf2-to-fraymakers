    {
      "$id": "3527b46d-bcc8-5805-875b-fb1efa542ecc",
      "code": "self.self = /* ? */;\nif ((parent && SSF2API.isReady()) || self.self) {\n\tself.controls = self.self.getControls();\n\tself.pressed1 = false;\n\tself.pressed2 = false;\n\tself.self.addEventListener(SSF2Event.CHAR_ATTACK_COMPLETE, self.self.toHelpless);\n\tself.naruto_language = self.self.getGlobalVariable(\"language_Select\");\n\tif (self.naruto_language != \"ENG\") {\n\t\tself.self.playVoiceSound(1);\n\t\tself.self.playAttackSound(1);\n\t\tself.self.playAttackSound(2);\n\t\tself.self.setXSpeed(0);\n\t\treturn;\n\t} else {\n\t\tself.self.playSound(\"ENG_naruto_chakradash_short\", true);\n\t}\n}",
