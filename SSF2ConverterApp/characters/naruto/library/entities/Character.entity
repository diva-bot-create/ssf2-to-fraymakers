    {
      "$id": "21d0806f-d054-58d2-9e5c-f7060b544ec2",
      "length": 25,
      "name": "ledge_roll",
      "pluginMetadata": {},
      "type": "LABEL"
    },
    {
      "$id": "ff272cc9-1da1-5d25-a024-95aa8f960353",
      "code": "self.self = /* ? */;\nif ((parent && SSF2API.isReady()) || self.self) {\n\tself.self.setIntangibility(true);\n}\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "d2e97eb9-e72f-57bd-894d-dea3d84e8e8d",
      "code": "",
      "length": 3,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "eb3847b2-be94-5c37-9d04-bcbab56fbf7b",
      "code": "self.self.playSound(\"Naruto_jump_air\");\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "ee53557b-a20d-5bdc-beda-eb143e89d09e",
      "code": "",
      "length": 3,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "19677cd8-bdc8-51b8-aac0-e438265bc094",
      "code": "self.naruto_language = self.self.getGlobalVariable(\"language_Select\");\nif (self.naruto_language != \"JPN\") {\n\tself.self.playSound(\"ENG_naruto_jump1\", true);\n\treturn;\n} else {\n\tself.self.playSound(\"naruto_ledge_getup\");\n}",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "9b7fa2e6-3f1c-54fc-8d3a-56b04df888e9",
      "code": "",
      "length": 9,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "67d0343a-dc4f-521d-9ee8-df31b90dea90",
      "code": "self.self.setIntangibility(false);\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "fa0ebe1a-1738-53f8-b1d5-a6371c8a1101",
      "code": "",
      "length": 3,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "2274d530-620b-5eca-859a-189ae63044a3",
      "code": "if (self.self.getMetalStatus()) {\n\tself.self.playSound(\"metal_step_m1\");\n\treturn;\n}\nself.self.playSound(\"naruto_footstep\");",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "e26ae318-d8c7-5a12-a4e7-ef0e603915b5",
      "code": "",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "4d680350-8eca-567a-aa02-173dfa98f590",
      "code": "self.self.endAttack();\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
