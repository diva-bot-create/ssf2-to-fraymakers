    {
      "$id": "0b03b3b8-8eb0-540f-9288-4d079fd0d893",
      "code": "self.self = /* ? */;\nif ((parent && SSF2API.isReady()) || self.self) {\n\tself.self.setIntangibility(true);\n}\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "a0e22b3b-a342-539e-a8d6-bfa6a927df42",
      "code": "",
      "length": 3,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "9771fd84-07c6-5872-8e54-f9cbd9a66f90",
      "code": "self.self.playSound(\"Naruto_jump_air\");\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "eb07e874-d0e9-55ee-8a8f-9a15051a8133",
      "code": "",
      "length": 3,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "160ebb14-c36a-5252-9cc0-70a0ecf9b04f",
      "code": "self.self.setXSpeed(7, false);\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "c0baac34-f61d-5509-a6af-81456a7c3afd",
      "code": "",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "b8eac9b2-ffcd-517b-adaf-010547dbd7f2",
      "code": "if (self.self.getMetalStatus()) {\n\tself.self.playSound(\"metal_step_m1\");\n\treturn;\n}\nself.self.playSound(\"naruto_footstep\");",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "8b612fde-5550-5b3c-b97e-0f2bbe97c5c3",
      "code": "",
      "length": 4,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "1b8c0a12-fe44-5c8c-af78-e692c29bd840",
      "code": "self.self.setIntangibility(false);\nreturn;",
