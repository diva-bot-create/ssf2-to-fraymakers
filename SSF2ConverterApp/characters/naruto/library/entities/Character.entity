    {
      "$id": "f5e2397a-a7b2-5af3-a452-8ca1daeb668d",
      "length": 23,
      "name": "special_side_air",
      "pluginMetadata": {},
      "type": "LABEL"
    },
    {
      "$id": "253c5279-026a-56ca-82c6-325fbfb39849",
      "code": "self.self = /* ? */;\nif ((parent && SSF2API.isReady()) || self.self) {\n\tself.naruto_language = self.self.getGlobalVariable(\"language_Select\");\n}\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "b463680d-0618-5c20-8b3d-4d5235b53f07",
      "code": "self.self.playAttackSound(2);\nself.self.setAttackEnabled(false, \"b_forward\");\nself.self.setAttackEnabled(false, \"b_forward_air\");\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "29a70849-ff0f-581a-9a9f-f219a0c05f5d",
      "code": "",
      "length": 6,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "198abcd4-938e-5899-b29a-de200ad3b064",
      "code": "if (self.naruto_language != \"JPN\") {\n\tself.self.playSound(\"ENG_naruto_forgot2\", true);\n\tself.self.playAttackSound(1);\n\treturn;\n} else {\n\tself.self.playVoiceSound(1);\n}",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "cfe8619e-a32c-5e85-a3d0-617243cc9a2b",
      "code": "",
      "length": 2,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "3771cb08-55cd-53f4-b0e8-c145993e737a",
      "code": "self.self.fireProjectile(\"naruto_shuriken\");\nself.self.attachEffect(\"global_dust_heavy\");\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "572e4596-1b33-5230-8f63-6a4c97f0edd8",
      "code": "",
      "length": 5,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "56845f58-5449-5c8c-8420-dcd3c9a5aaa5",
      "code": "self.self.addEventListener(SSF2Event.GROUND_TOUCH, self.self.toIdle);\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "b9adf463-635b-563a-9745-bcb7edb2f781",
      "code": "",
      "length": 4,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
