    },
    {
      "$id": "4a733287-6c34-5ca6-a944-58e8d1452417",
      "length": 18,
      "name": "strong_up_attack",
      "pluginMetadata": {},
      "type": "LABEL"
    },
    {
      "$id": "e95f9dc3-e247-5d10-8d5c-fc73e0d37022",
      "code": "self.xframe = \"attack\";\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "ed17f574-0604-5416-aa15-921caddcb529",
      "code": "self.self.attachEffect(\"global_dust_swirl\");\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "f32cf258-f857-51c1-855c-5a4057e5d781",
      "code": "",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "f1019bca-71c9-5a3b-8c75-382414e7fa91",
      "code": "self.naruto_language = self.self.getGlobalVariable(\"language_Select\");\nif (self.naruto_language != \"ENG\") {\n\tself.self.playVoiceSound(1);\n\tself.self.playAttackSound(1);\n\tself.self.attachEffect(\"global_dust_light\");\n\treturn;\n} else {\n\tself.self.playVoiceSound(2);\n}",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "94d092d2-5967-5765-b5f3-abcc89b611cb",
      "code": "",
      "length": 9,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "32050c4b-226c-5807-8cff-cf0c9de5c403",
      "code": "if ((parent && SSF2API.isReady()) || self.self) {\n\tSSF2API.getCamera().shake(2);\n\tif (self.self.getMetalStatus()) {\n\t\tself.self.playSound(\"metal_step_m2\");\n\t\treturn;\n\t}\n\tself.self.playSound(\"naruto_footstep\");\n}",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "d91167f1-b780-5e66-a3e1-fa724a82e11c",
      "code": "",
      "length": 3,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "d6f712c9-06c8-5e57-92dc-dab387623b77",
      "code": "self.self.endAttack();\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "4bda7fb5-d57d-5710-ab0b-95aed213a50a",
      "length": 18,
      "pluginMetadata": {},
