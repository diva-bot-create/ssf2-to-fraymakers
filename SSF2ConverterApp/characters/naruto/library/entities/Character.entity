      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "f8756cac-4115-5667-b89b-63644efcff47",
      "code": "self.controls = self.self.getControls();\nif (self.controls.BUTTON1 != true) {\n} else {\n\tself.buttonCount = self.buttonCount + 1;\n}\nif ((self.controls.RIGHT == true && self.facing != true) || self.controls.LEFT == true) {\n\tself.opposite = self.opposite + 1;\n\tself.reverse = true;\n}\nreturn;",
