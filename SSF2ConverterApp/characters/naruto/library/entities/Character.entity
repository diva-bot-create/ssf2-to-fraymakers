    },
    {
      "$id": "6262fb52-ca8a-5fe6-8880-d6eb5128728f",
      "length": 2,
      "name": "attack2",
      "pluginMetadata": {},
      "type": "LABEL"
    },
    {
      "$id": "6aeccf20-f22f-5566-b084-209076710b27",
      "length": 43,
      "name": "rasenshuriken",
      "pluginMetadata": {},
      "type": "LABEL"
    },
    {
      "$id": "f5f4f6cf-b502-54df-9cdc-ec645c57ada3",
      "code": "self.self = /* ? */;\nif ((parent && SSF2API.isReady()) || self.self) {\n\tself.oodama = false;\n\tself.hasHit = false;\n\tself.xframe = null;\n\tself.naruto_language = self.self.getGlobalVariable(\"language_Select\");\n\tself.self.attachEffectOverlay(\"naruto_nSpec_Charge\");\n\tself.self.attachEffect(\"naruto_summonClone\");\n\tself.self.attachEffect(\"naruto_rasenChargeParticle\");\n\tself.self.addEventListener(SSF2Event.ATTACK_HIT, self.afterHit);\n}\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "67f13fcb-4f84-5e3e-8f9c-9c75b1029480",
      "code": "self.sfxStop2 = self.self.playAttackSound(3);\nif (self.naruto_language != \"ENG\") {\n\tself.sfxStop = self.self.playVoiceSound(1);\n\treturn;\n} else {\n\tself.sfxStop = self.self.playVoiceSound(3);\n}",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "86b4a3ea-eeee-5237-86f8-f1dd166f7601",
      "code": "",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "6d248acc-7663-5468-accf-d0e8f6a923f4",
      "code": "self.self.playSound(\"naruto_bunshin\");\nself.self.attachEffect(\"global_sparkle\", { y: -30 });\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "589d543a-a05e-5287-a7b1-292593730d71",
      "code": "",
      "length": 3,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "0378b8df-a699-5ee6-8215-e31df481b9a3",
      "code": "self.self.attachEffect(\"naruto_rasenChargeParticle\");\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "a9a2d3dd-b871-5df5-af89-ac8fa568f3bd",
      "code": "",
      "length": 5,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "76fecbf9-0d60-5438-a07c-2f4aff5aa69b",
      "code": "self.self.updateAttackStats({ cancelSoundOnEnd: true });\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "1af53101-d50f-55b5-a729-591288d5d878",
      "code": "self.xframe = \"charging\";\nself.self.attachEffect(\"naruto_rasenChargeParticle\");\nself.self.attachEffect(\"global_dust_swirl\");\nself.self.attachEffect(\"global_dust_heavy\");\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "e764110f-f80a-5b7b-a5c4-a0ffaab87bfa",
      "code": "",
      "length": 6,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "7ce2a352-dba9-59ef-aecf-ce949e6e1d72",
      "code": "self.self.attachEffect(\"global_dust_heavy\");\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "bb28efdb-d994-5d23-a77a-c01875534729",
      "code": "self.self.attachEffect(\"naruto_rasenChargeParticle\");\nreturn;",
      "length": 1,
      "pluginMetadata": {},
