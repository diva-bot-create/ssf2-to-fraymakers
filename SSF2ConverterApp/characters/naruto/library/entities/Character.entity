    {
      "$id": "5e621b8d-19aa-586f-9980-22f9d025f069",
      "length": 16,
      "name": "strong_forward_attack",
      "pluginMetadata": {},
      "type": "LABEL"
    },
    {
      "$id": "0ddf294d-6548-5e2e-b00c-03bbb9a005c5",
      "code": "self.xframe = \"attack\";\nif (self.naruto_language != \"ENG\") {\n\tself.self.playVoiceSound(1);\n\tself.self.playAttackSound(1);\n\tself.self.setXSpeed(26, false);\n\treturn;\n} else {\n\tself.self.playVoiceSound(2);\n}",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "e3e95176-fb39-5690-9354-e34c25cc1428",
      "code": "self.self.attachEffect(\"global_dust_heavy\");\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "3b5792d6-e5cc-5673-99f8-c509c7ecd994",
      "code": "",
      "length": 8,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "c77043df-5b62-51d8-92d7-6ae7b5a27ccb",
      "code": "self.self.setXSpeed(0, false);\nif ((parent && SSF2API.isReady()) || self.self) {\n\tSSF2API.getCamera().shake(2);\n\tif (self.self.getMetalStatus()) {\n\t\tself.self.playSound(\"metal_step_m1\");\n\t\treturn;\n\t}\n\tself.self.playSound(\"naruto_footstep\");\n}",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "d55746b7-e59b-58b8-b720-ad9bbcd96fd9",
      "code": "",
      "length": 4,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "b882eb83-0490-5a2b-8c18-bd225ea8f640",
      "code": "self.self.endAttack();\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
