      "code": "self.self.refreshAttackID();\nself.self.updateAttackBoxStats(1, { damage: 9, hasEffect: true, effect_id: \"effect_swordSlash\" });\nself.self.attachEffect(\"global_spark\", { x: self.self.flipX(-30), y: -28 });\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
