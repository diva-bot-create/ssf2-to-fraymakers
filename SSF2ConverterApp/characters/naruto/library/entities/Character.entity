    {
      "$id": "7e3750b6-210b-5759-8234-067ad75b8031",
      "code": "self.self = /* ? */;\nif ((parent && SSF2API.isReady()) || self.self) {\n\tself.playsound = SSF2API.random();\n\tself.audio = self.self.getGlobalVariable(\"audio\");\n\tself.naruto_language = self.self.getGlobalVariable(\"language_Select\");\n}\nreturn;",
