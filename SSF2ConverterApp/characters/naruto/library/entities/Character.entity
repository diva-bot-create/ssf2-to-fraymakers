    {
      "$id": "8bd24aea-eb75-5cca-9b3a-60febf5f2418",
      "code": "self.controls = self.self.getControls();\nif (self.controls.BUTTON1 != true) {\n} else {\n\tself.buttonCount = self.buttonCount + 1;\n}\nif ((self.controls.RIGHT == true && self.facing != true) || self.controls.LEFT == true) {\n\tself.opposite = self.opposite + 1;\n\tself.reverse = true;\n}\nself.self.attachEffect(\"naruto_summonClone\");\nif (self.self.isOnGround()) {\n\tself.self.stancePlayFrame(\"handClasp\");\n}\nself.self.attachEffect(\"global_sparkle\", { y: -30 });\nself.self.attachEffect(\"global_dust_swirl\");\nreturn;",
      "length": 1,
