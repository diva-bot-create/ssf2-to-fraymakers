      "code": "self.self = /* ? */;\nself.rand = 0;\nif ((parent && SSF2API.isReady()) || self.self) {\n\tself.rand = 100 * SSF2API.random();\n\tself.gotoAndStop(\"blink\");\n\tself.gotoAndStop(\"wait\");\n}\nif ((self.self && SSF2API.isReady()) || self.self.hasEventListener(SSF2Event.STATE_CHANGE, self.uncrouch)) {\n}",
