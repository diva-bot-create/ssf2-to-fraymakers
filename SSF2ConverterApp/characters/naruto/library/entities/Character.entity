    {
      "$id": "f3fc4009-af0c-547f-b657-606cb85f92ec",
      "code": "self.self = /* ? */;\nself.xframe = \"midair\";\nself.done = false;\nif ((parent && SSF2API.isReady()) || self.self) {\n\tif (self.self.getGlobalVariable(\"screwAttackOn\")) {\n\t\tself.self.endAttack();\n\t\tself.self.forceAttack(\"item_screw\");\n\t\treturn;\n\t}\n\tself.self.playSound(\"Naruto_jump_air\");\n}",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
