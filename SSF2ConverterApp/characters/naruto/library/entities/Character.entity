      "pluginMetadata": {},
      "type": "LABEL"
    },
    {
      "$id": "b2535e0f-803c-55a1-bbed-73cd595e9302",
      "code": "self.self.setGlobalVariable(\"jab\", false);\nself.self.setGlobalVariable(\"jab2\", false);\nif ((parent && SSF2API.isReady()) || self.self) {\n}\nif (/* ? */) {\n} else {\n\treturn;\n}\nif ((self.self.getCPUAction() < 10 && self.self.getCPUAction() > 0) || self.self.getCPULevel() >= 7) {\n\tSSF2API.print(\"Crouch Cancel (Turning)\");\n\tif (self.self.isFacingRight()) {\n\t\tself.self.importCPUControls([17408, 1, 16896, 1]);\n\t\tself.self.endAttack(\"crouch\");\n\t} else {\n\t\tself.self.importCPUControls([17408, 1, 16640, 1]);\n\t}\n}",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "35ecf157-782a-5ebc-abc8-a955ddabfdc7",
      "code": "",
      "length": 6,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "6a71a0f5-ed38-5505-9e19-33a4dfcfbbbc",
      "code": "self.self.stancePlayFrame(\"run\");\nreturn;",
