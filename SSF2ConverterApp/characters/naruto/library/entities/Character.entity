    },
    {
      "$id": "0d8b5cff-db4d-5fc7-86ea-8bef044213f0",
      "length": 23,
      "name": "special_side",
      "pluginMetadata": {},
      "type": "LABEL"
    },
    {
      "$id": "fcddc96f-ea75-5866-b7b5-39e2424e5845",
      "code": "self.self = /* ? */;\nif ((parent && SSF2API.isReady()) || self.self) {\n\tself.naruto_language = self.self.getGlobalVariable(\"language_Select\");\n}\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "89a528f5-6ce9-5721-a335-cba1d301a478",
      "code": "self.self.playAttackSound(2);\nself.self.setAttackEnabled(false, \"b_forward\");\nself.self.setAttackEnabled(false, \"b_forward_air\");\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "a7605710-ae4a-544b-8461-9bcbc579fa27",
      "code": "",
      "length": 6,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "94bf19a4-7e6c-51eb-ad27-3057aaaefeda",
      "code": "if (self.naruto_language != \"JPN\") {\n\tself.self.playSound(\"ENG_naruto_forgot2\", true);\n\tself.self.playAttackSound(1);\n\treturn;\n} else {\n\tself.self.playVoiceSound(1);\n}",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "93ac9220-b7ab-538f-9ff2-a6472dd7359c",
      "code": "",
      "length": 2,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "010d3730-abb2-5b39-a0c1-9233ad4ddad3",
      "code": "self.self.fireProjectile(\"naruto_shuriken\");\nself.self.attachEffect(\"global_dust_heavy\");\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "9c8cbf4f-e0fc-5dfe-84fc-eea0ab5c0959",
      "code": "",
      "length": 2,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "ef24d213-448a-5d2d-bfc8-754ce3e2bb89",
      "code": "if (self.self.getMetalStatus()) {\n\tself.self.playSound(\"metal_step_m1\");\n}\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "c6f9d40b-0140-57f8-b7dd-b49ec378aa12",
      "code": "",
      "length": 2,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "2e71854a-564f-5813-af2c-6d4d3b3930fa",
      "code": "self.self.addEventListener(SSF2Event.GROUND_TOUCH, self.self.toIdle);\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "1b326c88-c083-5e37-ba9b-696f2d75b5db",
      "code": "",
      "length": 4,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
