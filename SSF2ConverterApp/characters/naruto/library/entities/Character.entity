    {
      "$id": "bf849b89-1bc0-578b-b2f6-62c19cff68be",
      "code": "if (self.naruto_language != \"ENG\") {\n\tif ((self.playsound > 0.2 && self.playsound <= 0.4) || self.audio != 1) {\n\t\tself.self.playVoiceSound(1);\n\t\tself.self.setGlobalVariable(\"audio\", 1);\n\t}\n\tif ((self.playsound > 0.4 && self.playsound <= 0.6) || self.audio != 2) {\n\t\tself.self.playVoiceSound(2);\n\t\tself.self.setGlobalVariable(\"audio\", 2);\n\t}\n\tif ((self.playsound > 0.6 && self.playsound <= 0.8) || self.audio != 3) {\n\t\tself.self.playVoiceSound(3);\n\t\tself.self.setGlobalVariable(\"audio\", 3);\n\t}\n\tif ((self.playsound > 0.8 && self.playsound <= 1) || self.audio != 4) {\n\t\tself.self.playVoiceSound(4);\n\t\tself.self.setGlobalVariable(\"audio\", 4);\n\t}\n\tself.self.playAttackSound(1);\n\tself.self.attachEffect(\"global_dust_heavy\");\n\tself.self.setXSpeed(16, false);\n\treturn;\n} else {\n\tif ((self.playsound > 0.2 && self.playsound <= 0.4) || self.audio != 1) {\n\t\tself.self.playSound(\"ENG_naruto_grunt1\", true);\n\t\tself.self.setGlobalVariable(\"audio\", 1);\n\t}\n\tif ((self.playsound > 0.4 && self.playsound <= 0.6) || self.audio != 2) {\n\t\tself.self.playSound(\"ENG_naruto_grunt2\", true);\n\t\tself.self.setGlobalVariable(\"audio\", 2);\n\t}\n\tif ((self.playsound > 0.6 && self.playsound <= 0.8) || self.audio != 3) {\n\t\tself.self.playSound(\"ENG_naruto_forgot1\", true);\n\t\tself.self.setGlobalVariable(\"audio\", 3);\n\t}\n\tif ((self.playsound > 0.8 && self.playsound <= 1) || self.audio != 4) {\n\t\tself.self.playSound(\"ENG_naruto_forgot2\", true);\n\t\tself.self.setGlobalVariable(\"audio\", 4);\n\t}\n}",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "0b017ee3-2a0f-554b-8a7b-4aeb38232407",
      "code": "self.self.updateAttackBoxStats(1, { power: 15 });\nself.self.updateAttackBoxStats(2, { power: 15 });\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "1fddff65-1142-5c6a-bd6f-b8beeafab0b6",
      "code": "self.self.updateAttackBoxStats(1, { power: 5 });\nself.self.updateAttackBoxStats(2, { power: 5 });\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "14d7dd6f-e6b2-5d99-aaee-eab095c21b8b",
      "code": "",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "23820112-b512-5566-981d-e695bb62653c",
      "code": "self.self.playAttackSound(2);\nself.self.updateAttackBoxStats(1, { effectSound: \"brawl_kick_m\", canDI: true, weightKB: 0, direction: 70, power: 70, kbConstant: 70, damage: 7, hitLag: -1.2 });\nself.self.updateAttackBoxStats(2, { effectSound: \"brawl_kick_m\", canDI: true, weightKB: 0, direction: 70, power: 70, kbConstant: 70, damage: 7, hitLag: -1.2 });\nself.self.refreshAttackID();\nself.self.updateAttackStats({ xSpeedDecay: -1 });\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "594a8f96-5e3c-5ea2-86c6-01fc4e8aa6ec",
      "code": "",
      "length": 9,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
