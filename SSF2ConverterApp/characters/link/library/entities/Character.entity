    },
    {
      "$id": "e9aedfc1-fdef-5f22-8be5-0ad8c6c41480",
      "code": "self.self.setXSpeed(17.5, false);\nself.self.attachEffect(\"link_dust_heavy\");\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "ef6b16c5-8fa1-53b7-bbd9-4e60e913a5c6",
      "code": "self.self.pushEffectBehind(self.self.addEffectToList(self.self.attachEffect(\"slash_link_fsmash1\", { scaleX: 1.1, scaleY: 1.1, parentLock: true, syncHitStun: true })));\nself.self.clearEffectsOnStateChange(false);\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "fd856695-8715-5e27-bc98-df3a0414646e",
      "code": "self.continuePlaying = false;\nself.handled = false;\nif (self.self.getMetalStatus()) {\n\tself.self.playSound(\"metal_step_m1\");\n}\nself.self.playAttackSound(1);\nself.self.playVoiceSound(2);\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "fc3e5f7a-688b-5e7e-ac0d-437aac57d848",
      "code": "self.self.setXSpeed(0, false);\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "81d1b4dd-fe54-5dfc-9d74-dacdddca3ffc",
      "code": "self.wasntLeft = true;\nself.wasntRight = true;\nif (self.self.getControls().C_LEFT) {\n\tself.wasntLeft = false;\n}\nif (self.self.getControls().C_RIGHT) {\n\tself.wasntRight = false;\n}\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "cfd9f7d7-ff9a-514f-8b91-d8f5cc389805",
      "code": "self.self.createTimer(1, 10, self.check);\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "ba34986c-c832-5213-a8f5-edc33929d834",
      "code": "",
      "length": 6,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "36db7512-1f84-5352-8b86-48257e0bb07b",
      "code": "if (self.self.getMetalStatus()) {\n\tself.self.playSound(\"metal_step_m2\");\n}\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "ca0b144a-e265-55c0-9dfc-efc7382482bf",
      "code": "",
      "length": 2,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "3fcf1a68-ef7b-5fcd-8243-2509882b1d23",
      "code": "self.self.endAttack();\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "b73ba5a3-fe4f-558b-936a-e97d553e7252",
      "code": "self.self.updateAttackBoxStats(1, { damage: 13, direction: 45, power: 85, kbConstant: 89, effectSound: \"sw_brawl_hit_H\" });\nself.self.refreshAttackID();\nself.self.attachEffect(\"global_spark\", { x: self.flipX(-15), y: -20 });\nself.self.removeAllEffects();\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "29647773-1cc4-5acc-bd1b-1e3197c86ee8",
      "code": "",
