      "name": "roll",
      "pluginMetadata": {},
      "type": "LABEL"
    },
    {
      "$id": "89428fc2-81da-524f-ba01-4923c4f3d91d",
      "code": "self.self = /* ? */;\nif ((parent && SSF2API.isReady()) || self.self) {\n\tself.self.setGlobalVariable(\"nStoredLabel\", null);\n\tself.self.setGlobalVariable(\"sStoredLabel\", null);\n}\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "0ae2b134-2560-501e-90b7-a07fa6604447",
      "code": "self.effect = self.self.attachEffect(\"global_dust_heavy\", { scaleX: 0.8, scaleY: 0.8 });\nself.effect.scaleX = -self.effect.scaleX;\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "ea4f6764-9b89-5507-954a-93b56741926a",
      "code": "if ((parent && SSF2API.isReady()) || self.self) {\n\tself.self.setIntangibility(true);\n}\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "d138090e-5ba5-5b1d-ba2f-db0d1fcb01d8",
      "code": "self.self.playSound(\"link_step\");\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "603a7dc5-2c5d-5aba-8f13-cb598116181a",
      "code": "",
      "length": 2,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "c3fc39ae-5ba7-58d1-b84c-047b1f6af74c",
      "code": "self.self.playSound(\"link_step2\");\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "f083e7f5-4ae1-5afa-86ae-54f37ebe3e41",
      "code": "",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "3bb343ae-fb5f-573c-ac35-b22f946a5cd2",
      "code": "if ((parent && SSF2API.isReady()) || self.self) {\n\tself.self.setIntangibility(false);\n}\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
