    {
      "$id": "d022ba59-3223-53e5-981f-b05df314e51b",
      "length": 25,
      "name": "ledge_attack",
      "pluginMetadata": {},
      "type": "LABEL"
    },
    {
      "$id": "dca66161-1682-518e-a795-8859c6a78297",
      "code": "self.self = /* ? */;\nif ((parent && SSF2API.isReady()) || self.self) {\n\tself.self.setIntangibility(true);\n\tself.playsound = SSF2API.random();\n\tself.audio = self.self.getGlobalVariable(\"audio\");\n}\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "2c47a316-0038-5eac-92d0-86dd1896c6de",
      "code": "",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "28ef01ec-b155-5936-8d73-625bf19ea2d2",
      "code": "self.self.playSound(\"link_jump01\");\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "085bd1c1-0e55-58c3-b4cd-c12876c50f61",
      "code": "",
      "length": 3,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "d957eb98-4120-5545-b435-603a9e30135a",
      "code": "self.self.setXSpeed(9, false);\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "1d9fcfd0-8cfe-5761-bd4e-ddd5c5310cd8",
      "code": "",
      "length": 2,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "14b4ad4e-ab47-5e4e-a3ae-34f432178d27",
      "code": "self.self.addEffectToList(self.self.attachEffect(\"slash_link_ledge\", { scaleX: 1.1, scaleY: 1.1, parentLock: true, syncHitStun: true }));\nself.self.clearEffectsOnStateChange();\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "962fcd58-ff1a-52a4-b4e7-ec5c93ea7c79",
      "code": "self.self.attachEffect(\"global_dust_light\");\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "61f9229f-2e23-5334-9ccc-a3d0423da71d",
      "code": "self.self.playAttackSound(1);\nif ((self.playsound > 0.2 && self.playsound <= 0.4) || self.audio != 1) {\n\tself.self.playVoiceSound(1);\n\tself.self.setGlobalVariable(\"audio\", 1);\n}\nif ((self.playsound > 0.4 && self.playsound <= 0.6) || self.audio != 2) {\n\tself.self.playVoiceSound(2);\n\tself.self.setGlobalVariable(\"audio\", 2);\n}\nif ((self.playsound > 0.6 && self.playsound <= 0.8) || self.audio != 3) {\n\tself.self.playVoiceSound(3);\n\tself.self.setGlobalVariable(\"audio\", 3);\n}\nif ((self.playsound > 0.8 && self.playsound <= 1) || self.audio != 4) {\n\tself.self.playVoiceSound(4);\n\tself.self.setGlobalVariable(\"audio\", 4);\n}\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "46b3f8e6-b863-5fb1-b732-9517884eb8fb",
      "code": "self.self.setIntangibility(false);\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "cf766c89-8ef1-5436-a89e-4af281970ccf",
      "code": "",
      "length": 11,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "e89bba0e-4e31-5979-8e0d-0d7bb9578b2d",
      "code": "self.self.endAttack();\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
