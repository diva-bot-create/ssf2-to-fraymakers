    {
      "$id": "5d85160e-af91-5b18-9b60-fe4a579aab69",
      "code": "self.self = /* ? */;\nif ((parent && SSF2API.isReady()) || self.self) {\n\tself.controls = self.self.getControls();\n\tself.maxCharge = self.self.getAttackStat(\"chargetime_max\");\n\tself.curCharge = self.self.getGlobalVariable(\"LinkNSpecCharge\");\n\tself.curFrame = self.self.getGlobalVariable(\"LinkNSpecFrame\");\n\tself.prepIt = self.self.getGlobalVariable(\"LinkNSpecPrepIt\");\n\tself.doIt = self.self.getGlobalVariable(\"LinkNSpecDoIt\");\n\tself.hasBomb = false;\n\tself.self.createTimer(1, -1, self.checkSpeckill, { persistent: true });\n\tself.self.addEventListener(SSF2Event.GROUND_TOUCH, self.toGround);\n\tself.curItem = self.self.getItem();\n\tif (self.curItem != null && self.curItem.getLinkageID() == \"link_bomb\") {\n\t\tself.self.createTimer(1, -1, self.checkFire);\n\t}\n\tif ((self.curFrame != null && self.curFrame > 1) || self.curCharge != null) {\n\t\tself.self.stancePlayFrame(\"bombArrow\");\n\t}\n}\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "12033ac3-e6ba-5f2a-8775-c9a12ad3905f",
      "code": "",
      "length": 6,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "a6de13b4-043f-54e1-827b-e273fe642521",
      "code": "self.self.setGlobalVariable(\"LinkNSpecSFX\", self.self.playAttackSound(1));\nself.self.attachEffect(\"global_spark\", { x: self.flipX(25), y: -40 });\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "121053ce-275e-516c-bbd1-28b86e2e734d",
      "code": "",
      "length": 4,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "c706ca95-e9c7-50b5-b705-294d5b92bcd6",
      "code": "self.controls = self.self.getControls();\nif (self.controls.BUTTON1) {\n} else {\n\tself.self.setGlobalVariable(\"LinkNSpecCharge\", 0);\n\tself.self.stancePlayFrame(\"attack\");\n}\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "41cb4301-5b79-5dd2-b46d-c63a8121edc2",
      "code": "self.prepIt = true;\nself.self.createTimer(1, -1, self.checkFire);\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "9abda769-7e85-5ae9-8bcf-21eb373866d3",
      "code": "",
      "length": 4,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "7f1000b3-be96-5bd2-b77d-f7b770b475e0",
      "code": "self.self.stancePlayFrame(\"loop1\");\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "25e15b69-567d-5791-b64b-0e33f545e573",
      "code": "if (self.doIt) {\n\treturn;\n}\nself.doIt = true;\nself.stopSFX();\nself.self.playAttackSound(2);\nself.self.attachEffect(\"global_dust_heavy\");\nif (self.hasBomb) {\n\tself.self.fireProjectile(\"nSpecBomb\");\n\tself.self.attachEffect(\"bombArrowSpawn\");\n\tself.self.removeItem();\n}\nself.self.fireProjectile(\"nSpecArrow\");\nself.self.attachEffect(\"arrowSpawn\");",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "487bd1b2-e516-5b0e-a00a-dc150e5d6019",
      "code": "",
      "length": 10,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "db6352a2-395b-5a2d-a127-aab0b960d0d6",
      "code": "self.self.endAttack();\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "33a9a377-88fe-5cea-87c6-826abffee076",
      "code": "",
      "length": 7,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
