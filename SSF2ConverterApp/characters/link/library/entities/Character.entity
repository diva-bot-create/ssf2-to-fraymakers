    },
    {
      "$id": "f51672b8-02eb-5d86-8ee8-f3babd4cee6a",
      "length": 1,
      "pluginMetadata": {},
      "symbol": null,
      "tweenType": "LINEAR",
      "tweened": false,
      "type": "IMAGE"
    },
    {
      "$id": "b5e61e8a-4e47-5a81-889e-43c56877627d",
      "length": 16,
      "name": "throw_back",
      "pluginMetadata": {},
      "type": "LABEL"
    },
    {
      "$id": "7f33a753-62be-55d8-a911-841c9b8c8a14",
      "code": "self.self = /* ? */;\nif ((parent && SSF2API.isReady()) || self.self) {\n\tself.playsound = SSF2API.random();\n\tself.audio = self.self.getGlobalVariable(\"audio\");\n}\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "b137872b-f18a-5c83-a22c-fdfdbf514aed",
      "code": "self.self.playSound(\"link_kickwind\");\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "23d11af6-9e65-5b43-8d1c-2b2be1980609",
      "code": "",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "5ddbba99-b363-5a1c-b6af-1cc24a81bc69",
      "code": "if ((self.playsound > 0.2 && self.playsound <= 0.4) || self.audio != 1) {\n\tself.self.playVoiceSound(1);\n\tself.self.setGlobalVariable(\"audio\", 1);\n}\nif ((self.playsound > 0.4 && self.playsound <= 0.6) || self.audio != 2) {\n\tself.self.playVoiceSound(2);\n\tself.self.setGlobalVariable(\"audio\", 2);\n}\nif ((self.playsound > 0.6 && self.playsound <= 0.8) || self.audio != 3) {\n\tself.self.playVoiceSound(3);\n\tself.self.setGlobalVariable(\"audio\", 3);\n}\nif ((self.playsound > 0.8 && self.playsound <= 1) || self.audio != 4) {\n\tself.self.playVoiceSound(4);\n\tself.self.setGlobalVariable(\"audio\", 4);\n}\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "edf5afe0-a415-5d3c-a8df-a36338ce5389",
      "code": "",
      "length": 2,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "bc721af0-c761-5b68-a4da-20d105b3dd2b",
      "code": "self.self.attachEffect(\"global_dust_light\", { flipOnX: true });\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "a3c0504d-04da-5958-9126-780d20486fb5",
      "code": "",
      "length": 7,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "98f9f224-4a50-5bac-a58c-186815332957",
      "code": "if (self.self.getMetalStatus()) {\n\tself.self.playSound(\"metal_step_m1\");\n}\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "67871a4d-c30e-56c9-872e-2b1b80797377",
      "code": "self.self.endAttack();\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "63c1ae66-c9db-556a-8495-ff65660484cd",
