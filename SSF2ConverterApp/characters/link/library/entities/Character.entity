    {
      "$id": "ebd31b06-3712-5709-95bb-4b7829f856c8",
      "code": "self.fired = true;\nself.sSpecStored = self.self.getGlobalVariable(\"sStoredLabel\");\nif (self.sSpecStored == \"boom_throw\") {\n\tself.self.playSound(\"link_boomerang_throw\");\n\tself.self.attachEffect(\"global_dust_light\");\n\treturn;\n}\nself.self.setGlobalVariable(\"sStoredLabel\", \"boom_throw\");\nself.fired = self.self.fireProjectile(\"sSpecBoomerang\");\nif (self.fired) {\n}\nself.self.playAttackSound(1);\nif (self.self.isFacingRight()) {\n\tif (self.self.getControls().UP) {\n\t\tself.self.getCurrentProjectile().angleControl(self.self.getCurrentProjectile().getProjectileStat(\"xspeed\"), self.upDir);\n\t}\n\tif (self.self.getControls().DOWN) {\n\t\tself.self.getCurrentProjectile().angleControl(self.self.getCurrentProjectile().getProjectileStat(\"xspeed\"), self.downDir);\n\t}\n}\nif (self.self.isFacingRight()) {\n}\nif (self.self.getControls().UP) {\n\tself.self.getCurrentProjectile().angleControl(self.self.getCurrentProjectile().getProjectileStat(\"xspeed\"), 180 - self.upDir);\n}\nif (self.self.getControls().DOWN) {\n\tself.self.getCurrentProjectile().angleControl(self.self.getCurrentProjectile().getProjectileStat(\"xspeed\"), 180 - self.downDir);\n}",
      "length": 1,
      "pluginMetadata": {},
