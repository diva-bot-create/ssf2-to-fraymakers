    {
      "$id": "769353cf-a1db-53b2-933a-224deeba56b8",
      "length": 22,
      "name": "throw_up",
      "pluginMetadata": {},
      "type": "LABEL"
    },
    {
      "$id": "0cd1fc85-088d-53b3-b0dd-f56279b6d839",
      "code": "self.self = /* ? */;\nif ((parent && SSF2API.isReady()) || self.self) {\n\tself.playsound = SSF2API.random();\n\tself.audio = self.self.getGlobalVariable(\"audio\");\n}\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "4a6f1d11-cd1a-5f4d-b979-fcadb3918e2c",
      "code": "self.self.playSound(\"link_kickwind\");\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "2c2802fd-38e9-5ff4-a134-11db60d93d1c",
      "code": "",
      "length": 5,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "93e7d5e2-da9b-5151-acfb-5953eef0120d",
      "code": "if ((self.playsound > 0.2 && self.playsound <= 0.4) || self.audio != 1) {\n\tself.self.playVoiceSound(1);\n\tself.self.setGlobalVariable(\"audio\", 1);\n}\nif ((self.playsound > 0.4 && self.playsound <= 0.6) || self.audio != 2) {\n\tself.self.playVoiceSound(2);\n\tself.self.setGlobalVariable(\"audio\", 2);\n}\nif ((self.playsound > 0.6 && self.playsound <= 0.8) || self.audio != 3) {\n\tself.self.playVoiceSound(3);\n\tself.self.setGlobalVariable(\"audio\", 3);\n}\nif ((self.playsound > 0.8 && self.playsound <= 1) || self.audio != 4) {\n\tself.self.playVoiceSound(4);\n\tself.self.setGlobalVariable(\"audio\", 4);\n}\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "4eac2926-fcf0-57e6-9798-24c5d9e6af17",
      "code": "self.self.playSound(\"link_kickwind\");\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "649397f4-641b-529c-b50d-6ccfee15421f",
      "code": "",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "097bc2f6-a7f0-54ad-90a9-d37f3db64aec",
      "code": "self.self.attachEffect(\"global_dust_cloud\");\nself.self.addEffectToList(self.self.attachEffect(\"slash_link_uthrow\", { scaleX: 1.1, scaleY: 1.1, parentLock: true, syncHitStun: true }));\nself.self.clearEffectsOnStateChange();\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "b13b7778-1b68-5fe2-a0e5-4c6bf72b0307",
      "code": "return;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "82984214-4046-5eb0-a0b1-c7d21980a321",
      "code": "self.self.updateAttackBoxStats(1, { direction: 90, damage: 2, power: 24, kbConstant: 230, hitStun: 3, selfHitStun: 5, hitLag: -1, effectSound: \"sw_brawl_hit_M\", hasEffect: true });\nself.self.refreshAttackID();\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "4e70ea47-3ff4-5edb-9bd6-4eccb7c19228",
      "code": "self.self.updateAttackBoxStats(1, { direction: 20, damage: 5, power: 50, kbConstant: 100, hitStun: 3, selfHitStun: 5, hitLag: -1.1 });\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "f2a72d44-ce7b-55c1-b65e-fd24d963b661",
      "code": "",
      "length": 3,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "c0b095b4-d2fa-5270-8dd3-b240cb6e2913",
      "code": "if (self.self.getMetalStatus()) {\n\tself.self.playSound(\"metal_land_m\");\n}\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "06cecbd2-e3ae-55f6-b8c9-2141b5686a6b",
      "code": "",
      "length": 3,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
