    },
    {
      "$id": "b2d33759-5f02-5698-a05f-4ea236b958cd",
      "code": "self.self = /* ? */;\nif ((parent && SSF2API.isReady()) || self.self) {\n\tself.self.setGlobalVariable(\"tether\", false);\n\tself.self.setGlobalVariable(\"nStoredLabel\", null);\n\tself.self.setGlobalVariable(\"sStoredLabel\", null);\n\tself.self.playSound(\"link_runstart\");\n}\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "c675a0df-89ba-53b0-806a-a1132b5144ec",
      "code": "",
      "length": 7,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "220cde58-5f09-5a56-9fcd-35814c70f3c3",
      "code": "self.self.stancePlayFrame(\"run\");\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "eefaa39e-c74d-5e4b-a31c-c78fc394b275",
      "code": "if (self.self.getMetalStatus()) {\n\tself.self.playSound(\"metal_step_m1\");\n\treturn;\n}\nself.self.playSound(\"link_step\");",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "191de81e-b9dc-59f6-bbe2-67aadd1bf069",
      "code": "",
      "length": 7,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "610eb331-c269-563b-bf58-04ef9c0610dd",
      "code": "if (self.self.getMetalStatus()) {\n\tself.self.playSound(\"metal_step_m2\");\n\treturn;\n}\nself.self.playSound(\"link_step2\");",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
