    {
      "$id": "5c8c4b48-d647-506f-8501-17acef0d1c5b",
      "code": "self.self = /* ? */;\nself.sSpecStored = null;\nself.sSpecLabel = null;\nself.fromProjectile = false;\nself.upDir = 20;\nself.downDir = 360 - self.upDir;\nif ((parent && SSF2API.isReady()) || self.self) {\n\tself.self.setGlobalVariable(\"nStoredLabel\", null);\n\tself.sSpecStored = self.self.getGlobalVariable(\"sStoredLabel\");\n\tif (self.sSpecStored != \"Frame1\" && self.sSpecStored != null) {\n\t}\n}\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
