      "code": "self.updateStats = false;\nself.self.updateAttackBoxStats(1, { power: 30, kbConstant: 100, damage: 2, hitStun: 2, selfHitStun: 1 });\nself.self.updateAttackBoxStats(2, { power: 0, kbConstant: 100, damage: 2, hitStun: 2, selfHitStun: 1 });\nself.self.updateAttackStats({ refreshRate: 1 });\nreturn;\n}\n\n\nfunction b_up__frame8() {\nself.self.stancePlayFrame(\"charging\");\nif (self.chargeCount != 19) {\n} else {\n\tself.self.playAttackSound(19);\n}\nreturn;",
