    {
      "$id": "f98fe3ac-df93-52f2-8bc6-af3a1151be1f",
      "code": "self.self.refreshAttackID();\nself.self.updateAttackBoxStats(1, { damage: 8, power: 80, direction: 50, weightKB: 0, kbConstant: 90, hitStun: 5, selfHitStun: 3, hitLag: -1 });\nself.self.updateAttackBoxStats(2, { damage: 8, power: 80, direction: 50, weightKB: 0, kbConstant: 90, hitStun: 5, selfHitStun: 3, hitLag: -1 });\nself.self.updateAttackStats({ refreshRate: 100 });\nself.self.destroyTimer(self.playWind);\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "823b075c-89be-5691-8c41-c1b7263fb5aa",
      "code": "self.self.attachEffect(\"global_spark\", { x: self.flipX(36), y: -70 });\nself.self.updateAttackStats({ xSpeedCap: 6.5, air_ease: -1 });\nreturn;",
