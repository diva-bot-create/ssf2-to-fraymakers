    },
    {
      "$id": "164ef57b-1102-5ed6-8095-9cc1c8a50bff",
      "length": 2,
      "name": "done",
      "pluginMetadata": {},
      "type": "LABEL"
    },
    {
      "$id": "3c552db1-9595-58ef-8b12-b004c6b7628c",
      "code": "self.self = /* ? */;\nself.done = false;\nif ((SSF2API.isReady() && self.self) || self.self.getGlobalVariable(\"screwAttackOn\")) {\n}",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "7769ddd7-9c4b-5f85-9597-c66d2ce0df6f",
      "code": "",
      "length": 3,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "8ce03e72-6f93-52ba-9047-bd7997df1478",
      "code": "self.self.playSound(\"link_kickwind\");\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "a6b103cd-9e3d-5799-acdf-60fb96b24b4e",
      "code": "",
      "length": 11,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "8350fda0-723f-5b19-9293-faff0bc16628",
      "code": "self.done = true;\nself.stop();\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "5e3090ed-068e-546f-a581-bd16f5d7b05a",
      "code": "self.self.stancePlayFrame(\"done\");\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
