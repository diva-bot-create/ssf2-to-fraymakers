    {
      "$id": "1a5ed24b-a4fb-5ce8-8d23-eda16c3eea12",
      "length": 14,
      "name": "bombArrow",
      "pluginMetadata": {},
      "type": "LABEL"
    },
    {
      "$id": "069ae681-60d5-5c79-93a3-cafb0fbb8e33",
      "length": 2,
      "name": "loop2",
      "pluginMetadata": {},
      "type": "LABEL"
    },
    {
      "$id": "f4e724cb-67b1-5866-8820-c864f60df45d",
      "code": "self.self = /* ? */;\nif ((parent && SSF2API.isReady()) || self.self) {\n\tself.controls = self.self.getControls();\n\tself.maxCharge = self.self.getAttackStat(\"chargetime_max\");\n\tself.curCharge = self.self.getGlobalVariable(\"LinkNSpecCharge\");\n\tself.curFrame = self.self.getGlobalVariable(\"LinkNSpecFrame\");\n\tself.prepIt = self.self.getGlobalVariable(\"LinkNSpecPrepIt\");\n\tself.doIt = self.self.getGlobalVariable(\"LinkNSpecDoIt\");\n\tself.hasBomb = false;\n\tself.self.createTimer(1, -1, self.checkSpeckill, { persistent: true });\n\tself.self.addEventListener(SSF2Event.GROUND_LEAVE, self.toAir);\n\tself.curItem = self.self.getItem();\n\tif (self.curItem != null && self.curItem.getLinkageID() == \"link_bomb\") {\n\t\tself.self.createTimer(1, -1, self.checkFire);\n\t}\n\tif ((self.curFrame != null && self.curFrame > 1) || self.curCharge != null) {\n\t\tself.self.stancePlayFrame(\"bombArrow\");\n\t}\n}\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "a8a3c680-80b4-5bbe-b0f0-b9877abe6947",
      "code": "",
      "length": 6,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "14472c67-2ac4-55e4-b648-f54efb492e86",
      "code": "self.self.setGlobalVariable(\"LinkNSpecSFX\", self.self.playAttackSound(1));\nself.self.attachEffect(\"global_spark\", { x: self.flipX(35), y: -40 });\nself.self.attachEffect(\"global_dust_light\");\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "21020057-5693-5e6e-b360-180fdd9173a4",
      "code": "",
      "length": 4,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "bb8a4493-78e8-5855-a442-c15493711289",
      "code": "self.controls = self.self.getControls();\nif (self.controls.BUTTON1) {\n} else {\n\tself.self.setGlobalVariable(\"LinkNSpecCharge\", 0);\n\tself.self.stancePlayFrame(\"attack\");\n}\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "718ed33f-ed54-52bc-8712-2304fcf85e58",
      "code": "self.prepIt = true;\nself.self.createTimer(1, -1, self.checkFire);\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "fe674e4b-95b1-53aa-a4ce-780504bd8add",
      "code": "",
      "length": 4,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "0e1b7eb3-ecc7-5e5f-9108-f875a551e9b4",
      "code": "self.self.stancePlayFrame(\"loop1\");\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "e4706e9b-43b8-51ee-ad59-722bd7e9d690",
      "code": "if (self.doIt) {\n\treturn;\n}\nself.doIt = true;\nself.stopSFX();\nself.self.playAttackSound(2);\nself.self.attachEffect(\"global_dust_heavy\");\nif (self.hasBomb) {\n\tself.self.fireProjectile(\"nSpecBomb\");\n\tself.self.attachEffect(\"bombArrowSpawn\");\n\tself.self.removeItem();\n}\nself.self.fireProjectile(\"nSpecArrow\");\nself.self.attachEffect(\"arrowSpawn\");",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "b169aadd-af6b-510c-af40-1b09f19d66dc",
      "code": "",
      "length": 10,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
