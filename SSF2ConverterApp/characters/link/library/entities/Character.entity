    {
      "$id": "9af333e5-8834-5cb4-bb9c-fc72ffc22c1b",
      "code": "self.self = /* ? */;\nif ((parent && SSF2API.isReady()) || self.self) {\n\tself.windY = 5;\n\tself.self.attachEffect(\"link_dust_cloud\", { scaleY: 0.8 });\n\tself.self.setGlobalVariable(\"nStoredLabel\", null);\n\tself.self.setGlobalVariable(\"sStoredLabel\", null);\n\tself.self.setXSpeed(self.self.getXSpeed() * 0.3);\n\tself.self.addEventListener(SSF2Event.CHAR_ATTACK_COMPLETE, self.self.toHelpless);\n}\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "fbab76a3-a73b-5d96-8339-2df8113a0055",
      "code": "self.self.playVoiceSound(1);\nself.self.playAttackSound(1);\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "e8ae4441-665e-5de8-928e-8ea612ba30fe",
      "code": "self.self.updateAttackStats({ air_ease: 0 });\nself.self.createTimer(1, 21, self.uSpecConstant);\nself.self.createTimer(4, 21, self.playWind);\nself.self.attachEffect(\"global_sparkle\", { x: self.flipX(-10) });\nself.self.addEffectToList(self.self.attachEffect(\"slash_link_uspeca\", { scaleX: 1.1, scaleY: 1.1, parentLock: true, syncHitStun: true }));\nself.self.clearEffectsOnStateChange();\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "b9d06be9-a4c4-5a48-9573-5d3a45db8f93",
