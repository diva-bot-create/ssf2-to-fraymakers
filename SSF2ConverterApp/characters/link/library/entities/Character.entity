    {
      "$id": "968b2f6f-6c75-5f24-a398-2ac8fd245bc2",
      "code": "self.self = /* ? */;\nif ((parent && SSF2API.isReady()) || self.self) {\n\tself.self.setGlobalVariable(\"nStoredLabel\", null);\n\tself.self.setGlobalVariable(\"sStoredLabel\", null);\n}\nif ((parent && SSF2API.isReady()) || self.self) {\n\tself.playsound = SSF2API.random();\n\tself.audio = self.self.getGlobalVariable(\"audio\");\n}\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "fdc31ee5-c18e-5e3d-9d7d-de4faeb4df92",
      "code": "",
      "length": 3,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "3092442d-1778-591a-8ad4-c28b748f295b",
      "code": "self.self.playAttackSound(1);\nself.self.attachEffect(\"global_dust_light\");\nself.self.pushEffectBehind(self.self.addEffectToList(self.self.attachEffect(\"slash_link_utilt\", { scaleX: 1.1, scaleY: 1.1, parentLock: true, syncHitStun: true })));\nself.self.clearEffectsOnStateChange();\nif ((self.playsound > 0.2 && self.playsound <= 0.4) || self.audio != 1) {\n\tself.self.playVoiceSound(1);\n\tself.self.setGlobalVariable(\"audio\", 1);\n}\nif ((self.playsound > 0.4 && self.playsound <= 0.6) || self.audio != 2) {\n\tself.self.playVoiceSound(2);\n\tself.self.setGlobalVariable(\"audio\", 2);\n}\nif ((self.playsound > 0.6 && self.playsound <= 0.8) || self.audio != 3) {\n\tself.self.playVoiceSound(3);\n\tself.self.setGlobalVariable(\"audio\", 3);\n}\nif ((self.playsound > 0.8 && self.playsound <= 1) || self.audio != 4) {\n\tself.self.playVoiceSound(4);\n\tself.self.setGlobalVariable(\"audio\", 4);\n}\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "95eb76bf-bba4-5d32-87ba-a7479b9ba70d",
      "code": "",
      "length": 8,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "c8cf937e-363f-53df-800b-eb557fa2264a",
      "code": "self.self.endAttack();\nreturn;",
