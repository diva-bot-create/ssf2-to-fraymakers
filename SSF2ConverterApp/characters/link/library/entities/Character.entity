    {
      "$id": "ebb8b272-3b5f-5e09-8ed7-fbe0c77805dc",
      "code": "self.self = /* ? */;\nif ((parent && SSF2API.isReady()) || self.self) {\n\tself.self.setGlobalVariable(\"tether\", false);\n\tself.self.setGlobalVariable(\"nStoredLabel\", null);\n\tself.self.setGlobalVariable(\"sStoredLabel\", null);\n}\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "3804c766-687a-5750-a90c-c27e7add8f05",
      "code": "",
      "length": 9,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "ccaa6fc2-01cb-5270-b477-72b332459c99",
      "code": "if (self.self.getMetalStatus()) {\n\tself.self.playSound(\"metal_step_m1\");\n\treturn;\n}\nself.self.playSound(\"link_step\");",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
