    },
    {
      "$id": "60e29df6-9a55-53d2-b489-220f1735de05",
      "code": "self.self = /* ? */;\nself.done = false;\nif ((SSF2API.isReady() && self.self) || self.self.getGlobalVariable(\"screwAttackOn\")) {\n}",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "321a72a8-7c74-54dd-b170-5da3add0cf89",
      "code": "self.self.playSound(\"link_jump01\");\nif (self.self.getMetalStatus()) {\n} else {\n\tself.self.playSound(\"link_jump_vfx\", true);\n}\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "d11df170-caf4-58b0-bf65-36ad72ab3159",
      "code": "",
      "length": 11,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "6bd9ef09-976d-5fbc-80de-38bdaf5f26c8",
      "code": "self.done = true;\nself.stop();\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "0a69c441-09c9-5671-b474-20a257a248c5",
      "code": "self.self.stancePlayFrame(\"done\");\nreturn;",
