      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "15c02d07-405f-5c5d-9944-2fbd29a109b2",
      "code": "self.self.addEventListener(SSF2Event.GROUND_TOUCH, self.jumpToContinue);\nself.self.removeEventListener(SSF2Event.GROUND_TOUCH, self.self.toIdle);\nself.self.playAttackSound(1);\nself.self.addEffectToList(self.self.attachEffect(\"slash_link_uair\", { scaleX: 1.1, scaleY: 1.1, parentLock: true, syncHitStun: true }));\nself.self.clearEffectsOnStateChange();\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "518edd76-bc52-54a8-b88c-72744a2e4da0",
      "code": "if ((self.playsound > 0.2 && self.playsound <= 0.4) || self.audio != 1) {\n\tself.self.playVoiceSound(1);\n\tself.self.setGlobalVariable(\"audio\", 1);\n}\nif ((self.playsound > 0.4 && self.playsound <= 0.6) || self.audio != 2) {\n\tself.self.playVoiceSound(2);\n\tself.self.setGlobalVariable(\"audio\", 2);\n}\nif ((self.playsound > 0.6 && self.playsound <= 0.8) || self.audio != 3) {\n\tself.self.playVoiceSound(3);\n\tself.self.setGlobalVariable(\"audio\", 3);\n}\nif ((self.playsound > 0.8 && self.playsound <= 1) || self.audio != 4) {\n\tself.self.playVoiceSound(4);\n\tself.self.setGlobalVariable(\"audio\", 4);\n}\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "1bd8904b-61b0-58d6-9ceb-582c652b8bf5",
