    },
    {
      "$id": "0797a220-47a1-56e5-b5af-2fc88caee830",
      "code": "if ((parent && SSF2API.isReady()) || self.self) {\n\tself.self.setGlobalVariable(\"nStoredLabel\", null);\n\tself.self.setGlobalVariable(\"sStoredLabel\", null);\n\tself.self.setLandingLag(false);\n}\nself.self = /* ? */;\nif ((parent && SSF2API.isReady()) || self.self) {\n\tself.playsound = SSF2API.random();\n\tself.audio = self.self.getGlobalVariable(\"audio\");\n}\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "21f06f98-7ada-51d2-9501-20e7e5aec010",
      "code": "self.self.playAttackSound(1);\nself.self.setLandingLag(true);\nif ((self.playsound > 0.2 && self.playsound <= 0.4) || self.audio != 1) {\n\tself.self.playVoiceSound(1);\n\tself.self.setGlobalVariable(\"audio\", 1);\n}\nif ((self.playsound > 0.4 && self.playsound <= 0.6) || self.audio != 2) {\n\tself.self.playVoiceSound(2);\n\tself.self.setGlobalVariable(\"audio\", 2);\n}\nif ((self.playsound > 0.6 && self.playsound <= 0.8) || self.audio != 3) {\n\tself.self.playVoiceSound(3);\n\tself.self.setGlobalVariable(\"audio\", 3);\n}\nif ((self.playsound > 0.8 && self.playsound <= 1) || self.audio != 4) {\n\tself.self.playVoiceSound(4);\n\tself.self.setGlobalVariable(\"audio\", 4);\n}\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "e77c9bba-1c9c-5348-86ba-7353960974b9",
      "code": "self.self.attachEffect(\"global_dust_blast\", { x: self.self.flipX(42), y: -33, parentLock: true });\nself.self.addEffectToList(self.self.attachEffect(\"trail_link_nair\", { scaleX: 1.1, scaleY: 1.1, parentLock: true, syncHitStun: true }));\nself.self.clearEffectsOnStateChange();\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "c205048e-45e0-506a-ac93-fa923d808232",
      "code": "",
      "length": 4,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "c99e94e4-f569-5fe2-bbd8-4bfb8041ef3e",
      "code": "self.self.updateAttackBoxStats(1, { damage: 6, power: 15 });\nself.self.updateAttackBoxStats(2, { damage: 6, power: 15 });\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
