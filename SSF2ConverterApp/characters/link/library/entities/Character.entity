    {
      "$id": "23a598ad-ba42-51df-ac44-1b049db0c1e7",
      "code": "self.self.setLandingLag(true);\nself.self.pushEffectBehind(self.self.addEffectToList(self.self.attachEffect(\"slash_link_fairb\", { scaleX: 1.1, scaleY: 1.1, parentLock: true, syncHitStun: true })));\nself.self.clearEffectsOnStateChange();\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
