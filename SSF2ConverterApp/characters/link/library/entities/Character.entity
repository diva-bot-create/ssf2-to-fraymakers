      "code": "self.self = /* ? */;\nif ((parent && SSF2API.isReady()) || self.self) {\n\tself.self.setGlobalVariable(\"tether\", false);\n\tself.self.setGlobalVariable(\"nStoredLabel\", null);\n\tself.self.setGlobalVariable(\"sStoredLabel\", null);\n\tSSF2API.getCamera().shake(2);\n\tif (self.self.getMetalStatus()) {\n\t\tself.self.playSound(\"metal_land_m\");\n\t\treturn;\n\t}\n\tself.self.playSound(\"link_landHeavy\");\n}",
