      "code": "self.self.setGlobalVariable(\"LinkNSpecSFX\", self.self.playAttackSound(1));\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "2cbebb1f-d39b-5d18-ab8b-e6a763294b23",
      "code": "",
