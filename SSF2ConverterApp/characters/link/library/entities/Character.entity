    {
      "$id": "6a3f3b7c-eb2f-564a-94d9-da02c432c1da",
      "code": "self.self = /* ? */;\nself.speed = -23;\nself.updateStats = true;\nif (SSF2API.isReady() && self.self) {\n}\n}\n\n\nfunction b_up__frame0() {\nself.self = /* ? */;\nself.xframe = null;\nself.chargeCount = 13;\nif ((parent && SSF2API.isReady()) || self.self) {\n\tself.self.setGlobalVariable(\"nStoredLabel\", null);\n\tself.self.setGlobalVariable(\"sStoredLabel\", null);\n}\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "a37ac098-48b9-5782-9512-e6a80e9891a2",
      "code": "self.self.setXSpeed(self.self.getXSpeed() / 2);\nself.self.playSound(\"screw1\");\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "e3e66099-e91d-57de-981f-e9234616702f",
      "code": "self.self.createTimer(1, 10, self.moveUp);\nself.self.setYSpeed(-23);\nself.self.playSound(\"screw2\");\nreturn;\n}\n\n\nfunction b_up__frame2() {\nself.self.attachEffect(\"global_sparkle\", { x: self.flipX(-25), y: -50 });\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "9e863826-551c-58c7-b11f-a1c3efc66b16",
      "code": "self.xframe = \"charging\";\nself.self.attachEffect(\"link_dust_swirl\");\nself.self.attachEffect(\"link_dust_light\");\nself.self.playAttackSound(self.chargeCount);\nreturn;",
