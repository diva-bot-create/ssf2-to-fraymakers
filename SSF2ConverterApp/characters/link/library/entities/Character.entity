    {
      "$id": "8211917b-86cd-5b11-a51a-ce4ec893fdfd",
      "length": 23,
      "name": "throw_down",
      "pluginMetadata": {},
      "type": "LABEL"
    },
    {
      "$id": "f2918457-44a0-5389-ac8a-31621d771778",
      "code": "self.self = /* ? */;\nif ((parent && SSF2API.isReady()) || self.self) {\n\tself.playsound = SSF2API.random();\n\tself.audio = self.self.getGlobalVariable(\"audio\");\n}\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "d04c64dc-c914-5892-b872-25f839097bde",
      "code": "self.self.playSound(\"link_kickwind\");\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "b327a3d1-7eb3-51f8-9b64-0ce13ebe3c16",
      "code": "",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "a75fb1a5-7139-5f44-b255-9132415b4792",
      "code": "self.self.forceGrabbedHurtFrame(\"downed\");\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "74f7aee2-ac41-517d-ba77-f5fe0c403377",
      "code": "self.self.swapDepthsWithGrabbedOpponent(true);\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "dcbc77fa-e340-5073-9a42-8b5cc44d8167",
      "code": "",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "6bdb8d9f-8885-5a4f-a3ce-2fb72c0c65a9",
      "code": "if ((self.playsound > 0.2 && self.playsound <= 0.4) || self.audio != 1) {\n\tself.self.playVoiceSound(1);\n\tself.self.setGlobalVariable(\"audio\", 1);\n}\nif ((self.playsound > 0.4 && self.playsound <= 0.6) || self.audio != 2) {\n\tself.self.playVoiceSound(2);\n\tself.self.setGlobalVariable(\"audio\", 2);\n}\nif ((self.playsound > 0.6 && self.playsound <= 0.8) || self.audio != 3) {\n\tself.self.playVoiceSound(3);\n\tself.self.setGlobalVariable(\"audio\", 3);\n}\nif ((self.playsound > 0.8 && self.playsound <= 1) || self.audio != 4) {\n\tself.self.playVoiceSound(4);\n\tself.self.setGlobalVariable(\"audio\", 4);\n}\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "1bd51f9e-d07b-5cbd-bcdf-c55e46e6aa4e",
      "code": "",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "ed417838-8db7-5be4-8b22-2c500240c4ff",
      "code": "self.self.playSound(\"link_kickwind\");\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "0752f797-0b66-5303-99a2-cbb0362f83b5",
      "code": "",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "6d6c1118-3767-5de2-97f1-368885339849",
      "code": "self.self.attachEffect(\"global_dust_cloud\");\nif (self.self.getMetalStatus()) {\n\tself.self.playSound(\"metal_land_l\");\n}\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "01aceb02-6e19-5db3-bd7d-c70ac02db842",
      "code": "return;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "f37c8979-8af1-5fdf-917f-31828da50461",
      "code": "self.self.swapDepthsWithGrabbedOpponent(false);\nif (self.self.getMetalStatus()) {\n\tself.self.playSound(\"metal_land_m\");\n}\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "993248d7-db07-5ed0-bcb7-e3f9cacb5d79",
      "code": "",
      "length": 9,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
