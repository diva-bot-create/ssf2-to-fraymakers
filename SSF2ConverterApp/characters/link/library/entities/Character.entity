    {
      "$id": "ea3f4f30-915e-56a3-a4d9-da57a4a9899e",
      "length": 10,
      "name": "tilt_forward",
      "pluginMetadata": {},
      "type": "LABEL"
    },
    {
      "$id": "a5f7ba47-1ee9-5a20-b57d-fb6e96ba312c",
      "length": 10,
      "name": "remove",
      "pluginMetadata": {},
      "type": "LABEL"
    },
    {
      "$id": "43a52f9e-ee31-576e-aafa-bf8fe07416d6",
      "code": "self.self = /* ? */;\nif ((parent && SSF2API.isReady()) || self.self) {\n\tself.playsound = SSF2API.random();\n\tself.audio = self.self.getGlobalVariable(\"audio\");\n\tself.self.setGlobalVariable(\"nStoredLabel\", null);\n\tself.self.setGlobalVariable(\"sStoredLabel\", null);\n}\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "27c7764f-41c6-591a-a10a-5dfdef71b9ef",
      "code": "",
      "length": 6,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "dc9fc75d-31bb-52ea-a4c2-e29a8295f75f",
      "code": "self.self.addEffectToList(self.self.attachEffect(\"slash_link_ftilt\", { scaleX: 1.1, scaleY: 1.1, parentLock: true, syncHitStun: true }));\nself.self.clearEffectsOnStateChange();\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "f6d5fb7f-fc0d-5df9-aaaf-fa8f0e92eb54",
      "code": "",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "5f777e6b-4190-5d39-9f3f-ee54d2125558",
      "code": "self.self.attachEffect(\"global_dust_light\");\nself.self.playAttackSound(1);\nif (self.self.getMetalStatus()) {\n\tself.self.playSound(\"metal_step_m1\");\n}\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "1a5ccf2c-9d6f-5989-a26f-d543a25f8530",
      "code": "if ((self.playsound > 0.2 && self.playsound <= 0.4) || self.audio != 1) {\n\tself.self.playVoiceSound(1);\n\tself.self.setGlobalVariable(\"audio\", 1);\n}\nif ((self.playsound > 0.4 && self.playsound <= 0.6) || self.audio != 2) {\n\tself.self.playVoiceSound(2);\n\tself.self.setGlobalVariable(\"audio\", 2);\n}\nif ((self.playsound > 0.6 && self.playsound <= 0.8) || self.audio != 3) {\n\tself.self.playVoiceSound(3);\n\tself.self.setGlobalVariable(\"audio\", 3);\n}\nif ((self.playsound > 0.8 && self.playsound <= 1) || self.audio != 4) {\n\tself.self.playVoiceSound(4);\n\tself.self.setGlobalVariable(\"audio\", 4);\n}\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "71970e25-4d0e-50d0-a965-4b8231477d4a",
      "code": "",
      "length": 8,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "caa12118-6dd9-5414-8c58-ceb5358f4623",
      "code": "self.self.endAttack();\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
