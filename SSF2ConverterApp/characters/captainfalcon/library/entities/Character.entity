    },
    {
      "$id": "97cd7fe3-8adb-5000-adaa-67551f6587c0",
      "code": "self.self = /* ? */;\nself.hasHit = false;\nif (SSF2API.isReady()) {\n\tself.self.playVoiceSound(1);\n}\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "9f602757-8b79-568c-9d3c-4372c94b23dc",
      "code": "",
      "length": 3,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "2b66d6c6-447d-5f7d-b296-7780518c06dd",
      "code": "self.self.setXSpeed(-5, false);\nself.self.attachEffect(\"global_dust_heavy\");\nself.self.updateAttackStats({ air_ease: 0 });\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "b3b2da6d-89d8-57bd-ba2d-20512a98cce8",
      "code": "",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "f133215f-a1ed-5d3f-8ac7-a626faa127fd",
      "code": "self.self.playAttackSound(1);\nself.self.createTimer(1, 13, self.physics);\nself.self.fireProjectile(\"captainfalcon_dspecProj\");\nself.projectile = self.self.getCurrentProjectile();\nself.self.addEventListener(SSF2Event.HIT_WALL, self.crash);\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "52a08095-6cf8-5ebf-8e5b-7e566e7418b2",
      "code": "",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "4d317b1a-a256-5464-8faa-fe791572ed55",
      "code": "self.self.updateAttackBoxStats(1, { damage: 12, kbConstant: 60 });\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "d4c0b2d5-fa1f-55b7-8742-a2cc5444f992",
      "code": "",
      "length": 3,
      "pluginMetadata": {},
