      "$id": "ef282fa2-5bd4-56f3-a663-f8c111fadf76",
      "code": "self.self = /* ? */;\nif (self.self && SSF2API.isReady()) {\n}",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "00f20d49-93f5-57e2-b6ff-04c33495a489",
      "code": "",
      "length": 27,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "eb22f2ac-010e-5ca9-a2fe-a571119dcb9e",
      "code": "self.self.destroyTimer(self.effects);\nself.self.updateAttackStats({ superArmor: true });\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "2dffaa0d-b846-5163-930d-01432fa6db0b",
      "code": "",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "36a4a9f1-6f5a-5b13-bfad-71f518e9ff69",
      "code": "self.self.getItem().activateItem();\nself.self.playAttackSound(1);\nself.self.playVoiceSound(1);\nSSF2API.getCamera().shake(6);\nself.self.attachEffect(\"global_dust_heavy\", { x: self.self.flipX(5), y: 3, scaleX: -0.75, scaleY: -0.75 });\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "8bd5abb2-e78e-56d5-aa03-97872631f875",
      "code": "",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "825b6d4d-62cb-5a2e-9dbe-34be663fa8e0",
      "code": "self.self.getItem().deactivateItem();\nself.self.updateAttackStats({ superArmor: false });\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "93360e72-8608-576d-93bd-a636e7740683",
      "code": "",
