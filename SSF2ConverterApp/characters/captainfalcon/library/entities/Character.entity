    {
      "$id": "5ccd3def-288c-5419-9909-04b5c4140fe3",
      "length": 19,
      "name": "aerial_forward",
      "pluginMetadata": {},
      "type": "LABEL"
    },
    {
      "$id": "5cc61ae8-8921-5c95-9dac-27633d910f67",
      "code": "self.self = /* ? */;\nif (SSF2API.isReady()) {\n\tself.playsound = SSF2API.random();\n\tself.audio = self.self.getGlobalVariable(\"audio\");\n\tself.self.setLandingLag(false);\n}\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "ed3460eb-5b5c-58dc-8fa8-2e2f4eb85090",
      "code": "",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "a2a72a5e-579f-5732-90e8-2bcab2452c7d",
      "code": "self.self.setLandingLag(true);\nself.self.attachEffect(\"global_spark\", { x: self.flipX(23), y: -20 });\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "90b8e3fe-8391-55a9-8524-7567e1907586",
      "code": "",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "eaf1f2ee-ab2d-51ef-962c-6d49ef980619",
      "code": "self.self.addEffectToList(self.self.attachEffect(\"cfalcon_fairsparkle\", { x: self.self.flipX(33), y: -20, parentLock: true }));\nself.self.clearEffectsOnStateChange();\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "bccfeabc-e0ff-5432-bd72-7b01774d8b9f",
      "code": "",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "a3460959-c2f3-5b19-bf62-abc3f3137291",
      "code": "self.self.attachEffect(\"wind_wave\", { x: self.self.flipX(28), y: -20, scaleX: 0.6, scaleY: 0.6, parentLock: true });\nif ((self.playsound > 0.2 && self.playsound <= 0.4) || self.audio != 1) {\n\tself.self.playVoiceSound(1);\n\tself.self.setGlobalVariable(\"audio\", 1);\n}\nif ((self.playsound > 0.4 && self.playsound <= 0.6) || self.audio != 2) {\n\tself.self.playVoiceSound(2);\n\tself.self.setGlobalVariable(\"audio\", 2);\n}\nif ((self.playsound > 0.6 && self.playsound <= 0.8) || self.audio != 3) {\n\tself.self.playVoiceSound(3);\n\tself.self.setGlobalVariable(\"audio\", 3);\n}\nif ((self.playsound > 0.8 && self.playsound <= 1) || self.audio != 4) {\n\tself.self.playVoiceSound(4);\n\tself.self.setGlobalVariable(\"audio\", 4);\n}\nself.self.playAttackSound(1);\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "b34b3505-c09c-51d2-8636-9116ffbb6b63",
      "code": "self.self.updateAttackBoxStats(1, { damage: 6, direction: 42, power: 35, kbConstant: 80, shock: false, hitStun: 2, selfHitStun: 1, effect_id: \"effect_hit2\", effectSound: \"brawl_kick_s\" });\nself.self.updateAttackBoxStats(2, { damage: 6, direction: 42, power: 35, kbConstant: 80, shock: false, hitStun: 2, selfHitStun: 1, effect_id: \"effect_hit2\", effectSound: \"brawl_kick_s\" });\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "5c6ea824-167b-5b9b-9e68-64594c31a006",
      "code": "",
      "length": 8,
      "pluginMetadata": {},
