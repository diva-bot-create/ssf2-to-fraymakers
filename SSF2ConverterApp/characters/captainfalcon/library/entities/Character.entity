    },
    {
      "$id": "6cd17729-eb8e-5fd0-8099-bbad08766c9b",
      "code": "self.self.updateAttackStats({ xSpeedDecay: 0.75, xSpeedDecayAir: 0.875 });\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "2808851e-e2bf-5ce1-afcd-c15f4ac1d3ef",
      "code": "",
      "length": 1,
      "pluginMetadata": {},
