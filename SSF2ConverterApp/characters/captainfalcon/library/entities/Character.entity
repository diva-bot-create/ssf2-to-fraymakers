    },
    {
      "$id": "03f56cbf-1f25-5108-9592-d560a3663ac9",
      "code": "self.self = /* ? */;\nself.horiz = 7;\nif (SSF2API.isReady() && self.self) {\n}",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "62885f9f-30b9-50b4-9a87-516dd87cfea7",
      "code": "",
      "length": 3,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "6a8b9c18-0349-52b1-9523-abc7c43571c7",
      "code": "self.self.createTimer(1, 0, self.alterHoriz);\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "45f969ac-8cf0-5805-9cfe-027ff7d7734f",
      "code": "self.self.attachEffect(\"global_sparkle\", { x: self.flipX(18), y: -5 });\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "9eef8f20-c0b5-561c-9650-1210615f9583",
      "code": "",
      "length": 2,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "e0882995-6daf-5247-a2cc-4af54d8b80d2",
      "code": "self.self.playAttackSound(3);\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "545c0b51-360b-5b73-af75-9e206aa01c2f",
      "code": "self.self.setXSpeed(self.horiz, false);\nself.self.setYSpeed(-23);\nself.self.createTimer(1, 14, self.checkGrabbed);\nself.self.createTimer(1, 3, self.afterImage);\nself.self.destroyTimer(self.alterHoriz);\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "915ece64-b95b-54bc-85cf-4544468ffe23",
      "code": "self.self.updateAttackStats({ allowControl: true, air_ease: 2 });\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "936dcba2-c05c-5c9c-9d43-ddfb0bb6651d",
      "code": "self.self.createTimer(2, 3, self.afterImage);\nself.self.updateAttackStats({ xSpeedCap: 7 });\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "c5d72389-e523-5b59-a872-2da5460f7bc2",
      "code": "",
      "length": 4,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "39b6ce44-3d6a-566b-9d42-e8449fadc4c0",
      "code": "self.self.createTimer(3, 2, self.afterImage);\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "cbf950cd-841c-5299-bca3-e4888df5dae5",
      "code": "if (self.self.isOnGround()) {\n\tself.self.toHeavyLand();\n}\nself.self.addEventListener(SSF2Event.GROUND_TOUCH, self.self.toHeavyLand);\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "6cd35a45-1395-54a7-a54e-e35e6d3da81d",
      "code": "",
      "length": 3,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "55ffd95b-efd4-50ba-9269-aa75c998df16",
      "code": "self.self.playSound(\"raptorBoost1\");\nself.self.updateAttackStats({ air_ease: -1 });\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "aaef09bb-8f01-5e4e-8114-ef14fc52708e",
      "code": "self.self.updateAttackStats({ xSpeedDecayAir: -1.65 });\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "04346a30-09e2-555d-ac94-fe5c520bbd38",
      "code": "",
      "length": 4,
