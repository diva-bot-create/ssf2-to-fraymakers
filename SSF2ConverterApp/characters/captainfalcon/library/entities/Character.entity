    {
      "$id": "bb8c253c-164e-55fd-9eb5-82587ea4c569",
      "code": "self.self = /* ? */;\nif (SSF2API.isReady()) {\n\tself.self.setLandingLag(false);\n}\nif (SSF2API.isReady()) {\n\tself.playsound = SSF2API.random();\n\tself.audio = self.self.getGlobalVariable(\"audio\");\n}\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "48c0fa07-3081-5629-9317-b0c5051b8387",
      "code": "",
      "length": 2,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "c54d8951-a050-532b-aab4-e2ad872c2229",
      "code": "self.self.playAttackSound(1);\nself.self.setLandingLag(true);\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "2b6506d7-5c74-5a4c-b8ee-a40282ef847d",
      "code": "self.self.attachEffect(\"global_dust_blast\", { x: self.self.flipX(-28), y: -25, parentLock: true });\nself.self.addEffectToList(self.self.attachEffect(\"trail_cfalcon_bair\", { y: 10, scaleX: 1.15, scaleY: 1.15, parentLock: true, syncHitStun: true }));\nself.self.clearEffectsOnStateChange();\nif ((self.playsound > 0.2 && self.playsound <= 0.4) || self.audio != 1) {\n\tself.self.playVoiceSound(1);\n\tself.self.setGlobalVariable(\"audio\", 1);\n}\nif ((self.playsound > 0.4 && self.playsound <= 0.6) || self.audio != 2) {\n\tself.self.playVoiceSound(2);\n\tself.self.setGlobalVariable(\"audio\", 2);\n}\nif ((self.playsound > 0.6 && self.playsound <= 0.8) || self.audio != 3) {\n\tself.self.playVoiceSound(3);\n\tself.self.setGlobalVariable(\"audio\", 3);\n}\nif ((self.playsound > 0.8 && self.playsound <= 1) || self.audio != 4) {\n\tself.self.playVoiceSound(4);\n\tself.self.setGlobalVariable(\"audio\", 4);\n}\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "f1b9ea3c-35e9-5ef8-bd4f-90fdede60cb3",
      "code": "",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "7138e388-c200-5949-8db3-3ed380d6b63d",
      "code": "self.self.updateAttackBoxStats(1, { damage: 8, direction: 45, power: 20, kbConstant: 100, hitStun: 3, selfHitStun: 1 });\nself.self.updateAttackBoxStats(2, { damage: 8, direction: 45, power: 20, kbConstant: 100 });\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "a6b9a674-8c18-5f89-8020-5be756c4c206",
