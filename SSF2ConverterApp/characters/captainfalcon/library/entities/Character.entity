    {
      "$id": "edffc5f8-da25-5812-bf94-b970f4e31a4c",
      "code": "self.self.removeAllEffects();\nSSF2API.getCamera().shake(2);\nif (self.self.getMetalStatus()) {\n\tself.self.playSound(\"metal_land_m\");\n\treturn;\n}\nself.self.playSound(\"falcon_dspecLand\");",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
