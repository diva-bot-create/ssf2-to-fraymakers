      "code": "self.self.resetJumps();\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "944dd01c-3794-5429-91d7-2eef6c615a42",
      "code": "",
