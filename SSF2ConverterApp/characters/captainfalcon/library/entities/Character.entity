    {
      "$id": "a094ca92-90ac-5d73-b482-f6e67d3d0db5",
      "length": 25,
      "name": "throw_back",
      "pluginMetadata": {},
      "type": "LABEL"
    },
    {
      "$id": "2940d47a-d772-5a89-88ca-124bf3636cf1",
      "code": "if (SSF2API.isReady()) {\n\tself.self = /* ? */;\n\tself.playsound = SSF2API.random();\n\tself.audio = self.self.getGlobalVariable(\"audio\");\n\tself.self.swapDepthsWithGrabbedOpponent(true);\n}\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "b211888b-485d-5e28-bb93-e878da5f520e",
      "code": "self.self.playSound(\"cfalcon_kickwind\");\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "34e50f40-f854-5cb8-b0a9-f19b6df8305f",
      "code": "self.self.swapDepthsWithGrabbedOpponent(false);\nif ((self.playsound > 0.2 && self.playsound <= 0.4) || self.audio != 1) {\n\tself.self.playVoiceSound(1);\n\tself.self.setGlobalVariable(\"audio\", 1);\n}\nif ((self.playsound > 0.4 && self.playsound <= 0.6) || self.audio != 2) {\n\tself.self.playVoiceSound(2);\n\tself.self.setGlobalVariable(\"audio\", 2);\n}\nif ((self.playsound > 0.6 && self.playsound <= 0.8) || self.audio != 3) {\n\tself.self.playVoiceSound(3);\n\tself.self.setGlobalVariable(\"audio\", 3);\n}\nif ((self.playsound > 0.8 && self.playsound <= 1) || self.audio != 4) {\n\tself.self.playVoiceSound(4);\n\tself.self.setGlobalVariable(\"audio\", 4);\n}\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "25954d33-527d-5dc6-adb7-600f428b7e2d",
      "code": "",
      "length": 2,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "6e6b3e2f-afbe-55ce-9db9-0b4f14511d25",
      "code": "SSF2API.getCamera().shake(1);\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "a12ab8b7-5b43-53d3-9cdd-751aeb3b6d80",
      "code": "",
      "length": 4,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "ca410c01-9491-585a-a5af-9ac04121bd26",
      "code": "self.self.swapDepthsWithGrabbedOpponent(true);\nself.self.refreshAttackID();\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "25202263-9f22-55eb-a0b5-dff952521d49",
      "code": "",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "156c666e-e431-5a6a-b839-0d4baa540515",
      "code": "SSF2API.getCamera().shake(9);\nreturn;",
      "length": 1,
      "pluginMetadata": {},
