    },
    {
      "$id": "a4339b16-98e0-5bc6-b73e-c3523432f9c9",
      "code": "if (self.self.getMetalStatus()) {\n\tSSF2API.playSound(\"metal_step_m1\");\n\treturn;\n}\nSSF2API.playSound(\"falcon_footstep\");",
