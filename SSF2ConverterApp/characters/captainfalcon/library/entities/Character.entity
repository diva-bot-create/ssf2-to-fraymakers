    },
    {
      "$id": "fb90793d-bb0e-5f9f-9691-137570f3d578",
      "code": "self.hasHit = false;\nif (SSF2API.isReady()) {\n\tself.self = /* ? */;\n\tself.self.addEventListener(SSF2Event.GROUND_TOUCH, self.toFrame);\n\tself.self.addEventListener(SSF2Event.GROUND_TOUCH, self.self.resetMovement);\n\tself.self.addEventListener(SSF2Event.HIT_WALL, self.crash);\n}\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "6c3c2835-ed6c-583b-b2e9-3ea89eed2eee",
      "code": "self.self.playVoiceSound(1);\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "180cccb6-c7be-5014-b2b3-ae0df1d41820",
      "code": "self.self.setYSpeed(-8);\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "37df2033-4ada-5fe5-a82f-0bb28465aaae",
      "code": "",
      "length": 5,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "0db98e1c-d396-554a-8a32-7fed33c14aa1",
      "code": "self.self.updateAttackStats({ air_ease: -1 });\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "2073630a-5604-5cd6-856b-0e6136c765b6",
      "code": "self.self.createTimer(1, 7, self.physics);\nself.self.playAttackSound(1);\nself.self.fireProjectile(\"captainfalcon_dspecairProj\", 0, 5);\nself.projectile = self.self.getCurrentProjectile();\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "8a37a4c0-1c06-50c7-b75d-3afdeab9817d",
      "code": "",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "d708ec8d-38b1-5919-8704-9d5c764fdfb8",
      "code": "self.self.updateAttackBoxStats(1, { damage: 13, kbConstant: 65 });\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "5820c733-940a-5588-aecd-7d60c8d01f36",
      "code": "",
