    {
      "$id": "b08a79c0-0f5b-58c1-ab96-48e6fc8d5e3e",
      "length": 16,
      "name": "tilt_forward",
      "pluginMetadata": {},
      "type": "LABEL"
    },
    {
      "$id": "67c4d56e-ad79-50b5-bef9-44c6f9f362a1",
      "code": "if (SSF2API.isReady()) {\n\tself.self = /* ? */;\n}\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "24310fed-e1dc-537a-ad48-25e2c52ba872",
      "code": "self.playsound = SSF2API.random();\nself.audio = self.self.getGlobalVariable(\"audio\");\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "a783d663-1d16-58a3-8098-ab4774e002b4",
      "code": "",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "48036060-455d-55f4-b6b6-81fea21caa50",
      "code": "if ((self.playsound > 0.2 && self.playsound <= 0.4) || self.audio != 1) {\n\tif (root != null && parent != null) {\n\t}\n\tif (/* ? */) {\n\t\tself.self.setGlobalVariable(\"audio\", 1);\n\t}\n}\nif ((self.playsound > 0.4 && self.playsound <= 0.6) || self.audio != 2) {\n\tif (root != null && parent != null) {\n\t}\n\tif (/* ? */) {\n\t\tself.self.setGlobalVariable(\"audio\", 2);\n\t}\n}\nif ((self.playsound > 0.6 && self.playsound <= 0.8) || self.audio != 3) {\n\tif (root != null && parent != null) {\n\t}\n\tif (/* ? */) {\n\t\tself.self.setGlobalVariable(\"audio\", 3);\n\t}\n}\nif ((self.playsound > 0.8 && self.playsound <= 1) || self.audio != 4) {\n\tif (root != null && parent != null) {\n\t}\n\tif (/* ? */) {\n\t\tself.self.setGlobalVariable(\"audio\", 4);\n\t}\n}\nif (root != null && parent != null) {\n}",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "30c933ec-b6f7-5f35-9dd3-ab005d8010d1",
      "code": "self.self.attachEffect(\"global_dust_light\");\nself.self.attachEffect(\"global_dust_swirl\");\nself.self.addEffectToList(self.self.attachEffect(\"trail_cfalcon_ftilt\", { scaleX: 1.15, scaleY: 1.15, parentLock: true, syncHitStun: true }));\nself.self.clearEffectsOnStateChange();\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "c2909e8f-32f1-5e2d-a75e-bf820843c698",
      "code": "",
      "length": 2,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "10e83829-2aeb-5f21-adf6-99bed35a7a75",
      "code": "self.self.setXSpeed(4, false);\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "40bb3f52-ffd6-5db2-81dd-c4704c745e73",
      "code": "",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "d64cd91d-b730-5499-b33f-26e8d495d29d",
      "code": "if (self.self.getMetalStatus()) {\n\tself.self.playSound(\"metal_step_m1\");\n}\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "30a2dcf1-de84-5fc6-8627-c0c239a0d9c1",
      "code": "",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "5309b9f7-f3d2-54e6-ae98-2258922c439b",
      "code": "if (self.self.getMetalStatus()) {\n\tself.self.playSound(\"metal_step_m2\");\n}\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "9c3aa9b9-bfd2-5e43-b4ff-710c7f8a7cde",
      "code": "",
      "length": 3,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "309b2e6f-a5bc-570e-9d85-769f783b9a47",
      "code": "self.self.endAttack();\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
