      "pluginMetadata": {},
      "type": "LABEL"
    },
    {
      "$id": "89049c45-c102-5a54-9764-ed3e6348a1c7",
      "code": "self.self = /* ? */;\nself.horiz = 7;\nif (SSF2API.isReady() && self.self) {\n}",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "95c28532-94a4-5a85-8cbb-16a86f4ae466",
      "code": "self.self.createTimer(1, 0, self.alterHoriz);\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "febe020c-1989-52ee-a91b-a4de63471a08",
      "code": "self.self.attachEffect(\"global_sparkle\", { x: self.flipX(18), y: 5 });\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "9e55a308-f63a-5a76-a30e-8dfcb672a708",
      "code": "",
      "length": 2,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "cae8f3c7-e6cc-59de-a45b-00ceb5474bd9",
      "code": "self.self.playAttackSound(3);\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "5a668adb-07f9-5c14-82dd-288cc2075270",
      "code": "self.self.setXSpeed(self.horiz, false);\nself.self.setYSpeed(-23);\nself.self.createTimer(1, 14, self.checkGrabbed);\nself.self.createTimer(1, 3, self.afterImage);\nself.self.destroyTimer(self.alterHoriz);\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "1e397395-a456-5d68-8038-accc226f4d93",
      "code": "self.self.updateAttackStats({ allowControl: true, air_ease: 2 });\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "cf508288-3109-58d1-a7e5-e1766e1fc3ed",
      "code": "self.self.createTimer(2, 3, self.afterImage);\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "79c19803-b550-5791-8409-81b0529b5114",
      "code": "",
      "length": 5,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "c0b86035-67e1-5cba-b956-3f8e9c729c09",
      "code": "self.self.createTimer(3, 2, self.afterImage);\nself.self.updateAttackStats({ xSpeedCap: 7 });\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "f2ba3ef6-eabe-5adb-8c20-538fab1d5212",
      "code": "if (self.self.isOnGround()) {\n\tself.self.toHeavyLand();\n}\nself.self.addEventListener(SSF2Event.GROUND_TOUCH, self.self.toHeavyLand);\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "f0aebddc-4215-5295-b239-94d57f6c77f6",
      "code": "",
      "length": 3,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "d3770b3a-22f9-5578-9481-950e1f4bcd81",
      "code": "self.self.playSound(\"raptorBoost1\");\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "46d89dfe-3854-5580-8d5f-74aa87685f67",
      "code": "",
      "length": 2,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "c902fe00-1ed0-5ab9-8271-a1b662011786",
      "code": "self.self.updateAttackStats({ xSpeedDecayAir: -1.65, air_ease: -1 });\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "96e8beb5-f283-5a00-b343-ef40303487d9",
      "code": "",
      "length": 8,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "29a7b931-6d4b-5f5c-a7ff-185a4e11e7fb",
      "code": "return;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "a43dde9f-a69f-5051-8ed2-6235af35786b",
      "code": "",
      "length": 7,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "d25d0980-6472-517e-9669-010ccbc522b9",
      "code": "if (self.self.isOnGround()) {\n\tself.self.toLand();\n\treturn;\n}\nself.self.setGlobalVariable(\"usedSpec\", true);\nself.self.toHelpless();",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "12457039-0da1-5cc1-af6b-61917d6775fd",
      "code": "self.self.resetMovement();\nself.self.updateAttackStats({ allowControl: false, air_ease: 0 });\nself.self.unnattachFromGround();\nself.self.removeEventListener(SSF2Event.CHAR_ATTACK_COMPLETE, self.self.toHelpless);\nself.self.removeEventListener(SSF2Event.GROUND_TOUCH, self.self.toHeavyLand);\nself.self.destroyTimer(self.checkGrabbed);\nself.self.destroyTimer(self.afterImage);\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "4afa93fb-9de6-50f6-be08-1c0cf06069fb",
      "code": "",
      "length": 2,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "6156474a-4a84-5e7e-b914-29b2d342f655",
      "code": "self.self.resetMovement();\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "3fecaf61-8d47-5b0d-bd46-3be1b995ab36",
      "code": "self.self.updateAttackBoxStats(1, { effect_id: \"effect_firehit_heavy\" });\nself.self.refreshAttackID();\nself.self.resetMovement();\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "e855291a-0c55-514d-bbe4-835e8fbd8d62",
      "code": "",
      "length": 3,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "ba6afbd0-8281-50f9-bbfd-8f18df161ff9",
      "code": "self.self.setXSpeed(-6, false);\nself.self.setYSpeed(-20);\nself.self.playAttackSound(2);\nself.foe = self.self.getGrabbedOpponent();\nself.self.releaseOpponent();\nif (self.foe) {\n\tself.foe.forceHitStun(1, 0);\n}\nself.self.attachEffect(\"effect_explosion\", { scaleX: 1.5, scaleY: 1.5, x: self.self.flipX(20), y: -25 });\nself.self.playVoiceSound(1);\nself.self.updateAttackStats({ air_ease: -1 });\nSSF2API.getCamera().shake(5);\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "d32f462d-b832-58d4-8ebb-62490f0c2b64",
