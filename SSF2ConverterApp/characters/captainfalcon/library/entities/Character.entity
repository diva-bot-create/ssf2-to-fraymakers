    {
      "$id": "fc74189f-8844-53d8-8ff5-cf999ec105e0",
      "length": 18,
      "name": "aerial_up",
      "pluginMetadata": {},
      "type": "LABEL"
    },
    {
      "$id": "5074b03f-4941-5983-b78c-86f65809b5e2",
      "code": "self.self = /* ? */;\nif (SSF2API.isReady()) {\n\tself.self.setLandingLag(false);\n}\nif (SSF2API.isReady()) {\n\tself.playsound = SSF2API.random();\n\tself.audio = self.self.getGlobalVariable(\"audio\");\n}\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "0e825a82-514e-562f-9264-1bca867badbd",
      "code": "",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "5356312b-80f6-57fc-8724-7a10288a1a4f",
      "code": "self.self.setLandingLag(true);\nself.self.addEffectToList(self.self.attachEffect(\"trail_cfalcon_uair\", { y: 5, scaleX: 1.15, scaleY: 1.15, parentLock: true, syncHitStun: true }));\nself.self.clearEffectsOnStateChange();\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "cbe25b6f-8f7d-594b-a18b-f37b26490917",
      "code": "",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "869e2baf-b5f6-557e-a74d-5129be7d3f58",
      "code": "self.self.playAttackSound(1);\nself.self.updateAttackBoxStats(1, { damage: 10, power: 15, kbConstant: 90 });\nself.self.updateAttackBoxStats(2, { damage: 10, power: 15, kbConstant: 90 });\nif ((self.playsound > 0.2 && self.playsound <= 0.4) || self.audio != 1) {\n\tself.self.playVoiceSound(1);\n\tself.self.setGlobalVariable(\"audio\", 1);\n}\nif ((self.playsound > 0.4 && self.playsound <= 0.6) || self.audio != 2) {\n\tself.self.playVoiceSound(2);\n\tself.self.setGlobalVariable(\"audio\", 2);\n}\nif ((self.playsound > 0.6 && self.playsound <= 0.8) || self.audio != 3) {\n\tself.self.playVoiceSound(3);\n\tself.self.setGlobalVariable(\"audio\", 3);\n}\nif ((self.playsound > 0.8 && self.playsound <= 1) || self.audio != 4) {\n\tself.self.playVoiceSound(4);\n\tself.self.setGlobalVariable(\"audio\", 4);\n}\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "5ad7b3f1-f66a-56e2-af43-29cf223106b0",
      "code": "self.self.updateAttackBoxStats(2, { direction: 30, damage: 8, power: 8, kbConstant: 80 });\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "95ac6067-df6b-55bf-b941-952828cdf08c",
      "code": "self.self.updateAttackBoxStats(1, { damage: 8, direction: 0, power: 6, kbConstant: 70, selfHitStun: 1, hitStun: 1, hitLag: -1 });\nself.self.updateAttackBoxStats(2, { damage: 6, direction: 0, power: 6, kbConstant: 70, selfHitStun: 1, hitStun: 1, hitLag: -1 });\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "cbf97cc9-2941-5d6e-9a22-ef161b4d43f2",
      "code": "",
      "length": 7,
