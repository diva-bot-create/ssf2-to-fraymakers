    },
    {
      "$id": "121ae2a9-ae30-5b4e-b3ca-92bddcc0e28e",
      "code": "self.self.getItem().activateItem();\nself.self.playAttackSound(1);\nself.self.attachEffect(\"global_dust_heavy\", { x: self.self.flipX(5), y: 3, scaleX: -0.5, scaleY: -0.5 });\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "4a1075c2-4c4d-5f0a-8643-7cdb314ced68",
      "code": "",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "0f521a4f-ee5f-5c0d-8f5f-aee3b7dced29",
      "code": "self.self.getItem().deactivateItem();\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "06af91f4-5f0d-5997-a2f5-cd8c7b39352d",
      "code": "",
      "length": 9,
