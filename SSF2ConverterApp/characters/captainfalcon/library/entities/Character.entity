    },
    {
      "$id": "3a6f65b3-5e27-5ebf-9714-8eec2dc3f085",
      "code": "if (SSF2API.isReady()) {\n\tself.self = /* ? */;\n\tself.self.setGlobalVariable(\"jab\", false);\n\tself.self.setGlobalVariable(\"jab2\", false);\n}\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "f9705599-ef40-529a-bfb8-8a5deb41b9b8",
      "code": "",
      "length": 5,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "5dc28d5b-3a03-5447-91cd-e396bee0c6ae",
      "code": "if (self.self.getMetalStatus()) {\n\tself.self.playSound(\"metal_step_m1\");\n\treturn;\n}\nself.self.playSound(\"falcon_footstep\");",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "8afdb5e5-5897-532e-90b8-9ea179c725be",
      "code": "",
      "length": 8,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "64cbe738-e9ef-51ae-8613-3d4f11bc13d3",
      "code": "if (self.self.getMetalStatus()) {\n\tself.self.playSound(\"metal_step_m2\");\n\treturn;\n}\nself.self.playSound(\"falcon_footstep2\");",
