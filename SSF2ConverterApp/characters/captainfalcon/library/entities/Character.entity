      "code": "if (SSF2API.isReady()) {\n} else {\n\treturn;\n}\nself.self = /* ? */;\nself.self.setGlobalVariable(\"jab\", false);\nself.self.setGlobalVariable(\"jab2\", false);\nif (self.self.getMetalStatus()) {\n} else {\n\tself.self.playSound(\"cfalcon_dizzy\", true);\n}",
