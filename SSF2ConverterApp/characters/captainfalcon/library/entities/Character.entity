    },
    {
      "$id": "edf6d3e4-1724-59a8-b338-aa98769359f5",
      "code": "self.self.endAttack();\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "60b29add-d11d-5a3f-980e-e31a070ee8fe",
      "code": "self.hasHit = true;\nself.self.resetMovement();\nself.self.setXSpeed(-8, false);\nself.self.setYSpeed(-11);\nself.self.updateAttackStats({ allowControl: true });\nself.self.destroyTimer(self.physics);\nself.self.removeEventListener(SSF2Event.GROUND_TOUCH, self.toFrame);\nif (self.projectile != null && !self.projectile.isDisposed()) {\n}",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
