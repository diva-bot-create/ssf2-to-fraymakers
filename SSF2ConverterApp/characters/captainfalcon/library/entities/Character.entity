    {
      "$id": "8f8d8e1e-0ad9-55ed-8129-f8d42d59a8ff",
      "length": 20,
      "name": "strong_up_attack",
      "pluginMetadata": {},
      "type": "LABEL"
    },
    {
      "$id": "ba1355a4-c1b9-5502-8c0a-baa63750572b",
      "code": "self.xframe = \"attack\";\nself.self.destroyTimer(self.effects);\nself.chargeTime = self.self.getExecTime() - 1;\nself.damageCharged = 2 * self.chargeTime / 40 + 4;\nself.self.updateAttackBoxStats(1, { damage: self.damageCharged });\nself.self.updateAttackBoxStats(2, { damage: self.damageCharged });\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "7b71cf6d-596f-5960-a081-4dfe309c4430",
      "code": "",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "329bf01b-6bbe-5cf7-9019-5cd632f10269",
      "code": "self.self.attachEffect(\"global_dust_cloud\");\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "db30b144-9b29-5aa5-8f2f-4f7d1ca597b6",
      "code": "self.self.playVoiceSound(1);\nself.self.playSound(\"cfalcon_smashstart\");\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "0e7bbcb0-ce1b-5fd6-bbbe-acaf11e53172",
      "code": "self.self.playAttackSound(1);\nself.self.addEffectToList(self.self.attachEffect(\"trail_cfalcon_usmash\", { y: 20, scaleX: 1.15, scaleY: 1.15, parentLock: true, syncHitStun: true }));\nself.self.clearEffectsOnStateChange();\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "e748dfd6-8fc8-5287-9c8e-b9b7a8908547",
      "code": "",
      "length": 3,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "50e922d8-57bd-5128-862d-7578b1f8b792",
      "code": "self.self.updateAttackBoxStats(1, { damage: 13, power: 30, kbConstant: 128, effectSound: \"brawl_kick_l\", weightKB: 0, direction: 70 });\nself.self.updateAttackBoxStats(2, { damage: 12, power: 30, kbConstant: 110, effectSound: \"brawl_kick_l\", weightKB: 0, direction: 70 });\nself.self.playSound(\"cfalcon_smashstart\");\nself.self.refreshAttackID();\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "f3fd5730-9c5d-51f8-819c-d37cb6c67e32",
      "code": "self.self.playAttackSound(1);\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "8d4a6568-0a21-5e0b-b8b1-995b7fb00cef",
      "code": "",
      "length": 3,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "a2954246-45ef-5fd5-bc19-cb8c76982cec",
      "code": "self.self.updateAttackStats({ air_ease: -1 });\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "913ef906-ccbb-5188-9f55-1a62f15057af",
      "code": "if (self.self.getMetalStatus()) {\n\tself.self.playSound(\"metal_land_s\");\n}\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "5ff16e1b-8d41-5f2a-b3a6-b3f44baac194",
      "code": "",
      "length": 4,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "c744172a-e34e-5fd0-8b21-572128d5af4b",
      "code": "self.self.endAttack();\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
