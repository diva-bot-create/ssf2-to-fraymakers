    {
      "$id": "ea3b10d1-fa4a-55dc-936e-2b8147348856",
      "length": 33,
      "name": "special_side",
      "pluginMetadata": {},
      "type": "LABEL"
    },
    {
      "$id": "4eb57787-86ca-5008-993f-be52983cc1d2",
      "length": 15,
      "name": "afterHit",
      "pluginMetadata": {},
      "type": "LABEL"
    },
    {
      "$id": "ad593eec-9911-57b9-8e6d-cc7df20cf0f5",
      "length": 15,
      "name": "fall",
      "pluginMetadata": {},
      "type": "LABEL"
    },
    {
      "$id": "d59504ab-4a52-59ae-87db-34a83f924103",
      "code": "self.self = /* ? */;\nself.hasHit = false;\nif (SSF2API.isReady()) {\n\tself.grounded = self.self.isOnGround();\n\tself.self.addEventListener(SSF2Event.ATTACK_CONNECT, self.toFrame);\n\tself.self.addEventListener(SSF2Event.ATTACK_CONNECT_SHIELD, self.toFrame);\n\tself.self.addEffectToList(self.self.attachEffect(\"raptorboost_effect\", { syncHitStun: true, parentLock: true }));\n}\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "56cbec65-257a-5b04-b3b5-f5b8a54c4311",
      "code": "self.self.playSound(\"raptorBoost1\");\nself.self.clearEffectsOnStateChange();\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "1167a3d6-ad4e-5c2f-a046-3001ed1ea2ec",
      "code": "",
      "length": 4,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "6526683f-d6f0-5d66-86d1-1ce22af008d2",
      "code": "self.effect1 = self.self.attachEffect(\"raptorboost_effect_trail\", { parentLock: true });\nself.self.addEffectToList(self.effect1);\nself.self.createTimer(1, 0, self.followCF);\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "574eca42-ad2e-5253-99b8-eee3248311ec",
      "code": "self.self.setXSpeed(21.6, false);\nself.self.createTimer(2, 7, self.checkGround);\nself.self.playAttackSound(2);\nself.self.attachEffect(\"global_dust_heavy\");\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "79d81043-be71-5ce9-8fde-35515f3edc59",
      "code": "",
      "length": 9,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "64fcca71-f3fd-52cc-8073-c04ae23a6f5b",
      "code": "self.self.resetMovement();\nself.self.setXSpeed(0);\nself.self.updateAttackStats({ canFallOff: false });\nself.self.attachEffect(\"global_dust_cloud\");\nself.effect1.gotoAndStop(\"end\");\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "4e641807-1b02-5c02-9dc5-f8de2d55fc76",
      "code": "",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "08dc6afa-161a-5191-8012-131214519402",
      "code": "SSF2API.getCamera().shake(4);\nif (self.self.getMetalStatus()) {\n\tself.self.playSound(\"metal_land_m\");\n\treturn;\n}\nself.self.playSound(\"falcon_dspecLand\");",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "bb03553e-703c-58f0-86bc-3454d4578563",
      "code": "",
      "length": 10,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "e2be52b4-894b-52dc-b9a2-14c27b930932",
      "code": "self.self.resetMovement();\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "a7f37dd2-78d1-5445-8e40-3ab2cf277a6c",
      "code": "",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "60dd056f-dd0f-583f-94f9-60b1e6f13725",
      "code": "self.self.endAttack();\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "5ce99421-8620-5f61-a798-d2e2ada77b9c",
      "code": "self.hasHit = true;\nself.self.updateAttackBoxStats(1, { allowTurboInterrupt: true, damage: 7, direction: 90, power: 78, kbConstant: 65, hitStun: 1, hitLag: -1.1, selfHitStun: 0, hasEffect: true, effect_id: \"effect_firehit_light\", effectSound: \"brawl_punch_m\", bypassShield: false, priority: 4 });\nself.self.updateAttackStats({ canFallOff: false });\nself.effect1.gotoAndStop(\"end\");\nself.self.addEffectToList(self.self.attachEffect(\"raptorboost_ground_hit\", { syncHitStun: true, parentLock: true }));\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "870c78e1-4332-52ae-815d-265240a5a984",
      "code": "",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "8722c849-bd9f-5bd0-a6cc-3ebbfeb39c10",
      "code": "self.self.resetMovement();\nself.self.setXSpeed(0);\nself.checkGround();\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "d7b07942-b41d-55ce-9758-af8445519925",
      "code": "",
      "length": 2,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "92d78047-c55b-58da-88d9-549783f69a5c",
      "code": "self.self.playSound(\"cfalcon_swing_l\");\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "92b4254a-38bf-5f13-b790-8d5449bac4f4",
      "code": "",
      "length": 8,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "aff40fc6-e226-53a3-b7a9-a56f6581ba69",
      "code": "self.self.endAttack();\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "8ff9504e-f8e7-5c07-9893-0bd5e295221d",
      "code": "self.self.destroyTimer(self.checkGround);\nself.effect1.gotoAndStop(\"end\");\nself.self.addEventListener(SSF2Event.GROUND_TOUCH, self.self.toHeavyLand);\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "2252411e-f8f9-592b-ad99-5c3fa45ffef7",
