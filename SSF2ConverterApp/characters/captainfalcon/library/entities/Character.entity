    {
      "$id": "5ffbb5ef-ed40-5018-9c97-2fb3fca92fff",
      "code": "if (SSF2API.isReady()) {\n\tself.self = /* ? */;\n}\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "4b69386c-06ce-51a7-a4e2-8bf24d02b8dd",
      "code": "self.effect = self.self.attachEffect(\"global_dust_heavy\", { scaleX: 0.8, scaleY: 0.8 });\nself.effect.scaleX = -self.effect.scaleX;\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "0e1f62ac-45fc-5f37-8534-878768547f3f",
      "code": "self.self.setIntangibility(true);\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "9e783270-5e12-52ec-a12d-a77a0ad714d2",
      "code": "",
      "length": 6,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "4400ee79-1633-50fa-89ac-b3f87513b34e",
      "code": "self.self.setIntangibility(false);\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "267eb407-c59f-5039-b59a-a94b975ce936",
