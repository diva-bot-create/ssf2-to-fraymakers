    {
      "$id": "06ade26a-5964-553c-a6b6-02013b3ead31",
      "length": 7,
      "name": "special_neutral",
      "pluginMetadata": {},
      "type": "LABEL"
    },
    {
      "$id": "2045ed4a-ffb3-5f8f-b6ca-19727039bae5",
      "length": 44,
      "name": "continue",
      "pluginMetadata": {},
      "type": "LABEL"
    },
    {
      "$id": "7cefb7a3-3912-52e3-b8f4-aea6c882c70f",
      "length": 10,
      "name": "reversed",
      "pluginMetadata": {},
      "type": "LABEL"
    },
    {
      "$id": "d0c85660-e8d2-5ab4-8097-6470ae559989",
      "code": "self.self = /* ? */;\nself.reverseStats = { damage: 28, direction: 35, power: 50, kbConstant: 100, hitStun: 11, selfHitStun: 9 };\nif ((SSF2API.isReady() && self.self) || self.reversed) {\n}",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "1c27054a-d9f2-5b9e-8832-1522d0e707e2",
      "code": "if (self.curFrame == currentFrame) {\n} else {\n\tself.self.setGlobalVariable(\"FalconPunchVFX\", self.self.playVoiceSound(1));\n}\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "d34d4b52-766c-5742-be08-4d6d501ee1dc",
      "code": "if (self.curFrame == currentFrame) {\n} else {\n\tself.charge = self.self.playAttackSound(1);\n\tself.self.setGlobalVariable(\"FalconPunchSFX\", self.charge);\n}\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "862cd42b-374b-5e96-9ad9-615ad903269a",
      "code": "",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "502652f9-66de-53cf-ba60-4cca59b32433",
      "code": "self.controls = self.self.getControls();\nif ((self.curFrame != currentFrame && self.self.isFacingRight() == self.controls.LEFT) || self.controls.LEFT != self.controls.RIGHT) {\n\tself.self.stancePlayFrame(\"reversed\");\n}\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "c056eaa5-7eb6-5960-86df-4489a7618e3c",
      "code": "",
      "length": 18,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "619ce7f4-706f-5df7-b1f4-5053db9fe6fe",
      "code": "if (self.curFrame == currentFrame) {\n} else {\n\tself.self.attachEffect(\"global_dust_heavy\");\n}\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "51eaecc9-7798-5a3e-92c8-d22776fb9426",
      "code": "if (self.curFrame != currentFrame) {\n\tSSF2API.getCamera().shake(6);\n\tself.self.setGlobalVariable(\"FalconPunchVFX\", self.self.playVoiceSound(2));\n\tself.self.updateAttackStats({ air_ease: 0 });\n\treturn;\n} else {\n\tself.killAttackboxes();\n}",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "495d738d-3d37-592d-8410-fead88b37aad",
      "code": "if (self.curFrame != currentFrame) {\n\tself.checkAtkilled();\n\treturn;\n} else {\n\tself.killAttackboxes();\n}",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "d1dfd304-93c8-5551-b6a8-8944dacb7174",
      "code": "self.self.setXSpeed(8, false);\nSSF2API.stopSound(self.charge);\nif (self.curFrame != currentFrame) {\n\tself.checkAtkilled();\n\tself.self.playAttackSound(2);\n\tself.self.setGlobalVariable(\"FalconPunchSFX\", self.self.playAttackSound(3));\n\treturn;\n} else {\n\tself.killAttackboxes();\n}",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "e6fb686b-4b64-5118-b378-9c146f90ae93",
      "code": "",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "d959565d-edd0-5d9d-83df-c8529864a87f",
      "code": "if (self.curFrame == currentFrame) {\n} else {\n\tself.self.attachEffect(\"falconAfterEffect\");\n}\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "8b2492aa-9519-524f-9069-351fc00c35a2",
      "code": "",
      "length": 6,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "6e5bef04-3618-5b20-9fa5-b50ad0411690",
      "code": "self.self.updateAttackStats({ air_ease: -1 });\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "a2806132-3bed-5dfe-8918-73cb45e2fdfd",
      "code": "",
      "length": 14,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "9dafcbe5-4777-5a40-872d-660a6044bc09",
      "code": "self.self.destroyTimer(self.checkSpeckill);\nself.self.setGlobalVariable(\"FalconPunchReversed\", false);\nself.self.setGlobalVariable(\"FalconPunchAtkID\", null);\nself.self.setGlobalVariable(\"FalconPunchFrame\", 0);\nself.self.endAttack();\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "ae25ae1c-81a0-5e2d-ab03-ffc27ff05881",
      "code": "if (self.curFrame == currentFrame) {\n} else {\n\tself.self.updateAttackBoxStats(1, self.reverseStats);\n\tself.self.updateAttackBoxStats(2, self.reverseStats);\n\tself.reversed = true;\n}\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "facda8c7-c438-5c4e-b80b-87e2aa3ae6c2",
      "code": "",
      "length": 3,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "575d4ca7-a15e-5f6f-ad5a-ad307cde4d0a",
      "code": "if (self.curFrame == currentFrame) {\n} else {\n\tself.self.flip();\n}\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "963dbc9a-dd9f-5cc0-a4fd-05800d930ff1",
      "code": "",
      "length": 4,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "497d7330-d861-5b6a-a18f-84c59e5e23bb",
      "code": "self.self.stancePlayFrame(\"continue\");\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "778d857f-f039-5443-a463-a6d2e221e6ef",
