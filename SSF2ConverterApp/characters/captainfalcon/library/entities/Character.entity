    {
      "$id": "6a750170-8917-597d-af51-f3ad30d5f832",
      "length": 21,
      "name": "tilt_up",
      "pluginMetadata": {},
      "type": "LABEL"
    },
    {
      "$id": "6910e4e1-24fa-5bc1-b1a5-a9bc33fcd698",
      "code": "if (SSF2API.isReady()) {\n\tself.self = /* ? */;\n\tself.playsound = SSF2API.random();\n\tself.audio = self.self.getGlobalVariable(\"audio\");\n}\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "1bea803d-ae41-5952-adb5-422f93ce6186",
      "code": "",
      "length": 3,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "513fde4c-5ab4-58f6-a3da-2c6eff192086",
      "code": "if ((self.playsound > 0.2 && self.playsound <= 0.4) || self.audio != 1) {\n\tself.self.playVoiceSound(1);\n\tself.self.setGlobalVariable(\"audio\", 1);\n}\nif ((self.playsound > 0.4 && self.playsound <= 0.6) || self.audio != 2) {\n\tself.self.playVoiceSound(2);\n\tself.self.setGlobalVariable(\"audio\", 2);\n}\nif ((self.playsound > 0.6 && self.playsound <= 0.8) || self.audio != 3) {\n\tself.self.playVoiceSound(3);\n\tself.self.setGlobalVariable(\"audio\", 3);\n}\nif ((self.playsound > 0.8 && self.playsound <= 1) || self.audio != 4) {\n\tself.self.playVoiceSound(4);\n\tself.self.setGlobalVariable(\"audio\", 4);\n}\nself.self.attachEffect(\"global_spark\", { y: -80 });\nself.self.playAttackSound(1);\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "18082eda-eb7c-5a13-80aa-c5b2950092c7",
      "code": "",
      "length": 2,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "4cf85a44-f563-55a4-a8f8-3f37a6b129a3",
      "code": "self.self.setXSpeed(3, false);\nself.self.playAttackSound(2);\nself.self.addEffectToList(self.self.attachEffect(\"trail_cfalcon_utilt\", { scaleX: 1.15, scaleY: 1.15, parentLock: true, syncHitStun: true }));\nself.self.clearEffectsOnStateChange();\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "8e860e7d-8563-5b10-a2a5-d4f94ee358ca",
      "code": "self.self.attachEffect(\"global_dust_light\");\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "db16bbbf-0adb-5793-b2ef-a71657f3b5c7",
      "code": "SSF2API.getCamera().shake(3);\nif (self.self.getMetalStatus()) {\n\tself.self.playSound(\"metal_step_m2\");\n}\nself.self.setXSpeed(0);\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "69f3784c-d676-5d30-a820-00068164cd1e",
      "code": "self.self.playAttackSound(3);\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "65ef64c5-4262-5c00-acbb-7f3e6e8881fd",
      "code": "",
      "length": 9,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "9b19731d-9ea2-5359-ba1b-87ac4f25f816",
      "code": "self.self.endAttack();\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
