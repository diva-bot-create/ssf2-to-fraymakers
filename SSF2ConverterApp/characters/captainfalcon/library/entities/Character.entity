    },
    {
      "$id": "d1fe1723-46f0-54e6-b923-9af4c0c8e8f4",
      "code": "self.self.getItem().activateItem();\nself.self.playAttackSound(1);\nself.self.attachEffect(\"global_dust_light\", { x: self.self.flipX(-10) });\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "9fde0b6a-2d15-510d-a550-3ad2fc5df2b7",
      "code": "",
