      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "a3a1f3df-7306-5671-8505-1899a0cec842",
      "code": "self.self.getItem().deactivateItem();\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "76ad62fc-3521-52d4-8cca-4865f901bbd9",
