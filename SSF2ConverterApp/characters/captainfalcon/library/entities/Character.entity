      "type": "LABEL"
    },
    {
      "$id": "e2a794f6-1288-5d40-a38a-ba2d8433dd0f",
      "code": "self.self = /* ? */;\nif (SSF2API.isReady()) {\n} else {\n\treturn;\n}\nself.self.setGlobalVariable(\"jab\", false);\nself.self.setGlobalVariable(\"jab2\", false);\nif (self.self.getMetalStatus()) {\n\tself.self.playSound(\"metal_step_m1\");\n}\nself.self.playSound(\"falcon_footstep\");",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "4a26a266-3bd6-5183-a27d-e3a15441959d",
      "code": "",
      "length": 5,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "25b26b97-138b-531c-aa26-bd8f41a24cfd",
      "code": "if (self.self.getMetalStatus()) {\n\tself.self.playSound(\"metal_step_m2\");\n\treturn;\n}\nself.self.playSound(\"falcon_footstep2\");",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "3db9efd0-e80f-59bc-b543-800e9692b5ea",
      "code": "",
      "length": 5,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
    {
      "$id": "d0c5f3ff-7bb5-5f2b-9d9c-d6e44e0b7e4d",
      "code": "self.self.stancePlayFrame(\"run\");\nreturn;",
      "length": 1,
      "pluginMetadata": {},
      "type": "FRAME_SCRIPT"
    },
